        "background": "", "sources_intro": "", "drug_substance_section": "",
        "excipient_intro": "", "manufacturing_section": "",
        "container_closure_section": "", "utilities_section": "",
        "control_strategy": "", "observation": "", "conclusion": "",
        "reference": "NA",
    }

    ann_summary = []
    for ann in annexure_data:
        if isinstance(ann, dict):
            ann_summary.append({
                "material":       ann.get("material_name", "N/A"),
                "supplier":       ann.get("supplier_name", "N/A"),
                "elements_count": len(ann.get("elements", []) or []),
            })

    pde_values = pde_values or ICH_PDE
    t5 = safe_calc_table(calc_tables, "class1_2a")
    t6 = safe_calc_table(calc_tables, "class2b")
    t7 = safe_calc_table(calc_tables, "class3")

    crossing: Dict = {}
    for table in (t5, t6, t7):
        for sym in table.get("elements", []):
            pde = pde_values[sym]["pde"]
            total = table.get("element_totals", {}).get(sym, 0)
            if pde and total > pde * 0.3:
