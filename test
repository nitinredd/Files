// ── TABLE OF CONTENTS ─────────────────────────────────────────────────────────
// Dynamic: uses entries extracted from the reference PDF.
// Falls back to computed defaults based on figureCount.
function buildTOC(tocEntries, figureCount) {
  figureCount = figureCount||0;
  // Compute page estimates for default TOC
  var p14   = 3;               // Sections 1-4
  var pRisk = p14+1;           // Risk assessment / Section 5
  var pComp = pRisk+1+figureCount; // After figure(s)
  var pCtrl = pComp+3;         // Control / conclusion (after calc tables ~3pp)
  var pAnn  = pCtrl+1;         // Annexure list
  var pRef  = pAnn+1;          // References
  var pRev  = pRef;            // Revision history (same page usually)

  // Default: 9-section structure (oral products)
  var def9=[
    {no:"1",title:"Abstract",                                         page:String(p14)},
    {no:"2",title:"Objective",                                        page:String(p14)},
    {no:"3",title:"Details of the study location / testing location", page:String(p14)},
    {no:"4",title:"Background",                                       page:String(p14)},
    {no:"5",title:"Drug product elemental impurity risk assessment",  page:String(pRisk)},
    {no:"6",title:"Summary & Conclusion",                             page:String(pCtrl)},
    {no:"7",title:"Reference",                                        page:String(pAnn)},
    {no:"8",title:"List of Annexures",                                page:String(pRef)},
    {no:"9",title:"Revision History",                                 page:String(pRev)},
  ];

  var entries = (Array.isArray(tocEntries)&&tocEntries.length) ? tocEntries : def9;

  var W=[600, CW-600-900, 900];
  var tbl=new Table({
    width:{size:CW,type:WidthType.DXA}, columnWidths:W,
    rows:[
      new TableRow({children:[
        cell("S. No.",{bold:true,fill:CLR.HDR_GREY,w:W[0],size:SZ.SM}),
        cell("Title", {bold:true,fill:CLR.HDR_GREY,w:W[1],size:SZ.SM}),
        cell("Page#", {bold:true,fill:CLR.HDR_GREY,w:W[2],size:SZ.SM}),
      ]}),
    ].concat(entries.map(function(e){
      return new TableRow({children:[
        cell(e.no||"",    {w:W[0],size:SZ.SM}),
        cellL(e.title||"",{w:W[1],size:SZ.SM}),
        cell(e.page||"",  {w:W[2],size:SZ.SM}),
      ]});
    })),
  });
  return [ctrPara("TABLE OF CONTENTS",true,SZ.MD), tbl, pgBrk()];
}

// ── ALL TEXT SECTIONS ────────────────────────────────────────────────────────
// Renders sections 1-4 and all narrative sub-sections that follow.
// Keeping everything here avoids duplication with buildSourcesSection.
function buildTextSections(txt) {
  txt=txt||{};
  var ch=[];

  function addSec(num, title, content) {
    if (!content && content !== "") return;  // skip empty optional sections
    ch.push(secHd(num+". "+title));
    bodyParas(content).forEach(function(p){ch.push(p);});
    ch.push(blk());
  }

  // Sections 1-4
  addSec(1,"Abstract",   txt.abstract||"");
  addSec(2,"Objective",  txt.objective||"");
  addSec(3,"Details of the study location / testing location",
            txt.study_location||"NA");

  ch.push(secHd("4. Background:"));
  bodyParas(txt.background||"").forEach(function(p){ch.push(p);});
  ch.push(blk());

  // Drug substance / excipient / manufacturing narrative (after Table 2)
  // These appear AFTER the composition table and Table 2 in the document flow.
  // They are stored here and rendered after buildSourcesSection in generateReport.
  var postCompSections = [
    txt.sources_intro,
    txt.drug_substance_section,
    txt.excipient_intro,
    txt.manufacturing_section,
    txt.container_closure_section,
    txt.utilities_section,
    txt.control_strategy,
    txt.testing_recommendation,
  ];
  var hasPostComp = postCompSections.some(function(t){return !!t;});

  // Store for use by generateReport — do NOT render here
  // (they are rendered by buildPostCompSections after Table 2)
  ch._postCompSections = postCompSections;
  ch._hasPostComp = hasPostComp;

  ch.push(pgBrk());
  return ch;
}

// Renders the narrative sections that appear after the composition table + Table 2
function buildPostCompSections(txt) {
