    _sig = f"{bn_product}|" + ",".join(
        sorted(safe_str(getattr(f, "name", "")) for f in (bn_files or [])))
    if bn_files and bn_product and st.session_state.get("bn_upload_sig") != _sig:
        st.session_state["bn_upload_sig"] = _sig
        for k in ("benoc_annexures", "benoc_meta", "benoc_preview",
                  "benoc_validation", "benoc_docx_bytes", "benoc_report_ready",
                  "benoc_fname"):
            st.session_state.pop(k, None)
        try:
            # Structures and dissolution charts always auto-generate when the
            # source data is present, and degrade to blank when it is not.
            st.session_state["bn_gen_structures"] = True
            st.session_state["bn_gen_charts"] = True
            _bar = st.progress(0, text="Analyzing files… 0%")
            annexures = _process_annexures_with_progress(
                "BE NOC Application", list(bn_files or []), _bar, 5, 100)
            _bar.empty()
            st.session_state["benoc_annexures"] = annexures
            _meta = _auto_meta(bn_product, "", "BE NOC Application")
            _meta.update({
                "title": ("Application for Grant of NOC for Import of Innovator "
                          "Product for Bio-Equivalence Study"),
                "company_name": "Dr. Reddy's Laboratories Ltd.",
                "company_address": "",
                "declared_by": "",
                "declarant_title": "",
                # Every gap-fill channel stays empty: the assembled sections come
                # from the uploaded annexures, and an absent source renders
                # "Not provided." rather than a fabricated value.
                "api_overrides": [],
                "manual_process_narrative": "",
                "manual_composition": [],
                "manual_equipment": [],
                "manual_dissolution": {},
            })
            st.session_state["benoc_meta"] = _meta
            # Validation is computed for the structural can_generate gate only —
