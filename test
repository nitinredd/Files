def initialize_session_state():
    defaults = {
        "mode": "slm", "current_page": "chat", "chat_history": [],
        "models_loaded": False, "phi4": None, "embedder": None,
        "nli": None, "faiss_store": None, "neo4j": None,
    }
    for k, v in defaults.items():
        if k not in st.session_state:
            st.session_state[k] = v


def load_infrastructure():
    if st.session_state.models_loaded:
        return
    initialize_db()
    initialize_cost_tracker()
    st.session_state.phi4 = load_phi4()
    st.session_state.embedder = load_embedder_model()
    st.session_state.nli = load_nli_model()
    faiss_store = FAISSStore()
    faiss_store.load()
    st.session_state.faiss_store = faiss_store
    neo4j = Neo4jClient()
    neo4j.create_schema()
    st.session_state.neo4j = neo4j
    st.session_state.models_loaded = True


def render_sidebar():
    with st.sidebar:
        st.title("Analytical AI Expert")
        st.caption("HPLC Knowledge System v1.0")
        st.divider()

        st.subheader("Inference Mode")
        c1, c2 = st.columns(2)
        with c1:
            if st.button("SLM Only",
                         type="primary" if st.session_state.mode == "slm" else "secondary",
                         use_container_width=True):
                st.session_state.mode = "slm"
                st.rerun()
        with c2:
            if st.button("Hybrid",
                         type="primary" if st.session_state.mode == "hybrid" else "secondary",
                         use_container_width=True):
                st.session_state.mode = "hybrid"
                st.rerun()

        if st.session_state.mode == "slm":
            st.success("SLM Only -- Rs.0 per query")
        else:
            st.warning("Hybrid -- GPT-4o via Azure")

        st.divider()
        st.subheader("Model Status")
        if st.session_state.get("models_loaded"):
            st.success("All models loaded")
            st.caption("- Phi-4-mini (Generation)")
            st.caption("- BGE-M3 (Embedding)")
            st.caption("- DeBERTa-v3-large (Verification)")
        else:
            st.warning("Loading models...")

        neo4j = st.session_state.get("neo4j")
        if neo4j:
            if neo4j.is_connected:
                st.success("Neo4j connected")
            else:
                st.warning("Neo4j offline (graph features disabled)")

        st.divider()
        stats = db_get_corpus_stats()
        st.subheader("Corpus Index")
        st.metric("Documents", stats["document_count"])
        st.metric("Paragraphs", f"{stats['paragraph_count']:,}")
        if neo4j and neo4j.is_connected:
            gs = neo4j.get_graph_stats()
            st.metric("Concepts", f"{gs.get('concepts', 0):,}")
            st.metric("Relationships", f"{gs.get('relationships', 0):,}")

        st.divider()
        st.subheader("Navigation")
        for page_id, label in [
            ("chat", "Chat"), ("ingest", "Ingest Documents"),
            ("graph", "Knowledge Graph"), ("analytics", "Cost Analytics")
        ]:
            if st.button(label, use_container_width=True,
                         type="primary" if st.session_state.current_page == page_id else "secondary"):
                st.session_state.current_page = page_id
