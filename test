    "citrate", "acid", "oxide", "cellulose", "glycol", "alcohol", "acetate",
    "stearate", "phosphate", "chloride", "sodium", "calcium", "potassium",
    "magnesium", "dioxide", "copolymer", "ester", "water", "spheres", "sphere",
}

# RS material family vocabulary. Each family maps distinctive aliases/brands to a
# shared canonical family token. Product-agnostic chemical identities, not
# one-off product mappings.
_RS_FAMILY_RULES: Dict[str, Dict[str, Any]] = {
