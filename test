            c2.write(f"{info['pages']} pages")
            c3.write(f"{info['paragraphs']:,} paragraphs")
            c4.write(info.get('timestamp', '')[:10])
            c5.success("Done")
        st.divider()

    st.subheader("Upload New Documents")
    uploaded_files = st.file_uploader("Select PDF files", type=["pdf"], accept_multiple_files=True)

    if uploaded_files:
        st.write(f"**{len(uploaded_files)} file(s) selected**")
        for f in uploaded_files:
            st.caption(f"- {f.name}")

        if st.button("Start Ingestion", type="primary"):
            overall_bar = st.progress(0, text="Overall progress")
            results_container = st.container()

            for file_idx, uploaded_file in enumerate(uploaded_files):
                with results_container:
                    st.markdown(f"**Processing: {uploaded_file.name}**")
                    file_bar = st.progress(0)
                    step_text = st.empty()

                with tempfile.NamedTemporaryFile(delete=False, suffix=".pdf") as tmp:
                    tmp.write(uploaded_file.read())
                    tmp_path = Path(tmp.name)

                def make_callback(fb, st_):
                    def callback(step, pct, detail=""):
                        fb.progress(min(pct, 1.0))
                        st_.caption(f"{step} {detail}")
                    return callback

                result = ingest_pdf(
                    tmp_path,
                    neo4j=st.session_state.neo4j,
                    progress_callback=make_callback(file_bar, step_text)
                )
                tmp_path.unlink(missing_ok=True)

                with results_container:
                    if result.get("skipped"):
                        st.info(f"{result['filename']} -- already ingested, skipped")
                    elif result["success"]:
                        st.success(
                            f"**{result['filename']}** complete\n\n"
                            f"- {result['pages']} pages extracted\n"
                            f"- {result['paragraphs']:,} paragraphs stored"
                        )
                    else:
                        st.error(f"{result['filename']} -- {result.get('error', 'Unknown error')}")

                overall_bar.progress(
                    (file_idx + 1) / len(uploaded_files),
                    text=f"{file_idx + 1}/{len(uploaded_files)} documents processed"
                )

            st.balloons()

            # Stage 2: Auto FAISS build — runs automatically after all books finish
            with st.status(
                "Building FAISS vector index -- this may take several hours...",
                expanded=True
            ) as faiss_status:
                st.write("Loading all paragraphs from database...")
                all_paras = db_get_all_paragraphs()
                st.write(f"Found {len(all_paras):,} paragraphs to embed")
                texts = [p["text"] for p in all_paras]
                ids = [p["paragraph_id"] for p in all_paras]
                embedder = Embedder(st.session_state.embedder)
                st.write("Running BGE-M3 embeddings (batch_size=2, this is the slow part)...")
                embeddings = embedder.embed_paragraphs(texts, show_progress=True)
                st.write("Writing FAISS index to disk...")
                st.session_state.faiss_store.build(embeddings, ids)
                faiss_status.update(label="FAISS index built", state="complete")

            st.success(
                f"FAISS index ready -- {st.session_state.faiss_store.total_vectors:,} vectors indexed. "
                "System is ready for queries."
            )
            st.rerun()

    st.divider()
    st.subheader("Corpus Statistics")
    stats = db_get_corpus_stats()
    c1, c2, c3, c4 = st.columns(4)
    c1.metric("Documents", stats["document_count"])
    c2.metric("Paragraphs", f"{stats['paragraph_count']:,}")
    vectors = st.session_state.faiss_store.total_vectors if st.session_state.faiss_store else 0
    c3.metric("FAISS Vectors", f"{vectors:,}")
    if st.session_state.neo4j and st.session_state.neo4j.is_connected:
        gs = st.session_state.neo4j.get_graph_stats()
        c4.metric("Graph Concepts", f"{gs.get('concepts', 0):,}")
    else:
        c4.metric("Neo4j", "Not connected")

    if stats["documents"]:
        import pandas as pd
        st.subheader("Document Breakdown")
        df = pd.DataFrame(stats["documents"])
        st.dataframe(
            df[["filename", "page_count", "paragraph_count", "indexed_at"]],
            use_container_width=True, hide_index=True
        )

    # ── FIX 3: GPT-4o Concept Extraction ──────────────────────
    st.divider()
    st.subheader("Concept Extraction -> Neo4j Knowledge Graph")
    st.caption(
        "Run this after FAISS is ready. "
        "Uses GPT-4o via Azure API. ~57 minutes for 17,000 paragraphs."
    )

    if st.button("Extract Concepts with GPT-4o", type="primary"):
        if not AZURE_OPENAI_API_KEY or not AZURE_OPENAI_ENDPOINT:
            st.error("Azure OpenAI credentials are not configured in config.")
            st.stop()
        if not st.session_state.neo4j or not st.session_state.neo4j.is_connected:
            st.error("Neo4j is not connected.")
            st.stop()

        import asyncio

        all_paras = db_get_all_paragraphs()
        checkpoint_path = DATA_DIR / "concept_extraction_checkpoint.json"
        checkpoint = {}
        if checkpoint_path.exists():
            with open(checkpoint_path) as f:
                checkpoint = json.load(f)

        remaining = [p for p in all_paras if p["paragraph_id"] not in checkpoint]
        total = len(all_paras)
        st.write(
            f"Total paragraphs: {total:,} | "
            f"Already done: {len(checkpoint):,} | "
            f"Remaining: {len(remaining):,}"
        )

        extraction_bar = st.progress(len(checkpoint) / max(total, 1))
        extraction_status = st.empty()

        done_count_ref = [len(checkpoint)]
        total_concepts_ref = [0]
        total_relationships_ref = [0]
        neo4j_client = st.session_state.neo4j

        async def run_extraction():
            semaphore = asyncio.Semaphore(5)
            loop = asyncio.get_running_loop()

            async def process_one(para):
                async with semaphore:
                    try:
                        result = await loop.run_in_executor(
                            None, _call_azure_concepts, para["text"]
                        )
                        concepts = result.get("concepts", [])
                        relationships = result.get("relationships", [])
                        if concepts:
                            neo4j_client.store_concepts(
                                para["paragraph_id"], concepts, relationships
                            )
                            total_concepts_ref[0] += len(concepts)
                            total_relationships_ref[0] += len(relationships)
                        checkpoint[para["paragraph_id"]] = "done"
                        done_count_ref[0] += 1
                    except Exception as e:
                        logger.error(
                            f"Concept extraction failed for {para['paragraph_id']}: {e}"
                        )
                        done_count_ref[0] += 1

            completed = 0
            for coro in asyncio.as_completed(
                [asyncio.create_task(process_one(p)) for p in remaining]
            ):
                await coro
                completed += 1
                if completed % 50 == 0 or completed == len(remaining):
                    pct = min(done_count_ref[0] / max(total, 1), 1.0)
                    extraction_bar.progress(pct)
                    extraction_status.caption(
                        f"Processed {done_count_ref[0]}/{total} paragraphs | "
                        f"{total_concepts_ref[0]} concepts | "
                        f"{total_relationships_ref[0]} relationships"
                    )
                if completed % 100 == 0:
                    with open(checkpoint_path, "w") as f:
                        json.dump(checkpoint, f)

            # Final checkpoint save
            with open(checkpoint_path, "w") as f:
                json.dump(checkpoint, f)

        asyncio.run(run_extraction())

        st.success(
            f"Concept extraction complete -- {total_concepts_ref[0]} concepts and "
            f"{total_relationships_ref[0]} relationships stored in Neo4j."
        )


