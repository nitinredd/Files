# 3b. CALCULATION IDENTITY AGGREGATION (Red Flag 3)
#     Composition stays stage-wise for Section 4; Section 5 calculation collapses
#     repeated / synonymous material rows into ONE calculation identity each.
# ════════════════════════════════════════════════════════════════════════════
def aggregate_calculation_identities(parsed: Dict) -> Dict:
    """
    Collapse repeated/synonymous component rows into one calculation identity,
    summing quantity_per_unit and amount_in_maximum_dose. Uses the same family
    recognition as the mapper (with negative-pair protection) so e.g. HPC/Klucel
    variants merge but Triethyl citrate never merges with ATBC. q.s. rows are
    NOT aggregated (kept separate, calculation-exempt). Returns a parsed-like
    dict whose 'rows' are the aggregated identities, plus an audit trail.
    """
    rows = parsed.get("rows", []) or []
    no_of_doses = parsed.get("no_of_doses")

    buckets: List[Dict] = []          # each: {family, key, ident, members[]}
    qs_rows: List[Dict] = []

    def bucket_for(name: str):
        ident = _rs_identity(name)
        fam = ident.get("family", "")
        dist = _rs_distinctive(ident.get("tokens", set()))
        for b in buckets:
            bfam = b["ident"].get("family", "")
            # Block chemically distinct families that share weak generic tokens
            if _rs_pair_blocked(fam, bfam):
                continue
            # Strong merge: identical recognised family
            if fam and bfam and fam == bfam:
                return b
            # Else merge only on distinctive (non-generic) token equality
            if not fam and not bfam:
                bdist = _rs_distinctive(b["ident"].get("tokens", set()))
                if dist and bdist and dist == bdist:
                    return b
        return None

    for r in rows:
        if r.get("_is_qs"):
            qs_rows.append(r)
            continue
        name = r.get("component", "")
        b = bucket_for(name)
        if b is None:
            b = {"ident": _rs_identity(name), "members": []}
            buckets.append(b)
        b["members"].append(r)

    agg_rows: List[Dict] = []
    aggregation_warnings: List[str] = []
    for b in buckets:
        members = b["members"]
        qty_sum = 0.0
        had_qty = False
        amt_sum = 0.0
        had_amt = False
        stages, names, src = [], [], []
        for m in members:
            q = m.get("quantity")
            if isinstance(q, (int, float)):
                qty_sum += q; had_qty = True
            a = m.get("amount_in_maximum_dose_mg")
            if isinstance(a, (int, float)):
                amt_sum += a; had_amt = True
            names.append(m.get("component", ""))
            st = m.get("stage") or (m.get("columns", {}) or {}).get("Stage")
            if st:
                stages.append(_s(st))
            src.append(m.get("component", ""))

        # Recompute amount from summed qty × doses when possible (authoritative)
        amount = None
        basis = members[0].get("amount_basis", "none")
        if had_qty and no_of_doses:
            amount = round(qty_sum * no_of_doses, 6)
            basis = "aggregated_quantity_times_doses"
        elif had_amt:
            amount = round(amt_sum, 6)
            basis = "aggregated_amount_sum"

        primary = members[0].get("component", "")
        # Prefer the recognised family label as the canonical display name
        canon_name = b["ident"].get("family") or primary
        canon_name = canon_name if canon_name else primary
        if len(members) > 1:
            aggregation_warnings.append(
                f"Aggregated {len(members)} rows into '{canon_name}' "
                f"(stages: {', '.join(stages) or 'n/a'}).")
        agg_rows.append({
            "component": canon_name if len(members) > 1 else primary,
            "quantity": round(qty_sum, 6) if had_qty else None,
            "amount_in_maximum_dose_mg": amount,
            "amount_basis": basis,
            "_is_qs": False,
            "solvents": members[0].get("solvents", {}) or {},
            "columns": {},
            "_aggregation": {
                "source_rows": len(members),
                "stages": stages,
                "original_names": names,
                "aggregation_reason": (b["ident"].get("family") and "family identity")
                                      or "distinctive-token identity",
            },
        })

    # q.s. rows preserved as separate calculation-exempt rows
    for q in qs_rows:
        agg_rows.append({
            "component": q.get("component", ""),
            "quantity": q.get("quantity"),
            "amount_in_maximum_dose_mg": None,
            "amount_basis": "qs",
            "_is_qs": True,
            "solvents": {}, "columns": {},
            "_aggregation": {"source_rows": 1, "stages": [], "original_names":
                             [q.get("component", "")], "aggregation_reason": "q.s. row"},
        })

    out = dict(parsed)
    out["rows"] = agg_rows
    out["aggregation_warnings"] = aggregation_warnings
    out["needs_dose_basis"] = any(
        (not r["_is_qs"]) and r["amount_in_maximum_dose_mg"] is None for r in agg_rows)
    return out


