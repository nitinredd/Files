# EMBEDDER
# ═══════════════════════════════════════════════════════════════

class Embedder:
    def __init__(self, model):
        self.model = model

    def embed_paragraphs(self, texts: List[str], show_progress: bool = True) -> np.ndarray:
        return self.model.encode(
            texts, batch_size=EMBEDDING_BATCH_SIZE, max_length=EMBEDDING_MAX_LENGTH,
            show_progress_bar=show_progress, normalize_embeddings=True, convert_to_numpy=True
        )

    def embed_query(self, query: str) -> np.ndarray:
        return self.model.encode(
            [query], batch_size=1, normalize_embeddings=True, convert_to_numpy=True
        )[0]


# ═══════════════════════════════════════════════════════════════
# FAISS STORE
# ═══════════════════════════════════════════════════════════════

class FAISSStore:
    def __init__(self):
        self.index = None
        self.paragraph_ids: List[str] = []
        self.dimension = 1024  # BGE-M3 output dimension

    def build(self, embeddings: np.ndarray, paragraph_ids: List[str]):
        import faiss
        self.paragraph_ids = paragraph_ids
        self.index = faiss.IndexFlatIP(self.dimension)
        self.index.add(embeddings.astype(np.float32))
        faiss.write_index(self.index, str(FAISS_INDEX_PATH))
        with open(FAISS_META_PATH, "wb") as f:
            pickle.dump(self.paragraph_ids, f)
        logger.info(f"FAISS index built: {self.index.ntotal} vectors")

    def load(self) -> bool:
        import faiss
        if not FAISS_INDEX_PATH.exists() or not FAISS_META_PATH.exists():
            return False
        self.index = faiss.read_index(str(FAISS_INDEX_PATH))
        with open(FAISS_META_PATH, "rb") as f:
            self.paragraph_ids = pickle.load(f)
        logger.info(f"FAISS index loaded: {self.index.ntotal} vectors")
        return True

    def search(self, query_embedding: np.ndarray, top_k: int = RETRIEVAL_TOP_K) -> List[Tuple[str, float]]:
        if self.index is None or self.index.ntotal == 0:
            return []
        scores, indices = self.index.search(
            query_embedding.reshape(1, -1).astype(np.float32), top_k
        )
        return [
            (self.paragraph_ids[idx], float(score))
            for score, idx in zip(scores[0], indices[0])
            if 0 <= idx < len(self.paragraph_ids)
        ]

    @property
    def total_vectors(self) -> int:
        return self.index.ntotal if self.index else 0


# ═══════════════════════════════════════════════════════════════
# RETRIEVER — PIKE-RAG (FAISS + Neo4j 2-hop)
# ═══════════════════════════════════════════════════════════════

class Retriever:
    def __init__(self, embedder: Embedder, faiss_store: FAISSStore, neo4j: Neo4jClient):
        self.embedder = embedder
        self.faiss_store = faiss_store
        self.neo4j = neo4j

    def retrieve(self, query: str, top_k: int = RETRIEVAL_TOP_K) -> List[Dict]:
        query_emb = self.embedder.embed_query(query)
        faiss_results = self.faiss_store.search(query_emb, top_k=top_k)
        if not faiss_results:
            return []

        faiss_ids = [r[0] for r in faiss_results]
        faiss_scores = {r[0]: r[1] for r in faiss_results}

        graph_ids = []
        if self.neo4j.is_connected:
            graph_ids = self.neo4j.get_related_paragraphs(faiss_ids[:5])

        all_ids = faiss_ids + [g for g in graph_ids if g not in faiss_ids]
        paragraphs = []
        for para_id in all_ids[:top_k]:
            para = db_get_paragraph(para_id)
            if para:
                para["relevance_score"] = faiss_scores.get(para_id, 0.0)
                para["source"] = "faiss" if para_id in faiss_scores else "graph"
                paragraphs.append(para)

        paragraphs.sort(key=lambda x: x["relevance_score"], reverse=True)
        return paragraphs


