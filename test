import { useState, useEffect, useRef, useCallback } from 'react'
import PromptInput from './components/PromptInput'
import SandDissolve from './components/SandDissolve'
import ReconstructedPrompt from './components/ReconstructedPrompt'
import HistorySidebar from './components/HistorySidebar'

// ─── Constants ────────────────────────────────────────────────────────────────

const APP_STATE = {
  INPUT: 'input',
  DISSOLVING: 'dissolving',
  REVEAL: 'reveal',
}

const API = 'http://localhost:8000'

const STATUS_CYCLE = ['EXTRACTING INTENT', 'MAPPING TO PRINCIPLES', 'SYNTHESISING']

// ─── App ─────────────────────────────────────────────────────────────────────

export default function App() {
  // ── App state ──────────────────────────────────────────────────────────────
  const [appState, setAppState] = useState(APP_STATE.INPUT)
  const [backendStatus, setBackendStatus] = useState('checking')
  const [bannerDismissed, setBannerDismissed] = useState(false)
  const [sidebarOpen, setSidebarOpen] = useState(true)

  // ── Dissolving state ───────────────────────────────────────────────────────
  const [dissolveText, setDissolveText] = useState('')
  const [dissolveRect, setDissolveRect] = useState(null)
  const [progressPercent, setProgressPercent] = useState(0)
  const [progressStatus, setProgressStatus] = useState(STATUS_CYCLE[0])

  // ── Reveal state ───────────────────────────────────────────────────────────
  const [reconstructionData, setReconstructionData] = useState(null)
  const [reconstructionError, setReconstructionError] = useState(null)
  const [revealMode, setRevealMode] = useState('fresh') // 'fresh' | 'history'

  // ── History ────────────────────────────────────────────────────────────────
  const [history, setHistory] = useState([])
  const [activeHistoryId, setActiveHistoryId] = useState(null)

  // ── Async coordination refs ────────────────────────────────────────────────
  // Both the sand animation AND the API call must complete before REVEAL.
  // Whichever finishes second triggers the transition.
  const apiResultRef = useRef(null)
  const animDoneRef = useRef(false)
  const currentInputRef = useRef('')
  const statusIntervalRef = useRef(null)

  // ── Health check ───────────────────────────────────────────────────────────
  useEffect(() => {
    const check = async () => {
      try {
        const res = await fetch(`${API}/health`, {
          signal: AbortSignal.timeout(6000),
        })
        setBackendStatus(res.ok ? 'online' : 'offline')
      } catch {
        setBackendStatus('offline')
      }
    }
    check()
  }, [])

  // ── Add to history ─────────────────────────────────────────────────────────
  const addToHistory = useCallback((data, inputText) => {
    const id =
      typeof crypto.randomUUID === 'function'
        ? crypto.randomUUID()
        : `${Date.now()}-${Math.random().toString(36).slice(2)}`

    const item = {
      id,
      timestamp: new Date(),
      userInput: inputText,
      reconstructedPrompt: data.reconstructed_prompt,
      confidence: data.confidence,
      strategy: data.strategy_used,
      technique: data.technique,
      isConversational: data.is_conversational ?? false,
    }

    setHistory((prev) => [item, ...prev].slice(0, 50))
    setActiveHistoryId(id)
    return id
  }, [])

  // ── Transition to REVEAL ───────────────────────────────────────────────────
  const transitionToReveal = useCallback(
    (data, error) => {
      if (data) {
        setReconstructionData(data)
        addToHistory(data, currentInputRef.current)
      }
      if (error) setReconstructionError(error)
      setRevealMode('fresh')
      setAppState(APP_STATE.REVEAL)
    },
    [addToHistory]
  )

  // ── Animation completion callback ──────────────────────────────────────────
  const handleAnimationComplete = useCallback(() => {
    animDoneRef.current = true
    if (apiResultRef.current !== null) {
      const { data, error } = apiResultRef.current
      transitionToReveal(data, error)
    }
  }, [transitionToReveal])

  // ── Main submit handler ────────────────────────────────────────────────────
  const handleSubmit = useCallback(
    async (text, rect) => {
      // Reset coordination
      apiResultRef.current = null
      animDoneRef.current = false
      currentInputRef.current = text

      // Setup dissolving state
      setDissolveText(text)
      setDissolveRect(rect)
      setProgressPercent(0)
      setProgressStatus(STATUS_CYCLE[0])
      setReconstructionData(null)
      setReconstructionError(null)
      setRevealMode('fresh')
      setAppState(APP_STATE.DISSOLVING)

      // Animate progress bar: 0 → 85% over 2s (triggers after one paint)
      requestAnimationFrame(() =>
        requestAnimationFrame(() => setProgressPercent(85))
      )

      // Cycle status labels
      let statusIdx = 0
      statusIntervalRef.current = setInterval(() => {
        statusIdx = (statusIdx + 1) % STATUS_CYCLE.length
        setProgressStatus(STATUS_CYCLE[statusIdx])
      }, 800)

      try {
        const sessionId =
          typeof crypto.randomUUID === 'function'
            ? crypto.randomUUID()
            : Math.random().toString(36).slice(2)

        const res = await fetch(`${API}/reconstruct`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ query: text, session_id: sessionId }),
        })

        clearInterval(statusIntervalRef.current)
        setProgressPercent(100)
        setProgressStatus('COMPLETE')

        if (!res.ok) {
          const msg = `HTTP ${res.status} — reconstruction failed.`
          apiResultRef.current = { data: null, error: msg }
          if (animDoneRef.current) transitionToReveal(null, msg)
          return
        }

        const data = await res.json()
        apiResultRef.current = { data, error: null }
        if (animDoneRef.current) transitionToReveal(data, null)
      } catch (err) {
        clearInterval(statusIntervalRef.current)
        setProgressPercent(100)
        const msg = err.message || 'Network error — could not reach backend.'
        apiResultRef.current = { data: null, error: msg }
        if (animDoneRef.current) transitionToReveal(null, msg)
      }
    },
    [transitionToReveal]
  )

  // ── History selection ──────────────────────────────────────────────────────
  const handleHistorySelect = useCallback((item) => {
    setReconstructionData({
      reconstructed_prompt: item.reconstructedPrompt,
      confidence: item.confidence,
      strategy_used: item.strategy,
      technique: item.technique,
      is_conversational: item.isConversational,
    })
    setReconstructionError(null)
    setActiveHistoryId(item.id)
    setRevealMode('history')
    setAppState(APP_STATE.REVEAL)
  }, [])

  // ── History clear ──────────────────────────────────────────────────────────
  const handleClearHistory = useCallback(() => {
    setHistory([])
    setActiveHistoryId(null)
    if (appState === APP_STATE.REVEAL) {
      setAppState(APP_STATE.INPUT)
      setReconstructionData(null)
      setReconstructionError(null)
    }
  }, [appState])

  // ── Reset to INPUT ─────────────────────────────────────────────────────────
  const handleReset = () => {
    clearInterval(statusIntervalRef.current)
    apiResultRef.current = null
    animDoneRef.current = false
    currentInputRef.current = ''

    setAppState(APP_STATE.INPUT)
    setDissolveText('')
    setDissolveRect(null)
    setProgressPercent(0)
    setProgressStatus(STATUS_CYCLE[0])
    setReconstructionData(null)
    setReconstructionError(null)
    setRevealMode('fresh')
    setActiveHistoryId(null)
  }

  // ── Render ─────────────────────────────────────────────────────────────────
  const isInputOrDissolving =
    appState === APP_STATE.INPUT || appState === APP_STATE.DISSOLVING

  return (
    <div className="app-root">
      {/* ── Offline banner ── */}
      {backendStatus === 'offline' && !bannerDismissed && (
        <div className="offline-banner" role="alert">
          <span>⚠ Backend offline — check that uvicorn is running on port 8000</span>
          <button
            className="dismiss-btn"
            onClick={() => setBannerDismissed(true)}
            aria-label="Dismiss"
          >
            ×
          </button>
        </div>
      )}

      {/* ── Header ── */}
      <header className="app-header">
        <div className="header-content">
          <span className="app-name">Prompt Coach</span>
        </div>
      </header>

      {/* ── Body: sidebar + main ── */}
      <div className="app-body">
        {/* History sidebar — always rendered when backend is ready */}
        {backendStatus !== 'checking' && (
          <HistorySidebar
            history={history}
            activeId={activeHistoryId}
            onSelect={handleHistorySelect}
            onClear={handleClearHistory}
            isOpen={sidebarOpen}
            onToggle={() => setSidebarOpen((o) => !o)}
          />
        )}

        {/* Main content */}
        <main className="app-main">
          {/* Loading screen */}
          {backendStatus === 'checking' && (
            <div className="loading-screen" aria-label="Loading">
              <div className="loading-content">
                <span className="loading-app-name">Prompt Coach</span>
                <div className="loading-bar-track">
                  <div className="loading-bar-fill" />
                </div>
              </div>
            </div>
          )}

          {backendStatus !== 'checking' && (
            <>
              {/* INPUT + DISSOLVING — share the PromptInput card */}
              <div
                className={isInputOrDissolving ? 'state-visible' : 'state-hidden'}
                aria-hidden={!isInputOrDissolving}
              >
                <PromptInput
                  onSubmit={handleSubmit}
                  isDissolving={appState === APP_STATE.DISSOLVING}
                  progressPercent={progressPercent}
                  progressStatus={progressStatus}
                />
              </div>

              {/* Sand dissolve canvas overlay */}
              {appState === APP_STATE.DISSOLVING && (
                <SandDissolve
                  text={dissolveText}
                  sourceRect={dissolveRect}
                  onComplete={handleAnimationComplete}
                />
              )}

              {/* REVEAL */}
              {appState === APP_STATE.REVEAL && (
                <div className="reveal-state" aria-live="polite">
                  <ReconstructedPrompt
                    data={reconstructionData}
                    error={reconstructionError}
                    instant={revealMode === 'history'}
                  />

                  <div className="reveal-footer">
                    <button className="new-prompt-btn" onClick={handleReset}>
                      NEW PROMPT
                    </button>
                  </div>
                </div>
              )}
            </>
          )}
        </main>
      </div>
    </div>
  )
}
