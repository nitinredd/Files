    # ── Step 2: mode-specific dose basis (missing-details only) ───────────────
    parsed = None
    excel_bytes = st.session_state.get("rs_excel_bytes")

    if mode == "insufficient_material_names_only":
        st.error("❌ This Excel has material names but no quantity, strength, MDD, "
                 "or amount-in-maximum-dose columns. A residual-solvent assessment "
                 "cannot be calculated. Please upload a richer Excel (with strength "
                 "columns, component MDD, or an amount-in-maximum-dose column).")
        return

    if mode == "unit_composition_strength_columns":
        strengths = cls.get("strengths", [])
        max_strength = max(strengths, key=lambda x: x[2]) if strengths else None
        st.markdown("**Missing calculation basis detected — unit-composition Excel.**")
        st.write("Detected strength columns: " +
                 ", ".join(lbl for _i, lbl, _mg in strengths))
        if max_strength:
            st.write(f"Auto-selected maximum strength: **{max_strength[1]}**")
