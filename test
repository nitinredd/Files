import React from 'react'
import { motion } from 'framer-motion'
import { FiDownload } from 'react-icons/fi'

export default function Message({ from, text, downloadUrl, downloadName }) {
  const isUser = from === 'user'

  return (
    <motion.div
      initial={{ opacity: 0, y: 10, scale: 0.97 }}
      animate={{ opacity: 1, y: 0, scale: 1 }}
      transition={{ duration: 0.2, ease: 'easeOut' }}
      className={`flex items-end gap-2 ${isUser ? 'flex-row-reverse' : 'flex-row'}`}
    >
      {/* Bot avatar */}
      {!isUser && (
        <div
          className="w-8 h-8 rounded-2xl flex-shrink-0 flex items-center justify-center text-white text-xs font-bold mb-0.5"
          style={{ background: 'linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%)' }}
        >
          SP
        </div>
      )}

      {/* Bubble */}
      <div
        className={`max-w-[78%] px-4 py-3 text-sm leading-relaxed break-words ${
          isUser
            ? 'text-white rounded-3xl rounded-br-sm'
            : 'bg-white text-slate-800 rounded-3xl rounded-bl-sm shadow-sm border border-slate-100'
        }`}
        style={isUser ? { background: 'linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%)' } : {}}
      >
        <p className="whitespace-pre-wrap m-0">{text}</p>

        {downloadUrl && (
          <button
            onClick={() => window.open(downloadUrl, '_blank', 'noopener')}
            className="mt-3 flex items-center justify-center gap-2 w-full bg-indigo-50 hover:bg-indigo-100 text-indigo-600 font-semibold text-xs rounded-2xl px-3 py-2.5 border border-indigo-100 transition-colors"
          >
            <FiDownload size={13} />
            {downloadName || 'Download Formulas'}
          </button>
        )}
      </div>
    </motion.div>
  )
}
