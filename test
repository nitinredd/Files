          tc("", { w: 1800 }), tc("", { w: 3240 }), tc("", { w: 2160 }),
        ]}),
      ];

  const sigTbl = new Table({
    width: { size: CONTENT_W, type: WidthType.DXA },
    columnWidths: [2700, 1800, 3240, 2160],
