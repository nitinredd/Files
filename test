                    continue
                ann = process_annexure(raw_json, i+1)
                annexure_data.append(ann)
                els   = ann.get("elements", []) or []
                concs = [_parse_conc(e.get("concentration_value")) for e in els if isinstance(e, dict)]
                numeric_concs = [c for c in concs if isinstance(c, (int, float))]
                n_005 = sum(1 for c in numeric_concs if abs(c - 0.05) < 0.001)
                n_real= sum(1 for c in numeric_concs if c > 0 and abs(c - 0.05) > 0.001)
                has_warn = ann.get("_warning_placeholder_values", False)
                status = "⚠️" if has_warn else "✅"
                st.write(
