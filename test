# PRE-FLIGHT VALIDATION (zero API cost — runs before any Claude call)
# ============================================================================
def validate_inputs(ref_pdf_bytes: bytes, excel_bytes: bytes,
                    annexure_raw: List[Tuple[str, str]]) -> List[str]:
    errors: List[str] = []

    # 1. Reference PDF
    try:
        doc = fitz.open(stream=ref_pdf_bytes, filetype="pdf")
        n = len(doc)
        doc.close()
        if n == 0:
            errors.append("Reference PDF has 0 pages.")
        elif n < 5:
            errors.append(f"Reference PDF has only {n} pages — expected 15+.")
    except Exception as e:
        errors.append(f"Reference PDF cannot be opened: {e}")

    # 2. Excel
    try:
        wb = openpyxl.load_workbook(BytesIO(excel_bytes), data_only=True)
        if not wb.worksheets:
            errors.append("Excel file has no sheets.")
        else:
            ws = wb.worksheets[0]
            rows_with_data = sum(
                1 for row in ws.iter_rows(values_only=True)
                if any(c is not None for c in row)
            )
            if rows_with_data < 3:
                errors.append(
                    f"Excel sheet 1 has only {rows_with_data} non-empty rows."
                )
        wb.close()
    except Exception as e:
        errors.append(f"Excel cannot be opened: {e}")

    # 3. Annexure JSONs — accept both {} (dict) and [] (list) at root; strip BOM
    if not annexure_raw:
        errors.append("No annexure JSON files uploaded.")
    for i, (name, raw) in enumerate(annexure_raw):
        try:
            cleaned = raw.lstrip("\ufeff")
            obj = json.loads(cleaned)
            if not isinstance(obj, (dict, list)):
                errors.append(
                    f"Annexure {i + 1} ({name}): JSON must be object {{}} or array []."
                )
        except json.JSONDecodeError as e:
            errors.append(f"Annexure {i + 1} ({name}): invalid JSON — {e}")

    # 4. Node.js
    import shutil
    if not shutil.which("node"):
        errors.append("Node.js not found in PATH. Install Node.js >= 18.")
    else:
        probe = subprocess.run(
            ["node", "-e", "require('docx'); process.exit(0)"],
            capture_output=True, timeout=10,
        )
        if probe.returncode != 0:
            errors.append(
                "npm package 'docx' not importable. "
                "Run: npm install docx  (in the folder containing generate_report.js)"
            )
        probe2 = subprocess.run(
            ["node", "-e", "require('jszip'); process.exit(0)"],
            capture_output=True, timeout=10,
        )
        if probe2.returncode != 0:
            errors.append(
                "npm package 'jszip' not installed. "
                "Run: npm install jszip"
            )

    # 5. GCP credentials
    creds_path = os.environ.get("GOOGLE_APPLICATION_CREDENTIALS", "")
    if creds_path and not Path(creds_path).exists():
        errors.append(f"GCP credentials file not found: {creds_path}")

    return errors


