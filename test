#app
import { useState, useEffect, useRef, useCallback } from 'react'
import PromptInput from './components/PromptInput'
import SandDissolve from './components/SandDissolve'
import ReconstructedPrompt from './components/ReconstructedPrompt'
import ResponseStream from './components/ResponseStream'

const APP_STATE = {
  INPUT: 'input',
  DISSOLVING: 'dissolving',
  REVEAL: 'reveal',
}

const API = 'http://localhost:8000'

export default function App() {
  // ── App lifecycle ──────────────────────────────────────────────────────────
  const [appState, setAppState] = useState(APP_STATE.INPUT)
  const [backendStatus, setBackendStatus] = useState('checking') // checking | online | offline
  const [bannerDismissed, setBannerDismissed] = useState(false)

  // ── Dissolving state ───────────────────────────────────────────────────────
  const [dissolveText, setDissolveText] = useState('')
  const [dissolveRect, setDissolveRect] = useState(null)
  const [progressPercent, setProgressPercent] = useState(0)
  const [progressStatus, setProgressStatus] = useState('EXTRACTING INTENT')

  // ── Reveal state ───────────────────────────────────────────────────────────
  const [reconstructionData, setReconstructionData] = useState(null)
  const [reconstructionError, setReconstructionError] = useState(null)
  const [streamedResponse, setStreamedResponse] = useState('')
  const [isStreaming, setIsStreaming] = useState(false)

  // ── Sync refs for async coordination ──────────────────────────────────────
  // We need both the animation AND the API call to finish before revealing.
  // Whichever completes first sets its ref; the second one triggers the transition.
  const apiResultRef = useRef(null)     // null = pending, object = done
  const animDoneRef = useRef(false)
  const progressTimerRef = useRef(null)
  const statusIntervalRef = useRef(null)

  // ── Health check on mount ──────────────────────────────────────────────────
  useEffect(() => {
    const check = async () => {
      try {
        const res = await fetch(`${API}/health`, {
          signal: AbortSignal.timeout(6000),
        })
        setBackendStatus(res.ok ? 'online' : 'offline')
      } catch {
        setBackendStatus('offline')
      }
    }
    check()
  }, [])

  // ── Transition to REVEAL ───────────────────────────────────────────────────
  const transitionToReveal = useCallback((data, error) => {
    if (data) setReconstructionData(data)
    if (error) setReconstructionError(error)
    setAppState(APP_STATE.REVEAL)
    if (data?.reconstructed_prompt) {
      streamResponse(data.reconstructed_prompt)
    }
  }, []) // eslint-disable-line react-hooks/exhaustive-deps

  // ── Called when sand dissolve animation finishes ───────────────────────────
  const handleAnimationComplete = useCallback(() => {
    animDoneRef.current = true
    // If API already returned, transition now; else wait for API
    if (apiResultRef.current !== null) {
      const { data, error } = apiResultRef.current
      transitionToReveal(data, error)
    }
  }, [transitionToReveal])

  // ── Main reconstruct flow ──────────────────────────────────────────────────
  const handleSubmit = useCallback(async (text, rect) => {
    // Reset coordination refs
    apiResultRef.current = null
    animDoneRef.current = false

    // Set up dissolving state
    setDissolveText(text)
    setDissolveRect(rect)
    setProgressPercent(0)
    setProgressStatus('EXTRACTING INTENT')
    setReconstructionData(null)
    setReconstructionError(null)
    setStreamedResponse('')
    setIsStreaming(false)
    setAppState(APP_STATE.DISSOLVING)

    // Animate progress bar 0 → 85% over ~2s
    requestAnimationFrame(() => {
      requestAnimationFrame(() => setProgressPercent(85))
    })

    // Cycle status messages
    const statuses = ['EXTRACTING INTENT', 'MAPPING TO PRINCIPLES', 'SYNTHESISING']
    let statusIdx = 0
    statusIntervalRef.current = setInterval(() => {
      statusIdx = (statusIdx + 1) % statuses.length
      setProgressStatus(statuses[statusIdx])
    }, 800)

    // API call
    try {
      const sessionId =
        typeof crypto.randomUUID === 'function'
          ? crypto.randomUUID()
          : Math.random().toString(36).slice(2)

      const res = await fetch(`${API}/reconstruct`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ query: text, session_id: sessionId }),
      })

      clearInterval(statusIntervalRef.current)
      setProgressPercent(100)
      setProgressStatus('COMPLETE')

      if (!res.ok) {
        const msg = `HTTP ${res.status} — Reconstruction failed.`
        apiResultRef.current = { data: null, error: msg }
        if (animDoneRef.current) transitionToReveal(null, msg)
        return
      }

      const data = await res.json()
      apiResultRef.current = { data, error: null }
      if (animDoneRef.current) transitionToReveal(data, null)
    } catch (err) {
      clearInterval(statusIntervalRef.current)
      setProgressPercent(100)
      const msg = err.message || 'Network error — could not reach backend.'
      apiResultRef.current = { data: null, error: msg }
      if (animDoneRef.current) transitionToReveal(null, msg)
    }
  }, [transitionToReveal])

  // ── SSE streaming via fetch + ReadableStream ───────────────────────────────
  const streamResponse = async (prompt) => {
    setIsStreaming(true)
    setStreamedResponse('')
    try {
      const res = await fetch(`${API}/chat`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ reconstructed_prompt: prompt }),
      })

      const reader = res.body.getReader()
      const decoder = new TextDecoder()
      let buffer = ''

      while (true) {
        const { done, value } = await reader.read()
        if (done) break

        buffer += decoder.decode(value, { stream: true })
        const lines = buffer.split('\n')
        buffer = lines.pop() ?? ''

        for (const line of lines) {
          if (!line.startsWith('data: ')) continue
          const raw = line.slice(6).trim()
          if (!raw) continue
          try {
            const payload = JSON.parse(raw)
            if (payload.done) {
              setIsStreaming(false)
              return
            }
            if (payload.token) {
              setStreamedResponse((prev) => prev + payload.token)
            }
          } catch {
            // malformed SSE line — skip
          }
        }
      }
    } catch (err) {
      console.error('Streaming error:', err)
    } finally {
      setIsStreaming(false)
    }
  }

  // ── Reset to INPUT state ───────────────────────────────────────────────────
  const handleReset = () => {
    clearInterval(statusIntervalRef.current)
    clearTimeout(progressTimerRef.current)
    apiResultRef.current = null
    animDoneRef.current = false

    setAppState(APP_STATE.INPUT)
    setDissolveText('')
    setDissolveRect(null)
    setProgressPercent(0)
    setProgressStatus('EXTRACTING INTENT')
    setReconstructionData(null)
    setReconstructionError(null)
    setStreamedResponse('')
    setIsStreaming(false)
  }

  // ── Render ─────────────────────────────────────────────────────────────────
  return (
    <div className="app-root">
      {/* ── Offline banner ── */}
      {backendStatus === 'offline' && !bannerDismissed && (
        <div className="offline-banner" role="alert">
          <span>⚠ Backend offline — check that uvicorn is running on port 8000</span>
          <button
            className="dismiss-btn"
            onClick={() => setBannerDismissed(true)}
            aria-label="Dismiss banner"
          >
            ×
          </button>
        </div>
      )}

      {/* ── Header ── */}
      <header className="app-header">
        <div className="header-content">
          <span className="app-name">Prompt Coach</span>
          <span className="status-chip" aria-label="System status: ready, 5 prompts learned">
            <span className="status-dot" />
            READY · 5 PROMPTS LEARNED
          </span>
        </div>
      </header>

      {/* ── Main content ── */}
      <main className="app-main">
        {/* Loading screen while health check is in flight */}
        {backendStatus === 'checking' && (
          <div className="loading-screen" aria-label="Loading Prompt Coach">
            <div className="loading-content">
              <span className="loading-app-name">Prompt Coach</span>
              <div className="loading-bar-track">
                <div className="loading-bar-fill" />
              </div>
            </div>
          </div>
        )}

        {backendStatus !== 'checking' && (
          <>
            {/* INPUT + DISSOLVING share the PromptInput card */}
            <div
              className={
                appState === APP_STATE.INPUT || appState === APP_STATE.DISSOLVING
                  ? 'state-visible'
                  : 'state-hidden'
              }
              aria-hidden={appState === APP_STATE.REVEAL}
            >
              <PromptInput
                onSubmit={handleSubmit}
                isDissolving={appState === APP_STATE.DISSOLVING}
                progressPercent={progressPercent}
                progressStatus={progressStatus}
              />
            </div>

            {/* Sand dissolve canvas — rendered on top during DISSOLVING */}
            {appState === APP_STATE.DISSOLVING && (
              <SandDissolve
                text={dissolveText}
                sourceRect={dissolveRect}
                onComplete={handleAnimationComplete}
              />
            )}

            {/* REVEAL state */}
            {appState === APP_STATE.REVEAL && (
              <div className="reveal-state" aria-live="polite">
                <div className="reveal-card">
                  <div className="reveal-panels">
                    {/* Left — reconstructed prompt */}
                    <ReconstructedPrompt
                      data={reconstructionData}
                      error={reconstructionError}
                    />

                    {/* Divider */}
                    <div className="panel-divider" aria-hidden="true">
                      <div className="divider-line" />
                      <span className="diamond">◆</span>
                      <div className="divider-line" />
                    </div>

                    {/* Right — model response */}
                    <ResponseStream
                      response={streamedResponse}
                      isStreaming={isStreaming}
                    />
                  </div>
                </div>

                <div className="reveal-footer">
                  <button className="new-prompt-btn" onClick={handleReset}>
                    NEW PROMPT
                  </button>
                </div>
              </div>
            )}
          </>
        )}
      </main>
    </div>
  )
}
