def deg_eg_page_prompt(page_no: int, total: int) -> str:
    return (
        f"This is page {page_no} of {total} of a DEG/EG annexure. Extract any "
        "ADDITIONAL DEG or EG statements, and any DRL SAP material code / CAS "
        "number / DRL specification number visible on THIS page only.\n"
        "Same rules: numeric DEG/EG limits ONLY from vendor CoA / vendor spec / "
        "USP <469>; policy statements are not material-specific limits; category "
        "phrases go to declaration_scopes; never emit solvents[] or elements[].\n"
        "STRICT: present=Yes REQUIRES a real source (vendor_coa/vendor_spec/"
        "usp_469) AND a non-null numeric limit AND a confirmed per-batch/CoA "
        "RESULT. Never Yes with null limit.\n"
        "A numeric DEG/EG limit shown with a PASS/COMPLIES verdict or a "
        "'USP <469>'/'USP/NF 469' reference IS a confirmed per-batch result → "
        "present=Yes, source=vendor_coa, confidence ≥ 0.90, spec_limit='NMT X "
        "ppm'. E.g. 'Ethylene Glycol Not more than 620 ppm PASS' and 'ETHYLENE "
        "GLYCOL (USP/NF 469) 620 PPM MAX Pass' → eg_present=Yes, 'NMT 620 ppm'.\n"
        "GUARANTEE CEILING (not confirmed presence): a max the vendor guarantees "
        "the material stays below, not quantified per batch, below the regulatory "
        "limit ('EG < 620 ppm, below Option 1, not quantified per batch', "
        "'guaranteed below X ppm') → present=No, source=vendor_guarantee_ceiling, "
        "keep the numeric limit for documentation.\n"
        "Scan patterns: 'Not more than X ppm', 'NMT X ppm', 'X PPM MAX', "
        "'≤ X ppm', '0.X%' (0.5% = 5000 ppm). Look in 'Residual solvents', "
        "numbered subsections, 'Impurities', 'Specifications', 'Tests'.\n"
        "SAP code ONLY from a 'SAP CODE:' / 'Material Code:' (10000/20000/30000/"
        "35000…) / 'Product Code:' label. Never a vendor/batch/lot/order number.\n\n"
        "Return ONLY JSON (object, not array):\n"
        "{\n"
        '  "material_code": "", "material_code_source": "sap_code|not_found",\n'
        '  "cas_number": "", "drl_specification_no": "",\n'
        '  "deg_eg_evidence": {"deg_present":"Yes|No|Unknown","deg_specification_limit":null,'
        '"deg_source":"vendor_coa|vendor_spec|vendor_guarantee_ceiling|usp_469|not_mentioned",'
        '"eg_present":"Yes|No|Unknown","eg_specification_limit":null,'
        '"eg_source":"vendor_coa|vendor_spec|vendor_guarantee_ceiling|usp_469|not_mentioned",'
        f'"raw_text":"","page":{page_no},"confidence":0.0}},\n'
        '  "declaration_scopes": []\n'
        "}"
    )


def convert_deg_eg_pdf_to_json(pdf_bytes: bytes, filename: str, index: int,
                               progress=None) -> Dict:
    """Convert one DEG/EG annexure PDF → strict JSON object. Never raises."""
    def _p(msg, pct=0.0):
        if progress:
            progress(msg, pct)
        logger.info(f"[{filename}] {msg}")

    _p("Rasterizing PDF…", 0.05)
    try:
        pages = rasterize_pdf(pdf_bytes, dpi=250)
    except Exception as e:
        err = DE.process_deg_eg_annexure(
            {"_error": True, "extraction_notes": f"PDF rasterization failed: {e}"},
            index)
        err["filename"] = filename
        return err
    if not pages:
        err = DE.process_deg_eg_annexure(
            {"_error": True, "extraction_notes": "PDF had no readable pages."}, index)
        err["filename"] = filename
        return err

    n = len(pages)
    _p(f"{n} page(s). Extracting material + DEG/EG evidence…", 0.12)
    meta_raw = claude_vision(pages[0], deg_eg_meta_prompt())
    meta = DE.deg_eg_safe_json(meta_raw, want="dict")
    if not isinstance(meta, dict):
        meta = {"_list_root": True, "schema_repaired": True}
    meta.setdefault("filename", filename)

    _REAL_SOURCES = ("vendor_coa", "vendor_spec", "usp_469")
    raw_texts = []
    mev0 = meta.get("deg_eg_evidence") or {}
    if _s(mev0.get("raw_text")):
        raw_texts.append(_s(mev0.get("raw_text")))

    # page sweep merges additional evidence + scopes across ALL pages. A later
    # page that carries a real numeric limit OR a real source overrides the
    # page-1 defaults for that glycol — even if page 1 already claimed Yes with a
    # null limit / 'not_mentioned' source (the canonical Polysorbate-80 bug).
    for pi in range(1, n):
        _p(f"Reading page {pi+1}/{n}…", 0.12 + 0.7 * pi / max(1, n))
        praw = claude_vision(pages[pi], deg_eg_page_prompt(pi + 1, n))
        pobj = DE.deg_eg_safe_json(praw, want="dict")
        if not isinstance(pobj, dict):
            continue
        pev = pobj.get("deg_eg_evidence") or {}
        mev = meta.get("deg_eg_evidence") or {}
        for which in ("deg", "eg"):
            p_present = pev.get(f"{which}_present")
            p_limit = pev.get(f"{which}_specification_limit")
            p_source = pev.get(f"{which}_source")
            has_real_limit = bool(_s(p_limit))
            has_real_source = p_source in _REAL_SOURCES
            m_present = mev.get(f"{which}_present")
            m_has_real = (bool(_s(mev.get(f"{which}_specification_limit")))
                          and mev.get(f"{which}_source") in _REAL_SOURCES)
            # Override when: this page upgrades presence to Yes, OR this page
            # supplies real evidence that the current merged record lacks.
            if p_present == "Yes" and (has_real_limit or has_real_source):
                if m_present != "Yes" or not m_has_real:
                    mev[f"{which}_present"] = "Yes"
                    if has_real_limit:
                        mev[f"{which}_specification_limit"] = p_limit
                    if has_real_source:
                        mev[f"{which}_source"] = p_source
                    if pobj.get("page") or pi + 1:
                        mev["page"] = pobj.get("page") or (pi + 1)
            elif (m_present != "Yes" and (has_real_limit or has_real_source)
                  and p_present in ("Yes", "Unknown", "No")):
                # page provides evidence though presence wasn't a clean Yes
                if has_real_limit and has_real_source:
                    mev[f"{which}_present"] = "Yes"
                    mev[f"{which}_specification_limit"] = p_limit
                    mev[f"{which}_source"] = p_source
                    mev["page"] = pobj.get("page") or (pi + 1)
        if _s(pev.get("raw_text")):
            raw_texts.append(_s(pev.get("raw_text")))
        if mev:
            meta["deg_eg_evidence"] = mev
        for sc in (pobj.get("declaration_scopes") or []):
            meta.setdefault("declaration_scopes", []).append(sc)
        # merge SAP/spec/CAS from any page if page 1 lacked them
        for fld in ("material_code", "material_code_source", "cas_number",
                    "drl_specification_no"):
            if not _s(meta.get(fld)) and _s(pobj.get(fld)):
                meta[fld] = pobj.get(fld)

    # concatenate raw_text across pages so the evidence trail is preserved
    if raw_texts:
        mev = meta.get("deg_eg_evidence") or {}
        mev["raw_text"] = " ".join(raw_texts)[:2000]
        meta["deg_eg_evidence"] = mev

    _p("Normalising…", 0.9)
    result = DE.process_deg_eg_annexure(meta, index)
    result["filename"] = filename
    _p("Done.", 1.0)
    return result


def build_zip(results: List[Dict]) -> bytes:
    buf = BytesIO()
    with zipfile.ZipFile(buf, "w", zipfile.ZIP_DEFLATED) as zf:
        manifest = []
        for r in results:
            num = r.get("annexure_number", "?")
            base = re.sub(r"[^A-Za-z0-9_\-]", "_",
                          _s(r.get("material_name")) or f"annexure_{num}")[:50]
            fname = f"DEGEG_annexure_{num}_{base}.json"
            zf.writestr(fname, json.dumps(r, indent=2, ensure_ascii=False))
            ev = r.get("deg_eg_evidence", {})
            manifest.append({"annexure_number": num, "filename": fname,
                             "material_name": r.get("material_name", ""),
                             "supplier_name": r.get("supplier_name", ""),
                             "deg_present": ev.get("deg_present"),
                             "eg_present": ev.get("eg_present"),
                             "error": r.get("_error", False)})
        zf.writestr("_manifest.json", json.dumps(manifest, indent=2))
    return buf.getvalue()


def main() -> None:
    st.set_page_config(page_title="DEG/EG Annexure Converter", layout="wide")
    st.title("🧪 DEG & EG Annexure PDF → JSON Converter")
    st.caption("Diethylene Glycol & Ethylene Glycol Risk Assessment | Dr. Reddy's "
               "IPDO | Separate from the RS and EI converters — extracts DEG/EG "
               "evidence only.")
    st.markdown("Upload vendor annexures (CoA, specifications, declarations, SDS, "
                "policy letters). Each PDF becomes one strict-schema JSON.")
    st.markdown("---")

    uploaded = st.file_uploader("Upload annexure PDF(s)", type=["pdf"],
                                accept_multiple_files=True)
    if not uploaded:
        st.info("📁 Upload one or more DEG/EG annexure PDFs to begin.")
        return

    if st.button("🚀 Convert All PDFs", type="primary"):
        results = []
        overall = st.progress(0.0)
        for idx, uf in enumerate(uploaded):
            status = st.empty()
            def cb(msg, pct, _s=status):
                _s.info(f"📄 {uf.name}: {msg}")
            try:
                res = convert_deg_eg_pdf_to_json(uf.getvalue(), uf.name, idx + 1, cb)
            except Exception as e:
                logger.exception("DEG/EG conversion error")
                res = DE.process_deg_eg_annexure(
                    {"_error": True, "extraction_notes": f"Unexpected error: {e}"},
                    idx + 1)
                res["filename"] = uf.name
            results.append(res)
            if res.get("_error"):
                status.error(f"❌ {uf.name}: {res.get('extraction_notes','failed')}")
            else:
                ev = res.get("deg_eg_evidence", {})
                mat = res.get("material_name") or "(material inferred / not resolved)"
                status.success(f"✅ {uf.name}: {mat} — DEG={ev.get('deg_present')} / "
                               f"EG={ev.get('eg_present')}")
                with st.expander(f"🔎 {uf.name} — extracted detail"):
                    st.json({k: res.get(k) for k in
                             ("material_name", "material_name_source",
                              "needs_material_confirmation", "supplier_name",
                              "annexure_type", "deg_eg_evidence",
                              "declaration_scopes", "schema_repaired")})
            overall.progress((idx + 1) / len(uploaded))

        n_ok = sum(1 for r in results if not r.get("_error"))
        st.success(f"Conversion complete: {n_ok}/{len(results)} succeeded.")
        st.download_button("📥 Download all JSON (ZIP)", data=build_zip(results),
            file_name=f"DEGEG_annexures_{datetime.now().strftime('%Y%m%d_%H%M%S')}.zip",
            mime="application/zip")


if __name__ == "__main__":
    main()
