def process_annexure(annexure_json: Any, index: int) -> Dict:
    """
    Extract EI data from one Document AI JSON annexure.
    Uses structured table extraction first (real numbers), then flat text fallback.
    """
    default = {"annexure_number":index,"supplier_name":"","material_name":"",
               "source_type":"","date_filled":"","elements":[]}

    tables     = _extract_docai_tables(annexure_json)
    table_text = _tables_to_text(tables) if tables else ""
    flat_text  = _flatten_docai_json(annexure_json)

    if table_text:
        content = (
            "STRUCTURED TABLES (use these for concentration values):\n"
            + table_text[:5000]
            + "\n\nMETADATA TEXT (use for supplier/material name):\n"
            + flat_text[:1500]
        )
        note = "Tables above contain vendor-declared concentrations. Read EVERY number exactly."
    else:
        content = flat_text[:7000]
        note = "Extract all elemental impurity concentrations from the text."

    prompt = (
        f"Extract elemental impurity data from Annexure {index}.\n\n"
        f"{note}\n\n"
        "CRITICAL: concentration_value MUST be the ACTUAL value from the document.\n"
        "- Printed value '0.3' → 0.3\n"
        "- '<0.5' → 0.5\n"
        "- BLQ / ND / Not Detected → 0.0  (NOT 0.05)\n"
        "- Blank / NA / not tested → 0.0\n"
        "- ONLY use 0.05 if 0.05 is literally printed in the document.\n"
        "- Blank / NA / not tested / not reported means concentration_value null, not 0.0.\n"
        "- This null rule overrides any conflicting wording above.\n"
        "- Do not output absent elements. Do not fill all 25 ICH Q3D elements by template.\n\n"
        "Return ONLY this JSON:\n"
        "{\n"
        f'  "annexure_number":{index},\n'
        '  "supplier_name":"exact supplier name","material_name":"exact material name",\n'
        '  "source_type":"","date_filled":"",\n'
        '  "elements":[{"symbol":"Pb","name":"Lead","class":"1",\n'
        '    "concentration_value":0.3,"concentration_unit":"ppm",\n'
        '    "analytical_method":"ICP-MS","intentionally_added":"No",\n'
        '    "observed_level":"0.3","listed_in_coa":"Yes",\n'
        '    "data_status":"reported","comments":""}]\n'
        "}\n\nDocument:\n" + content
    )

    raw    = call_claude([{"role":"user","content":prompt}], max_tokens=4096)
    parsed = safe_json_parse(raw, default)
    if not isinstance(parsed, dict): return default
    for k, v in default.items(): parsed.setdefault(k, v)
    if not isinstance(parsed.get("elements"), list): parsed["elements"] = []
    if isinstance(annexure_json, dict) and isinstance(annexure_json.get("_source"), dict):
        parsed["_source"] = annexure_json["_source"]
    if not parsed["elements"]:
        parsed["_error"] = "No elemental impurity rows were extracted from this annexure."

    # Flag 0.05 plague
    vals  = [_parse_conc(e.get("concentration_value"))
             for e in parsed["elements"] if isinstance(e,dict)]
    vals  = [v for v in vals if isinstance(v, (int, float))]
    n_005 = sum(1 for v in vals if isinstance(v,(int,float)) and abs(v-0.05)<0.001)
    if vals and n_005/len(vals) > 0.5:
        logger.warning(f"Annexure {index}: {n_005}/{len(vals)} elements=0.05 (placeholder?)")
        parsed["_warning_placeholder_values"] = True
        parsed["_n_placeholder"] = n_005
    return parsed


# ── Calculation engine ────────────────────────────────────────────────────────
def _parse_conc(val: Any) -> float:
    """Parse concentration to µg/g (ppm). BLQ/ND → 0.0 (not 0.05)."""
    if val is None: return 0.0
    if isinstance(val, (int, float)): return max(0.0, float(val))
    s = str(val).strip().lower()
    if s in ("","na","nd","blq","bdl","none","null","nq",
             "not detected","not quantified","below lod","below loq",
             "below limit","absent"): return 0.0
    s = re.sub(r"(ppm|µg/g|ug/g|\s)", "", s)
    s = s.replace("<","").replace(">","")
    try: return max(0.0, float(s))
    except: return 0.0


def _parse_conc(val: Any) -> Optional[float]:
    """Parse concentration to ug/g (ppm). Missing/not reported stays None."""
    if val is None:
        return None
    if isinstance(val, (int, float)):
        return max(0.0, float(val))
    s = str(val).strip().lower()
    missing_terms = {
        "", "na", "n/a", "none", "null", "not tested", "not reported",
        "not available", "not applicable", "not provided", "nr",
        "not determined", "no data", "not_reported", "not reported.",
    }
    non_detect_terms = {
        "nd", "blq", "bdl", "nq", "not detected", "not quantified",
        "below lod", "below loq", "below limit", "absent",
    }
    if s in missing_terms:
        return None
    if s in non_detect_terms:
        return 0.0
    s = re.sub(r"(ppm|µg/g|Âµg/g|ug/g|mcg/g|\s)", "", s)
    s = s.replace("<","").replace(">","")
    match = re.search(r"[-+]?\d*\.?\d+(?:[eE][-+]?\d+)?", s)
    if not match:
        return None
    try:
        return max(0.0, float(match.group(0)))
    except Exception:
        return None


def _parse_amount_g(val: Any) -> float:
    """Parse ingredient amount to grams."""
    if val is None: return 0.0
    s = str(val).strip().lower()
    if s in ("","q.s.","qs","na","qs to ph","qs to 1ml","qs to volume"): return 0.0
    s = re.sub(r"[^\d.\-eE]","",s)
    try: return float(s)
    except: return 0.0


def _build_conc_map(annexure_data: List[Dict]) -> Dict[str, Dict[str, Optional[float]]]:
    conc_map: Dict[str, Dict[str, Optional[float]]] = {}
    for ann in annexure_data:
        if not isinstance(ann, dict): continue
        material = safe_str(ann.get("material_name",""))
        if not material: continue
        elem_dict: Dict[str, Optional[float]] = {}
        for el in (ann.get("elements") or []):
            if not isinstance(el, dict): continue
            sym = safe_str(el.get("symbol",""))
            status = safe_str(el.get("data_status","")).lower()
            conc = None if any(t in status for t in ("not_reported", "not reported", "not tested", "missing")) \
                else _parse_conc(el.get("concentration_value"))
            if sym:
                elem_dict[sym] = conc
        conc_map[material] = elem_dict
    return conc_map


def _match_ingredient(name: str, conc_map: Dict[str, Dict[str, Optional[float]]]) -> Dict[str, Optional[float]]:
    """Match ingredient to annexure via exact, synonym, token-overlap, substring."""
    if not conc_map or not name: return {}
    name_lower = name.lower().strip()

    # Strategy 1: exact match
    for key in conc_map:
        if key and key.lower().strip() == name_lower:
            return conc_map[key]

    # Strategy 2: synonym expansion
    candidate_names: set = {name_lower}
    for base_name, synonyms in EXCIPIENT_SYNONYMS.items():
        all_variants = [base_name] + synonyms
        for variant in all_variants:
            vl = variant.lower()
            if vl == name_lower or vl in name_lower or name_lower in vl:
                candidate_names.update(v.lower() for v in all_variants)
                break
    for candidate in candidate_names:
        for key in conc_map:
            if key and key.lower().strip() == candidate:
                logger.debug(f"Synonym: '{name}' -> '{key}'")
                return conc_map[key]

    # Strategy 3: token overlap + substring
    best_key: Optional[str] = None
    best_score: float = 0.0
    for key in conc_map:
        if not key: continue
        kl = key.lower().strip()
        tn = set(t for t in re.split(r'[\s\(\)\-,/\.\*]+', name_lower) if len(t) > 1)
        tk = set(t for t in re.split(r'[\s\(\)\-,/\.\*]+', kl)         if len(t) > 1)
        if not tn or not tk: continue
        score = len(tn & tk) / max(len(tn), len(tk))
        if name_lower in kl or kl in name_lower:
            score = max(score, 0.5)
        for cand in candidate_names:
            tc = set(t for t in re.split(r'[\s\(\)\-,/\.\*]+', cand) if len(t) > 1)
            if tc:
                score = max(score, len(tc & tk) / max(len(tc), len(tk)))
        if score > best_score:
            best_score = score; best_key = key

    if best_score >= 0.15 and best_key:
        logger.debug(f"Token: '{name}' -> '{best_key}' ({best_score:.2f})")
        return conc_map[best_key]
    logger.warning(f"No match for '{name}' (best={best_score:.2f})")
    return {}


def _quality_flag(severity: str, code: str, message: str,
                  details: Optional[Dict] = None) -> Dict:
    return {
        "severity": severity,
        "code": code,
        "message": message,
        "details": details or {},
    }


def _numeric_values(values: List[Any]) -> List[float]:
    nums: List[float] = []
    for value in values:
        if isinstance(value, (int, float)) and value is not None:
            nums.append(float(value))
    return nums


def diagnose_ei_data_quality(comp_data: Dict, annexure_data: List[Dict],
                             calc_tables: Dict) -> List[Dict]:
    flags: List[Dict] = []

    for ann in annexure_data:
        if not isinstance(ann, dict):
            continue
        material = safe_str(ann.get("material_name", "unknown material"))
        supplier = safe_str(ann.get("supplier_name", "unknown supplier"))
        elements = [e for e in (ann.get("elements") or []) if isinstance(e, dict)]
        if ann.get("_error") or not elements:
            flags.append(_quality_flag(
                "critical", "annexure_no_ei_rows",
                f"No elemental impurity rows were extracted for {material} ({supplier}).",
                {"material": material, "supplier": supplier},
            ))
            continue
        vals = [_parse_conc(e.get("concentration_value")) for e in elements]
        vals = [v for v in vals if isinstance(v, (int, float))]
        if not vals:
            flags.append(_quality_flag(
                "critical", "annexure_no_numeric_concentrations",
                f"Annexure for {material} has no numeric supplier concentration values.",
                {"material": material, "supplier": supplier},
            ))
        if len(vals) >= 5:
            counts: Dict[float, int] = {}
            for value in vals:
                rounded = round(value, 4)
                counts[rounded] = counts.get(rounded, 0) + 1
            value, count = max(counts.items(), key=lambda item: item[1])
            if count / len(vals) >= 0.5:
                severity = "critical" if abs(value - 0.05) < 0.001 else "warning"
                flags.append(_quality_flag(
                    severity, "uniform_annexure_concentrations",
                    f"{count}/{len(vals)} concentrations for {material} are identical ({value:g} ug/g).",
                    {"material": material, "value": value, "count": count, "total": len(vals)},
                ))

    t5 = safe_calc_table(calc_tables, "class1_2a")
    all_rows = [r for r in t5.get("rows", []) if isinstance(r, dict)]
    unmatched = [r for r in all_rows if not safe_str(r.get("matched_annexure", ""))]
    if unmatched:
        flags.append(_quality_flag(
            "critical", "ingredient_annexure_mismatch",
            f"{len(unmatched)} composition ingredient(s) did not match any supplier annexure.",
            {"ingredients": [r.get("ingredient", "") for r in unmatched[:12]]},
        ))

    mdd_g = safe_float(comp_data.get("mdd_g", 0.0), default=0.0)
    total_intake = safe_float(t5.get("total_daily_intake", 0.0), default=0.0)
    if mdd_g > 0 and total_intake > 0 and abs(mdd_g - total_intake) > max(0.05 * mdd_g, 0.05):
        flags.append(_quality_flag(
            "warning", "mdd_scaling_mismatch",
            f"Calculated ingredient daily intake is {total_intake:g} g/day but product MDD is {mdd_g:g} g/day.",
            {"calculated_daily_intake_g": total_intake, "mdd_g": mdd_g},
        ))

    high_risk_terms = ("glucose", "dextrose", "talc", "iron oxide", "ferric oxide")
    sorted_rows = sorted(all_rows, key=lambda r: safe_float(r.get("daily_intake_g", 0.0)), reverse=True)
    high_mass_names = {safe_str(r.get("ingredient", "")).lower() for r in sorted_rows[:3]}
    for row in all_rows:
        ingredient = safe_str(row.get("ingredient", ""))
        ingredient_l = ingredient.lower()
        is_high_risk = any(term in ingredient_l for term in high_risk_terms)
        is_high_mass = ingredient_l in high_mass_names
        if not (is_high_risk or is_high_mass):
            continue
        totals = _numeric_values(list((row.get("total_mass") or {}).values()))
        if not safe_str(row.get("matched_annexure", "")):
            flags.append(_quality_flag(
                "critical", "high_risk_or_mass_unmatched",
                f"High-mass or high-risk ingredient '{ingredient}' has no matched supplier annexure.",
                {"ingredient": ingredient, "daily_intake_g": row.get("daily_intake_g")},
            ))
        elif not totals:
            flags.append(_quality_flag(
                "critical", "high_risk_or_mass_missing_concentrations",
                f"High-mass or high-risk ingredient '{ingredient}' has no reported concentration values in the calculation.",
                {"ingredient": ingredient, "matched_annexure": row.get("matched_annexure")},
            ))
        elif sum(totals) == 0:
            flags.append(_quality_flag(
                "warning", "high_risk_or_mass_zero_exposure",
                f"High-mass or high-risk ingredient '{ingredient}' contributes zero exposure across reported elements.",
                {"ingredient": ingredient, "matched_annexure": row.get("matched_annexure")},
            ))
        missing_elements = row.get("data_gap_elements") or []
        if safe_str(row.get("matched_annexure", "")) and missing_elements:
            flags.append(_quality_flag(
                "warning", "high_risk_or_mass_partial_concentration_gap",
                f"High-mass or high-risk ingredient '{ingredient}' is missing reported values for {len(missing_elements)} element(s).",
                {"ingredient": ingredient, "missing_elements": missing_elements[:12]},
            ))

    for key in ("class1_2a", "class2b", "class3"):
        table = safe_calc_table(calc_tables, key)
        totals = _numeric_values(list((table.get("element_totals") or {}).values()))
        positive = [round(v, 6) for v in totals if v > 0]
        if len(positive) >= 4:
            counts: Dict[float, int] = {}
            for value in positive:
                counts[value] = counts.get(value, 0) + 1
            value, count = max(counts.items(), key=lambda item: item[1])
            if count >= 3 and count / len(positive) >= 0.5:
                flags.append(_quality_flag(
                    "critical", "uniform_element_exposure_totals",
                    f"{count}/{len(positive)} positive total exposures in {key} are identical ({value:g} ug/day).",
                    {"table": key, "value": value, "count": count, "total": len(positive)},
                ))

    return flags


def calculate_ei_tables(comp_data: Dict, annexure_data: List[Dict]) -> Dict:
    """
    Product-agnostic EI calculation.
    
    Formula: Daily_exposure (µg/day) = Amount_in_MDD (g/day) × Conc (µg/g)
    
    For each ingredient:
      amount_in_mdd_g = ingredient_amount × (mdd_g / dose_unit_mass)
      daily_exposure  = amount_in_mdd_g × measured_conc_µg_per_g
    
    mdd_g = total mass of drug product per day in grams
    This works for: oral sachets, injections, tablets, topical, etc.
    """
    route       = safe_str(comp_data.get("route",""))
    mdd_g       = safe_float(comp_data.get("mdd_g", 0.0), default=0.0)
    doses_per_day = safe_int(comp_data.get("doses_per_day", 0), default=0)
    if not route:
        raise ValueError("Route of administration is missing; route-specific PDE selection cannot continue.")
    if doses_per_day <= 0:
        raise ValueError("doses_per_day is missing or invalid; EI exposure scaling cannot continue.")

    # Column keys Claude extracted from the spreadsheet
    ingredient_col  = safe_str(comp_data.get("ingredient_col", ""))
    amount_col      = safe_str(comp_data.get("amount_col", ""))
    amount_unit_raw = safe_str(comp_data.get("amount_unit", "")).lower()
    if not amount_unit_raw:
        raise ValueError("Ingredient amount unit is missing; EI exposure scaling cannot continue.")

    def _get_field(row: Dict, col_key: str, fallbacks: List[str]) -> str:
        """Get a value from a row, checking columns dict first, then direct keys."""
        cols_dict = row.get("columns", {})
        if isinstance(cols_dict, dict):
            # Try exact column key
            if col_key and col_key in cols_dict:
                return safe_str(cols_dict[col_key])
            # Try all column values if key not found
            for k, v in cols_dict.items():
                for fb in fallbacks:
                    if fb.lower() in k.lower():
                        return safe_str(v)
        # Try direct row keys
        for fb in fallbacks:
            if fb in row:
                return safe_str(row[fb])
        return ""

    # Build ingredient list with daily intake in grams
    ingredients: List[Dict] = []
    sections = comp_data.get("sections") or []
    for section in sections:
        if not isinstance(section, dict): continue
        for row in (section.get("rows") or []):
            if not isinstance(row, dict): continue

            # ── Get ingredient name ──────────────────────────────────────────
            name = _get_field(row, ingredient_col,
                              ["ingredient","name","Name of Ingredient",
                               "material","Material","component","Component"])
            if not name: continue

            # ── Get raw amount ───────────────────────────────────────────────
            raw_amount_str = _get_field(row, amount_col,
                                        ["amount","qty","Qty","40mg","quantity",
                                         "Quantity","mg/unit","mg/0.65mL","mg/mL"])
            amount_raw = _parse_amount_g(raw_amount_str)
            if amount_raw == 0:
                continue  # skip fillers/QS with no amount

            # ── Convert to grams based on reported unit ──────────────────────
            if "µg" in amount_unit_raw or "ug" in amount_unit_raw:
                amount_g = amount_raw / 1_000_000.0
            elif "mg" in amount_unit_raw:
                amount_g = amount_raw / 1000.0
            elif "ml" in amount_unit_raw:
                # mL ≈ g for aqueous solutions
                amount_g = amount_raw
            elif "g" in amount_unit_raw:
                amount_g = amount_raw
            else:
                raise ValueError(f"Unsupported ingredient amount unit: {amount_unit_raw}")

            # ── Scale to daily dose ──────────────────────────────────────────
            # daily_g = per-dose amount in grams × number of doses per day
            # This is the ONLY correct formula — never divide by anything.
            # doses_per_day for Esomeprazole 40mg × 6 sachets = 6
            # daily_g for Sugar Spheres (302mg/sachet) = 0.302 × 6 = 1.812g ✓
            daily_g = round(amount_g * doses_per_day, 8)
            ingredients.append({"name": name, "daily_g": daily_g})

    mdd_total = comp_data.get("mdd_total_mg_per_day", 0)
    logger.info(
        f"EI calc: {len(ingredients)} ingredients | route={route} | "
        f"doses_per_day={doses_per_day} | mdd_strength={comp_data.get('mdd_strength_mg',0)}mg | "
        f"mdd_total={mdd_total}mg/day | annexures={len(annexure_data)}"
    )

    conc_map = _build_conc_map(annexure_data)

    def build_one_table(elements: List[str]) -> Dict:
        rows: List[Dict] = []
        elem_totals: Dict[str, float] = {sym: 0.0 for sym in elements}
        elem_known_counts: Dict[str, int] = {sym: 0 for sym in elements}
        total_intake = 0.0
        for ing in ingredients:
            if ing["daily_g"] == 0: continue  # strict zero only; tiny values are valid
            ing_concs = _match_ingredient(ing["name"], conc_map)
            matched_key = ""
            for key, values in conc_map.items():
                if values is ing_concs:
                    matched_key = key
                    break
            measured: Dict[str, Optional[float]] = {}
            total_mass: Dict[str, Optional[float]] = {}
            missing_elements: List[str] = []
            for sym in elements:
                conc = ing_concs.get(sym) if matched_key else None
                if conc is None:
                    measured[sym] = None
                    total_mass[sym] = None
                    missing_elements.append(sym)
                    continue
                measured[sym] = round(conc, 4)
                mass = ing["daily_g"] * conc
                total_mass[sym] = round(mass, 6)
                elem_totals[sym] = round(elem_totals[sym] + mass, 6)
                elem_known_counts[sym] += 1
            total_intake += ing["daily_g"]
            rows.append({"ingredient": ing["name"],
                         "daily_intake_g": round(ing["daily_g"], 6),
                         "measured_conc": measured,
                         "total_mass": total_mass,
                         "matched_annexure": matched_key,
                         "data_gap_elements": missing_elements,
                         "has_concentration_gap": bool(missing_elements)})

        # PDE by route
        pde_vals = {sym: get_pde(sym, route) for sym in elements}
        threshold = {sym: round(pde_vals[sym]*0.30, 4) if pde_vals[sym] else None
                     for sym in elements}
        return {
            "elements":           elements,
            "rows":               rows,
            "total_daily_intake": round(total_intake, 6),
            "element_totals":     {sym: (round(elem_totals[sym], 6)
                                         if elem_known_counts[sym] else None)
                                   for sym in elements},
            "element_known_counts": elem_known_counts,
            "pde":                pde_vals,
            "threshold_30pct":    threshold,
            "route":              route,
        }

    calc_tables = {
        "class1_2a": build_one_table(TABLE5_ELEMENTS),
        "class2b":   build_one_table(TABLE6_ELEMENTS),
        "class3":    build_one_table(TABLE7_ELEMENTS),
    }
    calc_tables["data_quality_flags"] = diagnose_ei_data_quality(
        comp_data, annexure_data, calc_tables)
    return calc_tables


# ── Text section generation ───────────────────────────────────────────────────
def generate_text_sections(ref_structure: Dict, annexure_data: List[Dict],
                           calc_tables: Dict, comp_data: Dict) -> Dict:
    """
    Generate all narrative text sections dynamically.
    The prompt is product-agnostic — Claude uses reference structure + calculations.
    """
    empty: Dict = {
        "abstract":"","objective":"","study_location":"NA","background":"",
        "sources_intro":"","drug_substance_section":"","excipient_intro":"",
        "manufacturing_section":"","container_closure_section":"","utilities_section":"",
        "control_strategy":"","testing_recommendation":"","conclusion":"",
        "observation":"","reference":"NA",
    }
    meta    = ref_structure.get("meta", {}) or {}
    route   = safe_str(comp_data.get("route",""))
    mdd_g   = safe_float(comp_data.get("mdd_g",0.0))
    doses   = safe_int(comp_data.get("doses_per_day",1))
    toc     = ref_structure.get("toc_entries",[]) or []

    ann_summary = [{"material":a.get("material_name","N/A"),
                    "supplier":a.get("supplier_name","N/A"),
                    "n_elements":len(a.get("elements",[])or[])}
                   for a in annexure_data if isinstance(a, dict)]

    t5 = safe_calc_table(calc_tables,"class1_2a")
    t6 = safe_calc_table(calc_tables,"class2b")
    t7 = safe_calc_table(calc_tables,"class3")

    crossing = {}
    for sym in TABLE5_ELEMENTS:
        pde_val = t5["pde"].get(sym, 0) or 0
        total   = t5["element_totals"].get(sym, 0) or 0
        if pde_val and total > pde_val * 0.3:
            rows_with_sym = [r for r in t5.get("rows",[]) if isinstance(r,dict)]
            dominant = max(rows_with_sym,
                          key=lambda r: safe_float((r.get("total_mass",{}) or {}).get(sym, 0) or 0),
                          default={})
            crossing[sym] = {
                "total":               round(total, 4),
                "pde":                 round(pde_val, 4),
                "pde30":               round(pde_val * 0.3, 4),
                "pct_pde":             round(total / pde_val * 100, 1),
                "dominant_contributor":dominant.get("ingredient", "unknown"),
            }

    # Tell Claude how many TOC sections there are so it writes the right structure
    toc_info = ""
    if toc:
        toc_info = "TOC sections from reference: " + "; ".join(
            f"{e.get('no','?')}. {e.get('title','')}" for e in toc[:15])

    prompt = (
        "You are a pharmaceutical regulatory writer creating an ICH Q3D (R2) TSR.\n\n"
        f"Product: {meta.get('product_name','')}\n"
        f"Dosage form: {meta.get('dosage_form','')}\n"
        f"Route: {route}\n"
        f"MDD: {mdd_g}g/day ({doses} dose(s)/day)\n"
        f"Document No: {meta.get('document_no','')}\n\n"
        f"{toc_info}\n\n"
        f"Annexures ({len(annexure_data)} materials):\n{json.dumps(ann_summary)}\n\n"
        "Calculation formula: Daily exposure (µg/day) = Amount_in_MDD(g) × Conc(µg/g)\n"
        f"- Class 1+2A totals: {json.dumps(t5['element_totals'])}\n"
        f"- Class 2B totals:   {json.dumps(t6['element_totals'])}\n"
        f"- Class 3 totals:    {json.dumps(t7['element_totals'])}\n"
        f"- Route-specific PDEs used: {route}\n"
        f"- Elements crossing 30% PDE: {json.dumps(crossing)}\n\n"
        "Generate concise factual ICH Q3D regulatory text matching the product.\n"
        "Return ONLY this JSON (no markdown):\n"
        '{"abstract":"","objective":"","study_location":"NA","background":"",\n'
        '"sources_intro":"","drug_substance_section":"","excipient_intro":"",\n'
        '"manufacturing_section":"","container_closure_section":"","utilities_section":"",\n'
        '"control_strategy":"","testing_recommendation":"","conclusion":"",\n'
        '"observation":"","reference":"NA"}'
    )
    raw    = claude_text(prompt, max_tokens=6000)
    parsed = safe_json_parse(raw, {})
    if not isinstance(parsed, dict):
        logger.error("Text generation returned no valid JSON; using empty sections")
        return empty
    for k, v in empty.items(): parsed.setdefault(k, v)
    return parsed


def resolve_report_generator_script() -> Path:
    script_dir = Path(__file__).parent
    candidates = [
        script_dir / "generate_report.js",
        script_dir / "generate_report(2).js",
    ]
    for candidate in candidates:
        if candidate.exists():
            return candidate
    found = sorted(script_dir.glob("generate_report*.js"))
    if found:
        return found[0]
    raise FileNotFoundError("No generate_report*.js script found next to the Streamlit app.")


# ── Assemble and invoke Node.js ───────────────────────────────────────────────
def assemble_and_generate(ref_structure: Dict, page_images: List[bytes],
                          figure_pages: List[Dict], annexure_data: List[Dict],
                          comp_data: Dict, calc_tables: Dict, text_sections: Dict,
                          ref_bytes: bytes = b"", logo_b64: str = "",
                          logo_type: str = "") -> bytes:

    figures_b64: List[Dict] = []
    for fig in figure_pages:
        if not isinstance(fig, dict): continue
        pi = fig.get("page_index")
        if pi is None: continue
        try:
            img_bytes = extract_figure_from_page(ref_bytes, pi, dpi=200)
        except Exception as e:
            logger.warning(f"Figure raster p{pi}: {e}")
            img_bytes = safe_list_get(page_images, pi, b"")
        if not img_bytes: continue
        figures_b64.append({"page_index":pi,
                             "description":fig.get("description",""),
                             "figure_label":fig.get("figure_label","Figure 1"),
                             "data_b64":base64.standard_b64encode(img_bytes).decode(),
                             "media_type":"image/png"})

    annexure_list = [{"material":a.get("material_name","N/A"),
                      "supplier":a.get("supplier_name","N/A"),
                      "annexure":f"Annexure {a.get('annexure_number','?')}"}
                     for a in annexure_data if isinstance(a, dict)]

    additional_tables = extract_additional_tables([])

    report_data = {
        "meta":              ref_structure.get("meta",{}) or {},
        "toc_entries":       ref_structure.get("toc_entries",[]) or [],
        "logo_b64":          logo_b64,
        "logo_type":         logo_type,
        "text_sections":     text_sections or {},
        # Composition: exact columns from Excel as extracted
        "composition":       comp_data.get("sections",[]) or [],
        "comp_columns":      comp_data.get("columns",[]) or [],
        "comp_meta":         {"route": comp_data.get("route","oral"),
                              "mdd_g": comp_data.get("mdd_g",0.0),
                              "doses_per_day": comp_data.get("doses_per_day",1),
                              "unit": comp_data.get("unit",""),
                              "ingredient_col": comp_data.get("ingredient_col",""),
                              "amount_col": comp_data.get("amount_col",""),
                              "amount_unit": comp_data.get("amount_unit","mg")},
        "annexure_list":     annexure_list,
        "calc_tables":       calc_tables or {},
        "revision_history":  ref_structure.get("revision_history",[]) or [],
        "signatures":        ref_structure.get("signatures",[]) or [],
        "figures":           figures_b64,
        "pde_values":        dict(ICH_PDE),
        # All non-EI tables extracted verbatim from reference PDF
        "additional_tables": additional_tables,
    }

    with tempfile.TemporaryDirectory() as tmpdir:
        json_path = Path(tmpdir) / "report_data.json"
        docx_path = Path(tmpdir) / "report.docx"
        js_script = resolve_report_generator_script()
        with open(json_path,"w",encoding="utf-8") as f:
            json.dump(report_data, f, ensure_ascii=False)
        result = subprocess.run(
            ["node", str(js_script), str(json_path), str(docx_path)],
            capture_output=True, text=True, timeout=180, env=node_runtime_env())
        if result.returncode != 0:
            raise RuntimeError(
                f"Node.js failed (exit {result.returncode}).\n"
                f"STDERR: {result.stderr[-2000:]}\nSTDOUT: {result.stdout[-500:]}")
        if not docx_path.exists():
            raise RuntimeError(f"Node.js OK but no DOCX written.\nSTDOUT: {result.stdout}")
        docx_bytes = docx_path.read_bytes()
        if len(docx_bytes) < 5000:
            raise RuntimeError(f"DOCX too small ({len(docx_bytes)} bytes).")
        return docx_bytes


