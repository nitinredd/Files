import { useState } from 'react'

// ─── Icons ───────────────────────────────────────────────────────────────────

function HistoryIcon() {
  return (
    <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
      <circle cx="11" cy="11" r="8.25" stroke="currentColor" strokeWidth="1.3" />
      <path
        d="M11 7.5v3.75l2.5 2.5"
        stroke="currentColor"
        strokeWidth="1.3"
        strokeLinecap="round"
        strokeLinejoin="round"
      />
    </svg>
  )
}

function TrashIcon() {
  return (
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
      <path
        d="M2.5 3.5h9M5.5 3.5V2.5a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 .5.5v1M11 3.5l-.6 7.5a.5.5 0 0 1-.5.5H4.1a.5.5 0 0 1-.5-.5L3 3.5"
        stroke="currentColor"
        strokeWidth="1.15"
        strokeLinecap="round"
      />
    </svg>
  )
}

/** Chevron — points left when open (close action), right when closed (open action). */
function ChevronIcon({ open }) {
  return (
    <svg
      width="7"
      height="12"
      viewBox="0 0 7 12"
      fill="none"
      aria-hidden="true"
      style={{
        transform: open ? 'rotate(0deg)' : 'rotate(180deg)',
        transition: 'transform 280ms cubic-bezier(0.4, 0, 0.2, 1)',
        display: 'block',
      }}
    >
      <path
        d="M5.5 1L1 6l4.5 5"
        stroke="currentColor"
        strokeWidth="1.5"
        strokeLinecap="round"
        strokeLinejoin="round"
      />
    </svg>
  )
}

// ─── Helpers ─────────────────────────────────────────────────────────────────

function formatRelativeTime(date) {
  const diff = Date.now() - date.getTime()
  const mins = Math.floor(diff / 60_000)
  if (mins < 1) return 'just now'
  if (mins < 60) return `${mins}m ago`
  const hrs = Math.floor(mins / 60)
  if (hrs < 24) return `${hrs}h ago`
  return date.toLocaleDateString('en-GB', { day: '2-digit', month: 'short' })
}

function confidenceVariant(score) {
  if (score >= 0.8) return 'chip-conf-high'
  if (score >= 0.5) return 'chip-conf-mid'
  return 'chip-conf-low'
}

// ─── Component ───────────────────────────────────────────────────────────────

/**
 * HistorySidebar — collapsible glass panel.
 *
 * Props:
 *   history    — array of history items
 *   activeId   — id of the currently displayed item
 *   onSelect   — called with an item when user clicks a history entry
 *   onClear    — called to clear all history
 *   isOpen     — sidebar open/closed state (controlled from App)
 *   onToggle   — toggle callback
 */
export default function HistorySidebar({ history, activeId, onSelect, onClear, isOpen, onToggle }) {
  const [confirmClear, setConfirmClear] = useState(false)

  const handleClearClick = () => {
    if (confirmClear) {
      onClear()
      setConfirmClear(false)
    } else {
      setConfirmClear(true)
      setTimeout(() => setConfirmClear(false), 3000)
    }
  }

  return (
    /*
     * sidebar-container: relative-positioned flex wrapper.
     * Its width is driven by sidebar-clip, which animates.
     * The toggle button is absolute-positioned at left:100%,
     * so it always sits at the seam — visible whether open or closed.
     */
    <div className="sidebar-container">
      {/* Clipping shell — this width transitions */}
      <div className={`sidebar-clip${isOpen ? '' : ' sidebar-clip-collapsed'}`}>
        <aside className="sidebar" aria-label="Reconstruction history">
          {/* Sticky header */}
          <div className="sidebar-header">
            <span className="sidebar-label">HISTORY</span>
            {history.length > 0 && (
              <button
                className={`sidebar-clear-btn${confirmClear ? ' sidebar-clear-confirm' : ''}`}
                onClick={handleClearClick}
                aria-label={confirmClear ? 'Confirm clear' : 'Clear history'}
                title={confirmClear ? 'Click again to confirm' : 'Clear all history'}
              >
                {confirmClear ? (
                  <span className="sidebar-clear-label">CONFIRM</span>
                ) : (
                  <TrashIcon />
                )}
              </button>
            )}
          </div>

          {/* Content */}
          {history.length === 0 ? (
            <div className="sidebar-empty">
              <span className="sidebar-empty-icon">
                <HistoryIcon />
              </span>
              <p className="sidebar-empty-text">Reconstructions will appear here</p>
            </div>
          ) : (
            <ul className="history-list" role="list">
              {history.map((item) => (
                <li key={item.id}>
                  <button
                    className={`history-item${activeId === item.id ? ' history-item-active' : ''}`}
                    onClick={() => onSelect(item)}
                    aria-current={activeId === item.id ? 'true' : undefined}
                    aria-label={`Load: ${item.userInput}`}
                  >
                    {activeId === item.id && (
                      <span className="history-active-bar" aria-hidden="true" />
                    )}
                    <span className="history-preview">{item.userInput}</span>
                    <span className="history-meta">
                      <span className="history-time">
                        {formatRelativeTime(item.timestamp)}
                      </span>
                      {!item.isConversational && typeof item.confidence === 'number' && (
                        <span className={`history-conf ${confidenceVariant(item.confidence)}`}>
                          {Math.round(item.confidence * 100)}%
                        </span>
                      )}
                      {item.isConversational && (
                        <span className="history-conf chip-conf-info">INFO</span>
                      )}
                    </span>
                  </button>
                </li>
              ))}
            </ul>
          )}
        </aside>
      </div>

      {/* Toggle pill — always at the seam, never clipped */}
      <button
        className="sidebar-toggle"
        onClick={onToggle}
        aria-label={isOpen ? 'Collapse history sidebar' : 'Expand history sidebar'}
        aria-expanded={isOpen}
      >
        <ChevronIcon open={isOpen} />
      </button>
    </div>
  )
}
