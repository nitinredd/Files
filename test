<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Analytical AI Expert</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.8.5/d3.min.js"></script>
<style>
  :root {
    --bg: #0A0E1A;
    --surface: #111827;
    --surface2: #1a2235;
    --border: #1e2d45;
    --accent: #2563EB;
    --accent2: #059669;
    --accent3: #7C3AED;
    --warn: #DC2626;
    --gold: #F59E0B;
    --text: #E2E8F0;
    --text2: #94A3B8;
    --text3: #475569;
    --verified: #10B981;
    --glow: rgba(37,99,235,0.15);
  }

- { margin: 0; padding: 0; box-sizing: border-box; }

body {
font-family: ‘DM Sans’, sans-serif;
background: var(–bg);
color: var(–text);
height: 100vh;
overflow: hidden;
display: flex;
flex-direction: column;
}

/* ── TOPBAR ── */
.topbar {
display: flex;
align-items: center;
justify-content: space-between;
padding: 0 24px;
height: 52px;
background: var(–surface);
border-bottom: 1px solid var(–border);
flex-shrink: 0;
z-index: 100;
}

.logo {
display: flex;
align-items: center;
gap: 10px;
}

.logo-icon {
width: 28px; height: 28px;
background: linear-gradient(135deg, var(–accent), var(–accent3));
border-radius: 6px;
display: flex; align-items: center; justify-content: center;
font-size: 14px;
}

.logo-text {
font-family: ‘Instrument Serif’, serif;
font-size: 17px;
color: var(–text);
letter-spacing: -0.3px;
}

.logo-text span { color: var(–accent); }

.topbar-right {
display: flex;
align-items: center;
gap: 8px;
}

.mode-toggle {
display: flex;
background: var(–bg);
border: 1px solid var(–border);
border-radius: 8px;
padding: 3px;
gap: 2px;
}

.mode-btn {
padding: 4px 12px;
border-radius: 6px;
font-size: 11px;
font-weight: 500;
cursor: pointer;
border: none;
background: transparent;
color: var(–text2);
transition: all 0.2s;
font-family: ‘DM Mono’, monospace;
letter-spacing: 0.3px;
}

.mode-btn.active {
background: var(–accent);
color: white;
}

.status-dot {
width: 7px; height: 7px;
border-radius: 50%;
background: var(–verified);
box-shadow: 0 0 6px var(–verified);
animation: pulse 2s infinite;
}

@keyframes pulse {
0%, 100% { opacity: 1; }
50% { opacity: 0.4; }
}

.status-label {
font-size: 11px;
color: var(–text2);
font-family: ‘DM Mono’, monospace;
}

/* ── MAIN LAYOUT ── */
.main {
display: grid;
grid-template-columns: 340px 1fr 320px;
flex: 1;
overflow: hidden;
}

/* ── LEFT: CHAT HISTORY ── */
.sidebar-left {
background: var(–surface);
border-right: 1px solid var(–border);
display: flex;
flex-direction: column;
overflow: hidden;
}

.sidebar-header {
padding: 14px 16px 10px;
font-size: 10px;
font-weight: 600;
color: var(–text3);
letter-spacing: 1.2px;
text-transform: uppercase;
border-bottom: 1px solid var(–border);
font-family: ‘DM Mono’, monospace;
}

.query-history {
flex: 1;
overflow-y: auto;
padding: 8px;
}

.query-history::-webkit-scrollbar { width: 3px; }
.query-history::-webkit-scrollbar-track { background: transparent; }
.query-history::-webkit-scrollbar-thumb { background: var(–border); border-radius: 2px; }

.history-item {
padding: 10px 12px;
border-radius: 8px;
cursor: pointer;
transition: all 0.15s;
margin-bottom: 2px;
border: 1px solid transparent;
}

.history-item:hover {
background: var(–surface2);
border-color: var(–border);
}

.history-item.active {
background: var(–surface2);
border-color: var(–accent);
}

.history-q {
font-size: 12px;
color: var(–text);
line-height: 1.4;
margin-bottom: 4px;
display: -webkit-box;
-webkit-line-clamp: 2;
-webkit-box-orient: vertical;
overflow: hidden;
}

.history-meta {
display: flex;
align-items: center;
gap: 6px;
}

.history-badge {
font-size: 9px;
font-family: ‘DM Mono’, monospace;
padding: 2px 6px;
border-radius: 3px;
font-weight: 500;
}

.badge-hybrid { background: rgba(37,99,235,0.15); color: #60A5FA; }
.badge-slm { background: rgba(124,58,237,0.15); color: #A78BFA; }
.badge-verified { background: rgba(16,185,129,0.15); color: #34D399; }

.history-time {
font-size: 10px;
color: var(–text3);
font-family: ‘DM Mono’, monospace;
}

/* ── CENTER: MAIN PANEL ── */
.center-panel {
display: flex;
flex-direction: column;
overflow: hidden;
position: relative;
}

/* Answer area */
.answer-area {
flex: 1;
overflow-y: auto;
padding: 24px 28px;
}

.answer-area::-webkit-scrollbar { width: 3px; }
.answer-area::-webkit-scrollbar-track { background: transparent; }
.answer-area::-webkit-scrollbar-thumb { background: var(–border); border-radius: 2px; }

.query-display {
margin-bottom: 20px;
}

.query-label {
font-size: 10px;
color: var(–text3);
font-family: ‘DM Mono’, monospace;
letter-spacing: 1px;
text-transform: uppercase;
margin-bottom: 6px;
}

.query-text {
font-family: ‘Instrument Serif’, serif;
font-size: 20px;
color: var(–text);
line-height: 1.35;
letter-spacing: -0.3px;
}

.answer-block {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 12px;
padding: 20px 22px;
margin-bottom: 16px;
}

.answer-header {
display: flex;
align-items: center;
justify-content: space-between;
margin-bottom: 14px;
padding-bottom: 12px;
border-bottom: 1px solid var(–border);
}

.answer-source {
display: flex;
align-items: center;
gap: 8px;
}

.model-tag {
font-size: 10px;
font-family: ‘DM Mono’, monospace;
padding: 3px 8px;
border-radius: 4px;
background: rgba(37,99,235,0.12);
color: #60A5FA;
border: 1px solid rgba(37,99,235,0.2);
}

.verification-summary {
display: flex;
align-items: center;
gap: 5px;
font-size: 11px;
color: var(–verified);
font-family: ‘DM Mono’, monospace;
}

.answer-text {
font-size: 13.5px;
line-height: 1.75;
color: var(–text);
}

.answer-text p { margin-bottom: 12px; }
.answer-text p:last-child { margin-bottom: 0; }

.inline-cite {
display: inline-flex;
align-items: center;
background: rgba(37,99,235,0.1);
border: 1px solid rgba(37,99,235,0.25);
border-radius: 3px;
padding: 0px 5px;
font-size: 10px;
font-family: ‘DM Mono’, monospace;
color: #60A5FA;
cursor: pointer;
margin-left: 2px;
vertical-align: middle;
transition: all 0.15s;
}

.inline-cite:hover {
background: rgba(37,99,235,0.2);
border-color: var(–accent);
}

/* Claims verification */
.claims-section {
margin-top: 16px;
}

.claims-title {
font-size: 10px;
font-family: ‘DM Mono’, monospace;
color: var(–text3);
letter-spacing: 1px;
text-transform: uppercase;
margin-bottom: 10px;
}

.claim-row {
display: flex;
align-items: flex-start;
gap: 10px;
padding: 10px 12px;
border-radius: 8px;
background: var(–surface2);
border: 1px solid var(–border);
margin-bottom: 6px;
cursor: pointer;
transition: all 0.15s;
}

.claim-row:hover { border-color: var(–accent); }
.claim-row.active { border-color: var(–accent); background: rgba(37,99,235,0.05); }

.claim-icon {
width: 16px; height: 16px;
border-radius: 50%;
flex-shrink: 0;
margin-top: 1px;
display: flex; align-items: center; justify-content: center;
font-size: 9px;
}

.claim-icon.verified { background: rgba(16,185,129,0.2); color: var(–verified); }
.claim-icon.rejected { background: rgba(220,38,38,0.2); color: var(–warn); }

.claim-content { flex: 1; }

.claim-text {
font-size: 12px;
color: var(–text);
line-height: 1.4;
margin-bottom: 4px;
}

.claim-source {
font-size: 10px;
font-family: ‘DM Mono’, monospace;
color: var(–text3);
}

.claim-source span { color: #60A5FA; }

/* Query input */
.query-input-area {
padding: 16px 20px;
background: var(–surface);
border-top: 1px solid var(–border);
flex-shrink: 0;
}

.input-wrapper {
display: flex;
align-items: flex-end;
gap: 10px;
background: var(–bg);
border: 1px solid var(–border);
border-radius: 12px;
padding: 10px 14px;
transition: border-color 0.2s;
}

.input-wrapper:focus-within { border-color: var(–accent); }

.query-input {
flex: 1;
background: transparent;
border: none;
outline: none;
color: var(–text);
font-family: ‘DM Sans’, sans-serif;
font-size: 13.5px;
line-height: 1.5;
resize: none;
min-height: 20px;
max-height: 100px;
}

.query-input::placeholder { color: var(–text3); }

.send-btn {
width: 34px; height: 34px;
border-radius: 8px;
background: var(–accent);
border: none;
cursor: pointer;
display: flex; align-items: center; justify-content: center;
flex-shrink: 0;
transition: all 0.2s;
color: white;
font-size: 14px;
}

.send-btn:hover { background: #1d4ed8; transform: scale(1.05); }

.input-actions {
display: flex;
align-items: center;
gap: 8px;
margin-top: 8px;
padding: 0 2px;
}

.input-action-btn {
display: flex;
align-items: center;
gap: 4px;
padding: 4px 10px;
border-radius: 6px;
background: var(–surface2);
border: 1px solid var(–border);
color: var(–text2);
font-size: 11px;
cursor: pointer;
font-family: ‘DM Sans’, sans-serif;
transition: all 0.15s;
}

.input-action-btn:hover { border-color: var(–accent); color: var(–text); }

.upload-icon { font-size: 12px; }

/* ── RIGHT: GRAPH PANEL ── */
.sidebar-right {
background: var(–surface);
border-left: 1px solid var(–border);
display: flex;
flex-direction: column;
overflow: hidden;
}

.graph-header {
padding: 14px 16px 10px;
border-bottom: 1px solid var(–border);
display: flex;
align-items: center;
justify-content: space-between;
flex-shrink: 0;
}

.graph-title {
font-size: 10px;
font-weight: 600;
color: var(–text3);
letter-spacing: 1.2px;
text-transform: uppercase;
font-family: ‘DM Mono’, monospace;
}

.graph-controls {
display: flex;
gap: 4px;
}

.graph-ctrl-btn {
width: 22px; height: 22px;
border-radius: 4px;
background: var(–bg);
border: 1px solid var(–border);
color: var(–text2);
font-size: 11px;
cursor: pointer;
display: flex; align-items: center; justify-content: center;
transition: all 0.15s;
}

.graph-ctrl-btn:hover { border-color: var(–accent); color: var(–text); }

#graph-canvas {
flex: 1;
min-height: 0;
}

/* Citation popup */
.citation-popup {
position: absolute;
background: var(–surface2);
border: 1px solid var(–accent);
border-radius: 10px;
padding: 14px 16px;
width: 280px;
box-shadow: 0 8px 32px rgba(0,0,0,0.5);
z-index: 200;
display: none;
animation: popIn 0.15s ease;
}

@keyframes popIn {
from { opacity: 0; transform: scale(0.95) translateY(4px); }
to { opacity: 1; transform: scale(1) translateY(0); }
}

.citation-popup.show { display: block; }

.popup-source {
font-size: 10px;
font-family: ‘DM Mono’, monospace;
color: #60A5FA;
margin-bottom: 8px;
padding-bottom: 8px;
border-bottom: 1px solid var(–border);
}

.popup-text {
font-size: 12px;
color: var(–text2);
line-height: 1.6;
}

.popup-close {
position: absolute;
top: 8px; right: 10px;
color: var(–text3);
cursor: pointer;
font-size: 14px;
line-height: 1;
}

/* Graph node tooltip */
.node-tooltip {
position: fixed;
background: var(–surface2);
border: 1px solid var(–border);
border-radius: 8px;
padding: 10px 14px;
font-size: 11px;
color: var(–text);
pointer-events: none;
z-index: 300;
display: none;
max-width: 200px;
box-shadow: 0 4px 20px rgba(0,0,0,0.4);
}

.node-tooltip.show { display: block; }
.tooltip-name { font-weight: 600; margin-bottom: 3px; font-size: 12px; }
.tooltip-category { color: var(–text3); font-family: ‘DM Mono’, monospace; font-size: 10px; }
.tooltip-hint { color: var(–text3); font-size: 10px; margin-top: 5px; }

/* Scrollbar */
::-webkit-scrollbar { width: 4px; height: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(–border); border-radius: 2px; }

/* Loading animation */
.thinking {
display: flex;
align-items: center;
gap: 6px;
color: var(–text3);
font-size: 12px;
font-family: ‘DM Mono’, monospace;
padding: 12px 0;
}

.thinking-dots span {
display: inline-block;
width: 5px; height: 5px;
border-radius: 50%;
background: var(–accent);
animation: bounce 1.2s infinite;
}

.thinking-dots span:nth-child(2) { animation-delay: 0.2s; }
.thinking-dots span:nth-child(3) { animation-delay: 0.4s; }

@keyframes bounce {
0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
30% { transform: translateY(-5px); opacity: 1; }
}

/* Highlight for active node concept in text */
.concept-highlight {
background: rgba(37,99,235,0.12);
border-bottom: 1px solid rgba(37,99,235,0.4);
cursor: pointer;
border-radius: 2px;
padding: 0 1px;
transition: background 0.15s;
}
.concept-highlight:hover { background: rgba(37,99,235,0.22); }

/* Graph legend */
.graph-legend {
padding: 10px 14px;
border-top: 1px solid var(–border);
display: flex;
flex-wrap: wrap;
gap: 8px;
flex-shrink: 0;
}

.legend-item {
display: flex;
align-items: center;
gap: 5px;
font-size: 10px;
color: var(–text3);
font-family: ‘DM Mono’, monospace;
}

.legend-dot {
width: 8px; height: 8px;
border-radius: 50%;
flex-shrink: 0;
}
</style>

</head>
