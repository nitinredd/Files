    st.caption("ICH Q3D (R2) | Dr. Reddy's IPDO | Claude claude-opus-4-6 via Vertex AI")
    st.markdown("---")

    col1, col2, col3 = st.columns(3)

    with col1:
        st.subheader("📄 Reference Report PDF")
        ref_pdf = st.file_uploader(
            "Previous approved TSR report (provides template, text & figures)",
            type=["pdf"], key="ref_pdf"
