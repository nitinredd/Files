def make_standard_table(doc: Document, headers: List[str],
                         rows: List[List[str]],
                         col_widths: List[float] = None,
                         header_fill: str = "D9D9D9") -> None:
    """
    Create a bordered table with shaded header row.
    col_widths in inches; defaults to equal widths.
    """
    total_w = 7.5
    if col_widths is None:
        col_widths = [total_w / len(headers)] * len(headers)

    tbl = doc.add_table(rows=1 + len(rows), cols=len(headers))
    tbl.style = "Table Grid"
    tbl.alignment = WD_TABLE_ALIGNMENT.CENTER

    # Header row
    hdr = tbl.rows[0]
    for i, (h, w) in enumerate(zip(headers, col_widths)):
        cell = hdr.cells[i]
        cell.width = Inches(w)
        shade_cell(cell, header_fill)
        p = cell.paragraphs[0]
        p.alignment = WD_ALIGN_PARAGRAPH.CENTER
        bold_run(p, str(h), size_pt=8)
        set_cell_border(cell)

    # Data rows
    for r_idx, row in enumerate(rows):
        tr = tbl.rows[r_idx + 1]
        for c_idx, val in enumerate(row):
            cell = tr.cells[c_idx]
            cell.width = Inches(col_widths[c_idx] if c_idx < len(col_widths) else 1.0)
            p = cell.paragraphs[0]
            p.alignment = WD_ALIGN_PARAGRAPH.CENTER
            normal_run(p, str(val), size_pt=8)
            set_cell_border(cell)

    doc.add_paragraph()  # spacing after table


