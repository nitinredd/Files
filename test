def _flatten_docai_json(obj: Any, depth: int = 0) -> str:
    """Flatten a Document AI JSON object into plain text."""
    if depth > 8:
        return ""
    parts: List[str] = []
    if isinstance(obj, dict):
        if "text" in obj and isinstance(obj["text"], str):
            parts.append(obj["text"])
        for v in obj.values():
            parts.append(_flatten_docai_json(v, depth + 1))
    elif isinstance(obj, list):
        for item in obj:
            parts.append(_flatten_docai_json(item, depth + 1))
    elif isinstance(obj, (str, int, float)):
        parts.append(str(obj))
    return " ".join(p for p in parts if p.strip())


def process_annexure(annexure_json: Any, index: int) -> Dict:
    """Extract structured EI declaration from one Document AI JSON file."""
    text_content = _flatten_docai_json(annexure_json)

    prompt = (
        f"Extract pharmaceutical elemental impurity data from Annexure {index}.\n\n"
        "Return ONLY this JSON (no markdown):\n"
        '{\n'
        f'  "annexure_number": {index},\n'
        '  "supplier_name": "",\n'
        '  "material_name": "",\n'
        '  "source_type": "Plant/Mineral/Synthetic",\n'
        '  "date_filled": "",\n'
        '  "elements": [\n'
        '    {"name": "", "symbol": "", "class": "1/2A/2B/3",\n'
        '     "intentionally_added": "Yes/No",\n'
        '     "concentration_value": 0.05, "concentration_unit": "ppm",\n'
        '     "analytical_method": "ICP-MS", "observed_level": "BLQ",\n'
        '     "frequency_of_testing": "Once", "listed_in_coa": "Yes/No",\n'
        '     "comments": ""}\n'
        '  ]\n'
        '}\n\n'
        "Rules:\n"
        "- concentration_value: numeric; BLQ → 0.05; NA/blank → 0\n"
        "- symbol: standard element symbol (Pb, As, Cd, Hg, etc.)\n\n"
        f"Document text:\n{text_content[:8000]}"
    )

    raw = call_claude([{"role": "user", "content": prompt}])
    default: Dict = {
        "annexure_number": index,
        "supplier_name":   "N/A",
        "material_name":   "N/A",
        "source_type":     "N/A",
        "date_filled":     "",
        "elements":        [],
    }
    parsed = safe_json_parse(raw, default)
    if not isinstance(parsed, dict):
        return default
    for k, v in default.items():
        parsed.setdefault(k, v)
    if not isinstance(parsed.get("elements"), list):
        parsed["elements"] = []
    return parsed


