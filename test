                _meta, annexures, generate_images=False, generate_charts=False)
            st.session_state["benoc_preview"] = preview
            st.session_state["benoc_validation"] = validation
        except Exception:
            logger.exception("BE NOC process error")
            st.error("Could not read the uploaded files. Please try again.")

    annexures = st.session_state.get("benoc_annexures")
    if annexures is None:
        return
    validation = st.session_state.get("benoc_validation", {})

    # Warning-first: generate unless a true STRUCTURAL error (no files / all
    # extraction failed). Content warnings are informational only → logger; they
    # never appear in the UI or the DOCX.
    for _w in validation.get("warnings", []):
        logger.info(f"[BE NOC] {_w}")
    if validation.get("errors"):
        for _e in validation["errors"]:
            logger.error("[BE NOC] %s", _e)
        st.error("None of the uploaded files could be read. Please check them "
                 "and try again.")
    elif st.button("Generate Report", type="primary", key="bn_generate",
                   use_container_width=True):
