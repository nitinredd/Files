// ── CALC TABLE ────────────────────────────────────────────────────────────────
function buildCalcTable(tableNum,tableData,pdeValues){
const safe=obj=>(obj&&typeof obj===‘object’)?obj:{};
const{elements=[],rows=[],total_daily_intake=0,
element_totals={},pde={},threshold_30pct={}}=safe(tableData);
const N=Math.max(1,elements.length);
const INGR=Math.round(CW*0.27), DI=Math.round(CW*0.07);
const avail=CW-INGR-DI;
const EW=Math.max(280,Math.floor(avail/(2*N)));
const colW=[INGR,DI,…Array(N).fill(EW),…Array(N).fill(EW)];

// Group classes
const grps=[];
elements.forEach(sym=>{
const cls=((pdeValues||{})[sym]||{}).class||’?’;
if(!grps.length||grps[grps.length-1].cls!==cls) grps.push({cls,count:1});
else grps[grps.length-1].count++;
});

const h1=new TableRow({children:[
cell(‘Component’,          {bold:true,fill:C.TH_LIGHT,w:INGR,size:S.XS}),
cell(‘Daily\nIntake\n(g)’, {bold:true,fill:C.TH_LIGHT,w:DI,size:S.XS}),
new TableCell({columnSpan:N,borders:bdrs(4),shading:shade(C.TH_LIGHT),margins:cm(),
children:[p([run(‘Measured Concentration (µg/g)’,true,S.XS)],AlignmentType.CENTER)]}),
new TableCell({columnSpan:N,borders:bdrs(4),shading:shade(C.TH_LIGHT),margins:cm(),
children:[p([run(‘Total Mass of Elemental Impurity (µg/day)’,true,S.XS)],AlignmentType.CENTER)]}),
]});

const h2cells=[eCell(C.TH_LIGHT,INGR),eCell(C.TH_LIGHT,DI)];
for(let r=0;r<2;r++) grps.forEach(g=>h2cells.push(new TableCell({
columnSpan:g.count,borders:bdrs(4),shading:shade(C.TH_LIGHT),margins:cm(),
children:[p([run(`Class ${g.cls}`,true,S.XS)],AlignmentType.CENTER)],
})));
const h2=new TableRow({children:h2cells});

const h3=new TableRow({children:[
eCell(C.TH_LIGHT,INGR),eCell(C.TH_LIGHT,DI),
…elements.map(sym=>cell(sym,{bold:true,fill:C.TH_LIGHT,w:EW,size:S.XS})),
…elements.map(sym=>cell(sym,{bold:true,fill:C.TH_LIGHT,w:EW,size:S.XS})),
]});

const fmt=(v,d=4)=>{
if(v==null||v===’’) return ‘’;
const n=parseFloat(String(v).replace(/[^0-9.eE-]/g,’’));
return isNaN(n)||!isFinite(n)?’’:n.toFixed(d);
};

const dataRows=(rows||[]).filter(Boolean).map(row=>{
const mc=row.measured_conc||{}, tm=row.total_mass||{};
return new TableRow({children:[
cellL(row.ingredient||’’,{w:INGR,size:S.XS}),
cell(fmt(row.daily_intake_g??0,3),{w:DI,size:S.XS}),
…elements.map(sym=>cell(fmt(mc[sym]??0,4),{w:EW,size:S.XS})),
…elements.map(sym=>cell(fmt(tm[sym]??0,4),{w:EW,size:S.XS})),
]});
});

const fRow=(label,vals,fill,isT=false)=>{
const sv=vals||{}, st=element_totals||{};
return new TableRow({children:[
cell(label,{bold:true,fill,align:AlignmentType.LEFT,w:INGR,size:S.XS}),
cell(label===‘TOTAL (daily intake) g/day’?fmt(total_daily_intake,3):’’,{fill,w:DI,size:S.XS}),
…elements.map(()=>eCell(fill,EW)),
…elements.map(sym=>{
const val=sv[sym]!=null?sv[sym]:null;
const tot=st[sym];
const ex=isT&&val!=null&&tot!=null&&isFinite(val)&&isFinite(tot)&&tot>val;
return cell(val!=null?fmt(val,3):’–’,
{fill:ex?C.THRESHOLD:fill,w:EW,size:S.XS,color:ex?C.EXCEEDED:C.BLACK});
}),
]});
};

const labels={5:‘Class 1 and Class 2A’,6:‘Class 2B’,7:‘Class 3’};
const tbl=new Table({width:{size:CW,type:WidthType.DXA},columnWidths:colW,rows:[
h1,h2,h3,…dataRows,
fRow(‘TOTAL (daily intake) g/day’,element_totals,C.TH_LIGHT),
fRow(‘PDE (µg/day)’,pde,C.TH_LIGHT),
fRow(‘Threshold Limit (30% of PDE)’,threshold_30pct,‘FFE699’,true),
]});

return [
p([run(`Table ${tableNum}: Theoretical Elemental Impurity Assessment (${labels[tableNum]||''}) — `+
`Evaluation of Daily Contribution of the Total Mass of Elemental Impurities`,true,S.SM)],
AlignmentType.LEFT,60,20),
tbl, blank(),
];
}

// ── SUMMARY ──────────────────────────────────────────────────────────────────
function buildSummarySection(txt){
const ch=[sHd(‘6. Summary & Conclusion’)];
if(txt.observation){
ch.push(p([run(‘Observation:’,true,S.BODY)]));
bodyParagraphs(txt.observation).forEach(pp=>ch.push(pp));
ch.push(blank());
}
if(txt.conclusion){
ch.push(p([run(‘Conclusion:’,true,S.BODY)]));
bodyParagraphs(txt.conclusion).forEach(pp=>ch.push(pp));
}
ch.push(pageBreak());
return ch;
}

