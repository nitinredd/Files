    "usp", "nf", "ep", "bp", "jp", "ip", "pheur", "eur", "ph", "grade", "anhydrous",
    "purified", "for", "of", "the", "and", "a", "an", "c", "cas", "no", "number",
    "lva", "dispersion", "coating", "premium", "cps", "cp", "mesh", "rs", "json",
    "annexure", "datasheet", "data", "sheet", "regulatory", "product", "operations",
    "gmbh", "inc", "llc", "ltd", "limited", "co", "company", "residual", "solvents",
    "solvent", "committee", "harmonization", "harmonisation", "statement",
    "declaration", "summary", "information", "quality", "spec", "specification",
    "type", "grade", "pharma", "pharmaceutical", "material", "supplier",
