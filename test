            mass = ing["daily_intake_g"] * conc
            total_mass[sym] = round(mass, 4)
            element_totals[sym] = round(element_totals[sym] + mass, 4)
        total_intake += ing["daily_intake_g"]
        rows.append({
            "ingredient": ing["name"],
            "daily_intake_g": round(ing["daily_intake_g"], 3),
            "measured_conc": measured,
            "total_mass": total_mass,
        })

    pde = {sym: ICH_PDE[sym]["pde"] for sym in elements}
    threshold = {
        sym: round(pde[sym] * 0.30, 3) if pde[sym] else None
        for sym in elements
    }

    return {
        "elements": elements,
        "rows": rows,
        "total_daily_intake": round(total_intake, 3),
        "element_totals": {sym: round(v, 4) for sym, v in element_totals.items()},
        "pde": pde,
        "threshold_30pct": threshold,
    }

return {
    "class1_2a": build_table(TABLE5_ELEMENTS),
    "class2b": build_table(TABLE6_ELEMENTS),
    "class3": build_table(TABLE7_ELEMENTS),
}
