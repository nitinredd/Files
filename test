def build_calculation_tables(doc: Document, excel_data: dict):
    """Tables 5, 6, 7 – Theoretical EI Assessment (Class 1/2A, 2B, 3)."""

    for table_num, key, class_label, class_desc in [
        (5, "class1_2a", "Class 1 and Class 2A",
         "Pb, As, Cd, Hg (Class 1) and Co, V, Ni (Class 2A)"),
        (6, "class2b",   "Class 2B",
         "Pd, Se, Tl, Au, Ir, Os, Rh, Ru, Ag, Pt"),
        (7, "class3",    "Class 3",
         "Li, Sb, Ba, Cr, Cu, Mg, Sn, Mo"),
    ]:
        p = doc.add_paragraph()
        bold_run(p,
            f"Table {table_num}: Theoretical Elemental Impurity Assessment ({class_label}) - "
            f"Evaluation of Daily Contribution of the Total Mass of Elemental Impurities in the "
            f"Esomeprazole Magnesium for Delayed Release Oral Suspension\n"
            f"Elements: {class_desc}", size_pt=9)

        rows = excel_data.get(key, [])
        if rows and len(rows) > 1:
            # First row = headers, rest = data
            headers = rows[0]
            data    = rows[1:]
            # Compute equal col widths
            n_cols = len(headers)
            col_w  = [7.5 / n_cols] * n_cols
            col_w[0] = 2.0  # ingredient name column wider
            remaining = (7.5 - 2.0) / max(n_cols - 1, 1)
            col_w = [2.0] + [remaining] * (n_cols - 1)
            make_standard_table(doc, headers=headers, rows=data, col_widths=col_w)
        else:
            add_body_paragraph(doc,
                f"[Table {table_num} – upload Excel with sheet '{key.upper()}' to populate]")

    doc.add_page_break()


