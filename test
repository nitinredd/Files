def _inj_generate_from_clean_inputs(_inj, meta: Dict, excel_bytes: bytes,
                                    annexure_data: List[Dict]) -> bytes:
    """Run the injection EI backend end-to-end from the minimal clean inputs.
    Same call sequence as the original injection workflow; every inferred value
    (dose volume, density, strength, doses/day) comes from the Excel as before —
    the UI simply no longer asks for or displays them."""
    raw = parse_injection_excel_raw(excel_bytes)
    parsed = _inj.parse_injection_excel(raw, meta["product_name"], doses_per_day=1)
    model_info = _inj.detect_calculation_model(annexure_data)
    comp = _inj.build_injection_comp_data(parsed, model_info)

    _errors, _warnings = _inj.validate_injection(parsed, model_info, comp,
                                                 annexure_data)
    for _w in (_errors or []) + (_warnings or []):
        logger.warning("[EI injection] %s", _w)

    header = dict(meta)
    header.update({
        "route": "parenteral",
