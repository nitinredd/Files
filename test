"""
citation_builder.py — Machine-readable audit trail for TSR Report Generator
Tracks every piece of content back to its exact source file, row, or guideline.
"""
import hashlib
import json
import re
from typing import Any, Dict, List, Optional, Tuple


class CitationBuilder:
    """Accumulates citations throughout the pipeline and emits a ledger JSON."""

    def __init__(self) -> None:
        self.citations: List[Dict] = []
        self._counter: int = 0
        self.inputs: Dict = {"reference_pdf": {}, "excel": {}, "annexures": []}

    def next_id(self) -> str:
        self._counter += 1
        return f"C{self._counter:04d}"

    # ── Input registration ────────────────────────────────────────────────────

    def register_pdf(self, filename: str, data: bytes, pages: int) -> None:
        self.inputs["reference_pdf"] = {
            "filename": filename,
            "sha256": sha256_hex(data),
            "pages": pages,
        }

    def register_excel(self, filename: str, data: bytes, sheet: str = "Sheet1") -> None:
        self.inputs["excel"] = {
            "filename": filename,
            "sha256": sha256_hex(data),
            "sheet": sheet,
        }

    def register_annexure(self, index: int, filename: str, data: bytes,
                           material_name: str, supplier: str) -> None:
        entry = {
            "index": index,
            "filename": filename,
            "sha256": sha256_hex(data),
            "material_name": material_name,
            "supplier": supplier,
        }
        anns = self.inputs["annexures"]
        # Extend list if needed
        while len(anns) < index:
            anns.append({})
        anns[index - 1] = entry

    # ── Citation factories ────────────────────────────────────────────────────

    def cite_measured_conc(
        self, table_name: str, ingredient: str, element: str,
        value: float, annexure_index: int, annexure_filename: str,
        material_name: str, supplier: str,
        field_path: str, raw_value: str,
        unit: str, analytical_method: str,
    ) -> str:
        cid = self.next_id()
        self.citations.append({
            "citation_id": cid,
            "section": table_name,
            "cell": {"row": ingredient, "col": f"{element}_measured_conc"},
            "value": str(value),
            "source_type": "annexure",
            "source": {
                "annexure_index": annexure_index,
                "filename": annexure_filename,
                "material_name": material_name,
                "supplier": supplier,
                "element_symbol": element,
                "field_path": field_path,
                "raw_value": raw_value,
                "unit": unit,
                "analytical_method": analytical_method,
            },
        })
        return cid

    def cite_daily_intake(
        self, table_name: str, ingredient: str,
        value: float, excel_filename: str,
        sheet_name: str, row_number: int,
        amount_raw: str, amount_unit: str,
        mdd_g: float, doses_per_day: int,
        amount_col: str,
    ) -> str:
        cid = self.next_id()
        self.citations.append({
            "citation_id": cid,
            "section": table_name,
            "cell": {"row": ingredient, "col": "daily_intake_g"},
            "value": str(value),
            "source_type": "excel_row",
            "source": {
                "filename": excel_filename,
                "sheet": sheet_name,
                "row_number": row_number,
                "amount_raw": amount_raw,
                "amount_unit": amount_unit,
                "amount_col": amount_col,
            },
            "formula": "amount_g = raw_amount / 1000 (if mg); daily_g = amount_g × doses_per_day",
            "formula_inputs": {
                "mdd_g": mdd_g,
                "doses_per_day": doses_per_day,
            },
        })
        return cid

    def cite_daily_exposure(
        self, table_name: str, ingredient: str, element: str,
        value: float, intake_cid: str, conc_cid: str,
        daily_intake_g: float, conc_ug_per_g: float,
    ) -> str:
        cid = self.next_id()
        self.citations.append({
            "citation_id": cid,
            "section": table_name,
            "cell": {"row": ingredient, "col": f"{element}_daily_exposure"},
            "value": str(value),
            "source_type": "calculated",
            "formula": "daily_exposure_ug_per_day = daily_intake_g × concentration_ug_per_g",
            "inputs": {
                "daily_intake_g": {"value": daily_intake_g, "citation_id": intake_cid},
                "concentration_ug_per_g": {"value": conc_ug_per_g, "citation_id": conc_cid},
            },
        })
        return cid

    def cite_pde(
        self, table_name: str, element: str, value: float,
        ich_class: str, route: str, guideline_table: str,
    ) -> str:
        cid = self.next_id()
        self.citations.append({
            "citation_id": cid,
            "section": table_name,
            "cell": {"row": "PDE", "col": element},
            "value": str(value),
            "source_type": "regulatory",
            "source": {
                "guideline": "ICH Q3D (R2)",
                "table": guideline_table,
                "element": element,
                "class": ich_class,
                "route": route,
                "unit": "µg/day",
            },
        })
        return cid

    def cite_threshold(
        self, table_name: str, element: str, value: float,
        pde_cid: str, pde_value: float,
    ) -> str:
        cid = self.next_id()
        self.citations.append({
            "citation_id": cid,
            "section": table_name,
            "cell": {"row": "Threshold (30% PDE)", "col": element},
            "value": str(value),
            "source_type": "derived",
            "formula": "threshold = PDE × 0.30",
            "guideline": "ICH Q3D (R2) Option 2b",
            "inputs": {
                "pde_value": {"value": pde_value, "citation_id": pde_cid},
                "factor": 0.30,
            },
        })
        return cid

    def cite_text_section(
        self, section_name: str, prompt_name: str,
        prompt_hash: str, meta_fields_used: List[str],
        annexure_numbers: List[int],
        calc_results_used: List[str],
        timestamp: str,
    ) -> str:
        cid = self.next_id()
        self.citations.append({
            "citation_id": cid,
            "section": f"Text: {section_name}",
            "cell": {"row": "paragraph", "col": "generated_text"},
            "source_type": "generated_text",
            "source": {
                "prompt_name": prompt_name,
                "prompt_hash": prompt_hash,
                "meta_fields_used": meta_fields_used,
                "annexure_numbers_referenced": annexure_numbers,
                "calc_results_referenced": calc_results_used,
                "model": "claude-opus-4-6",
                "timestamp": timestamp,
            },
        })
        return cid

    def cite_metadata_field(
        self, field_name: str, value: str,
        pdf_filename: str, page_number: int,
        extraction_method: str,
    ) -> str:
        cid = self.next_id()
        self.citations.append({
            "citation_id": cid,
            "section": "Header Metadata",
            "cell": {"row": "metadata", "col": field_name},
            "value": value,
            "source_type": "pdf_extraction",
            "source": {
                "filename": pdf_filename,
                "page_number": page_number,
                "extraction_method": extraction_method,
                "field_path": f"meta.{field_name}",
            },
        })
        return cid

    def cite_ingredient_match(
        self, ingredient_name: str, matched_material: str,
        annexure_index: int, match_score: float, match_method: str,
    ) -> str:
        cid = self.next_id()
        low_conf = match_score < 0.5
        self.citations.append({
            "citation_id": cid,
            "section": "Ingredient Matching",
            "cell": {"row": ingredient_name, "col": "annexure_match"},
            "source_type": "ingredient_match",
            "source": {
                "ingredient_name": ingredient_name,
                "matched_annexure_material": matched_material,
                "annexure_index": annexure_index,
                "match_score": round(match_score, 4),
                "match_method": match_method,
                "low_confidence": low_conf,
            },
            "flags": ["LOW_CONFIDENCE_MATCH"] if low_conf else [],
        })
        return cid

    # ── Ledger output ─────────────────────────────────────────────────────────

    def build_ledger(self, report_id: str, generated_at: str) -> Dict:
        type_counts: Dict[str, int] = {}
        for c in self.citations:
            t = c.get("source_type", "unknown")
            type_counts[t] = type_counts.get(t, 0) + 1
        low_conf = sum(
            1 for c in self.citations
            if "LOW_CONFIDENCE_MATCH" in (c.get("flags") or [])
        )
        return {
            "report_id": report_id,
            "generated_at": generated_at,
            "schema_version": "1.0",
            "inputs": self.inputs,
            "citations": self.citations,
            "summary": {
                "total_citations": len(self.citations),
                "by_type": type_counts,
                "low_confidence_matches": low_conf,
            },
        }

    def write_ledger(self, output_path: str, report_id: str, generated_at: str) -> Dict:
        ledger = self.build_ledger(report_id, generated_at)
        with open(output_path, "w", encoding="utf-8") as fh:
            json.dump(ledger, fh, ensure_ascii=False, indent=2)
        return ledger


# ── Module-level helpers ──────────────────────────────────────────────────────

def sha256_hex(data: bytes) -> str:
    return hashlib.sha256(data).hexdigest()


def find_field_path_in_docai(docai_obj: Any, target_value: str,
                              max_depth: int = 7) -> str:
    """
    Breadth-first search of the Document AI JSON tree for `target_value`.
    Returns a JSON-path string like "entities[3].mentionText" or
    "text_extraction" when the value cannot be located in the raw JSON
    (e.g. it was derived from the flattened text by Claude).
    """
    target = str(target_value).strip()
    if not target:
        return "text_extraction"

    def _search(obj: Any, path: str, depth: int) -> Optional[str]:
        if depth > max_depth:
            return None
        if isinstance(obj, str):
            return path if (target == obj.strip() or target in obj) else None
        if isinstance(obj, (int, float)):
            return path if str(obj).strip() == target else None
        if isinstance(obj, list):
            for idx, item in enumerate(obj):
                found = _search(item, f"{path}[{idx}]", depth + 1)
                if found:
                    return found
        if isinstance(obj, dict):
            for key, val in obj.items():
                seg = f"{path}.{key}" if path else key
                found = _search(val, seg, depth + 1)
                if found:
                    return found
        return None

    result = _search(docai_obj, "", 0)
    return result if result else "text_extraction"


def get_ich_guideline_table(element_class: str) -> str:
    """Return the ICH Q3D (R2) appendix table for a given element class."""
    cls = str(element_class).upper().replace(" ", "")
    if cls in ("1", "2A"):
        return "Table A.2.1"
    # Class 2B and Class 3 both per Table A.2.2 per ICH Q3D spec
    return "Table A.2.2"
