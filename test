def parse_injection_excel_raw(excel_bytes: bytes) -> Dict:
    """Load injection Excel and use Claude to extract the raw table structure."""
    import injection_support as _inj
    wb = openpyxl.load_workbook(BytesIO(excel_bytes), data_only=True)
    ws = wb.worksheets[0]
    rows_text: List[str] = []
    for i, row in enumerate(ws.iter_rows(values_only=True)):
        if any(c is not None for c in row):
            row_str = [str(c) if c is not None else "" for c in row]
            rows_text.append(f"Row {i+1}: {' | '.join(row_str)}")
    wb.close()
    sheet_dump = "\n".join(rows_text[:120])
    prompt = _inj.make_injection_excel_prompt() + "\n\nSpreadsheet:\n" + sheet_dump
    raw = claude_text(prompt, max_tokens=8192)
    txt = raw.strip()
    if txt.startswith("```"):
        txt = re.sub(r"^```[a-zA-Z]*\n?", "", txt).rstrip("`").strip()
    try:
        return json.loads(txt)
    except Exception as e:
        logger.warning(f"Injection Excel JSON parse failed: {e}")
        # minimal fallback structure
        return {"ingredient_col": "", "function_col": "", "qty_columns": [],
                "mgml_col": "", "mdd_col": "", "columns": [], "sections": []}


