    rows:[new TableRow({children:[new TableCell({
      borders:allBdr(12),
      margins:{top:600,right:600,bottom:600,left:600},
      children:[ctrPara(titleText,true,SZ.XL)],
    })]})],
  });
  return [sopRow, blk(), titleBox, pgBrk()];
}

// ── TABLE OF CONTENTS ────────────────────────────────────────────────────────
function buildTOC() {
  var entries = [
    {no:"1", title:"Abstract",                                         page:""},
    {no:"2", title:"Objective",                                        page:""},
    {no:"3", title:"Details of the study location / testing location", page:""},
    {no:"4", title:"Background",                                       page:""},
    {no:"5", title:"Observations",                                     page:""},
    {no:"6", title:"Summary & Conclusion",                             page:""},
    {no:"7", title:"Reference",                                        page:""},
    {no:"8", title:"Change History",                                   page:""},
  ];
  var W = [600, CW-600-900, 900];
  var tbl = new Table({
    width:{size:CW,type:WidthType.DXA}, columnWidths:W,
    rows:[
      new TableRow({children:[
        cell("S. No.",{bold:true,fill:CLR.HDR_GREY,w:W[0],size:SZ.SM}),
        cell("Title", {bold:true,fill:CLR.HDR_GREY,w:W[1],size:SZ.SM}),
        cell("Page#", {bold:true,fill:CLR.HDR_GREY,w:W[2],size:SZ.SM}),
      ]}),
    ].concat(entries.map(function(e){
      return new TableRow({children:[
        cell(e.no||"",    {w:W[0],size:SZ.SM}),
        cellL(e.title||"",{w:W[1],size:SZ.SM}),
        cell(e.page||"",  {w:W[2],size:SZ.SM}),
      ]});
    })),
  });
  return [ctrPara("TABLE OF CONTENTS",true,SZ.MD), tbl, pgBrk()];
}

// ── SECTIONS 1-4 ─────────────────────────────────────────────────────────────
function buildTextSections(txt) {
  txt = txt||{};
  var ch = [];
  function addSec(num, title, content) {
    ch.push(secHd(num+". "+title+":"));
    if (content) bodyParas(content).forEach(function(p){ch.push(p);});
    ch.push(blk());
  }
  addSec(1, "Abstract",                                         txt.abstract       || "");
  addSec(2, "Objective",                                        txt.objective      || "");
  addSec(3, "Details of the study location / testing location", txt.study_location || "Theoretical assessment");
  addSec(4, "Background",                                       txt.background     || "");
  return ch;
}

// ── COMPOSITION TABLE (Table 1) ──────────────────────────────────────────────
function buildCompositionTable(payload) {
  var sections    = Array.isArray(payload.composition) ? payload.composition : [];
  var compColumns = Array.isArray(payload.comp_columns) && payload.comp_columns.length
                      ? payload.comp_columns
                      : ["Name of Ingredient","Function","mg/unit"];
  var caption     = payload.composition_caption
                      || "Table 1: Qualitative and Quantitative composition";

  var N = compColumns.length;
  var firstW = Math.round(CW * 0.35);
  var restW  = N > 1 ? Math.floor((CW - firstW) / (N - 1)) : CW;
  var colWidths = [firstW];
  for (var ci = 1; ci < N - 1; ci++) colWidths.push(restW);
  if (N > 1) colWidths.push(CW - firstW - restW * (N - 2));
  var sz = N <= 4 ? SZ.SM : (N <= 6 ? SZ.XS : SZ.XXS);

  var hdrRow = new TableRow({children: compColumns.map(function(col, i) {
    return cell(String(col||""), {bold:true, fill:CLR.HDR_GREY, w:colWidths[i], size:sz});
  })});

  var dataRows = [];
  for (var si = 0; si < sections.length; si++) {
    var sec = sections[si];
    if (!sec || typeof sec !== "object") continue;
    if (sec.name) {
      dataRows.push(new TableRow({children:[new TableCell({
        columnSpan:N, borders:allBdr(4), shading:shade(CLR.SEC_BLUE), margins:mg(),
        children:[lftPara(sec.name, true, sz)],
      })]}));
    }
    var rArr = Array.isArray(sec.rows) ? sec.rows : [];
    for (var ri = 0; ri < rArr.length; ri++) {
      var row = rArr[ri];
      if (!row || typeof row !== "object") continue;
      var cells = colWidths.map(function(w, i) {
        var colName = compColumns[i] || "";
        var val = "";
        if (row.columns && typeof row.columns === "object") {
          val = row.columns[colName] != null ? String(row.columns[colName]) : "";
          if (!val && i === 0) val = String(row.ingredient || row.name || "");
        } else {
          if (i === 0) val = String(row.ingredient || row.name || "");
          else if (i === 1) val = String(row.function || row.role || "");
          else val = String(row.amount || row.qty || "");
        }
        return i === 0 ? cellL(val, {w:w, size:sz}) : cell(val, {w:w, size:sz});
      });
      dataRows.push(new TableRow({children: cells}));
    }
  }

  var tbl = new Table({
    width:{size:CW,type:WidthType.DXA},
    columnWidths:colWidths,
    rows:[hdrRow].concat(dataRows),
  });
  return [
    lftPara(caption, true, SZ.SM),
    blk(),
    tbl,
    pgBrk(),
  ];
}

// ── TABLE 2: DEG/EG assessment ──────────────────────────────────────────────
function buildAssessmentTable(payload) {
  var rows    = Array.isArray(payload.assessment_table) ? payload.assessment_table
              : Array.isArray(payload.deg_eg_assessment) ? payload.deg_eg_assessment
              : [];
  var caption = payload.assessment_caption
              || "Table 2: Assessment of Diethylene Glycol and Ethylene Glycol in the input API and Excipients";
  var introTxt = payload.text_sections && payload.text_sections.risk_analysis_intro
              ? payload.text_sections.risk_analysis_intro
              : "API and excipients were assessed for the potential presence of Diethylene Glycol and Ethylene Glycol based on the COAs received from the respective manufacturers and in-house specifications, and applicable regulatory guidance. Summary of outcome is tabulated below.";
  if (rows.length === 0) return [];

  var cols = [
    "Material code",
    "Name of Ingredient",
    "Presence of\nDiethylene Glycol\n(Yes / No)",
    "Presence of\nEthylene Glycol\n(Yes / No)",
    "Specification\nlimit"
  ];

  var W = [
    Math.round(CW * 0.12),
    Math.round(CW * 0.30),
    Math.round(CW * 0.18),
    Math.round(CW * 0.18),
    0
  ];
  W[4] = CW - W[0] - W[1] - W[2] - W[3];
  var sz = SZ.SM;

  var hdrRow = new TableRow({children: cols.map(function(col, i) {
    return cell(col, {bold:true, fill:CLR.HDR_GREY, w:W[i], size:sz});
  })});

  var dataRows = rows.map(function(row) {
    var matCode    = String(row.material_code || row.code || "");
    var ingredient = String(row.ingredient || row.name || "");
    var degPresent = String(row.deg_present || row.diethylene_glycol || "Unknown");
    var egPresent  = String(row.eg_present  || row.ethylene_glycol  || "Unknown");
    var specLimit  = String(row.specification_limit || row.spec_limit || "Not applicable");
    return new TableRow({children:[
      cell(matCode,    {w:W[0], size:sz}),
      cellL(ingredient,{w:W[1], size:sz}),
      cell(degPresent, {w:W[2], size:sz}),
      cell(egPresent,  {w:W[3], size:sz}),
      cell(specLimit,  {w:W[4], size:sz}),
    ]});
  });

  var tbl = new Table({
    width:{size:CW, type:WidthType.DXA},
    columnWidths: W,
    rows: [hdrRow].concat(dataRows),
  });
  return [
    secHd("Risk analysis and evaluation for diethylene glycol and ethylene glycol in respective drug substances & excipients:"),
    bodyPara(introTxt),
    blk(),
    lftPara(caption, true, SZ.SM),
    tbl,
    blk(),
  ];
}

// ── POSITIVE-RISK DETAIL TABLES (one per material) ──────────────────────────
function buildPositiveRiskDetailTables(payload) {
  var details = Array.isArray(payload.detail_tables) ? payload.detail_tables : [];
  if (details.length === 0) return [];
  var ch = [];

  for (var d = 0; d < details.length; d++) {
    var item = details[d];
    if (!item || typeof item !== "object") continue;

    var material  = item.material  || "";
    var intro     = item.intro     || "";
    var caption   = item.caption
                    || (material
                          ? "Detailed assessment for " + material
                          : "Detailed assessment");
    var columns   = Array.isArray(item.columns) ? item.columns : [];
    var rows      = Array.isArray(item.rows)    ? item.rows    : [];
    var inference = item.inference || "";

    if (material) ch.push(secHd("Assessment for: " + material));
    if (intro)    bodyParas(intro).forEach(function(p){ch.push(p);});
    if (intro)    ch.push(blk());

    if (columns.length > 0 && rows.length > 0) {
      var N = columns.length;
      var firstW = Math.round(CW * 0.18);
      var restW  = N > 1 ? Math.floor((CW - firstW) / (N - 1)) : CW;
      var colWidths = [firstW];
      for (var ci = 1; ci < N - 1; ci++) colWidths.push(restW);
      if (N > 1) colWidths.push(CW - firstW - restW * (N - 2));
      var sz = N <= 4 ? SZ.SM : (N <= 8 ? SZ.XS : SZ.XXS);

      var hdrRow = new TableRow({children: columns.map(function(col, i) {
        return cell(String(col||""), {bold:true, fill:CLR.HDR_GREY, w:colWidths[i], size:sz});
      })});

      var dataRows = rows.map(function(row) {
        var rowArr = Array.isArray(row) ? row
                    : (row && typeof row === "object" && row.cells ? row.cells : []);
        var cells = colWidths.map(function(w, i) {
          var val = rowArr[i] != null ? String(rowArr[i]) : "";
          return i === 0 ? cellL(val, {w:w, size:sz}) : cell(val, {w:w, size:sz});
        });
        return new TableRow({children: cells});
      });

      var tbl = new Table({
        width:{size:CW, type:WidthType.DXA},
        columnWidths: colWidths,
        rows: [hdrRow].concat(dataRows),
      });
      ch.push(lftPara(caption, true, SZ.SM));
      ch.push(tbl);
      ch.push(blk());
    }

    if (inference) {
      bodyParas(inference).forEach(function(p){ch.push(p);});
      ch.push(blk());
    }
  }
  return ch;
}

// ── SECTION 5: OBSERVATIONS ──────────────────────────────────────────────────
function buildObservations(txt) {
  txt = txt||{};
  var ch = [];
  ch.push(secHd("5. Observations:"));
  if (txt.observations) {
    bodyParas(txt.observations).forEach(function(p){ch.push(p);});
  }
  ch.push(blk());
  return ch;
}

// ── SECTION 6: SUMMARY & CONCLUSION ──────────────────────────────────────────
function buildSummary(txt) {
  txt = txt||{};
  var ch = [secHd("6. Summary & Conclusion:")];
  if (txt.summary_conclusion) {
    bodyParas(txt.summary_conclusion).forEach(function(p){ch.push(p);});
  } else if (txt.conclusion) {
    bodyParas(txt.conclusion).forEach(function(p){ch.push(p);});
  }
  ch.push(blk());
  ch.push(pgBrk());
  return ch;
}

// ── SECTION 7: REFERENCE ─────────────────────────────────────────────────────
function buildReference(txt) {
  txt = txt||{};
  var ch = [];
  ch.push(secHd("7. Reference:"));
  var refs = txt.reference || txt.references || "";
  if (Array.isArray(refs)) {
    refs.forEach(function(r, idx) {
      ch.push(bodyPara((idx+1)+". "+String(r)));
    });
  } else if (refs) {
    bodyParas(refs).forEach(function(p){ch.push(p);});
  }
  ch.push(blk());
  return ch;
}

// ── SECTION 8: CHANGE HISTORY ────────────────────────────────────────────────
function buildRevision(revisions) {
  revisions = Array.isArray(revisions) ? revisions : [];
  if (revisions.length === 0) return [];
  var W = [Math.round(CW*0.40), 0]; W[1] = CW - W[0];
  var tbl = new Table({
    width:{size:CW,type:WidthType.DXA}, columnWidths:W,
    rows:[
      new TableRow({children:[
        cell("Document & version number",{bold:true,fill:CLR.HDR_GREY,w:W[0],size:SZ.SM}),
        cell("Brief Details of Changes",  {bold:true,fill:CLR.HDR_GREY,w:W[1],size:SZ.SM}),
      ]}),
    ].concat(revisions.filter(function(r){return r && typeof r==="object";}).map(function(r){
      return new TableRow({children:[
        cell(r.document_version||r.version||"",{w:W[0],size:SZ.SM}),
        cellL(r.changes||r.details||r.brief_details||"",{w:W[1],size:SZ.SM}),
      ]});
    })),
  });
  return [secHd("8. Change History:"), tbl, pgBrk()];
}

// ── ELECTRONIC SIGNATURES ────────────────────────────────────────────────────
function buildSignatures(meta, signatures) {
  meta = meta||{};
  var W = [Math.round(CW*0.25),Math.round(CW*0.15),Math.round(CW*0.32),0];
  W[3] = CW - W[0] - W[1] - W[2];

  var sigs = (Array.isArray(signatures) && signatures.length) ? signatures : [
    {intention:"Prepared by R&D",employee_id:"",user_name:"",date:""},
    {intention:"Reviewed by R&D",employee_id:"",user_name:"",date:""},
    {intention:"Approved by DQA",employee_id:"",user_name:"",date:""},
  ];

  var titleChildren = [];
  if (meta.title) {
    titleChildren.push(new Paragraph({
      alignment:AlignmentType.LEFT, spacing:{before:0,after:0},
      children:[new TextRun({text:"Title", bold:true, size:SZ.SM, font:F, noProof:true})],
    }));
    titleChildren.push(new Paragraph({
      alignment:AlignmentType.LEFT, spacing:{before:20,after:0},
      children:[new TextRun({text:meta.title||"", bold:false, size:SZ.XS, font:F, noProof:true})],
    }));
  }
  if (meta.document_no) {
    titleChildren.push(new Paragraph({
      alignment:AlignmentType.LEFT, spacing:{before:40,after:0},
      children:[
        new TextRun({text:"Document No  ", bold:true,  size:SZ.SM, font:F, noProof:true}),
        new TextRun({text:meta.document_no||"", bold:false, size:SZ.SM, font:F, noProof:true}),
      ],
    }));
  }
  if (meta.version) {
    titleChildren.push(new Paragraph({
      alignment:AlignmentType.LEFT, spacing:{before:20,after:0},
      children:[
        new TextRun({text:"Version  ", bold:true,  size:SZ.SM, font:F, noProof:true}),
        new TextRun({text:meta.version||"", bold:false, size:SZ.SM, font:F, noProof:true}),
      ],
    }));
  }
  if (meta.approved_date) {
    titleChildren.push(new Paragraph({
      alignment:AlignmentType.LEFT, spacing:{before:20,after:0},
      children:[
        new TextRun({text:"Approved Date  ", bold:true,  size:SZ.SM, font:F, noProof:true}),
        new TextRun({text:meta.approved_date||"", bold:false, size:SZ.SM, font:F, noProof:true}),
      ],
    }));
  }

  var metaBlock = [];
  if (titleChildren.length > 0) {
    var metaTable = new Table({
      width:{size:CW,type:WidthType.DXA}, columnWidths:[CW],
      rows:[new TableRow({children:[new TableCell({
        borders:allBdr(4), margins:mg(),
        children: titleChildren,
      })]})],
    });
    metaBlock.push(metaTable);
    metaBlock.push(blk());
  }

  var sigTbl = new Table({
    width:{size:CW,type:WidthType.DXA}, columnWidths:W,
    rows:[
      new TableRow({children:[
        cell("Intention",  {bold:true,fill:CLR.HDR_GREY,w:W[0],size:SZ.SM}),
        cell("Employee ID",{bold:true,fill:CLR.HDR_GREY,w:W[1],size:SZ.SM}),
        cell("User Name",  {bold:true,fill:CLR.HDR_GREY,w:W[2],size:SZ.SM}),
        cell("Date",       {bold:true,fill:CLR.HDR_GREY,w:W[3],size:SZ.SM}),
      ]}),
    ].concat(sigs.map(function(s){
      return new TableRow({children:[
        cellL(s.intention||"",  {w:W[0],size:SZ.SM}),
        cell(s.employee_id||"", {w:W[1],size:SZ.SM}),
        cellL(s.user_name||"",  {w:W[2],size:SZ.SM}),
        cell(s.date||"",        {w:W[3],size:SZ.SM}),
      ]});
    })),
  });

  var result = [ctrPara("ELECTRONIC SIGNATURES",true,SZ.MD), blk()];
  metaBlock.forEach(function(x){result.push(x);});
  result.push(sigTbl);
  return result;
}

// ── SPELL-OFF INJECTION ──────────────────────────────────────────────────────
function injectSpellOff(buf) {
  var spellOff = '<w:hideSpellingErrors/><w:hideGrammaticalErrors/>';
  return JSZip.loadAsync(buf).then(function(zip){
    var sf = zip.file("word/settings.xml");
    var sp;
    if (sf) {
      sp = sf.async("string").then(function(sxml){
        if (!sxml.includes("hideSpellingErrors"))
          sxml = sxml.replace("</w:settings>", spellOff+"</w:settings>");
        zip.file("word/settings.xml", sxml);
      });
    } else {
      zip.file("word/settings.xml",
        '<?xml version="1.0" encoding="UTF-8" standalone="yes"?>'+
        '<w:settings xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main">'+
        spellOff+'</w:settings>');
      sp = Promise.resolve();
    }
    return (sp || Promise.resolve()).then(function(){
      return zip.generateAsync({type:"nodebuffer",compression:"DEFLATE",
        compressionOptions:{level:6}});
    });
  });
}

// ── MAIN ASSEMBLY ────────────────────────────────────────────────────────────
function generateReport(dataPath, outPath) {
  var raw  = fs.readFileSync(dataPath,"utf-8");
  var data = JSON.parse(raw);

  var meta       = data.meta             || {};
  var logoB64    = data.logo_b64         || "";
  var logoType   = data.logo_type        || "";
  var txt        = data.text_sections    || {};
  var revHistory = data.revision_history || [];
  var signatures = data.signatures       || [];

  var ch = [];

  // Title page
  buildTitlePage(meta).forEach(function(x){ch.push(x);});
  // Table of contents
  buildTOC().forEach(function(x){ch.push(x);});
  // Sections 1-4: Abstract, Objective, Study Location, Background
  buildTextSections(txt).forEach(function(x){ch.push(x);});
  // Table 1: Composition
  buildCompositionTable(data).forEach(function(x){ch.push(x);});
  // Risk analysis text + Table 2: DEG/EG assessment per material
  buildAssessmentTable(data).forEach(function(x){ch.push(x);});
  // Post-assessment narrative
  if (txt.post_assessment_narrative) {
    bodyParas(txt.post_assessment_narrative).forEach(function(p){ch.push(p);});
    ch.push(blk());
  }
  ch.push(pgBrk());
  // Positive-risk detail tables (Table 3+)
  buildPositiveRiskDetailTables(data).forEach(function(x){ch.push(x);});
  // Section 5: Observations
  buildObservations(txt).forEach(function(x){ch.push(x);});
  // Section 6: Summary & Conclusion
  buildSummary(txt).forEach(function(x){ch.push(x);});
  // Section 7: Reference
  buildReference(txt).forEach(function(x){ch.push(x);});
  ch.push(pgBrk());
  // Section 8: Change History
  buildRevision(revHistory).forEach(function(x){ch.push(x);});
  // Electronic Signatures
  buildSignatures(meta, signatures).forEach(function(x){ch.push(x);});

  var doc = new Document({
    settings:{hideSpellingErrors:true, hideGrammaticalErrors:true},
    styles:{default:{document:{run:{font:F,size:SZ.TEXT,color:CLR.BLACK}}}},
    sections:[{
      properties:{page:{
        size:{width:PAGE_W,height:PAGE_H},
        margin:{top:MAR_T,right:MAR_R,bottom:MAR_B,left:MAR_L,header:360,footer:360},
      }},
      headers:{default:buildHeader(meta,logoB64,logoType)},
      footers:{default:buildFooter()},
      children:ch,
    }],
  });

  return Packer.toBuffer(doc)
    .then(injectSpellOff)
    .then(function(finalBuf){
      fs.writeFileSync(outPath,finalBuf);
      console.log("DEG/EG Report written: "+outPath+" ("+Math.round(finalBuf.length/1024)+" KB)");
    });
}

// ── Entry point ──────────────────────────────────────────────────────────────
var dp = process.argv[2], op = process.argv[3];
if (!dp || !op) {
  console.error("Usage: node generate_deg_eg.js <data.json> <out.docx>");
  process.exit(1);
}
generateReport(dp, op).catch(function(err){
  console.error("FATAL:", err.message || err);
  if (err.stack) console.error(err.stack.split("\n").slice(0,8).join("\n"));
  process.exit(1);
});
