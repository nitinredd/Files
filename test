    if st.button("🚀 Generate Report", type="primary",
                 disabled=not (ref_pdf and excel_file and annexure_files)):

        progress = st.progress(0)
        log = st.empty()

        try:
            # ── 1. Rasterize reference PDF ────────────────────────────────
            log.info("📄 Rasterizing reference PDF pages…")
            ref_bytes   = ref_pdf.getvalue()
            page_images = rasterize_pdf_pages(ref_bytes, dpi=150)
            emb_images  = extract_embedded_images(ref_bytes)
            st.success(f"Reference PDF: {len(page_images)} pages loaded")
            progress.progress(8)

            # ── 2. Identify figure pages ──────────────────────────────────
            log.info("🔍 Identifying figure/diagram pages with Claude…")
            figure_pages = identify_figure_pages(page_images)
            if figure_pages:
                st.success(f"Found {len(figure_pages)} figure page(s): "
                           + ", ".join(f"p{f['page_index']+1}" for f in figure_pages))
            else:
                st.warning("No figures detected. Check reference PDF quality.")
            progress.progress(18)

            # ── 3. Extract reference structure ────────────────────────────
            log.info("📑 Extracting report structure with Claude…")
            ref_structure = extract_reference_structure(page_images)
            meta = ref_structure.get("meta", {})
            st.success(f"Product: {meta.get('product_name','(extracted)')} | "
                       f"Doc: {meta.get('document_no','')}")
            progress.progress(35)

            # ── 4. Parse Excel ────────────────────────────────────────────
            log.info("📊 Parsing composition Excel…")
            comp_data = parse_composition_excel(excel_file.getvalue())
            n_ing = sum(len(s.get("rows",[])) for s in comp_data.get("sections",[]))
            st.success(f"Excel: {n_ing} ingredients across {len(comp_data.get('sections',[]))} sections | "
                       f"MDD: {comp_data.get('mdd_sachets',6)}× {comp_data.get('mdd_strength','40mg')}")
            progress.progress(45)

            # ── 5. Process annexures ──────────────────────────────────────
            log.info(f"🔬 Processing {len(annexure_files)} annexure(s) with Claude…")
            annexure_data = []
            for i, af in enumerate(sorted(annexure_files, key=lambda f: f.name)):
                raw_json = json.loads(af.read().decode("utf-8"))
                ann = process_annexure(raw_json, i+1)
                annexure_data.append(ann)
                st.write(f"  ✅ Annexure {i+1}: **{ann.get('material_name','?')}** "
                         f"({ann.get('supplier_name','?')}) — {len(ann.get('elements',[]))} elements")
                progress.progress(45 + int(20 * (i+1) / len(annexure_files)))

            # ── 6. Calculate Tables 5, 6, 7 ──────────────────────────────
            log.info("🧮 Calculating EI tables (Tables 5, 6, 7)…")
            calc_tables = calculate_ei_tables(comp_data, annexure_data)
            # Show crossing-30% elements
            crossing = [sym for sym in TABLE5_ELEMENTS
                        if ICH_PDE[sym]["pde"] and
                           calc_tables["class1_2a"]["element_totals"].get(sym,0) >
                           ICH_PDE[sym]["pde"] * 0.30]
            if crossing:
                st.warning(f"Elements crossing 30% PDE (confirmatory testing needed): {', '.join(crossing)}")
            else:
                st.success("All Class 1+2A elements below 30% PDE — Option 2b compliant")
            progress.progress(72)

            # ── 7. Generate text sections ─────────────────────────────────
            log.info("✍️ Generating report text sections with Claude…")
            text_sections = generate_text_sections(ref_structure, annexure_data, calc_tables, comp_data)
            progress.progress(82)

            # ── 8. Build DOCX ─────────────────────────────────────────────
            log.info("📝 Building Word document (Node.js / docx-js)…")
            docx_bytes = assemble_and_generate(
                ref_structure, page_images, figure_pages, emb_images,
                annexure_data, comp_data, calc_tables, text_sections
            )
            progress.progress(100)
            log.success("✅ Report generated!")

            doc_no  = meta.get("document_no", "TSR").replace("/","_").replace(" ","_")
            ver     = meta.get("version","v").split(",")[0].replace(" ","").replace(".","_")
            fname   = f"{doc_no}_{ver}_{datetime.now().strftime('%Y%m%d_%H%M%S')}.docx"

            st.download_button(
                "📥 Download Report (DOCX)",
                data=docx_bytes, file_name=fname,
                mime="application/vnd.openxmlformats-officedocument.wordprocessingml.document"
            )

        except Exception as e:
            st.error(f"Error: {e}")
            logger.exception("Pipeline error")

    with st.expander("ℹ️ How it works"):
        st.markdown("""
**Zero hardcoded product content.** Everything is derived from your uploads:

| Input | Used for |
|---|---|
| Reference PDF | Template layout, all boilerplate text, figures/diagrams (auto-extracted by page) |
| Annexure JSONs | Vendor element declarations → measured concentrations for Tables 5-7 |
| Composition Excel | Ingredient amounts → daily intakes → Table 1, basis for Tables 5-7 |

**Calculation pipeline (Tables 5, 6, 7):**
1. Daily intake (g) = ingredient amount (mg) × MDD sachets ÷ 1000
2. Total mass (µg/day) = daily intake × measured concentration (µg/g from annexure)
3. %PDE = total mass ÷ ICH Q3D PDE × 100
4. Threshold = 30% of PDE (ICH Q3D Option 2b)

**Figures:** Claude scans every page of the reference PDF to identify diagram pages,
then extracts those images and embeds them in the new report at the correct position.
        """)

if __name__ == "__main__":
    main()
