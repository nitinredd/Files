def _route_files(files: List[Any]) -> Tuple[Optional[bytes], List[Any], Optional[bytes]]:
    """Split ONE upload widget's files by kind.
    Returns (excel_bytes, annexure_files, image_bytes) — first Excel/image wins."""
    excel_bytes: Optional[bytes] = None
    image_bytes: Optional[bytes] = None
    annexure_files: List[Any] = []
    for f in (files or []):
        name = safe_str(getattr(f, "name", "")).lower()
        if name.endswith((".xlsx", ".xls")):
            if excel_bytes is None:
                excel_bytes = f.getvalue()
        elif name.endswith((".png", ".jpg", ".jpeg")):
            if image_bytes is None:
                image_bytes = f.getvalue()
        elif name.endswith((".pdf", ".docx", ".doc", ".json")):
            annexure_files.append(f)
        else:
            logger.warning("Ignoring unsupported upload: %s", name)
    return excel_bytes, annexure_files, image_bytes


def _process_annexures_with_progress(doc_type: str, annexure_files: List[Any],
                                     bar, lo: int = 5, hi: int = 90) -> List[Dict]:
    """Convert annexures behind ONE progress bar. Per-file failures are logged and
    skipped — never surfaced — so one bad file cannot stop a generation."""
    out: List[Dict] = []
    n = len(annexure_files or [])
    if not n:
        return out
    for i, f in enumerate(annexure_files):
        pct = lo + int((hi - lo) * (i / n))
        bar.progress(min(pct, 99), text=f"Analyzing files… {pct}%")
        try:
            out.extend(dispatch_annexures(doc_type, [f]) or [])
        except Exception:
            logger.exception("Annexure processing failed for %s",
                             getattr(f, "name", "?"))
    bar.progress(hi, text=f"Analyzing files… {hi}%")
    return out


