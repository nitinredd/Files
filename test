#!/usr/bin/env python3
"""
deg_eg.py — Diethylene Glycol (DEG) & Ethylene Glycol (EG) Risk Assessment.

FULLY ISOLATED workflow. No imports of residual_solvent or any EI module.
NO calculations, NO exposure formula, NO MDD×ppm, NO PDE, NO USP <467> matrix,
NO Total Daily Exposure. Only:
  - composition parsing (Section 4 Table 1, stage-wise, q.s. preserved)
  - annexure-driven Yes/No DEG/EG presence + specification limits
  - per-material detail tables for positive findings
  - narrative + warning-first validation

The ONLY thing reused from the EI injection workflow is the identity-resolver
*architecture* (descriptor stripping, identity pooling, brand/family aliases,
canonical tokens, negative-pair protection, confidence scoring). It is ported
here with DEG/EG-appropriate material vocabulary; no EI scientific logic.
"""
import re
import json
import logging
from typing import Any, Dict, List, Optional, Tuple

