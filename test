function fmt(val, dec) {
  if (dec==null) dec=4;
  if (val==null||val==="") return "";
  var n=parseFloat(String(val).replace(/[^0-9.eE+\-]/g,""));
  if (isNaN(n)||!isFinite(n)) return "";
  return n.toFixed(dec);
}

// Residual Solvent risk Assessment tables (nested solvent groups)
function buildSolventAssessmentTable(tableNum, tableData) {
  var d = (tableData && typeof tableData === "object") ? tableData : {};
  var solvents    = Array.isArray(d.solvents) ? d.solvents : [];
  var rows        = Array.isArray(d.rows) ? d.rows : [];
  var totals      = d.totals || {};
  var usp_limits  = d.usp_limits || {};
  var caption     = d.caption || ("Table " + tableNum + ": Residual Solvent risk Assessment in drug product and comparison against the control levels");

  if (solvents.length === 0 && rows.length === 0) return [];

  var N = solvents.length;
  var totalCols = 3 + 2 * N;
  var sz = totalCols <= 9 ? SZ.SM : (totalCols <= 13 ? SZ.XS : SZ.XXS);

  var COMP_W = Math.round(CW * 0.20);
  var QTY_W  = Math.round(CW * 0.09);
  var AMT_W  = Math.round(CW * 0.11);
  var fixedW = COMP_W + QTY_W + AMT_W;
  var solColCount = 2 * N;
  var solW   = solColCount > 0 ? Math.floor((CW - fixedW) / solColCount) : 200;
  // Ensure exact width sum
  var usedW = fixedW + solW * solColCount;
  var drift = CW - usedW;

  var colWidths = [COMP_W, QTY_W, AMT_W];
  for (var ci = 0; ci < solColCount; ci++) colWidths.push(solW);
  if (colWidths.length > 0) colWidths[colWidths.length-1] += drift;

  // Header row 1
  var h1cells = [
    cell("Components", {bold:true, fill:CLR.HDR_GREY, w:COMP_W, size:sz}),
    cell("Quantity\n/ unit\n(mg)", {bold:true, fill:CLR.HDR_GREY, w:QTY_W, size:sz}),
    cell("*Amount in\nMaximum\nDose (mg)", {bold:true, fill:CLR.HDR_GREY, w:AMT_W, size:sz}),
  ];
  for (var si = 0; si < N; si++) {
    h1cells.push(new TableCell({
      columnSpan: 2, borders: allBdr(4), shading: shade(CLR.HDR_GREY),
      margins: mg(), verticalAlign: VerticalAlign.CENTER,
      children:[new Paragraph({
        alignment:AlignmentType.CENTER, spacing:{before:0,after:0},
        children:[new TextRun({text:String(solvents[si]||""), bold:true, size:sz, font:F, noProof:true})],
      })],
    }));
  }
  var h1 = new TableRow({tableHeader:true, children: h1cells});

  // Header row 2
  var h2cells = [
    emptyCell(CLR.HDR_GREY, COMP_W),
    emptyCell(CLR.HDR_GREY, QTY_W),
    emptyCell(CLR.HDR_GREY, AMT_W),
  ];
  for (var si2 = 0; si2 < N; si2++) {
    h2cells.push(cell("Limit\n(ppm)", {bold:true, fill:CLR.HDR_GREY, w:solW, size:sz}));
    h2cells.push(cell("Daily\nExposure\n(mg)", {bold:true, fill:CLR.HDR_GREY, w:solW, size:sz}));
  }
  var h2 = new TableRow({tableHeader:true, children: h2cells});

  // Data rows
  var dataRows = rows.filter(Boolean).map(function(row) {
    var cells = [
      cellL(String(row.component || row.ingredient || ""), {w:COMP_W, size:sz}),
      cell(row.quantity != null ? String(row.quantity) : "", {w:QTY_W, size:sz}),
      cell(row.amount_max_dose != null ? String(row.amount_max_dose) : "", {w:AMT_W, size:sz}),
    ];
    var solventData = row.solvents || {};
    for (var si3 = 0; si3 < N; si3++) {
      var sName = solvents[si3];
      var sd = solventData[sName] || {};
      cells.push(cell(sd.limit != null ? String(sd.limit) : "", {w:solW, size:sz}));
      cells.push(cell(sd.daily_exposure != null ? String(sd.daily_exposure) : "", {w:solW, size:sz}));
    }
    return new TableRow({children: cells});
  });

  // Drug Product (mg) row — optional
  var extraRows = [];
  if (d.drug_product_row && typeof d.drug_product_row === "object") {
    var dp = d.drug_product_row;
    var dpCells = [
      cellL("Drug Product (mg)", {w:COMP_W, size:sz, bold:true}),
      cell(dp.quantity != null ? String(dp.quantity) : "", {w:QTY_W, size:sz, bold:true}),
      cell(dp.amount_max_dose != null ? String(dp.amount_max_dose) : "", {w:AMT_W, size:sz, bold:true}),
    ];
    var dpSolv = dp.solvents || {};
    for (var di = 0; di < N; di++) {
      var dsn = solvents[di]; var dsd = dpSolv[dsn] || {};
      dpCells.push(cell(dsd.limit != null ? String(dsd.limit) : "", {w:solW, size:sz}));
      dpCells.push(cell(dsd.daily_exposure != null ? String(dsd.daily_exposure) : "", {w:solW, size:sz}));
    }
    extraRows.push(new TableRow({children: dpCells}));
  }

  // Total Daily Exposure row
  var totCells = [
    new TableCell({
      columnSpan: 3, borders: allBdr(4), shading: shade(CLR.HDR_GREY),
      margins: mg(), verticalAlign: VerticalAlign.CENTER,
      children:[new Paragraph({
        alignment:AlignmentType.CENTER, spacing:{before:0,after:0},
        children:[new TextRun({text:"Total Daily Exposure (mg)", bold:true, size:sz, font:F, noProof:true})],
      })],
    }),
  ];
  for (var ti = 0; ti < N; ti++) {
    var sn = solvents[ti];
    var totVal = (totals[sn] || {});
    totCells.push(cell(totVal.limit_total != null ? String(totVal.limit_total) : "", {w:solW, size:sz, bold:true}));
    totCells.push(cell(totVal.exposure_total != null ? String(totVal.exposure_total) : "", {w:solW, size:sz, bold:true}));
  }
  var totalRow = new TableRow({children: totCells});

  // USP <467> Limit row
  var uspCells = [
    new TableCell({
      columnSpan: 3, borders: allBdr(4), shading: shade(CLR.THRESH_BG),
      margins: mg(), verticalAlign: VerticalAlign.CENTER,
      children:[new Paragraph({
        alignment:AlignmentType.CENTER, spacing:{before:0,after:0},
        children:[new TextRun({text:"Residual solvent Limit as per current USP <467>", bold:true, size:sz, font:F, noProof:true})],
      })],
    }),
  ];
  for (var ui = 0; ui < N; ui++) {
    var usn = solvents[ui];
    var uVal = (usp_limits[usn] || {});
    uspCells.push(cell(uVal.limit != null ? String(uVal.limit) : "", {w:solW, size:sz, bold:true, fill:CLR.THRESH_BG}));
    uspCells.push(cell(uVal.pde != null ? String(uVal.pde) : "", {w:solW, size:sz, bold:true, fill:CLR.THRESH_BG}));
  }
  var uspRow = new TableRow({children: uspCells});

  var tbl = new Table({
    width:{size:CW, type:WidthType.DXA},
    columnWidths: colWidths,
    rows: [h1, h2].concat(dataRows).concat(extraRows).concat([totalRow, uspRow]),
  });

  return [lftPara(caption, true, SZ.SM), tbl, blk()];
}

function buildSection5(txt, supplierDeclarations, solventTables, meta) {
  txt = txt || {};
  meta = meta || {};
  var product = meta.product_name || "the drug product";
  var ch = [];
  ch.push(secHd("5.0 Residual Solvents Risk Assessment of " + product + ":"));

  bodyParas(txt.section5_intro || "").forEach(function(p){ch.push(p);});
  ch.push(blk());

  buildSupplierDeclarations(supplierDeclarations).forEach(function(x){ch.push(x);});

  ch.push(pgBrk());

  solventTables = solventTables || {};
  var tableKeys = Object.keys(solventTables);
  if (tableKeys.length > 0) {
    tableKeys.forEach(function(key) {
      var tData = solventTables[key];
      var tNum = tData.table_number || key;
      buildSolventAssessmentTable(tNum, tData).forEach(function(x){ch.push(x);});
      ch.push(pgBrk());
    });
  }

  if (txt.notes) {
    bodyParas(txt.notes).forEach(function(p){ch.push(p);});
    ch.push(blk());
  }
  if (Array.isArray(txt.note_bullets) && txt.note_bullets.length > 0) {
    ch.push(lftPara("Note:", true, SZ.TEXT));
    txt.note_bullets.forEach(function(bullet) {
      ch.push(bodyPara("\u2022 " + String(bullet||"")));
    });
    ch.push(blk());
  }

  return ch;
}

