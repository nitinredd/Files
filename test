// ============================================================================
// NUMBER FORMATTER
// ============================================================================
function fmt(val, dec) {
  if (dec == null) dec = 4;
  if (val == null || val === "") return "";
  var n = parseFloat(String(val).replace(/[^0-9.eE+\-]/g, ""));
  if (isNaN(n) || !isFinite(n)) return "";
  return n.toFixed(dec);
}


// ============================================================================
// CALCULATION TABLES  (Tables 5, 6, 7)
// Responsive: cell font shrinks for wide tables so they fit on one page.
// ============================================================================
function buildCalcTable(tableNum, tableData, pdeValues) {
  var safe = function (o) { return (o && typeof o === "object") ? o : {}; };
  var d           = safe(tableData);
  var elements    = Array.isArray(d.elements) ? d.elements : [];
  var rows        = Array.isArray(d.rows)     ? d.rows     : [];
  var dailyTotal  = d.total_daily_intake || 0;
  var eTotals     = safe(d.element_totals);
  var pde         = safe(d.pde);
  var thresh      = safe(d.threshold_30pct);

  if (elements.length === 0) {
    return [leftPara("Table " + tableNum + ": No elements data.", false, SZ.SM)];
  }

  var N = elements.length;
  var totalCols = 2 + 2 * N;
  var cellSz = totalCols <= 12 ? SZ.SM : (totalCols <= 18 ? SZ.XS : SZ.XXS);

  var INGR_W = Math.round(CW * 0.25);
  var DI_W   = Math.round(CW * 0.06);
  var EW     = Math.max(240, Math.floor((CW - INGR_W - DI_W) / (2 * N)));
  var colW   = [INGR_W, DI_W];
  for (var ci = 0; ci < 2 * N; ci++) colW.push(EW);

  // Group same-class elements
  var grps = [];
  for (var gi = 0; gi < elements.length; gi++) {
    var sym = elements[gi];
    var cls = (safe(pdeValues)[sym] || {}).class || "?";
    if (grps.length && grps[grps.length - 1].cls === cls) {
      grps[grps.length - 1].count++;
    } else {
      grps.push({ cls: cls, count: 1 });
    }
  }

  // Header row 1
  var h1 = new TableRow({
    children: [
      mkCell("Component",          { bold: true, fill: COLOR.HEADER_GREY, w: INGR_W, size: cellSz }),
      mkCell("Daily\nIntake\n(g)", { bold: true, fill: COLOR.HEADER_GREY, w: DI_W,   size: cellSz }),
      new TableCell({
        columnSpan: N, borders: allBorders(4), shading: cellShade(COLOR.HEADER_GREY), margins: cm(),
        children: [centerPara("Measured Concentration (\u00B5g/g)", true, cellSz)],
      }),
      new TableCell({
        columnSpan: N, borders: allBorders(4), shading: cellShade(COLOR.HEADER_GREY), margins: cm(),
        children: [centerPara("Total Mass of Elemental Impurity (\u00B5g/day)", true, cellSz)],
      }),
    ],
  });

  // Header row 2: class groupings
  var h2cells = [emptyCell(COLOR.HEADER_GREY, INGR_W), emptyCell(COLOR.HEADER_GREY, DI_W)];
  for (var h = 0; h < 2; h++) {
    for (var g = 0; g < grps.length; g++) {
      h2cells.push(new TableCell({
        columnSpan: grps[g].count, borders: allBorders(4),
        shading: cellShade(COLOR.HEADER_GREY), margins: cm(),
        children: [centerPara("Class " + grps[g].cls, true, cellSz)],
      }));
    }
  }
  var h2 = new TableRow({ children: h2cells });

  // Header row 3: element symbols
  var h3cells = [emptyCell(COLOR.HEADER_GREY, INGR_W), emptyCell(COLOR.HEADER_GREY, DI_W)];
  for (var hh = 0; hh < 2; hh++) {
    for (var ei = 0; ei < elements.length; ei++) {
      h3cells.push(mkCell(elements[ei], { bold: true, fill: COLOR.HEADER_GREY, w: EW, size: cellSz }));
    }
  }
  var h3 = new TableRow({ children: h3cells });

  // Data rows
  var dataRows = [];
  for (var ri = 0; ri < rows.length; ri++) {
    var row = rows[ri];
    if (!row || typeof row !== "object") continue;
    var mc = safe(row.measured_conc);
    var tm = safe(row.total_mass);
    var rCells = [
      mkCellL(row.ingredient || "", { w: INGR_W, size: cellSz }),
      mkCell(fmt(row.daily_intake_g != null ? row.daily_intake_g : 0, 3), { w: DI_W, size: cellSz }),
    ];
    for (var mei = 0; mei < elements.length; mei++) {
      rCells.push(mkCell(fmt(mc[elements[mei]] != null ? mc[elements[mei]] : 0, 4),
                         { w: EW, size: cellSz }));
    }
    for (var tei = 0; tei < elements.length; tei++) {
      rCells.push(mkCell(fmt(tm[elements[tei]] != null ? tm[elements[tei]] : 0, 4),
                         { w: EW, size: cellSz }));
    }
    dataRows.push(new TableRow({ children: rCells }));
  }

  // Footer rows
  function mkFooter(label, vals, fillColor, isThresh) {
    var sv = vals || {};
    var st = eTotals || {};
    var fc = [
      mkCell(label, { bold: true, fill: fillColor, align: AlignmentType.LEFT, w: INGR_W, size: cellSz }),
      mkCell(label === "TOTAL (daily intake) g/day" ? fmt(dailyTotal, 3) : "",
             { fill: fillColor, w: DI_W, size: cellSz }),
    ];
    for (var bi = 0; bi < elements.length; bi++) fc.push(emptyCell(fillColor, EW));
    for (var vi = 0; vi < elements.length; vi++) {
      var vs = elements[vi];
      var val = sv[vs] != null ? sv[vs] : null;
      var tot = st[vs] != null ? st[vs] : null;
      var ex  = isThresh && val != null && tot != null && isFinite(val) && isFinite(tot) && tot > val;
      fc.push(mkCell(val != null ? fmt(val, 3) : "\u2013", {
        fill:  ex ? COLOR.EXCEEDED_BG  : fillColor,
        w:     EW, size: cellSz,
        color: ex ? COLOR.EXCEEDED_TXT : COLOR.BLACK,
      }));
    }
    return new TableRow({ children: fc });
  }

  var labels = { 5: "Class 1 and Class 2A", 6: "Class 2B", 7: "Class 3" };
  var caption = "Table " + tableNum
    + ": Theoretical Elemental Impurity Assessment (" + (labels[tableNum] || "") + ")"
    + " \u2014 Evaluation of Daily Contribution of the Total Mass";

  var tbl = new Table({
    width: { size: CW, type: WidthType.DXA },
    columnWidths: colW,
    rows: [h1, h2, h3].concat(dataRows).concat([
      mkFooter("TOTAL (daily intake) g/day", eTotals,  COLOR.HEADER_GREY, false),
      mkFooter("PDE (\u00B5g/day)",           pde,      COLOR.HEADER_GREY, false),
      mkFooter("Threshold Limit (30% of PDE)", thresh,  COLOR.THRESHOLD_BG, true),
    ]),
  });

  return [leftPara(caption, true, SZ.SM), tbl, blankPara()];
}


// ============================================================================
// SUMMARY & CONCLUSION
// ============================================================================
function buildSummarySection(txt) {
  txt = txt || {};
  var ch = [sectionHeading("6. Summary & Conclusion")];

  if (txt.observation) {
    ch.push(leftPara("Observation:", true, SZ.HDR));
    var op = bodyParagraphs(txt.observation);
    for (var i = 0; i < op.length; i++) ch.push(op[i]);
    ch.push(blankPara());
  }
  if (txt.conclusion) {
    ch.push(leftPara("Conclusion:", true, SZ.HDR));
    var cp = bodyParagraphs(txt.conclusion);
    for (var j = 0; j < cp.length; j++) ch.push(cp[j]);
  }
  ch.push(pgBreak());
  return ch;
}


// ============================================================================
// LIST OF ANNEXURES  (Table 8)
// ============================================================================
function buildAnnexureList(list) {
  list = Array.isArray(list) ? list : [];
  var W0 = Math.round(CW * 0.38);
  var W1 = Math.round(CW * 0.36);
  var W2 = CW - W0 - W1;

  var tbl = new Table({
    width: { size: CW, type: WidthType.DXA },
    columnWidths: [W0, W1, W2],
    rows: [
      new TableRow({
        children: [
          mkCell("Name of Ingredient", { bold: true, fill: COLOR.HEADER_GREY, w: W0, size: SZ.SM }),
          mkCell("Vendor",             { bold: true, fill: COLOR.HEADER_GREY, w: W1, size: SZ.SM }),
          mkCell("Title of Annexure",  { bold: true, fill: COLOR.HEADER_GREY, w: W2, size: SZ.SM }),
        ],
      }),
    ].concat(list.map(function (a, idx) {
      return new TableRow({
        children: [
          mkCellL(a.material || "", { w: W0, size: SZ.SM }),
          mkCellL(a.supplier || "", { w: W1, size: SZ.SM }),
          mkCell(a.annexure || ("Annexure " + (idx + 1)), { w: W2, size: SZ.SM }),
        ],
      });
    })),
  });

  return [sectionHeading("8. List of annexures"),
          leftPara("Table No: 8 List of annexures", true, SZ.SM), tbl, pgBreak()];
}


// ============================================================================
// REVISION HISTORY
// ============================================================================
function buildRevisionHistory(revisions) {
  var list = Array.isArray(revisions) ? revisions : [];
  var W0   = Math.round(CW * 0.40);
  var W1   = CW - W0;

  var tbl = new Table({
    width: { size: CW, type: WidthType.DXA },
    columnWidths: [W0, W1],
    rows: [
      new TableRow({
        children: [
          mkCell("Document and Version Number", { bold: true, fill: COLOR.HEADER_GREY, w: W0, size: SZ.SM }),
          mkCell("Brief details of changes",    { bold: true, fill: COLOR.HEADER_GREY, w: W1, size: SZ.SM }),
        ],
      }),
    ].concat(list.filter(function (r) { return r && typeof r === "object"; }).map(function (r) {
      return new TableRow({
        children: [
          mkCellL(r.document_version || r["Document and Version Number"] || "", { w: W0, size: SZ.SM }),
          mkCellL(r.changes || r["Brief details of changes"] || "",             { w: W1, size: SZ.SM }),
        ],
      });
    })),
