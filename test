def extract_annexure_data(annexure_json: dict, annexure_number: int) -> dict:
    """
    Given a Document-AI JSON for one annexure, use Claude to extract structured
    elemental impurity declaration data.
    """
    prompt = f"""
You are a pharmaceutical regulatory data extraction specialist.

Below is a JSON file produced by Document AI, representing an elemental impurity 
declaration form from a pharmaceutical excipient or drug substance supplier 
(Annexure {annexure_number} of a Dr. Reddy's ICH Q3D risk assessment).

Extract ALL information into this exact JSON schema. Do not add commentary.
Return ONLY the JSON object.

{{
  "annexure_number": {annexure_number},
  "supplier_name": "",
  "material_name": "",
  "source_type": "Plant/Mineral/Synthetic/Mineral derived/Plant derived/Fermentation derived",
  "date_filled": "",
  "elements": [
    {{
      "name": "",
      "symbol": "",
      "class": "1/2A/2B/3",
      "intentionally_added": "Yes/No",
      "expected_concentration": "",
      "analytical_method": "",
      "observed_level_range": "",
      "frequency_of_testing": "",
      "listed_in_coa": "Yes/No",
      "comments": ""
    }}
  ]
}}

Document AI JSON:
{json.dumps(annexure_json, indent=2)[:12000]}
"""
    try:
        raw = call_claude(prompt)
        # Extract JSON from response
        start = raw.find("{")
        end   = raw.rfind("}") + 1
        if start >= 0 and end > start:
            return json.loads(raw[start:end])
    except Exception as e:
        logger.error(f"Annexure {annexure_number} extraction failed: {e}")
    return {"annexure_number": annexure_number, "supplier_name": "N/A",
            "material_name": "N/A", "elements": []}


def generate_observations_and_conclusion(summary: dict) -> Tuple[str, str]:
    """
    Ask Claude to write the Observation + Conclusion text based on calculation summary.
    Returns (observation_text, conclusion_text).
    """
    prompt = f"""
You are writing the Observations and Conclusion section of a Dr. Reddy's IPDO 
Elemental Impurities Risk Assessment Technical Summary Report following ICH Q3D (R2).

Product: Esomeprazole Magnesium for Delayed Release Oral Suspension 10/20/40 mg
Max Daily Dose: 240 mg/day (6 sachets of 40 mg, worst case)

Summary of theoretical elemental impurity calculations:
{json.dumps(summary, indent=2)}

Write two clearly labeled sections:

OBSERVATION:
- Note about daily intake basis (240 mg/day = 6 sachets of 40 mg, worst case)
- Whether any source had potential to transfer EI
- Whether calculated daily exposures were ≤30% of PDE (Option 2b compliance)
- Drug product compliance statement with ICH Q3D R2 Option 2b

CONCLUSION:
- Overall compliance statement (Option 2b)
- Any elements crossing 30% PDE requiring confirmatory testing (mention Class 1 and 2A 
  for Dextrose Anhydrous 16.878 gm dose) 
- Confirmatory testing plan on Exhibit batches

Keep the tone formal and consistent with regulatory pharmaceutical writing.
Return plain text only (no markdown, no JSON).
"""
    raw = call_claude(prompt)
    # Split at "CONCLUSION:"
    obs, conc = "", ""
    if "CONCLUSION:" in raw.upper():
        idx = raw.upper().index("CONCLUSION:")
        obs  = raw[:idx].replace("OBSERVATION:", "").strip()
        conc = raw[idx:].replace("CONCLUSION:", "").strip()
    else:
        obs = raw.strip()
    return obs, conc


