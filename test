def _run_deg_eg_workflow() -> None:
    """Fully isolated DEG & EG (Diethylene/Ethylene Glycol) Risk Assessment.
    No calculations, no exposure formula, no PDE, no USP <467> matrix — only
    composition + annexure-driven Yes/No presence + spec limits + conclusion."""
