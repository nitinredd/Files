  return [sopRow, blk(), titleBox, pgBrk()];
}

// ── TABLE OF CONTENTS ─────────────────────────────────────────────────────────
// Dynamic: uses entries extracted from the reference PDF.
// Falls back to computed defaults based on figureCount.
function buildTOC(tocEntries, figureCount) {
  figureCount = figureCount||0;
  // Compute page estimates for default TOC
  var p14   = 3;               // Sections 1-4
  var pRisk = p14+1;           // Risk assessment / Section 5
  var pComp = pRisk+1+figureCount; // After figure(s)
  var pCtrl = pComp+3;         // Control / conclusion (after calc tables ~3pp)
  var pAnn  = pCtrl+1;         // Annexure list
  var pRef  = pAnn+1;          // References
  var pRev  = pRef;            // Revision history (same page usually)

  // Default: 9-section structure (oral products)
  var def9=[
    {no:"1",title:"Abstract",                                         page:String(p14)},
    {no:"2",title:"Objective",                                        page:String(p14)},
    {no:"3",title:"Details of the study location / testing location", page:String(p14)},
    {no:"4",title:"Background",                                       page:String(p14)},
    {no:"5",title:"Drug product elemental impurity risk assessment",  page:String(pRisk)},
    {no:"6",title:"Summary & Conclusion",                             page:String(pCtrl)},
    {no:"7",title:"Reference",                                        page:String(pAnn)},
    {no:"8",title:"List of Annexures",                                page:String(pRef)},
    {no:"9",title:"Revision History",                                 page:String(pRev)},
  ];

  var entries = (Array.isArray(tocEntries)&&tocEntries.length) ? tocEntries : def9;

  var W=[600, CW-600-900, 900];
  var tbl=new Table({
    width:{size:CW,type:WidthType.DXA}, columnWidths:W,
    rows:[
      new TableRow({children:[
        cell("S. No.",{bold:true,fill:CLR.HDR_GREY,w:W[0],size:SZ.SM}),
        cell("Title", {bold:true,fill:CLR.HDR_GREY,w:W[1],size:SZ.SM}),
        cell("Page#", {bold:true,fill:CLR.HDR_GREY,w:W[2],size:SZ.SM}),
      ]}),
    ].concat(entries.map(function(e){
      return new TableRow({children:[
        cell(e.no||"",    {w:W[0],size:SZ.SM}),
        cellL(e.title||"",{w:W[1],size:SZ.SM}),
        cell(e.page||"",  {w:W[2],size:SZ.SM}),
      ]});
    })),
  });
  return [ctrPara("TABLE OF CONTENTS",true,SZ.MD), tbl, pgBrk()];
}

// ── ALL TEXT SECTIONS ────────────────────────────────────────────────────────
// Renders sections 1-4 and all narrative sub-sections that follow.
// Keeping everything here avoids duplication with buildSourcesSection.
function buildTextSections(txt) {
  txt=txt||{};
  var ch=[];

  function addSec(num, title, content) {
    if (!content && content !== "") return;  // skip empty optional sections
    ch.push(secHd(num+". "+title));
    bodyParas(content).forEach(function(p){ch.push(p);});
    ch.push(blk());
  }

  // Sections 1-4
  addSec(1,"Abstract",   txt.abstract||"");
  addSec(2,"Objective",  txt.objective||"");
  addSec(3,"Details of the study location / testing location",
            txt.study_location||"NA");

  ch.push(secHd("4. Background:"));
  bodyParas(txt.background||"").forEach(function(p){ch.push(p);});
  ch.push(blk());

  // Drug substance / excipient / manufacturing narrative (after Table 2)
  // These appear AFTER the composition table and Table 2 in the document flow.
  // They are stored here and rendered after buildSourcesSection in generateReport.
  var postCompSections = [
    txt.sources_intro,
    txt.drug_substance_section,
    txt.excipient_intro,
    txt.manufacturing_section,
    txt.container_closure_section,
    txt.utilities_section,
    txt.control_strategy,
    txt.testing_recommendation,
  ];
  var hasPostComp = postCompSections.some(function(t){return !!t;});

  // Store for use by generateReport — do NOT render here
  // (they are rendered by buildPostCompSections after Table 2)
  ch._postCompSections = postCompSections;
  ch._hasPostComp = hasPostComp;

  ch.push(pgBrk());
  return ch;
}

// Renders the narrative sections that appear after the composition table + Table 2
function buildPostCompSections(txt) {
  txt=txt||{};
  var ch=[];
  var sections = [
    txt.sources_intro,
    txt.drug_substance_section,
    txt.excipient_intro,
    txt.manufacturing_section,
    txt.container_closure_section,
    txt.utilities_section,
    txt.control_strategy,
    txt.testing_recommendation,
  ];
  sections.forEach(function(t){
    if(t){
      bodyParas(t).forEach(function(p){ch.push(p);});
      ch.push(blk());
    }
  });
  if (ch.length > 0) ch.push(pgBrk());
  return ch;
}

// ── GENERIC TABLE RENDERER ───────────────────────────────────────────────────
// Renders ANY table from extracted PDF/Excel data with exact column headers.
// columns: array of header strings
// rows: array of arrays (same length as columns)
// caption: optional caption string
function renderGenericTable(caption, columns, rows) {
  if (!Array.isArray(columns)||!columns.length) return [];
  if (!Array.isArray(rows)||!rows.length) return [];

  var N = columns.length;
  // Distribute widths: first col gets 30%, rest share equally if >1 col
  var firstW = Math.round(CW * 0.30);
  var restW  = N > 1 ? Math.floor((CW - firstW) / (N - 1)) : CW;
  // Last col absorbs rounding remainder
  var colWidths = [firstW];
  for (var ci = 1; ci < N - 1; ci++) colWidths.push(restW);
  if (N > 1) colWidths.push(CW - firstW - restW * (N - 2));

  // Responsive font based on column count
  var sz = N <= 4 ? SZ.SM : (N <= 8 ? SZ.XS : SZ.XXS);

  var hdrCells = columns.map(function(col, i) {
    return cell(String(col||""), {bold:true, fill:CLR.HDR_GREY, w:colWidths[i], size:sz});
  });
  var hdrRow = new TableRow({children: hdrCells});

  var dataRows = rows.filter(Boolean).map(function(row) {
    var rowArr = Array.isArray(row) ? row : [];
    var cells = colWidths.map(function(w, i) {
      var val = rowArr[i] != null ? String(rowArr[i]) : "";
      return i === 0 ? cellL(val, {w:w, size:sz}) : cell(val, {w:w, size:sz});
    });
    return new TableRow({children: cells});
  });

  var tbl = new Table({
    width: {size:CW, type:WidthType.DXA},
    columnWidths: colWidths,
    rows: [hdrRow].concat(dataRows),
  });

  var result = [];
  if (caption) result.push(lftPara(caption, true, SZ.SM));
  result.push(tbl);
  result.push(blk());
  return result;
}


// ── COMPOSITION TABLE — uses exact columns extracted from Excel ───────────────
// sections: [{name, rows:[{ingredient, columns:{ColName:val}}]}]
// compColumns: exact column headers from Excel
function buildCompositionTable(sections, compColumns, compMeta) {
  compMeta    = compMeta    || {};
  compColumns = Array.isArray(compColumns) && compColumns.length ? compColumns : null;

  // Determine columns to render
  var cols;
  if (compColumns) {
    // Use exact columns from Excel as extracted by Claude
    cols = compColumns;
  } else {
    // Fallback: standard oral sachet columns
    cols = ["Name of Ingredient","Function",
            "40 mg\nmg/unit","20 mg\nmg/unit","10 mg\nmg/unit"];
  }

  var N = cols.length;
  var firstW = Math.round(CW * 0.35);
  var restW  = N > 1 ? Math.floor((CW - firstW) / (N - 1)) : CW;
  var colWidths = [firstW];
  for (var ci = 1; ci < N - 1; ci++) colWidths.push(restW);
  if (N > 1) colWidths.push(CW - firstW - restW * (N - 2));

  var sz = N <= 4 ? SZ.SM : (N <= 6 ? SZ.XS : SZ.XXS);

  var hdrRow = new TableRow({children: cols.map(function(col, i) {
    return cell(String(col||""), {bold:true, fill:CLR.HDR_GREY, w:colWidths[i], size:sz});
  })});

  var dataRows = [];
  var sArr = Array.isArray(sections) ? sections : [];
  for (var si = 0; si < sArr.length; si++) {
    var sec = sArr[si];
    if (!sec || typeof sec !== "object") continue;
    // Section header row (blue) spanning all columns
    if (sec.name) {
      dataRows.push(new TableRow({children:[new TableCell({
        columnSpan:N, borders:allBdr(4), shading:shade(CLR.SEC_BLUE), margins:mg(),
        children:[lftPara(sec.name, true, sz)],
      })]}));
    }
    var rArr = Array.isArray(sec.rows) ? sec.rows : [];
    for (var ri = 0; ri < rArr.length; ri++) {
      var row = rArr[ri];
      if (!row || typeof row !== "object") continue;
      // Extract values in column order from the "columns" map or fallback fields
      var cells = colWidths.map(function(w, i) {
        var colName = cols[i] || "";
        var val = "";
        if (row.columns && typeof row.columns === "object") {
          // New format: {ingredient:"...", columns:{ColName:val}}
          val = row.columns[colName] != null ? String(row.columns[colName]) : "";
          // If not found by exact name, try ingredient for first col
          if (!val && i === 0) val = String(row.ingredient || row.name || "");
        } else {
          // Old format fallback — generic, no product-specific keys
          if (i === 0) val = String(row.ingredient || row.name || "");
          else if (i === 1) val = String(row.function || row.role || row.status || "");
          else val = String(row.amount || row.qty || "");
        }
        return i === 0 ? cellL(val, {w:w, size:sz}) : cell(val, {w:w, size:sz});
      });
      dataRows.push(new TableRow({children: cells}));
    }
  }

  var tbl = new Table({
    width:{size:CW,type:WidthType.DXA},
    columnWidths:colWidths,
    rows:[hdrRow].concat(dataRows),
  });

  return [
    secHd("5. Drug product elemental impurity risk assessment"),
    lftPara("Table 1: Quantitative and Qualitative Composition", true, SZ.SM),
    tbl, pgBrk(),
  ];
}

// ── FIGURE ────────────────────────────────────────────────────────────────────
function buildFigure(fig) {
  if (!fig||!fig.data_b64||typeof fig.data_b64!=="string"||fig.data_b64.length<100) return[];
  var buf;
  try { buf=Buffer.from(fig.data_b64,"base64"); if(buf.length<500) return[]; }
  catch(e) { return[]; }
  var imgW=560, imgH=Math.round(imgW*0.52);
  return [
    lftPara(fig.figure_label||"Figure 1",true,SZ.SM),
    new Paragraph({alignment:AlignmentType.CENTER,spacing:{before:40,after:40},
      children:[new ImageRun({type:(fig.media_type||"").indexOf("jpeg")>=0?"jpg":"png",
                               data:buf,transformation:{width:imgW,height:imgH}})]}),
    blk(), pgBrk(),
  ];
}

// ── TABLE 2: ANNEXURE DETAILS ────────────────────────────────────────────────
// NOTE: Narrative text (sources_intro, drug_substance, excipient, manufacturing,
// container_closure, utilities, control_strategy) is rendered ONLY in
// buildTextSections to avoid duplication. This function renders Table 2 only.
function buildSourcesSection(txt, annexureList) {
  txt=txt||{}; annexureList=Array.isArray(annexureList)?annexureList:[];
  var ch=[];

  // Table 2: Annexure list (if annexures exist)
  if (annexureList.length > 0) {
    var W=[Math.round(CW*0.40),Math.round(CW*0.36),0];
    W[2]=CW-W[0]-W[1];
    var annTbl=new Table({
      width:{size:CW,type:WidthType.DXA}, columnWidths:W,
      rows:[
        new TableRow({children:[
          cell("Name of Excipient / Material",{bold:true,fill:CLR.HDR_GREY,w:W[0],size:SZ.SM}),
          cell("Vendor",                       {bold:true,fill:CLR.HDR_GREY,w:W[1],size:SZ.SM}),
          cell("Title of Annexure",            {bold:true,fill:CLR.HDR_GREY,w:W[2],size:SZ.SM}),
        ]}),
      ].concat(annexureList.map(function(a,i){
        return new TableRow({children:[
          cellL(a.material||"", {w:W[0],size:SZ.SM}),
          cellL(a.supplier||"", {w:W[1],size:SZ.SM}),
          cell(a.annexure||("Annexure "+(i+1)),{w:W[2],size:SZ.SM}),
        ]});
      })),
    });
    ch.push(lftPara("Table No.2 Details of Annexures",true,SZ.SM));
    ch.push(annTbl);
    ch.push(blk());
  }

  return ch;
}

// ── NUMBER FORMATTER ──────────────────────────────────────────────────────────
function fmt(val, dec) {
  if (dec==null) dec=4;
  if (val==null||val==="") return "";
  var n=parseFloat(String(val).replace(/[^0-9.eE+\-]/g,""));
  if (isNaN(n)||!isFinite(n)) return "";
  return n.toFixed(dec);
}

// ── CALCULATION TABLES 5/6/7 ─────────────────────────────────────────────────
// Formula: Daily exposure (µg/day) = daily_intake_g × conc_µg_per_g
// Responsive: font shrinks for wide tables
function buildTraceabilityTable(trace) {
  trace = Array.isArray(trace) ? trace : [];
  if (trace.length === 0) return [];
  var W = [Math.round(CW*0.24), Math.round(CW*0.11), Math.round(CW*0.08),
           Math.round(CW*0.24), Math.round(CW*0.14), 0];
  W[5] = CW - W[0] - W[1] - W[2] - W[3] - W[4];
  var hdr = new TableRow({children:[
    cell("Ingredient",       {bold:true,fill:CLR.HDR_GREY,w:W[0],size:SZ.SM}),
    cell("Section",          {bold:true,fill:CLR.HDR_GREY,w:W[1],size:SZ.SM}),
    cell("Daily (g)",        {bold:true,fill:CLR.HDR_GREY,w:W[2],size:SZ.SM}),
    cell("Source annexure",  {bold:true,fill:CLR.HDR_GREY,w:W[3],size:SZ.SM}),
    cell("Match / status",   {bold:true,fill:CLR.HDR_GREY,w:W[4],size:SZ.SM}),
    cell("Identity evidence", {bold:true,fill:CLR.HDR_GREY,w:W[5],size:SZ.SM}),
  ]});
  var rows = trace.map(function(t){
    var flags = Array.isArray(t.validation_flags) ? t.validation_flags : [];
    var evidence = [];
    if (t.detected_brand) evidence.push("Brand: " + t.detected_brand);
    if (t.material_family) evidence.push("Family: " + t.material_family);
    if (flags.length) evidence.push("Flags: " + flags.join(", "));
    if (t.match_reason) evidence.push(String(t.match_reason).slice(0, 180));
    return new TableRow({children:[
      cellL(String(t.ingredient||""),{w:W[0],size:SZ.XS}),
      cellL(String(t.section||""),   {w:W[1],size:SZ.XS}),
      cell(fmt(t.daily_g!=null?t.daily_g:0,5),{w:W[2],size:SZ.XS}),
      cellL(String(t.annexure||"")+(t.matched_to&&t.matched_to!=="\u2014"?(" ("+t.matched_to+")"):""),
            {w:W[3],size:SZ.XS}),
      cellL(String(t.status||"")+(t.match_type?(" / "+t.match_type):"")+
            (t.confidence!==""&&t.confidence!=null?(" "+t.confidence):""),
            {w:W[4],size:SZ.XS}),
      cellL(evidence.join("; "),{w:W[5],size:SZ.XS}),
    ]});
  });
  var tbl = new Table({width:{size:CW,type:WidthType.DXA}, columnWidths:W,
    rows:[hdr].concat(rows)});
  return [secHd("Source Traceability (ingredient \u2192 annexure)"),
          lftPara("Each calculated ingredient row and the annexure its elemental "+
                  "impurity values were taken from. Rows marked 'No match' contribute "+
                  "zero to all elements.",false,SZ.SM),
          tbl, pgBrk()];
}


function buildCalcTable(tableNum, tableData, pdeValues) {
  var d=(tableData&&typeof tableData==="object")?tableData:{};
  var elements  = Array.isArray(d.elements)?d.elements:[];
  var rows      = Array.isArray(d.rows)?d.rows:[];
  var total     = d.total_daily_intake||0;
  var eTotals   = d.element_totals||{};
  var pde       = d.pde||{};
  var thresh    = d.threshold_30pct||{};
  var route     = d.route||"oral";

  if (elements.length===0) return [lftPara("Table "+tableNum+": No elements data.",false,SZ.SM)];

  var N=elements.length;
  var totalCols=3+2*N;
  var sz=totalCols<=12?SZ.SM:(totalCols<=18?SZ.XS:SZ.XXS);
  // Fixed columns scale with column count so wide tables (many elements) leave
  // enough room for the element columns without overflowing the page boundary.
  var fixedFrac = totalCols > 16 ? 0.26 : (totalCols > 12 ? 0.30 : 0.35);
  var INGR=Math.round(CW*fixedFrac*0.63);   // Component
  var MGT =Math.round(CW*fixedFrac*0.20);   // mg/tab
  var DI  =Math.round(CW*fixedFrac*0.17);   // Daily Intake (g)
  // Element columns share ALL remaining width equally; the last one absorbs the
  // rounding remainder so the column widths sum EXACTLY to CW (no overflow).
  var nElemCols=2*N;
  var remaining=CW-INGR-MGT-DI;
  var EW=nElemCols>0?Math.floor(remaining/nElemCols):remaining;
  var colW=[INGR,MGT,DI];
  for(var ci=0;ci<nElemCols;ci++) colW.push(EW);
  // Fix rounding so the total equals CW precisely
  var widthSum=colW.reduce(function(a,b){return a+b;},0);
  if(colW.length>0) colW[colW.length-1]+=(CW-widthSum);

  // Group consecutive same-class elements
  var grps=[];
  for(var gi=0;gi<elements.length;gi++){
    var sym=elements[gi];
    var cls=((pdeValues||{})[sym]||{}).class||"?";
    if(grps.length&&grps[grps.length-1].cls===cls) grps[grps.length-1].count++;
    else grps.push({cls:cls,count:1});
  }

  // Header rows
  var h1=new TableRow({children:[
    cell("Component",        {bold:true,fill:CLR.HDR_GREY,w:INGR,size:sz}),
    cell("mg/tab",           {bold:true,fill:CLR.HDR_GREY,w:MGT, size:sz}),
    cell("Daily\nIntake\n(g)",{bold:true,fill:CLR.HDR_GREY,w:DI,  size:sz}),
    new TableCell({columnSpan:N,borders:allBdr(4),shading:shade(CLR.HDR_GREY),margins:mg(),
      children:[ctrPara("Measured Concentration (\u00B5g/g)",true,sz)]}),
    new TableCell({columnSpan:N,borders:allBdr(4),shading:shade(CLR.HDR_GREY),margins:mg(),
      children:[ctrPara("Daily Exposure (\u00B5g/day)",true,sz)]}),
  ]});

  var h2cells=[emptyCell(CLR.HDR_GREY,INGR),emptyCell(CLR.HDR_GREY,MGT),emptyCell(CLR.HDR_GREY,DI)];
  for(var h=0;h<2;h++) grps.forEach(function(g){
    h2cells.push(new TableCell({columnSpan:g.count,borders:allBdr(4),shading:shade(CLR.HDR_GREY),
      margins:mg(),children:[ctrPara("Class "+g.cls,true,sz)]}));
  });
  var h2=new TableRow({children:h2cells});

  var h3cells=[emptyCell(CLR.HDR_GREY,INGR),emptyCell(CLR.HDR_GREY,MGT),emptyCell(CLR.HDR_GREY,DI)];
  for(var hh=0;hh<2;hh++) elements.forEach(function(s){
    h3cells.push(cell(s,{bold:true,fill:CLR.HDR_GREY,w:EW,size:sz}));
  });
  var h3=new TableRow({children:h3cells});

  var dataRows=rows.filter(Boolean).map(function(row){
    var mc=row.measured_conc||{}, tm=row.total_mass||{};
    var cells=[
      cellL(row.ingredient||"",{w:INGR,size:sz}),
      cell(fmt(row.mg_per_unit!=null?row.mg_per_unit:0,3),{w:MGT,size:sz}),
      cell(fmt(row.daily_intake_g!=null?row.daily_intake_g:0,6),{w:DI,size:sz}),
    ];
    elements.forEach(function(s){ cells.push(cell(fmt(mc[s]!=null?mc[s]:0,4),{w:EW,size:sz})); });
    elements.forEach(function(s){ cells.push(cell(fmt(tm[s]!=null?tm[s]:0,6),{w:EW,size:sz})); });
    return new TableRow({children:cells});
  });

  function footerRow(label,vals,fill,isThresh){
    var fc=[
      cell(label,{bold:true,fill:fill,align:AlignmentType.LEFT,w:INGR,size:sz}),
      emptyCell(fill,MGT),
      cell(label==="TOTAL daily intake (g/day)"?fmt(total,6):"",{fill:fill,w:DI,size:sz}),
    ];
    elements.forEach(function(){ fc.push(emptyCell(fill,EW)); });
    elements.forEach(function(s){
      var val=vals[s]!=null?vals[s]:null;
      var tot=eTotals[s]!=null?eTotals[s]:null;
      var ex=isThresh&&val!=null&&tot!=null&&isFinite(val)&&isFinite(tot)&&tot>val;
      fc.push(cell(val!=null?fmt(val,3):"\u2013",{
        fill:ex?CLR.EXCEED_BG:fill, w:EW, size:sz,
        color:ex?CLR.EXCEED_TXT:CLR.BLACK,
      }));
    });
    return new TableRow({children:fc});
  }

  var lbls={5:"Class 1 and Class 2A",6:"Class 2B",7:"Class 3"};
  var caption="Table "+tableNum+": Theoretical Elemental Impurity Assessment ("
    +(lbls[tableNum]||"")+")"
    +" \u2014 Evaluation of Daily Exposure [Route: "+route+"]";

  var tbl=new Table({
    width:{size:CW,type:WidthType.DXA}, columnWidths:colW,
    rows:[h1,h2,h3].concat(dataRows).concat([
      footerRow("TOTAL daily intake (g/day)",eTotals,CLR.HDR_GREY,false),
      footerRow("PDE (\u00B5g/day)",         pde,    CLR.HDR_GREY,false),
      footerRow("Threshold (30% PDE)",       thresh, CLR.THRESH_BG,true),
    ]),
  });
  return [lftPara(caption,true,SZ.SM), tbl, blk()];
}

// ── ADDITIONAL TABLES (verbatim from reference PDF) ──────────────────────────
// Renders any extra tables that were extracted from the PDF but don't fit
// into the standard EI calculation tables.
// E.g.: Potential risk table, packing material table, summary tables, etc.
function buildAdditionalTables(additionalTables) {
  if (!Array.isArray(additionalTables) || !additionalTables.length) return [];
  var ch = [];
  for (var i = 0; i < additionalTables.length; i++) {
    var tbl = additionalTables[i];
    if (!tbl || typeof tbl !== "object") continue;
    var cols = Array.isArray(tbl.columns) ? tbl.columns : [];
    var rows = Array.isArray(tbl.rows)    ? tbl.rows    : [];
    if (!cols.length || !rows.length) continue;
    var parts = renderGenericTable(tbl.caption || "", cols, rows);
    parts.forEach(function(p) { ch.push(p); });
  }
  return ch;
}


// ── SUMMARY & CONCLUSION ──────────────────────────────────────────────────────
function buildSummary(txt) {
  txt=txt||{};
  var ch=[secHd("6. Summary & Conclusion")];
  if(txt.observation){
    ch.push(lftPara("Observation:",true,SZ.TEXT));
    bodyParas(txt.observation).forEach(function(p){ch.push(p);});
    ch.push(blk());
  }
  if(txt.conclusion){
    ch.push(lftPara("Conclusion:",true,SZ.TEXT));
    bodyParas(txt.conclusion).forEach(function(p){ch.push(p);});
  }
  ch.push(pgBrk());
  return ch;
}

