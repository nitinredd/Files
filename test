                        (f"Annexure {ann_no_map.get(mkey,'?')}" if mkey else "No match"),
                        mkey or "—", a.get("match_type",""), a.get("match_confidence",""),
                        ("Matched" if a.get("matched") else "No match")])
        st.session_state["inj_traceability_csv"] = buf.getvalue().encode("utf-8")

    except Exception as e:
        st.error(f"Report generation failed: {e}")
        logger.exception("Injection report error")


def _rs_debug_dump(name: str, obj) -> None:
    """Persist a debug JSON artifact for the RS pipeline (best-effort)."""
    try:
        import tempfile, os
        d = os.path.join(tempfile.gettempdir(), "rs_debug")
        os.makedirs(d, exist_ok=True)
        with open(os.path.join(d, name), "w") as f:
            json.dump(obj, f, indent=2, default=str)
    except Exception:
        pass


def _deg_debug_dump(name: str, obj) -> None:
    """Persist a debug JSON artifact for the DEG/EG pipeline and LOG its path.

    The DEG/EG evidence chain (vision extraction → normaliser → raw-text backstop
    → guarantee-ceiling / consistency guards) is entirely invisible once a report
    is rendered, so a wrong per-glycol limit is untraceable. The normaliser
    already records WHY each value exists (backstop_recoveries,
    guarantee_ceiling_notes, consistency_downgrades) — this writes them out."""
    try:
        import tempfile, os
        d = os.path.join(tempfile.gettempdir(), "deg_eg_debug")
        os.makedirs(d, exist_ok=True)
        p = os.path.join(d, name)
        with open(p, "w", encoding="utf-8") as f:
            json.dump(obj, f, indent=2, default=str, ensure_ascii=False)
        logger.warning("[DEG/EG debug] wrote %s", p)
    except Exception:
        logger.exception("[DEG/EG debug] dump failed for %s", name)


def _rs_str_df(rows: list):
    """Build a display-safe dataframe (all strings) to avoid Arrow type errors."""
    try:
        import pandas as pd
        if not rows:
            return pd.DataFrame()
        return pd.DataFrame(rows).astype(str)
    except Exception:
        return rows


def _run_residual_solvent_workflow() -> None:
    """Fully isolated, mode-aware Residual Solvent (USP <467> / ICH Q3C) workflow."""
    import residual_solvent as _rs

    # ── Step 1: minimal inputs — one product field, one dosage form, one upload ──
    c1, c2 = st.columns(2)
    with c1:
        rs_product = st.text_input("Product Name", key="rs_product")
    with c2:
        rs_dosage_form = st.text_input("Dosage Form", key="rs_dosage_form")

    # USP <467> is the standing default; the compendial priority is not a
    # per-run question for the scientist.
    st.session_state["rs_framework"] = _rs.DEFAULT_RS_FRAMEWORK

    rs_files = st.file_uploader(
        "Upload files", accept_multiple_files=True,
        type=["pdf", "docx", "json", "xlsx", "xls"], key="rs_files")
    rs_excel_bytes, rs_annx, _img = _route_files(rs_files)

    # Analysis auto-triggers on a new upload — no separate "Analyze" click. The
    # signature keeps a re-run from re-converting the same files every rerun.
    _sig = f"{rs_product}|{len(rs_files or [])}|" + ",".join(
        sorted(safe_str(getattr(f, 'name', '')) for f in (rs_files or [])))
    _fresh = bool(rs_excel_bytes and rs_product
                  and st.session_state.get("rs_upload_sig") != _sig)
    if _fresh:
        st.session_state["rs_upload_sig"] = _sig
        for k in ("rs_cls", "rs_parsed", "rs_calc", "rs_mapping", "rs_annexures",
                  "rs_errors", "rs_warnings", "rs_header", "rs_docx_bytes",
                  "rs_report_ready", "rs_excel_bytes", "rs_ready_to_calc",
                  # RS Bug 2: clear the single-strength dose/salt/overage inputs so a
                  # new product re-detects its own asterisk footnote (setdefault
                  # would otherwise keep the previous product's seeded values).
                  "rs_single_salt", "rs_single_overage", "rs_single_mdd",
                  "rs_single_vol", "rs_single_density"):
            st.session_state.pop(k, None)
        try:
            excel_bytes = rs_excel_bytes
            st.session_state["rs_excel_bytes"] = excel_bytes
            cls = _rs.classify_rs_excel(excel_bytes)
            _rs_debug_dump("debug_rs_classification.json",
                           {k: v for k, v in cls.items() if k != "sheets"})
            st.session_state["rs_cls"] = cls
            # RS-RF1: footnote inspection is warning-only — unresolved markers are
            # logged inside the validator and never block or surface in the UI.
            st.session_state["rs_footnote_validation"] = _rs.validate_excel_footnotes(cls)
            # annexures: auto-dispatch behind ONE progress bar (PDF → RS converter,
            # JSON → RS normaliser). Per-file failures are logged, never shown.
            _bar = st.progress(0, text="Analyzing files… 0%")
            annexures = _process_annexures_with_progress(
                "Residual Solvent Risk Assessment", rs_annx, _bar, 5, 100)
            _bar.empty()
            st.session_state["rs_annexures"] = annexures
            _rs_debug_dump("debug_rs_annexures.json", annexures)
            _meta = _auto_meta(rs_product, rs_dosage_form,
                               "Residual Solvent Risk Assessment")
            st.session_state["rs_header"] = {
                "title": f"Residual Solvent Risk Assessment for {rs_product.strip()}",
                "document_no": _meta["document_no"],
                "product_name": _meta["product_name"],
                "dosage_form": _meta["dosage_form"],
                "strength": "", "market": _meta["market"],
                "maximum_daily_dose": "",
                "department": _meta["department"], "version": _meta["version"],
                "protocol": _meta["protocol"], "sop_format_number": "",
            }
        except Exception:
            logger.exception("RS classify error")
            st.error("Could not read the composition Excel. Please check the file.")

    cls = st.session_state.get("rs_cls")
    if not cls:
        return

    mode = cls.get("mode")
    logger.info("[RS] Excel mode=%s sheet=%s", mode, cls.get("sheet", "?"))

    # ── Step 2: mode-specific dose basis (missing-details only) ───────────────
    parsed = None
    excel_bytes = st.session_state.get("rs_excel_bytes")

    if mode == "insufficient_material_names_only":
        st.error("This Excel has material names but no quantity, strength, MDD, "
                 "or amount-in-maximum-dose columns, so a residual-solvent "
                 "assessment cannot be calculated. Please upload an Excel that "
                 "includes strengths, component MDD, or amount in maximum dose.")
        return

    if mode == "unit_composition_strength_columns":
        strengths = cls.get("strengths", [])
        max_strength = max(strengths, key=lambda x: x[2]) if strengths else None
        mdd_in = st.number_input(
            "Maximum Daily Dose (mg/day)",
            min_value=0.0, value=0.0, step=10.0, key="rs_mdd_input")
        # No confirmation click — proceed as soon as a dose is entered.
        if mdd_in > 0 and max_strength:
            parsed = _rs.parse_unit_composition_excel(cls, mdd_mg_day=float(mdd_in))
            st.session_state["rs_header"]["strength"] = max_strength[1]
            st.session_state["rs_header"]["maximum_daily_dose"] = f"{mdd_in:g} mg"
            st.session_state["rs_parsed"] = parsed
            st.session_state["rs_ready_to_calc"] = True

    elif mode == "component_mdd_only":
        parsed = _rs.parse_component_mdd_only_excel(cls)
        st.session_state["rs_parsed"] = parsed
        st.session_state["rs_ready_to_calc"] = True
        if parsed.get("product_mdd_mg"):
            st.session_state["rs_header"]["maximum_daily_dose"] = \
                f"{parsed['product_mdd_mg']:g} mg"

    elif mode == "single_strength_unit_composition":
        # Single-strength unit composition: ONE quantity column with a unit basis
        # (mg/vial, mg/mL, mg/tablet, mg/sachet, mg/dose). RF1: ask ONE question —
        # the API's Maximum Daily Dose (mg/day). The dose multiplier is derived
        # from the auto-detected API row's per-unit quantity.
        unit_basis = cls.get("unit_basis") or "unit"
        is_liquid = unit_basis == "ml"

        # RS Bug 2: auto-detect a salt/base (or overage) footnote and apply it
        # silently. A salt-form API's dose multiplier must use the free-base label
        # strength (Trilaciclib 432/300 = 1.44), NOT the salt formulation weight
        # (432/349). Warning-first: a missing/unparseable footnote just leaves the
        # neutral default (salt_factor 1.0) and logs.
        _salt_detect = _rs.detect_salt_base_from_classified(cls)
        if _salt_detect and _salt_detect.get("kind") == "salt_base":
            st.session_state.setdefault(
                "rs_single_salt", round(float(_salt_detect["salt_factor"]), 4))
            logger.info("[RS] salt/base footnote detected: %g mg salt = %g mg base "
                        "(factor %.4f) — enter the API MDD as free base.",
                        _salt_detect["salt_weight"], _salt_detect["base_weight"],
                        _salt_detect["salt_factor"])
        elif _salt_detect and _salt_detect.get("kind") == "overage":
            st.session_state.setdefault(
                "rs_single_overage",
                round(float(_salt_detect["overage_pct"]) * 100.0, 2))
            logger.info("[RS] overage footnote detected: %g%%",
                        _salt_detect["overage_pct"] * 100)
        # Guarantee the widget keys exist (detected value, else the neutral
        # default) so the inputs below can read Session State without a
        # value=/key= conflict warning.
        st.session_state.setdefault("rs_single_salt", 1.0)
        st.session_state.setdefault("rs_single_overage", 0.0)

        # Volume-dosed liquids (mg/mL) ask for the daily dose VOLUME (mL/day); the
        # multiplier is that volume directly (RS Bug 1), so an API overage in the
        # mg/mL strength never skews the dose. Solids ask for the API MDD (mg/day).
        mdd_in = 0.0
        dose_vol_in = 0.0
        overage_in = 0.0
        # ONE minimal prompt: the dose, plus (liquids only) the auto-estimated
        # density as an optional override. Salt factor and overage are applied
        # silently from the footnote detection above.
        salt_in = float(st.session_state.get("rs_single_salt", 1.0) or 1.0)
        overage_in = float(st.session_state.get("rs_single_overage", 0.0) or 0.0) / 100.0
        if is_liquid:
            dose_vol_in = st.number_input(
                "Daily dose volume (mL/day)",
                min_value=0.0, value=0.0, step=0.001, format="%.3f",
                key="rs_single_vol")
            # RS-RF2: auto-estimate density from composition and pre-fill an
            # OPTIONAL, overridable field (never blocks; scientist updates only
            # if their formulation spec differs).
            _dens_est = _rs.estimate_density_from_classified(cls)
            st.session_state.setdefault("rs_single_density", _dens_est)
            density_in = st.number_input(
                f"Density (g/mL) — auto-estimated: {_dens_est:.3f}",
                min_value=0.0, step=0.001, format="%.3f", key="rs_single_density",
                help="Update only if your formulation specification differs. "
                     "Otherwise leave as-is.")
        else:
            mdd_in = st.number_input(
                "Maximum Daily Dose (mg/day)",
                min_value=0.0, value=0.0, step=0.001, format="%.3f",
                key="rs_single_mdd")
        if not is_liquid:
            _dens_est = 1.0
            density_in = 1.0
        # No confirmation click — proceed as soon as the dose is entered.
        if (dose_vol_in > 0) if is_liquid else (mdd_in > 0):
            parsed = _rs.parse_single_strength_unit_composition(
                cls, mdd_mg_day=float(mdd_in), unit_basis=unit_basis,
                salt_factor=float(salt_in), density_g_per_ml=float(density_in),
                dose_volume_ml=(float(dose_vol_in) if is_liquid else None),
                overage_pct=float(overage_in))
            # RS-RF2 audit: record which density was used and the auto-estimate.
            if is_liquid and isinstance(parsed, dict):
                parsed["density_auto_estimate"] = _dens_est
                parsed["density_source"] = (
                    "user_updated" if abs(float(density_in) - float(_dens_est)) > 1e-6
                    else "auto_estimated")
            hdr = st.session_state["rs_header"]
            # RF6a/6b: strength shows the API (label) strength, never the column
            # header; overage products carry a footnote.
            if parsed.get("strength_label"):
                hdr["strength"] = parsed["strength_label"]
            if parsed.get("strength_note"):
                hdr["strength_note"] = parsed["strength_note"]
            # RF6b: infer dosage form when the user did not supply one.
            if parsed.get("dosage_form_inferred") and not str(hdr.get("dosage_form") or "").strip():
                hdr["dosage_form"] = parsed["dosage_form_inferred"]
            # RF6c: MDD label in Table 1 — mg/day for solids, label dose for liquids.
            if parsed.get("mdd_mg_day"):
                hdr["maximum_daily_dose"] = f"{parsed['mdd_mg_day']:g} mg/day"
            elif is_liquid and parsed.get("product_mdd_mg"):
                hdr["maximum_daily_dose"] = (
                    f"{parsed['product_mdd_mg']:g} mg/day "
                    f"({dose_vol_in:g} mL/day)")
            st.session_state["rs_parsed"] = parsed
            st.session_state["rs_ready_to_calc"] = True
            if parsed.get("api_component"):
                logger.info("[RS] API detected: %s (%s mg/%s); dose multiplier = %s",
                            parsed["api_component"], parsed.get("api_qty_per_unit"),
                            unit_basis, parsed.get("multiplier"))

    elif mode == "detailed_rs_calculation":
        # Detailed mode: Excel is authoritative. Try the DETERMINISTIC flat parser
        # first (no LLM, no MDD/strength prompt). Only fall back to Claude vision
        # extraction if the flat parser cannot read usable rows.
        with st.spinner("Reading detailed RS calculation Excel…"):
            flat = _rs.parse_flat_detailed_rs_excel(excel_bytes)
            if flat and flat.get("rows"):
                _rs_debug_dump("debug_rs_raw_excel.json", flat)
                parsed = _rs.parse_rs_excel(flat)
            else:
                raw = _rs_parse_excel_raw(excel_bytes)
                _rs_debug_dump("debug_rs_raw_excel.json", raw)
                parsed = _rs.parse_rs_excel(raw)
        st.session_state["rs_parsed"] = parsed
        st.session_state["rs_ready_to_calc"] = True
        if parsed.get("product_mdd_mg"):
            st.session_state["rs_header"]["maximum_daily_dose"] = \
                f"{parsed['product_mdd_mg']:g} mg"

    elif mode == "combined_workbook":
        # Sheet 1 (unit composition) drives Section 4 Table 2; Sheet 2 (detailed
        # RS calculation) drives Section 5. Detailed sheet is the calculation
        # source; annexures are traceability evidence only.
        logger.info("[RS] combined workbook: unit sheet '%s' drives composition; "
                    "detailed sheet '%s' drives the calculation.",
                    cls["unit_sheet"]["sheet"], cls["detailed_sheet"]["sheet"])
        with st.spinner("Reading detailed RS calculation sheet…"):
            raw = _rs_parse_excel_raw(excel_bytes)
            _rs_debug_dump("debug_rs_raw_excel.json", raw)
            parsed = _rs.parse_rs_excel(raw)
        # Override the composition display with the unit-composition sheet so
        # Section 4 preserves stages/strengths verbatim.
        try:
            unit_cls = {**cls["unit_sheet"], "sheets": cls.get("sheets", [])}
            unit_parsed = _rs.parse_unit_composition_excel(unit_cls, mdd_mg_day=0.0)
            parsed["_display_sections"] = unit_parsed.get("_display_sections", [])
            parsed["_display_columns"] = unit_parsed.get("_display_columns", [])
        except Exception as _e:
            logger.warning(f"combined unit-sheet parse failed: {_e}")
        st.session_state["rs_parsed"] = parsed
        st.session_state["rs_ready_to_calc"] = True
        if parsed.get("product_mdd_mg"):
            st.session_state["rs_header"]["maximum_daily_dose"] = \
                f"{parsed['product_mdd_mg']:g} mg"

    # ── Step 3: calculate + validate once we have a parsed model ──────────────
    if st.session_state.get("rs_ready_to_calc") and st.session_state.get("rs_parsed"):
        parsed = st.session_state["rs_parsed"]
        annexures = st.session_state.get("rs_annexures", [])
        # display copy for Table 2 (deterministic parsers already set _display_*)
        if "_display_sections" not in parsed:
            parsed["_display_columns"] = parsed.get("columns", [])
            parsed["_display_sections"] = [{
                "name": "Composition",
                "rows": [{"ingredient": r["component"], "columns": r.get("columns", {})}
                         for r in parsed["rows"]]}]
        _rs_debug_dump("debug_rs_parsed.json",
                       {k: v for k, v in parsed.items() if k != "sheets"})

        comps = [r["component"] for r in parsed["rows"] if not r["_is_qs"]]

        # Section 5 calculation uses AGGREGATED identities for unit-composition /
        # MDD modes. For detailed / combined modes the Excel already carries the
        # final per-row solvent matrix, so it is authoritative — do NOT aggregate.
        if parsed.get("mode") in ("detailed_rs_calculation", "combined_workbook") \
           or parsed.get("solvents_display"):
            calc_parsed = dict(parsed)
        else:
            calc_parsed = _rs.aggregate_calculation_identities(parsed)
        calc_parsed["_display_sections"] = parsed.get("_display_sections", [])
        calc_parsed["_display_columns"] = parsed.get("_display_columns", [])
        _rs_debug_dump("debug_rs_parsed_aggregated.json",
                       {k: v for k, v in calc_parsed.items() if k != "sheets"})

        calc_comps = [r["component"] for r in calc_parsed["rows"] if not r["_is_qs"]]
        # RF8: dedup annexures by (material, supplier) and merge their solvent
        # evidence BEFORE mapping, so the richer record feeds mapping + calc.
        _rs_framework = st.session_state.get("rs_framework", _rs.DEFAULT_RS_FRAMEWORK)
        annexures, _rs_dup_warnings = _rs.dedup_rs_annexures(annexures, _rs_framework)
        if _rs_dup_warnings:
            logger.info("RS annexure dedup: %s", "; ".join(_rs_dup_warnings))
        mapping = _rs.map_components_to_annexures(calc_comps, annexures)
        _rs_debug_dump("debug_rs_mapping.json",
                       {k: {kk: vv for kk, vv in v.items() if kk != "_annexure"}
                        for k, v in mapping.items()})
        calc = _rs.calculate_rs_exposures(calc_parsed, mapping)
        _rs_debug_dump("debug_rs_calc.json", calc)

        header = st.session_state["rs_header"]
        text_stub = {"reference": "1. USP <467>\n2. ICH Q3C (R8)"}
        # First pass to get structured validation, then payload with it embedded
        val0 = _rs.validate_rs_full(calc_parsed, calc, mapping, annexures, None)
        payload_preview = _rs.build_rs_payload(header, calc_parsed, calc, mapping,
                                               annexures, text_stub, group_size=3,
                                               validation=val0,
                                               framework=st.session_state.get(
                                                   "rs_framework", _rs.DEFAULT_RS_FRAMEWORK))
        validation = _rs.validate_rs_full(calc_parsed, calc, mapping, annexures,
                                          payload_preview)
        _rs_debug_dump("debug_rs_payload.json", payload_preview)
        _rs_debug_dump("debug_rs_validation.json", validation)
        errors = validation["errors"]
        warnings = validation["warnings"]

        st.session_state["rs_parsed_calc"] = calc_parsed
        st.session_state["rs_calc"] = calc
        st.session_state["rs_mapping"] = mapping
        st.session_state["rs_validation"] = validation
        st.session_state["rs_errors"] = errors
        st.session_state["rs_warnings"] = warnings

        # Verification, mapping and warning surfaces are internal-only: they go to
        # the logger so the scientist sees a single Generate button.
        logger.info("[RS] mode=%s product=%s strength=%s doses=%s mdd=%s "
                    "solvent_source=%s solvents=%s conclusion=%s",
                    mode, header["product_name"],
                    parsed.get("selected_strength_label", header.get("strength")),
                    parsed.get("no_of_doses"), header.get("maximum_daily_dose"),
                    calc.get("solvent_source"), ", ".join(calc.get("solvents", [])),
                    validation["conclusion_status"])
        for _c, _m in mapping.items():
            logger.info("[RS mapping] %s → annexure %s (%s, conf %s)", _c,
                        _m.get("matched_annexure"), _m.get("matched_material"),
                        _m.get("confidence"))
        for _w in warnings:
            logger.warning("[RS] %s", _w)

        # WARNING-FIRST: generate unless there are true hard errors.
        if errors:
            for _e in errors:
                logger.error("[RS] %s", _e)
            st.error("This composition could not be assessed: "
                     + " ".join(errors[:2]))
        elif st.button("Generate Report", type="primary", key="rs_generate",
                       use_container_width=True):
            _generate_rs_report()

    if st.session_state.get("rs_report_ready") and st.session_state.get("rs_docx_bytes"):
        st.download_button("📥 Download Report",
            data=st.session_state["rs_docx_bytes"],
            file_name=st.session_state.get("rs_docx_fname", "TSR_residual_solvent.docx"),
            mime="application/vnd.openxmlformats-officedocument.wordprocessingml.document",
            key="dl_rs_docx", use_container_width=True)


def _rs_parse_excel_raw(excel_bytes: bytes) -> Dict:
    """Detailed-mode helper: dump the workbook and let Claude extract the full
    solvent matrix (only used for detailed_rs_calculation Excels)."""
    import residual_solvent as _rs
    wb = openpyxl.load_workbook(BytesIO(excel_bytes), data_only=True)
    dump_parts = []
    for ws in wb.worksheets:
        dump_parts.append(f"=== Sheet: {ws.title} ===")
        for i, row in enumerate(ws.iter_rows(values_only=True)):
            if any(c is not None for c in row):
                cells = [str(c) if c is not None else "" for c in row]
                dump_parts.append(f"Row {i+1}: {' | '.join(cells)}")
            if i > 150:
                break
    wb.close()
    prompt = _rs.rs_excel_prompt() + "\n\nSpreadsheet:\n" + "\n".join(dump_parts[:250])
    raw = claude_text(prompt, max_tokens=8192)
    return _rs.rs_safe_json(raw, want="dict")


def _generate_rs_report() -> None:
    """Build the RS report from validated session state and render via the RS JS.
    Warning-first: generates unless there are TRUE hard errors or an empty payload."""
    import residual_solvent as _rs
    try:
