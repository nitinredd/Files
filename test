"route": _infer_route(dosage_form), # auto-inferred
}

def _infer_route(dosage_form: str) -> str:
"""Product-agnostic route inference from dosage form text."""
dl = dosage_form.lower()
if any(k in dl for k in ["injection", "parenteral", "iv", "im", "vial", "ampoule"]):
return "parenteral"
if any(k in dl for k in ["tablet", "capsule", "sachet", "granule", "powder"]):
return "oral"
if any(k in dl for k in ["cream", "ointment", "gel", "lotion", "patch"]):
return "topical"
if any(k in dl for k in ["drop", "solution", "suspension"]) and \
any(k in dl for k in ["oral", "syrup"]):
return "oral"
return "oral" # default

