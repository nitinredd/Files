/**

- generate_report.js  –  Dr. Reddy’s IPDO TSR
- Pixel-exact replica of TSR-SOM-01-00066 v5.0
- Font: Arial  |  Body: 9pt  |  Small: 8pt  |  Heading: 10pt bold
  */
  “use strict”;
  const fs = require(“fs”);
  const {
  Document, Packer, Paragraph, TextRun, Table, TableRow, TableCell,
  ImageRun, Header, Footer, AlignmentType, BorderStyle, WidthType,
  ShadingType, VerticalAlign, PageNumber, PageBreak,
  convertInchesToTwip,
  } = require(“docx”);

const PW = convertInchesToTwip(8.27);
const PH = convertInchesToTwip(11.69);
const ML = convertInchesToTwip(0.59);
const MR = convertInchesToTwip(0.59);
const MT = convertInchesToTwip(1.18);
const MB = convertInchesToTwip(0.59);
const CW = PW - ML - MR;

const C = {
WHITE:“FFFFFF”, BLACK:“000000”,
TH_LIGHT:“D9D9D9”, TH_BLUE:“BDD7EE”,
THRESHOLD:“FFCCCC”, EXCEEDED:“FF0000”,
};
const F = “Arial”;
const PT = (pt) => pt * 2;
const S = { XS:PT(7), SM:PT(8), BODY:PT(9), MD:PT(10), LG:PT(11) };

const bdr  = (sz=4,clr=C.BLACK) => ({style:BorderStyle.SINGLE,size:sz,color:clr});
const bdrs = (sz=4) => ({top:bdr(sz),bottom:bdr(sz),left:bdr(sz),right:bdr(sz),
insideHorizontal:bdr(sz),insideVertical:bdr(sz)});
const shade= (fill) => ({fill,type:ShadingType.CLEAR,color:“auto”});
const cm   = (t=40,r=80,b=40,l=80) => ({top:t,right:r,bottom:b,left:l});

const run  = (text,bold=false,size=S.BODY,color=C.BLACK) =>
new TextRun({text:String(text??’’),bold,size,font:F,color});

function p(children_or_str,align=AlignmentType.LEFT,before=40,after=40){
let children = typeof children_or_str===‘string’
? [run(children_or_str)] : Array.isArray(children_or_str)
? children_or_str : [children_or_str];
return new Paragraph({alignment:align,spacing:{before,after,line:240},children});
}
const pC  = (t,bold=false,sz=S.BODY) => p([run(t,bold,sz)],AlignmentType.CENTER,40,40);
const pL  = (t,bold=false,sz=S.BODY) => p([run(t,bold,sz)],AlignmentType.LEFT,20,20);
const blank= ()=> p([run(’’)],AlignmentType.LEFT,20,20);
const pageBreak=()=> new Paragraph({children:[new PageBreak()]});
const sHd =(text)=> p([run(text,true,S.MD)],AlignmentType.LEFT,80,40);

function bodyParagraphs(text){
if(!text) return [];
return text.trim().split(/\n+/).filter(l=>l.trim()).map(l=>pL(l.trim(),false,S.BODY));
}

function cell(text,opts={}){
const{bold=false,size=S.SM,align=AlignmentType.CENTER,
fill=null,colSpan=1,w=null,color=C.BLACK}=opts;
return new TableCell({
columnSpan:colSpan,
width:w?{size:w,type:WidthType.DXA}:undefined,
borders:bdrs(4), shading:fill?shade(fill):undefined,
margins:cm(), verticalAlign:VerticalAlign.CENTER,
children:[new Paragraph({alignment:align,spacing:{before:0,after:0},
children:[new TextRun({text:String(text??’’),bold,size,font:F,color})]})],
});
}
const cellL=(text,opts={})=> cell(text,{…opts,align:AlignmentType.LEFT});

function cellML(lines,opts={}){
const{bold=false,size=S.SM,fill=null,colSpan=1,w=null}=opts;
const arr=Array.isArray(lines)?lines:[lines];
return new TableCell({
columnSpan:colSpan, width:w?{size:w,type:WidthType.DXA}:undefined,
borders:bdrs(4), shading:fill?shade(fill):undefined,
margins:cm(), verticalAlign:VerticalAlign.CENTER,
children:arr.filter(Boolean).map(l=>new Paragraph({
alignment:AlignmentType.LEFT, spacing:{before:0,after:0},
children:[new TextRun({text:String(l),bold,size,font:F})],
})),
});
}
const eCell=(fill=null,w=null)=> new TableCell({
width:w?{size:w,type:WidthType.DXA}:undefined,
borders:bdrs(4), shading:fill?shade(fill):undefined, margins:cm(),
children:[new Paragraph({children:[new TextRun(’’)]})],
});

// ── HEADER ──────────────────────────────────────────────────────────────────
function buildHeader(meta){
const{title=’’,document_no=’’,product_name=’’,dosage_form=’’,
version=’’,strength=’’,department=’’,market=’’,protocol=’’}=meta;
const C1=1440,C2=5760,C3=3060;
const r1=new TableRow({children:[
cell(‘IPDO’,{bold:true,size:S.MD,align:AlignmentType.LEFT,w:C1}),
cell(‘Technical Summary Report’,{bold:true,size:S.MD,w:C2}),
cell(“Dr. Reddy’s”,{bold:true,size:S.SM,align:AlignmentType.RIGHT,w:C3}),
]});
const r2=new TableRow({children:[
cellML([`Title: ${title}`],{size:S.XS,colSpan:2,w:C1+C2}),
cellML([`Department: ${department}`,`Strength: ${strength}`,
`Market: ${market}`,`Protocol: ${protocol}`],{size:S.XS,w:C3}),
]});
const W3=[(C1+C2)/3,(C1+C2)/3,(C1+C2)-Math.round((C1+C2)/3)*2];
const r3=new TableRow({children:[
cellL(`Document No: ${document_no}`,{size:S.XS,w:W3[0]}),
cellL(`Product Name: ${product_name}`,{size:S.XS,w:W3[1]}),
cellL(`Dosage Form: ${dosage_form}   Version: ${version}`,{size:S.XS,w:W3[2]+C3}),
]});
const tbl=new Table({width:{size:CW,type:WidthType.DXA},
columnWidths:[C1,C2,C3],rows:[r1,r2,r3]});
return new Header({children:[tbl,blank()]});
}

function buildFooter(){
return new Footer({children:[new Paragraph({
alignment:AlignmentType.CENTER, spacing:{before:0,after:0},
children:[
new TextRun({text:’Page ‘,size:S.XS,font:F}),
new TextRun({children:[PageNumber.CURRENT],size:S.XS,font:F}),
new TextRun({text:’ of ’,size:S.XS,font:F}),
new TextRun({children:[PageNumber.TOTAL_PAGES],size:S.XS,font:F}),
],
})]});
}

// ── TITLE PAGE ───────────────────────────────────────────────────────────────
function buildTitlePage(meta){
const sop=meta.sop_format_number||’’;
const box=new Table({width:{size:CW,type:WidthType.DXA},columnWidths:[CW],
rows:[new TableRow({children:[new TableCell({
borders:bdrs(8), margins:cm(300,400,300,400),
children:[pC(meta.title||’’,true,S.LG), blank(),
pC(`SOP Format Number: ${sop}`,false,S.BODY)],
})]})]});
return [box,pageBreak()];
}

// ── TOC ──────────────────────────────────────────────────────────────────────
function buildTOC(tocEntries){
const def=[
{no:‘1’,title:‘Abstract’,page:‘3’},
{no:‘2’,title:‘Objective’,page:‘3’},
{no:‘3’,title:‘Details of the study location / testing location’,page:‘3’},
{no:‘4’,title:‘Background’,page:‘3’},
{no:‘5’,title:‘Drug product elemental impurity risk assessment’,page:‘5’},
{no:‘6’,title:‘Summary & Conclusion’,page:‘17’},
{no:‘7’,title:‘Reference’,page:‘19’},
{no:‘8’,title:‘List of Annexures’,page:‘19’},
{no:‘9’,title:‘Revision History’,page:‘19’},
];
const entries=(tocEntries&&tocEntries.length)?tocEntries:def;
const W=[600,CW-600-1000,1000];
const tbl=new Table({width:{size:CW,type:WidthType.DXA},columnWidths:W,rows:[
new TableRow({children:[
cell(‘S. No.’,{bold:true,fill:C.TH_LIGHT,w:W[0],size:S.SM}),
cell(‘Title’, {bold:true,fill:C.TH_LIGHT,w:W[1],size:S.SM}),
cell(‘Page#’, {bold:true,fill:C.TH_LIGHT,w:W[2],size:S.SM}),
]}),
…entries.map(e=>new TableRow({children:[
cell(e.no||’’,   {w:W[0],size:S.SM}),
cellL(e.title||’’,{w:W[1],size:S.SM}),
cell(e.page||’’, {w:W[2],size:S.SM}),
]})),
]});
return [pC(‘TABLE OF CONTENTS’,true,S.MD),tbl,pageBreak()];
}

// ── SECTIONS 1–4 ─────────────────────────────────────────────────────────────
function buildTextSections(txt){
const ch=[];
const sec=(n,title,content)=>{
ch.push(sHd(`${n}. ${title}`));
bodyParagraphs(content).forEach(pp=>ch.push(pp));
ch.push(blank());
};
sec(1,‘Abstract’,txt.abstract||’’);
sec(2,‘Objective’,txt.objective||’’);
sec(3,‘Details of the study location / testing location’,txt.study_location||‘NA’);
ch.push(sHd(‘4. Background:’));
bodyParagraphs(txt.background||’’).forEach(pp=>ch.push(pp));
ch.push(blank());
ch.push(pageBreak());
return ch;
}

// ── COMPOSITION TABLE ────────────────────────────────────────────────────────
function buildCompositionTable(sections){
const W=[Math.round(CW*0.40),Math.round(CW*0.12),Math.round(CW*0.16),
Math.round(CW*0.16),CW-Math.round(CW*0.40)-Math.round(CW*0.12)-Math.round(CW*0.16)*2];
const rows=[];
(sections||[]).forEach(sec=>{
rows.push(new TableRow({children:[new TableCell({
columnSpan:5,borders:bdrs(4),shading:shade(C.TH_BLUE),margins:cm(),
children:[p([run(sec.name||’’,true,S.SM)],AlignmentType.LEFT)],
})]}));
(sec.rows||[]).filter(Boolean).forEach(r=>rows.push(new TableRow({children:[
cellL(r.ingredient||r.name||’’,{w:W[0],size:S.SM}),
cell(r.status||r.compendial_status||’’,{w:W[1],size:S.SM}),
cell(String(r[‘40mg’]||r.amount_40mg||’’),{w:W[2],size:S.SM}),
cell(String(r[‘20mg’]||r.amount_20mg||’’),{w:W[3],size:S.SM}),
cell(String(r[‘10mg’]||r.amount_10mg||’’),{w:W[4],size:S.SM}),
]})));
});
const tbl=new Table({width:{size:CW,type:WidthType.DXA},columnWidths:W,rows:[
new TableRow({children:[
cell(‘Name of Ingredient’,{bold:true,fill:C.TH_LIGHT,w:W[0],size:S.SM}),
cell(‘Compendial\nStatus’,{bold:true,fill:C.TH_LIGHT,w:W[1],size:S.SM}),
cell(‘40 mg\nmg/unit’,    {bold:true,fill:C.TH_LIGHT,w:W[2],size:S.SM}),
cell(‘20 mg\nmg/unit’,    {bold:true,fill:C.TH_LIGHT,w:W[3],size:S.SM}),
cell(‘10 mg\nmg/unit’,    {bold:true,fill:C.TH_LIGHT,w:W[4],size:S.SM}),
]}),
…rows
]});
return [
sHd(‘5. Drug product elemental impurity risk assessment’),
p([run(‘Table 1: Quantitative and Qualitative Composition’,true,S.SM)],
AlignmentType.LEFT,40,20),
tbl, pageBreak(),
];
}

// ── FIGURE ───────────────────────────────────────────────────────────────────
function buildFigure(fig){
if(!fig||!fig.data_b64||fig.data_b64.length<100) return [];
let buf;
try{ buf=Buffer.from(fig.data_b64,‘base64’); if(buf.length<500) return []; }
catch(e){ return []; }
const type=(fig.media_type||’’).includes(‘jpeg’)?‘jpg’:‘png’;
const imgW=560, imgH=Math.round(imgW*0.60);
const img=new ImageRun({type,data:buf,transformation:{width:imgW,height:imgH}});
return [
p([run(fig.figure_label||‘Figure 1’,true,S.SM)],AlignmentType.LEFT,40,20),
new Paragraph({alignment:AlignmentType.CENTER,spacing:{before:40,after:40},children:[img]}),
blank(), pageBreak(),
];
}

// ── SOURCES + TABLE 2 ────────────────────────────────────────────────────────
function buildSourcesSection(txt,annexureList){
const ch=[];
[txt.sources_intro,txt.drug_substance_section,txt.excipient_intro]
.forEach(t=>{ if(t){ bodyParagraphs(t).forEach(pp=>ch.push(pp)); ch.push(blank()); }});

const W=[Math.round(CW*0.38),Math.round(CW*0.36),CW-Math.round(CW*0.38)-Math.round(CW*0.36)];
const tbl2=new Table({width:{size:CW,type:WidthType.DXA},columnWidths:W,rows:[
new TableRow({children:[
cell(‘Name of Excipient / Material’,{bold:true,fill:C.TH_LIGHT,w:W[0],size:S.SM}),
cell(‘Vendor’,                       {bold:true,fill:C.TH_LIGHT,w:W[1],size:S.SM}),
cell(‘Title of Annexure’,            {bold:true,fill:C.TH_LIGHT,w:W[2],size:S.SM}),
