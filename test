                step=0.001, format="%.3f", help="0 = auto (read from Excel if present).")
        with oc3:
            ov_dose_vol = st.number_input("Dose volume (mL)", min_value=0.0, value=0.0,
                step=0.01, help="0 = auto (parsed from ratio header).")

    can_parse = bool(inj_excel and inj_annx and inj_product and inj_doc_no)
    if st.button("🔎 Analyze inputs", type="primary", disabled=not can_parse):
        for _k in ("inj_docx_bytes","inj_report_ready","inj_parsed","inj_model",
                   "inj_comp","inj_annexure_data","inj_errors","inj_warnings",
                   "inj_traceability_csv"):
