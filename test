"""
residual_solvent.py — Residual Solvent Risk Assessment backend (USP <467> / ICH Q3C).

COMPLETELY ISOLATED from the Elemental Impurity (EI) workflow. This module does
NOT import or reuse EI element classes, ICH_PDE / ICH_Q3D constants, EI annexure
schema, EI mapping, EI 30%-PDE logic, or the EI renderer. It contains:

  • rs_excel_prompt() / parse_rs_excel(raw) — detailed + basic Excel parser with a
        daily-intake hierarchy that normalises everything to
        component_amount_in_maximum_dose_mg.
  • rs_annexure_prompt() / process_rs_annexure(obj) — solvent-declaration converter
        with a consistent top-level schema (never a bare list), evidence typing,
        ppm conversion, and material-name (not document-descriptor) extraction.
  • map_components_to_annexures(...) — general identity resolver (no product rules).
  • calculate_rs_exposures(...) — exposure = amount_mg × limit_ppm / 1e6.
  • validate_rs(...) — strict gate that prevents false compliance / false zeros.
  • build_rs_payload(...) — clean payload for generate_residual_solvent.js.

Exposure formula (NOT the EI formula):
    Daily Exposure (mg/day) = Amount in Maximum Dose (mg/day) × Limit (ppm) / 1,000,000
"""

from __future__ import annotations
import re
import json
import logging
from typing import Any, Dict, List, Optional, Tuple

import residual_solvent_master as RSM

logger = logging.getLogger(__name__)


# ── tiny self-contained helpers (no EI dependency) ────────────────────────────
def _s(v: Any) -> str:
    return str(v).strip() if v is not None else ""


def _f(v: Any, default: float = 0.0) -> float:
    if isinstance(v, (int, float)):
        return float(v)
    try:
        return float(re.sub(r"[^0-9.\-eE]", "", str(v)))
    except Exception:
        return default


def _num_or_none(v: Any) -> Optional[float]:
    s = _s(v)
    if not s:
        return None
    m = re.search(r"-?[0-9]*\.?[0-9]+", s.replace(",", ""))
    return float(m.group(0)) if m else None


def _seq_in(needle: List[str], haystack: List[str]) -> bool:
    """True if the token list `needle` appears as a contiguous run in `haystack`.
    Used for precise solvent-name matching so 'ethanol' does not match inside
    'methanol' (whole-token comparison, not substring)."""
    if not needle:
        return False
    n = len(needle)
    for i in range(0, len(haystack) - n + 1):
        if haystack[i:i + n] == needle:
            return True
    # single-token exact membership fallback
    if n == 1:
        return needle[0] in haystack
    return False


# ── Generic residual-solvent CATEGORY / declaration-scope filter (Red Flag 1) ─
# These are declaration scopes or category labels, NOT real solvent entities.
# They must never become calculation columns. They are kept as evidence /
# declaration_scope text only.
_SOLVENT_CATEGORY_PATTERNS = [
    r"^\s*class\s*[i1]{1,3}\b", r"^\s*class\s*[i1v]{1,4}\b",
    r"\bclass\s*1\b", r"\bclass\s*2\b", r"\bclass\s*3\b",
    r"\bclass\s*i\b", r"\bclass\s*ii\b", r"\bclass\s*iii\b",
    r"\borganic\s+volatile\s+impurit", r"\bovi\b",
    r"\bother\s+residual\s+solvent", r"^\s*residual\s+solvents?\s*$",
    r"\bich\s*q3c\b", r"\busp\s*<?\s*467\s*>?\b",
    r"solvents?\s+listed\s+in\s+usp", r"\bclass\s*1\s*,?\s*2",
    r"^\s*water\s*$", r"^\s*purified\s+water\s*$",
    r"\bvolatile\s+impurit", r"^\s*solvents?\s*$",
]
_SOLVENT_CATEGORY_RE = re.compile("|".join(_SOLVENT_CATEGORY_PATTERNS), re.IGNORECASE)


def is_generic_solvent_category(name: str) -> bool:
    """True when `name` is a declaration scope / category, not a real solvent."""
    s = _s(name).lower()
    if not s:
        return True
    return bool(_SOLVENT_CATEGORY_RE.search(s))


def rs_safe_json(text: str, want: str = "dict") -> Any:
    """Shape-aware JSON parse. Never lets a bare list become a dict-expecting
    value (the EI 'list has no attribute get' failure mode)."""
    default: Any = {} if want == "dict" else []
    if not text:
        return default
    parsed = None
    for fn in (lambda t: json.loads(t),
               lambda t: json.loads(t[t.find("{"):t.rfind("}") + 1]),
               lambda t: json.loads(t[t.find("["):t.rfind("]") + 1])):
        try:
            parsed = fn(text)
            break
        except Exception:
            parsed = None
    if parsed is None:
        return default
    if want == "dict" and isinstance(parsed, list):
        # Wrap a bare array so callers can still use .get()
        return {"extracted_items": parsed, "schema_repaired": True}
    if want == "dict" and not isinstance(parsed, dict):
        return default
    return parsed


