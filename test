import { useState, useRef } from 'react'

const SCENARIOS = [
  'MOLECULAR PROFILE',
  'IMPURITIES',
  'METHOD DEVELOPMENT',
  'TROUBLESHOOTING',
  'SOP DOCUMENTATION',
]

/**
 * PromptInput — shown during INPUT state and reused as the card shell
 * during DISSOLVING state.
 *
 * Props:
 *   onSubmit(text, rect)  — called when user clicks Reconstruct.
 *                           rect = sourceRect of the textarea area for the
 *                           SandDissolve canvas to use as particle origin.
 *   isDissolving          — when true shows the dissolving UI variation
 *   progressPercent       — 0-100 for the progress bar fill
 *   progressStatus        — cycling status text shown below the card
 */
export default function PromptInput({
  onSubmit,
  isDissolving = false,
  progressPercent = 0,
  progressStatus = '',
}) {
  const [value, setValue] = useState('')
  const textareaRef = useRef(null)
  const textareaWrapRef = useRef(null)

  const handleSubmit = () => {
    const trimmed = value.trim()
    if (!trimmed || isDissolving) return

    const rect = textareaWrapRef.current?.getBoundingClientRect() ?? null
    onSubmit(trimmed, rect)
  }

  const handleKeyDown = (e) => {
    if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) {
      handleSubmit()
    }
  }

  return (
    <div className="input-state">
      {/* Hero */}
      <div className="hero-area">
        <h1 className="hero-headline">Your prompt, perfected.</h1>
        <p className="hero-sub">
          Designed for Analytical Scientists. Type anything — even rough notes.
          Prompt Coach reconstructs it into precision.
        </p>
      </div>

      {/* Card */}
      <div className="input-card">
        {/* Progress bar — only visible when dissolving */}
        <div
          className="card-progress-bar"
          style={{ display: isDissolving ? 'block' : 'none' }}
        >
          <div
            className="card-progress-fill"
            style={{
              width: `${progressPercent}%`,
              transition:
                progressPercent === 0
                  ? 'none'
                  : progressPercent >= 100
                  ? 'width 200ms ease'
                  : 'width 2000ms ease-out',
            }}
          />
        </div>

        {/* Textarea area — captured by SandDissolve */}
        <div ref={textareaWrapRef} className="textarea-wrap">
          <textarea
            ref={textareaRef}
            className="prompt-textarea"
            placeholder="e.g. check my hplc method for impurities"
            value={value}
            onChange={(e) => setValue(e.target.value)}
            onKeyDown={handleKeyDown}
            disabled={isDissolving}
            aria-label="Enter your analytical science prompt"
          />
        </div>

        <div className="card-divider" />

        {/* Footer */}
        {!isDissolving ? (
          <div className="card-footer">
            <span className="card-hint">Be as vague or specific as you like</span>
            <button
              className="reconstruct-btn"
              onClick={handleSubmit}
              disabled={!value.trim()}
              aria-label="Reconstruct prompt"
            >
              RECONSTRUCT
            </button>
          </div>
        ) : (
          <div className="card-footer-dissolving">
            <span className="reconstructing-label">
              <span className="spinner" />
              Reconstructing...
            </span>
          </div>
        )}
      </div>

      {/* Status cycling — below card during dissolving */}
      {isDissolving && (
        <div className="status-cycling-wrap">
          <span className="status-cycling" key={progressStatus}>
            {progressStatus}
          </span>
        </div>
      )}

      {/* Scenario chips — only in normal input mode */}
      {!isDissolving && (
        <div className="scenario-chips" aria-hidden="true">
          {SCENARIOS.map((s) => (
            <span key={s} className="scenario-chip">{s}</span>
          ))}
        </div>
      )}
    </div>
  )
}
