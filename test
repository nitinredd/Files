import json
import logging
from dataclasses import dataclass, field
from typing import List, Dict, Any

from langchain.schema import HumanMessage, SystemMessage

logger = logging.getLogger(__name__)

TECHNIQUE_MAP = {
    "characterization": "CHAIN-OF-THOUGHT",
    "HPLC": "CHAIN-OF-THOUGHT",
    "impurities": "TREE-OF-THOUGHT",
    "troubleshooting": "MULTI-MODAL",
    "documentation": "ROLE-BASED",
    "SOP": "ROLE-BASED",
    "method_development": "CHAIN-OF-THOUGHT",
    "stability": "CHAIN-OF-THOUGHT",
    "dissolution": "CHAIN-OF-THOUGHT",
    "general": "CHAIN-OF-THOUGHT",
}


@dataclass
class PrincipleEngine:
    structural_rules: List[str] = field(default_factory=list)
    anti_patterns: List[str] = field(default_factory=list)
    style_constitution: Dict[str, Any] = field(default_factory=dict)
    intent_mappings: Dict[str, str] = field(default_factory=dict)
    loaded: bool = False


@dataclass
class IntentObject:
    domain: str
    task_type: str
    primary_intent: str
    implicit_constraints: List[str]
    missing_parameters: List[str]
    unique_payload: Dict[str, Any]
    confidence_score: float


def _strip_json_fences(text: str) -> str:
    text = text.strip()
    if text.startswith("```"):
        lines = text.split("\n")
        # Remove first line (```json or ```) and last line (```)
        inner = lines[1:-1] if lines[-1].strip() == "```" else lines[1:]
        text = "\n".join(inner)
    return text.strip()


class PromptCoachAgent:
    def __init__(self, chat_model, sample_prompts: List[Dict]):
        self.chat_model = chat_model
        self.sample_prompts = sample_prompts
        self.principle_engine = PrincipleEngine()

    async def initialize(self):
        """One-time curriculum extraction pass over the sample prompts."""
        logger.info("Initializing PromptCoachAgent — extracting principles from sample prompts...")

        prompts_text = "\n\n".join([
            f"SCENARIO: {p['scenario']}\nTECHNIQUE: {p['technique']}\nPROMPT:\n{p['prompt']}"
            for p in self.sample_prompts
        ])

        extraction_system = (
            "You are a prompt engineering analyst specializing in pharmaceutical analytical science. "
            "Your task is to extract meta-principles from a set of expert-level analytical science prompts. "
            "Return your analysis as a JSON object with exactly this structure:\n"
            '{\n'
            '  "structural_rules": ["rule1", "rule2"],\n'
            '  "anti_patterns": ["anti_pattern1"],\n'
            '  "style_constitution": {\n'
            '    "register": "...",\n'
            '    "precision_level": "...",\n'
            '    "regulatory_awareness": "...",\n'
            '    "domain_vocabulary": ["term1", "term2"]\n'
            '  },\n'
            '  "intent_mappings": {\n'
            '    "characterization": "...",\n'
            '    "troubleshooting": "...",\n'
            '    "documentation": "...",\n'
            '    "method_development": "..."\n'
            '  }\n'
            '}\n'
            "Return ONLY the JSON object, no other text."
        )

        extraction_human = (
            f"Analyze these five expert pharmaceutical analytical science prompts and extract the underlying principles:\n\n"
            f"{prompts_text}\n\n"
            "Extract:\n"
            "1. structural_rules: The universal skeleton of excellent analytical science prompts\n"
            "2. anti_patterns: What good prompts never do\n"
            "3. style_constitution: Register, precision level, regulatory awareness, and domain vocabulary\n"
            "4. intent_mappings: How different analytical intents map to output structures\n"
            "Return ONLY the JSON object."
        )

        try:
            response = await self.chat_model.ainvoke([
                SystemMessage(content=extraction_system),
                HumanMessage(content=extraction_human),
            ])
            content = _strip_json_fences(response.content)
            data = json.loads(content)
            self.principle_engine.structural_rules = data.get("structural_rules", [])
            self.principle_engine.anti_patterns = data.get("anti_patterns", [])
            self.principle_engine.style_constitution = data.get("style_constitution", {})
            self.principle_engine.intent_mappings = data.get("intent_mappings", {})
            self.principle_engine.loaded = True
            logger.info(
                f"Principle engine loaded: {len(self.principle_engine.structural_rules)} rules, "
                f"{len(self.principle_engine.anti_patterns)} anti-patterns"
            )
        except Exception as e:
            logger.error(f"Principle extraction failed: {e}. Loading fallback principles.")
            self._load_fallback_principles()

    def _load_fallback_principles(self):
        self.principle_engine.structural_rules = [
            "Always begin with a role definition: 'Act as [Expert Role]'",
            "Specify the analytical context: technique, analyte, dosage form",
            "Define the specific task with clear scope and boundaries",
            "Include methodological constraints: acceptance criteria, regulatory references (ICH, USP, GMP)",
            "Specify output format explicitly: headings, bullet points, tables, regulatory-ready",
        ]
        self.principle_engine.anti_patterns = [
            "Vague analyte references without chemical or structural context",
            "Missing dosage form specification for quantitative methods",
            "Absent acceptance criteria for system suitability or method validation",
            "Unspecified regulatory context (ICH guideline, USP chapter, GMP standard)",
            "Undefined output format or reporting structure",
        ]
        self.principle_engine.style_constitution = {
            "register": "Formal pharmaceutical scientific",
            "precision_level": "High — specific parameters, concentration ranges, regulatory references",
            "regulatory_awareness": "ICH guidelines, USP methods, GMP documentation standards",
            "domain_vocabulary": [
                "API", "DMF", "HPLC", "RP-HPLC", "USP", "ICH", "RSD",
                "system suitability", "impurity", "degradant", "tailing factor",
                "theoretical plates", "isocratic", "gradient", "C18",
            ],
        }
        self.principle_engine.intent_mappings = {
            "characterization": (
                "DMF-anchored structured output: Chemical identity & structure → "
                "Physicochemical properties → Solid state attributes → Chromatographic behaviour"
            ),
            "troubleshooting": (
                "Ranked root cause analysis: Visual Observations → Defect Interpretation → "
                "Likely Root Causes (Ranked) → Corrective Actions → Parameters to Change"
            ),
            "documentation": (
                "Regulatory-ready SOP template with acceptance criteria, calculations, "
                "recommended actions for failures, and ready-to-use results table"
            ),
            "method_development": (
                "Chromatographic parameter enumeration: column chemistry → mobile phase → "
                "gradient/isocratic → flow rate → temperature → injection volume → UV detection"
            ),
        }
        self.principle_engine.loaded = True
        logger.info("Fallback principles loaded.")

    async def reconstruct(self, query: str) -> Dict[str, Any]:
        intent = await self._extract_intent(query)

        if intent.confidence_score > 0.7:
            strategy = "PRINCIPLE_SYNTHESIS"
            reconstructed = await self._high_confidence_synthesis(query, intent)
        elif intent.confidence_score >= 0.4:
            strategy = "FRACTAL_DECOMPOSITION"
            reconstructed = await self._medium_confidence_synthesis(query, intent)
        else:
            strategy = "ANALOGICAL_BRIDGING"
            reconstructed = await self._low_confidence_synthesis(query, intent)

        technique = TECHNIQUE_MAP.get(intent.domain, "CHAIN-OF-THOUGHT")
        tokens_estimate = int(len(reconstructed.split()) * 1.35)

        return {
            "reconstructed_prompt": reconstructed,
            "confidence": round(intent.confidence_score, 2),
            "strategy_used": strategy.replace("_", " "),
            "technique": technique,
            "tokens_estimate": tokens_estimate,
        }

    async def _extract_intent(self, query: str) -> IntentObject:
        system = (
            "You are an intent extraction specialist for pharmaceutical analytical science prompts. "
            "Analyze the user's query and extract all signals, returning a JSON object:\n"
            "{\n"
            '  "domain": "HPLC|characterization|impurities|dissolution|SOP|stability|method_development|troubleshooting|general",\n'
            '  "task_type": "identify|quantify|troubleshoot|document|develop|understand",\n'
            '  "primary_intent": "one sentence description of what the user wants",\n'
            '  "implicit_constraints": ["constraint1"],\n'
            '  "missing_parameters": ["missing1"],\n'
            '  "unique_payload": {"analyte": "...", "technique": "...", "dosage_form": "..."},\n'
            '  "confidence_score": 0.0\n'
            "}\n"
            "Confidence scoring rules:\n"
            "- >0.7: Clear analytical domain, identifiable task, enough context to reconstruct precisely\n"
            "- 0.4-0.7: Recognizable domain but missing key parameters\n"
            "- <0.4: Very vague or ambiguous, requires first-principles reasoning\n"
            "Return ONLY the JSON object."
        )
        human = f'Extract intent from this analytical scientist query: "{query}"'

        try:
            response = await self.chat_model.ainvoke([
                SystemMessage(content=system),
                HumanMessage(content=human),
            ])
            content = _strip_json_fences(response.content)
            data = json.loads(content)
            return IntentObject(
                domain=data.get("domain", "general"),
                task_type=data.get("task_type", "understand"),
                primary_intent=data.get("primary_intent", query),
                implicit_constraints=data.get("implicit_constraints", []),
                missing_parameters=data.get("missing_parameters", []),
                unique_payload=data.get("unique_payload", {}),
                confidence_score=float(data.get("confidence_score", 0.5)),
            )
        except Exception as e:
            logger.error(f"Intent extraction failed: {e}")
            return IntentObject(
                domain="general",
                task_type="understand",
                primary_intent=query,
                implicit_constraints=[],
                missing_parameters=[],
                unique_payload={},
                confidence_score=0.3,
            )

    async def _high_confidence_synthesis(self, query: str, intent: IntentObject) -> str:
        rules_text = "\n".join(f"- {r}" for r in self.principle_engine.structural_rules)
        anti_text = "\n".join(f"- {p}" for p in self.principle_engine.anti_patterns)
        mappings_text = json.dumps(self.principle_engine.intent_mappings, indent=2)

        system = (
            "You are Prompt Coach — an autonomous prompt reconstruction engine for pharmaceutical analytical scientists.\n\n"
            "INTERNALIZED STRUCTURAL RULES:\n"
            f"{rules_text}\n\n"
            "ANTI-PATTERNS TO AVOID:\n"
            f"{anti_text}\n\n"
            "INTENT-TO-STRUCTURE MAPPINGS:\n"
            f"{mappings_text}\n\n"
            "RECONSTRUCTION RULES:\n"
            "1. Begin with a role definition: 'Act as [appropriate expert role]'\n"
            "2. Include all relevant analytical context (analyte, technique, dosage form)\n"
            "3. Be specific about methodology, acceptance criteria, regulatory references\n"
            "4. Specify output format explicitly (headings, bullet points, table, regulatory-ready)\n"
            "5. Do NOT ask clarifying questions — reconstruct based on all available signals\n"
            "6. Do NOT add explanations or preamble — return ONLY the reconstructed prompt\n"
            "7. Match the register of expert pharmaceutical analytical prompts exactly"
        )

        human = (
            f'Original query: "{query}"\n\n'
            f"Extracted intent:\n"
            f"- Domain: {intent.domain}\n"
            f"- Task type: {intent.task_type}\n"
            f"- Primary intent: {intent.primary_intent}\n"
            f"- Implicit constraints: {', '.join(intent.implicit_constraints) or 'none identified'}\n"
            f"- Missing parameters: {', '.join(intent.missing_parameters) or 'none'}\n"
            f"- Payload: {json.dumps(intent.unique_payload)}\n\n"
            "Reconstruct into an expert pharmaceutical analytical science prompt. Return ONLY the prompt."
        )

        response = await self.chat_model.ainvoke([
            SystemMessage(content=system),
            HumanMessage(content=human),
        ])
        return response.content.strip()

    async def _medium_confidence_synthesis(self, query: str, intent: IntentObject) -> str:
        system = (
            "You are Prompt Coach. Use fractal decomposition to reconstruct this analytical science query.\n"
            "Decompose into atomic components, handle each independently, then synthesize.\n"
            "Components: ROLE | CONTEXT | TASK | CONSTRAINTS | FORMAT\n"
            "Return ONLY the final reconstructed prompt — no explanations, no component labels."
        )
        human = (
            f'Query: "{query}"\n'
            f"Domain: {intent.domain} | Task type: {intent.task_type}\n"
            f"Intent: {intent.primary_intent}\n"
            f"Missing parameters: {', '.join(intent.missing_parameters) or 'none'}\n\n"
            "Decomposition:\n"
            "ROLE: What pharmaceutical analytical expert role fits this domain?\n"
            "CONTEXT: What analytical context can be inferred from the query?\n"
            "TASK: What specific analytical task needs to be accomplished?\n"
            "CONSTRAINTS: What methodological constraints apply (ICH, USP, GMP, acceptance criteria)?\n"
            "FORMAT: What structured output format is appropriate for this task type?\n\n"
            "Synthesize into a single expert pharmaceutical analytical science prompt. Return ONLY the prompt."
        )
        response = await self.chat_model.ainvoke([
            SystemMessage(content=system),
            HumanMessage(content=human),
        ])
        return response.content.strip()

    async def _low_confidence_synthesis(self, query: str, intent: IntentObject) -> str:
        system = (
            "You are Prompt Coach's Shadow Agent — activated for low-confidence reconstruction.\n\n"
            "Your approach:\n"
            "1. Map the vague query to the most structurally similar known analytical scenario\n"
            "2. Use first-principles reasoning about what an analytical scientist actually needs\n"
            "3. Make no domain assumptions — reason from the ground up\n"
            "4. Build the best possible expert prompt given minimal signal\n\n"
            "Known pharmaceutical analytical scenarios:\n"
            "- Molecular characterization (DMF-based profile)\n"
            "- Impurity profiling and degradant identification\n"
            "- HPLC method development (conditions, column, mobile phase)\n"
            "- Chromatographic troubleshooting (peak shape, resolution, retention)\n"
            "- SOP documentation (system suitability, method validation)\n"
            "- Stability studies (forced degradation, storage conditions)\n"
            "- Dissolution testing (apparatus, media, acceptance criteria)\n\n"
            "Return ONLY the reconstructed prompt. Do not explain your reasoning."
        )
        human = (
            f'Vague query: "{query}"\n'
            f"Best intent read: {intent.primary_intent}\n"
            f"Domain signal: {intent.domain}\n\n"
            "Reconstruct into the most useful expert pharmaceutical analytical science prompt possible. "
            "Return ONLY the prompt."
        )
        response = await self.chat_model.ainvoke([
            SystemMessage(content=system),
            HumanMessage(content=human),
        ])
        return response.content.strip()
