            # annexures: auto-dispatch behind ONE progress bar.
            _bar = st.progress(0, text="Analyzing files… 0%")
            annexures = _process_annexures_with_progress(
                "DEG & EG Risk Assessment", de_annx, _bar, 5, 100)
            _bar.empty()
            st.session_state["de_annexures"] = annexures
            _deg_debug_dump("debug_deg_eg_annexures.json", annexures)
            # Per-glycol evidence provenance — the only place the DEG vs EG
            # decision is auditable after the fact.
            for _a in annexures:
                if not isinstance(_a, dict):
                    continue
                _ev = _a.get("deg_eg_evidence") or {}
                logger.warning(
                    "[DEG/EG evidence] %s | DEG present=%s limit=%r source=%s "
                    "|| EG present=%s limit=%r source=%s || recoveries=%s "
                    "gc_notes=%s downgrades=%s",
                    _a.get("material_name") or _a.get("filename"),
                    _ev.get("deg_present"), _ev.get("deg_specification_limit"),
                    _ev.get("deg_source"),
                    _ev.get("eg_present"), _ev.get("eg_specification_limit"),
                    _ev.get("eg_source"),
                    _a.get("backstop_recoveries"), _a.get("guarantee_ceiling_notes"),
                    _a.get("consistency_downgrades"))

            _meta = _auto_meta(de_product, "", "DEG & EG Risk Assessment")
            _meta["title"] = ("Risk Assessment of Diethylene Glycol and "
                              "Ethylene Glycol")
