// ─── Helpers ─────────────────────────────────────────────────────────────────

function confidenceClass(score) {
  if (score >= 0.8) return 'meta-confidence-high'
  if (score >= 0.5) return 'meta-confidence-mid'
  return 'meta-confidence-low'
}

// ─── Component ───────────────────────────────────────────────────────────────

/**
 * ReconstructedPrompt — single-panel reveal card.
 *
 * Props:
 *   data           — { reconstructed_prompt, confidence, strategy_used, technique, is_conversational }
 *   error          — error string if reconstruction failed
 *   instant        — skip typewriter; show text immediately (for history replay)
 */
export default function ReconstructedPrompt({ data, error, instant = false }) {
  const [displayText, setDisplayText] = useState('')
  const [copied, setCopied] = useState(false)
  const timerRef = useRef(null)

  const fullText = data?.reconstructed_prompt ?? ''
  const isConversational = data?.is_conversational ?? false

  // Typewriter animation
  useEffect(() => {
    clearInterval(timerRef.current)
    if (!fullText) { setDisplayText(''); return }

    if (instant) {
      setDisplayText(fullText)
      return
    }

    setDisplayText('')
    let i = 0
    timerRef.current = setInterval(() => {
      i += 1
      setDisplayText(fullText.slice(0, i))
      if (i >= fullText.length) clearInterval(timerRef.current)
    }, TYPEWRITER_MS)

    return () => clearInterval(timerRef.current)
  }, [fullText, instant])

  const handleCopy = async () => {
    try {
      await navigator.clipboard.writeText(fullText)
    } catch {
      const el = document.createElement('textarea')
      el.value = fullText
      el.style.position = 'fixed'
      el.style.opacity = '0'
      document.body.appendChild(el)
      el.select()
      document.execCommand('copy')
      document.body.removeChild(el)
    }
    setCopied(true)
    setTimeout(() => setCopied(false), 2000)
  }

  const confidencePct = data ? Math.round((data.confidence ?? 0) * 100) : null
  const strategy = data?.strategy_used ?? ''
  const technique = data?.technique ?? ''

  return (
    <div className="reveal-panel">
      {/* ── Header ── */}
      <div className="reveal-panel-header">
        <div className="reveal-panel-title">
          <span className="reveal-panel-label">
            {isConversational ? 'SYSTEM RESPONSE' : 'RECONSTRUCTED PROMPT'}
          </span>
        </div>

        {!error && fullText && !isConversational && (
          <div className="copy-wrap">
            {copied && <span className="copy-tooltip">COPIED</span>}
            <button
              className="copy-btn"
              onClick={handleCopy}
              aria-label="Copy to clipboard"
            >
              <CopyIcon />
            </button>
          </div>
        )}
      </div>

      {/* ── Body ── */}
      <div className="reveal-panel-body">
        {error ? (
          <div className="reveal-error">
            <span className="reveal-error-label">RECONSTRUCTION FAILED</span>
            <p className="reveal-error-detail">{error}</p>
          </div>
        ) : (
          <p
            className={`reveal-text ${isConversational ? 'reveal-text-conversational' : ''}`}
            aria-live={instant ? undefined : 'polite'}
          >
            {displayText}
            {!instant && displayText.length < fullText.length && fullText.length > 0 && (
              <span className="typewriter-cursor" aria-hidden="true" />
            )}
          </p>
        )}
      </div>

      {/* ── Metadata chips — only for analytical reconstructions ── */}
      {!error && !isConversational && confidencePct !== null && (
        <div className="reveal-panel-meta">
          <span className={`meta-chip ${confidenceClass(data.confidence)}`}>
            {confidencePct}% CONFIDENCE
          </span>
          {strategy && (
            <span className="meta-chip meta-strategy">{strategy}</span>
          )}
          {technique && (
            <span className="meta-chip meta-technique">{technique}</span>
          )}
        </div>
      )}
    </div>
  )
}
