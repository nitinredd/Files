_GENERATION_PROMPT = """You are Analytical AI Expert, a precise HPLC pharmaceutical knowledge assistant.

Given a question and numbered reference paragraphs from HPLC textbooks:
- Answer using ONLY information from the provided paragraphs
- Every factual claim MUST cite a specific paragraph ID from context
- Do NOT invent anything not present in the paragraphs
- If evidence is insufficient, say so explicitly
- Be precise -- audience is pharmaceutical analytical chemistry professionals

Respond ONLY with valid JSON:
{
  "answer_text": "Complete technical answer in clear prose",
  "claims": [
    {
      "claim": "One specific factual statement",
      "source_paragraph_id": "exact_paragraph_id_from_context",
      "reasoning": "Why this paragraph supports this claim"
    }
  ]
}"""


def _build_context(paragraphs: List[Dict]) -> str:
    parts = []
    for i, para in enumerate(paragraphs):
        label = "[graph-expanded]" if para.get("source") == "graph" else ""
        parts.append(
            f"[PARAGRAPH {i+1}] {label}\n"
            f"ID: {para['paragraph_id']}\n"
            f"Source: {para['doc_id']}, Page {para['page_num']}\n"
            f"Text: {para['text']}\n"
        )
    return "\n".join(parts)


def generate_answer(llm, query: str, paragraphs: List[Dict], mode: str = "slm") -> Dict:
    if not paragraphs:
        return {"answer_text": "No relevant paragraphs found in corpus.", "claims": []}

    user_message = f"Question: {query}\n\nReference Paragraphs:\n{_build_context(paragraphs[:15])}"

    if mode == "hybrid":
        return _generate_azure(user_message)
    return _generate_local(llm, user_message)


def _generate_local(llm, user_message: str) -> Dict:
    try:
        response = llm.create_chat_completion(
            messages=[
                {"role": "system", "content": _GENERATION_PROMPT},
                {"role": "user", "content": user_message}
            ],
            max_tokens=PHI4_MAX_TOKENS, temperature=PHI4_TEMPERATURE,
            response_format={"type": "json_object"}
        )
        parsed = json.loads(response["choices"][0]["message"]["content"])
        return {"answer_text": parsed.get("answer_text", ""), "claims": parsed.get("claims", [])}
    except Exception as e:
        logger.error(f"Local generation error: {e}")
        return {"answer_text": f"Generation error: {str(e)}", "claims": []}


def _generate_azure(user_message: str) -> Dict:
    try:
        from openai import AzureOpenAI
        client = AzureOpenAI(
            api_key=AZURE_OPENAI_API_KEY, azure_endpoint=AZURE_OPENAI_ENDPOINT,
            api_version=AZURE_OPENAI_API_VERSION
        )
        response = client.chat.completions.create(
            model=AZURE_OPENAI_DEPLOYMENT,
            messages=[
                {"role": "system", "content": _GENERATION_PROMPT},
                {"role": "user", "content": user_message}
            ],
            max_tokens=800, temperature=0.1,
            response_format={"type": "json_object"}
        )
        parsed = json.loads(response.choices[0].message.content)
        return {"answer_text": parsed.get("answer_text", ""), "claims": parsed.get("claims", [])}
    except Exception as e:
        logger.error(f"Azure generation error: {e}")
        return {"answer_text": f"Azure error: {str(e)}", "claims": []}


# ═══════════════════════════════════════════════════════════════
# NLI VERIFIER — DeBERTa-v3-large
# ═══════════════════════════════════════════════════════════════

_NLI_LABELS = ["contradiction", "entailment", "neutral"]


def nli_verify(nli_model, claim: str, source_paragraph: str) -> Dict:
    """
    CRITICAL: input order is (source_paragraph, claim) = (premise, hypothesis).
    Reversing this silently inverts all verification results.
    """
    cache_key = hashlib.md5(f"{claim}|||{source_paragraph}".encode()).hexdigest()
    cached = db_get_cached_claim(cache_key)
    if cached:
        return {"verdict": cached["verdict"], "confidence": cached["confidence"],
                "scores": {}, "cached": True}

    scores = nli_model.predict([(source_paragraph, claim)])
    row = scores[0] if scores.ndim == 2 else scores   # predict() returns (1, 3) for one pair
    scores_dict = {_NLI_LABELS[i]: float(row[i]) for i in range(3)}
    max_label = max(scores_dict, key=scores_dict.get)
    max_score = scores_dict[max_label]

    if max_label == "entailment" and max_score >= ENTAILMENT_THRESHOLD:
        verdict = "entailed"
    elif max_label == "contradiction" and max_score >= CONTRADICTION_THRESHOLD:
        verdict = "contradicted"
    else:
        verdict = "neutral"

    db_cache_claim(cache_key, verdict, max_score)
    return {"verdict": verdict, "confidence": max_score, "scores": scores_dict, "cached": False}


# ═══════════════════════════════════════════════════════════════
# 3-TIER VERIFICATION FIREWALL
# ═══════════════════════════════════════════════════════════════

class VerificationResult:
    def __init__(self, claim: Dict, tier_reached: int, verdict: str,
                 confidence: float, source_text: str = "", reason: str = ""):
        self.claim_text = claim.get("claim", "")
        self.source_paragraph_id = claim.get("source_paragraph_id", "")
        self.tier_reached = tier_reached
        self.verdict = verdict
        self.nli_verdict = ""
        self.confidence = confidence
        self.source_text = source_text
        self.reason = reason


def verify_claim(nli_model, claim: Dict) -> VerificationResult:
    paragraph_id = claim.get("source_paragraph_id", "")
    claim_text = claim.get("claim", "")

    # Tier 1: existence check
    paragraph = db_get_paragraph(paragraph_id)
    if paragraph is None:
        return VerificationResult(
            claim, tier_reached=1, verdict="rejected", confidence=0.0,
            reason=f"Paragraph ID '{paragraph_id}' not found in corpus"
        )

    source_text = paragraph["text"]

    # Tier 2: NLI entailment check
    nli_result = nli_verify(nli_model, claim_text, source_text)
    nli_verdict = nli_result["verdict"]
    confidence = nli_result["confidence"]

    if nli_verdict in ("contradicted", "neutral"):
        label = "CONTRADICTED" if nli_verdict == "contradicted" else "NOT SUPPORTED"
        result = VerificationResult(
            claim, tier_reached=2, verdict="rejected", confidence=confidence,
            source_text=source_text,
            reason=f"Claim is {label} by source paragraph ({confidence:.1%} confidence)"
        )
        result.nli_verdict = nli_verdict
        return result

    # Tier 3: passed
    result = VerificationResult(
        claim, tier_reached=3, verdict="verified", confidence=confidence,
        source_text=source_text, reason=f"Entailed with {confidence:.1%} confidence"
    )
    result.nli_verdict = nli_verdict
    return result


def verify_all_claims(nli_model, claims: List[Dict]) -> List[VerificationResult]:
    return [verify_claim(nli_model, c) for c in claims]


def assemble_response(answer_text: str, claims: List[Dict],
                      verification_results: List[VerificationResult]) -> Dict:
    verified = [r for r in verification_results if r.verdict == "verified"]
    rejected = [r for r in verification_results if r.verdict == "rejected"]

    if len(verified) == 0 and len(claims) > 0:
        return {
            "type": "refusal", "answer": None,
            "message": (
                "I cannot verify any claims from this query against the available textbooks. "
                "The retrieved paragraphs do not sufficiently support a complete answer."
            ),
            "verified_claims": [], "rejected_claims": verification_results
        }

    return {
        "type": "answer", "answer": answer_text,
        "verified_claims": verified, "rejected_claims": rejected,
        "verification_ratio": f"{len(verified)}/{len(claims)} claims verified"
    }


# ═══════════════════════════════════════════════════════════════
# INGESTION PIPELINE
# ═══════════════════════════════════════════════════════════════

def ingest_pdf(pdf_path: Path, neo4j: Neo4jClient,
               progress_callback: Optional[Callable] = None) -> Dict:
    """
    Stage 1: PDF -> SQLite -> Neo4j paragraph nodes only.
    Concept extraction and FAISS build happen separately after all books are loaded.
    Resumable: skips already-ingested documents automatically.
    """
    def progress(step, pct, detail=""):
        if progress_callback:
            progress_callback(step, pct, detail)
        logger.info(f"[{pct:.0%}] {step} {detail}")

    doc_id = pdf_path.stem

    if is_document_ingested(doc_id):
        return {"success": True, "skipped": True, "filename": pdf_path.name}

    progress("Extracting PDF text...", 0.10)
    pages = extract_pdf(pdf_path)
    if not pages:
        return {"success": False, "filename": pdf_path.name, "error": "No text extracted from PDF"}
    progress("PDF extraction complete", 0.25, f"-> {len(pages)} pages")

    progress("Chunking into paragraphs...", 0.30)
    paragraphs = chunk_document(pages)
    if not paragraphs:
        return {"success": False, "filename": pdf_path.name, "error": "No paragraphs generated"}
    progress("Chunking complete", 0.50, f"-> {len(paragraphs)} paragraphs from {len(pages)} pages")

    progress("Storing paragraphs in database...", 0.55)
    stored_count = sum(1 for p in paragraphs if db_store_paragraph(p))
    progress("Database storage complete", 0.70, f"-> {stored_count}/{len(paragraphs)} stored")

    if neo4j.is_connected:
        progress("Creating Neo4j paragraph nodes...", 0.75)
        for para in paragraphs:
            neo4j.store_paragraph(para.paragraph_id, para.doc_id, para.page_num, para.text[:200])
        progress("Neo4j nodes created", 0.90, f"-> {stored_count} paragraph nodes")

    db_store_document(doc_id, pdf_path.name, len(pages), stored_count)
    mark_document_ingested(doc_id, pdf_path.name, len(pages), stored_count)

    progress("Ingestion complete!", 1.0, f"-> {stored_count} paragraphs stored in SQLite + Neo4j")

    return {
        "success": True, "skipped": False, "filename": pdf_path.name,
        "pages": len(pages), "paragraphs": stored_count
    }


