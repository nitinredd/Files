# PAYLOAD BUILDER (matches generate_deg_eg.js)
# ════════════════════════════════════════════════════════════════════════════
def _derive_strength_from_composition(composition: Dict) -> str:
    """Build a strength label from the composition's strength columns
    (e.g. '40 mg / 20 mg / 10 mg')."""
    cols = composition.get("comp_columns", []) or []
    strengths = [c for c in cols if re.search(r"\d\s*(mg|mcg|µg|g|%)", _s(c),
                                              re.IGNORECASE)]
    return " / ".join(strengths) if strengths else ""


def build_deg_eg_payload(meta: Dict, composition: Dict, assessment: Dict,
                         text_sections: Dict, validation: Dict = None) -> Dict:
    validation = validation or {}

    # Auto-fill strength from composition strength columns if not provided.
    strength = _s(meta.get("strength")) or _derive_strength_from_composition(composition)

    # Auto-append product name to a generic-only title.
    product = _s(meta.get("product_name"))
    title = _s(meta.get("title")) or ("Risk Assessment of Diethylene Glycol and "
                                      "Ethylene Glycol")
    if product and product.lower() not in title.lower():
        title = f"{title} for {product}"

    # Ensure Change History renders in the body (Section 8): default one row.
    revision_history = meta.get("revision_history") or []
    if not revision_history:
        doc_no = _s(meta.get("document_no"))
        ver = _s(meta.get("version")) or "1.0, CURRENT"
        revision_history = [{
            "document_version": (f"{doc_no} / {ver}" if doc_no else ver),
            "changes": "New document. First issue.",
        }]

    return {
        "meta": {
            "product_name": product,
            "dosage_form": meta.get("dosage_form", ""),
            "strength": strength,
            "market": meta.get("market", ""),
            "department": meta.get("department", "FR&D"),
            "document_no": meta.get("document_no", ""),
            "version": meta.get("version", "1.0, CURRENT"),
            "protocol": meta.get("protocol", "NA"),
            "sop_format_number": meta.get("sop_format_number", ""),
            "title": title,
            "approved_date": meta.get("approved_date", ""),
        },
        "text_sections": text_sections,
        "composition": composition.get("composition", []),
        "comp_columns": composition.get("comp_columns", []),
        "composition_caption": "Table 1: Qualitative and Quantitative composition",
        "assessment_table": assessment.get("assessment_table", []),
        "assessment_caption": ("Table 2: Assessment of Diethylene Glycol and "
                               "Ethylene Glycol in the input API and Excipients"),
        "detail_tables": assessment.get("detail_tables", []),
        "revision_history": revision_history,
        "signatures": meta.get("signatures", []),
        # ── audit channels — all "_" prefixed so the JS renderer ignores them.
        # Never lands in the rendered document. Kept for internal telemetry only.
        "_verification_audit": {
            "conclusion_status": validation.get("conclusion_status", ""),
            "validation_warnings": validation.get("warnings", []),
            "manual_review_items": validation.get("manual_review_items", []),
            "unmapped_materials": validation.get("unmapped_materials", []),
        },
        # Internal-only cluster mapping (never rendered; no visible UI panel per
        # the DocGen UI-rebuild precedence).
        "_cluster_audit": assessment.get("_cluster_audit", []),
    }
