# ─── Conversational detection ────────────────────────────────────────────────

_CONVERSATIONAL_PATTERNS = [
    r"^(hello|hi|hey|greetings|howdy|hiya|sup|yo|good\s*(morning|afternoon|evening))\b",
    r"^(help|test|testing|ping)\s*[!?.]*$",
    r"(what can you|what do you|how do you|who are you|what is this|how does this|what is prompt|tell me about prompt|explain prompt)",
    r"^(what|how|tell me about|explain).{0,40}(yourself|this tool|this app|prompt coach)\b",
]

CONVERSATIONAL_RESPONSE = (
    "Prompt Coach is active.\n\n"
    "I reconstruct vague or incomplete queries into precision expert prompts for pharmaceutical "
    "analytical scientists. I am trained on five analytical science scenarios:\n\n"
    "1. Molecular Profile Understanding — comprehensive API characterisation from DMF or public sources, "
    "covering chemical identity, physicochemical properties, solid state attributes, and chromatographic behaviour\n\n"
    "2. Impurity and Degradant Identification — process impurity and degradant profiling with structural class, "
    "RP-HPLC retention behaviour, and control strategy recommendations\n\n"
    "3. Analytical Method Development — HPLC-UV conditions, column chemistry, mobile phase composition, "
    "gradient design, flow rate, and UV detection wavelength selection\n\n"
    "4. Chromatographic Troubleshooting — visual chromatogram analysis with ranked root cause assessment, "
    "corrective actions, and parameter change recommendations\n\n"
    "5. SOP Documentation — regulatory-ready system suitability templates with acceptance criteria, "
    "calculations, and results tables aligned with ICH and USP standards\n\n"
    "Type any analytical science query — rough notes, incomplete thoughts, or precise specifications — "
    "and I will reconstruct it into a structured, regulatory-aware expert prompt."
)


def _is_conversational(query: str) -> bool:
    """Detect greetings, meta-questions, and off-topic inputs."""
    q = query.lower().strip().rstrip("!?.,;: ")
    words = q.split()

    # Short greetings / meta (1–3 words)
    if len(words) <= 3:
        openers = {
            "hello", "hi", "hey", "greetings", "howdy", "yo", "sup", "hiya",
            "help", "test", "testing", "ping", "check",
        }
        if words and words[0] in openers:
            return True

    for pattern in _CONVERSATIONAL_PATTERNS:
        if re.search(pattern, q):
            return True

    return False


# ─── Markdown stripping ──────────────────────────────────────────────────────

def strip_markdown(text: str) -> str:
    """
    Remove common markdown formatting artifacts from LLM output.
    Preserves natural paragraph structure, numbered lists, and hyphen bullets.
    """
    # Headers: ## Header → Header (preserve the text)
    text = re.sub(r"^#{1,6}\s+", "", text, flags=re.MULTILINE)
    # Bold: **text** → text
    text = re.sub(r"\*\*(.+?)\*\*", r"\1", text, flags=re.DOTALL)
    # Bold: __text__ → text
    text = re.sub(r"__(.+?)__", r"\1", text, flags=re.DOTALL)
    # Italic: *text* → text (conservative — avoids stripping % or math *)
    text = re.sub(r"(?<!\*)\*([^\*\n]{1,200}?)\*(?!\*)", r"\1", text)
    # Italic: _text_ → text (word-boundary aware)
    text = re.sub(r"(?<!\w)_([^_\n]{1,200}?)_(?!\w)", r"\1", text)
    # Em-dash bullets at line start: — item → - item
    text = re.sub(r"^—\s+", "- ", text, flags=re.MULTILINE)
    # Horizontal rules
    text = re.sub(r"^\s*[-*_]{3,}\s*$", "", text, flags=re.MULTILINE)
    # Collapse 3+ consecutive newlines → 2
    text = re.sub(r"\n{3,}", "\n\n", text)
    return text.strip()


# ─── Principle Engine ────────────────────────────────────────────────────────

NO_MARKDOWN_INSTRUCTION = (
    "Write in clean plain text only. Do not use markdown formatting of any kind: "
    "no asterisks for bold or italic, no # headers, no em-dashes (—) as list markers, "
    "no horizontal rules (---). "
    "Use numbered lists (1. 2. 3.) or hyphen bullets (- ) for structure. "
    "Use clear heading words followed by a colon rather than markdown headers."
)


@dataclass
class PrincipleEngine:
    structural_rules: List[str] = field(default_factory=list)
    anti_patterns: List[str] = field(default_factory=list)
    style_constitution: Dict[str, Any] = field(default_factory=dict)
    intent_mappings: Dict[str, str] = field(default_factory=dict)
    loaded: bool = False


@dataclass
class IntentObject:
    domain: str
    task_type: str
    primary_intent: str
    implicit_constraints: List[str]
    missing_parameters: List[str]
    unique_payload: Dict[str, Any]
    confidence_score: float


def _strip_json_fences(text: str) -> str:
    text = text.strip()
    if text.startswith("```"):
        lines = text.split("\n")
        inner = lines[1:-1] if lines[-1].strip() == "```" else lines[1:]
        text = "\n".join(inner)
    return text.strip()


# ─── Agent ───────────────────────────────────────────────────────────────────

class PromptCoachAgent:
    def __init__(self, chat_model, sample_prompts: List[Dict]):
        self.chat_model = chat_model
        self.sample_prompts = sample_prompts
        self.principle_engine = PrincipleEngine()

    async def initialize(self):
        logger.info("Initializing PromptCoachAgent — extracting curriculum from sample prompts...")

        prompts_text = "\n\n".join([
            f"SCENARIO: {p['scenario']}\nTECHNIQUE: {p['technique']}\nPROMPT:\n{p['prompt']}"
            for p in self.sample_prompts
        ])

        extraction_system = (
            "You are a prompt engineering analyst specializing in pharmaceutical analytical science. "
            "Extract meta-principles from the sample prompts and return a JSON object:\n"
            '{\n'
            '  "structural_rules": ["rule1", ...],\n'
            '  "anti_patterns": ["anti1", ...],\n'
            '  "style_constitution": {"register": "...", "precision_level": "...", '
            '"regulatory_awareness": "...", "domain_vocabulary": ["term1", ...]},\n'
            '  "intent_mappings": {"characterization": "...", "troubleshooting": "...", '
            '"documentation": "...", "method_development": "..."}\n'
            "}\nReturn ONLY the JSON object."
        )

        extraction_human = (
            f"Analyze these expert pharmaceutical analytical science prompts:\n\n{prompts_text}\n\n"
            "Extract structural rules, anti-patterns, style constitution, and intent-to-structure mappings. "
            "Return ONLY the JSON object."
        )

        try:
            response = await self.chat_model.ainvoke([
                SystemMessage(content=extraction_system),
                HumanMessage(content=extraction_human),
            ])
            content = _strip_json_fences(response.content)
            data = json.loads(content)
            self.principle_engine.structural_rules = data.get("structural_rules", [])
            self.principle_engine.anti_patterns = data.get("anti_patterns", [])
            self.principle_engine.style_constitution = data.get("style_constitution", {})
            self.principle_engine.intent_mappings = data.get("intent_mappings", {})
            self.principle_engine.loaded = True
            logger.info(
                f"Principle engine loaded: {len(self.principle_engine.structural_rules)} rules, "
                f"{len(self.principle_engine.anti_patterns)} anti-patterns"
            )
        except Exception as e:
            logger.error(f"Curriculum extraction failed: {e}. Loading fallback principles.")
            self._load_fallback_principles()

    def _load_fallback_principles(self):
        self.principle_engine.structural_rules = [
            "Begin with a clear role definition: 'Act as [Expert Role]'",
            "Specify the analytical context: technique, analyte, dosage form",
            "Define the specific task with clear scope and deliverables",
            "Include methodological constraints: acceptance criteria, regulatory references (ICH, USP, GMP)",
            "Specify the output format explicitly: structure, headings, tables, regulatory-ready",
        ]
        self.principle_engine.anti_patterns = [
            "Vague analyte references without chemical or structural context",
            "Missing dosage form specification for quantitative methods",
            "Absent acceptance criteria for system suitability or method validation tasks",
            "Unspecified regulatory context (ICH guideline, USP chapter, GMP standard)",
            "Undefined output format or reporting structure",
        ]
        self.principle_engine.style_constitution = {
            "register": "Formal pharmaceutical scientific",
            "precision_level": "High — specific parameters, concentrations, regulatory references",
            "regulatory_awareness": "ICH guidelines, USP methods, GMP documentation standards",
            "domain_vocabulary": [
                "API", "DMF", "HPLC", "RP-HPLC", "USP", "ICH", "RSD",
                "system suitability", "impurity", "degradant", "tailing factor",
                "theoretical plates", "isocratic", "gradient", "C18",
            ],
        }
        self.principle_engine.intent_mappings = {
            "characterization": (
                "DMF-anchored structured output: Chemical identity and structure, "
                "Physicochemical properties, Solid state attributes, Chromatographic behaviour"
            ),
            "troubleshooting": (
                "Ranked root cause analysis: Visual Observations, Defect Interpretation, "
                "Likely Root Causes (ranked), Corrective Actions, Parameters to Change"
            ),
            "documentation": (
                "Regulatory-ready SOP with acceptance criteria, calculations, "
                "failure handling, and ready-to-use results table"
            ),
            "method_development": (
                "Chromatographic parameter enumeration: column chemistry, mobile phase, "
                "gradient or isocratic conditions, flow rate, column temperature, "
                "injection volume, UV detection wavelength"
            ),
        }
        self.principle_engine.loaded = True
        logger.info("Fallback principles loaded.")

    async def reconstruct(self, query: str) -> Dict[str, Any]:
        # Conversational / off-topic input — fast path, no LLM call
        if _is_conversational(query):
            return {
                "reconstructed_prompt": CONVERSATIONAL_RESPONSE,
                "confidence": 1.0,
                "strategy_used": "CONVERSATIONAL",
                "technique": "DIRECT",
                "tokens_estimate": len(CONVERSATIONAL_RESPONSE.split()),
                "is_conversational": True,
            }

        intent = await self._extract_intent(query)

        if intent.confidence_score > 0.7:
            strategy = "PRINCIPLE SYNTHESIS"
            reconstructed = await self._high_confidence_synthesis(query, intent)
        elif intent.confidence_score >= 0.4:
            strategy = "FRACTAL DECOMPOSITION"
            reconstructed = await self._medium_confidence_synthesis(query, intent)
        else:
            strategy = "ANALOGICAL BRIDGING"
            reconstructed = await self._low_confidence_synthesis(query, intent)

        reconstructed = strip_markdown(reconstructed)
        technique = TECHNIQUE_MAP.get(intent.domain, "CHAIN-OF-THOUGHT")
        tokens_estimate = int(len(reconstructed.split()) * 1.35)

        return {
            "reconstructed_prompt": reconstructed,
            "confidence": round(intent.confidence_score, 2),
            "strategy_used": strategy,
            "technique": technique,
            "tokens_estimate": tokens_estimate,
            "is_conversational": False,
        }

    async def _extract_intent(self, query: str) -> IntentObject:
        system = (
            "You are an intent extraction specialist for pharmaceutical analytical science prompts. "
            "Analyze the user query and extract all signals, returning a JSON object:\n"
            '{\n'
            '  "domain": "HPLC|characterization|impurities|dissolution|SOP|stability|method_development|troubleshooting|general",\n'
            '  "task_type": "identify|quantify|troubleshoot|document|develop|understand",\n'
            '  "primary_intent": "one sentence description",\n'
            '  "implicit_constraints": ["constraint1"],\n'
            '  "missing_parameters": ["missing1"],\n'
            '  "unique_payload": {"analyte": "...", "technique": "...", "dosage_form": "..."},\n'
            '  "confidence_score": 0.0\n'
            "}\n"
            "Confidence: >0.7 = clear domain and task; 0.4-0.7 = recognisable but incomplete; <0.4 = very vague.\n"
            "Return ONLY the JSON object."
        )
        human = f'Extract intent from: "{query}"'

        try:
            response = await self.chat_model.ainvoke([
                SystemMessage(content=system),
                HumanMessage(content=human),
            ])
            content = _strip_json_fences(response.content)
            data = json.loads(content)
            return IntentObject(
                domain=data.get("domain", "general"),
                task_type=data.get("task_type", "understand"),
                primary_intent=data.get("primary_intent", query),
                implicit_constraints=data.get("implicit_constraints", []),
                missing_parameters=data.get("missing_parameters", []),
                unique_payload=data.get("unique_payload", {}),
                confidence_score=float(data.get("confidence_score", 0.5)),
            )
        except Exception as e:
            logger.error(f"Intent extraction failed: {e}")
            return IntentObject(
                domain="general",
                task_type="understand",
                primary_intent=query,
                implicit_constraints=[],
                missing_parameters=[],
                unique_payload={},
                confidence_score=0.3,
            )

    def _base_system(self, extra: str = "") -> str:
        rules_text = "\n".join(f"- {r}" for r in self.principle_engine.structural_rules)
        anti_text = "\n".join(f"- {p}" for p in self.principle_engine.anti_patterns)
        return (
            "You are Prompt Coach — an autonomous prompt reconstruction engine for pharmaceutical analytical scientists.\n\n"
            f"STRUCTURAL RULES:\n{rules_text}\n\n"
            f"ANTI-PATTERNS TO AVOID:\n{anti_text}\n\n"
            f"FORMATTING RULE: {NO_MARKDOWN_INSTRUCTION}\n\n"
            "OUTPUT RULE: Return ONLY the reconstructed prompt. No preamble, no explanation, no labels.\n"
            f"{extra}"
        )

    async def _high_confidence_synthesis(self, query: str, intent: IntentObject) -> str:
        mappings_text = "\n".join(
            f"- {k}: {v}" for k, v in self.principle_engine.intent_mappings.items()
        )
        system = self._base_system(
            f"INTENT-TO-STRUCTURE MAPPINGS:\n{mappings_text}\n\n"
            "APPROACH: Direct principle-based synthesis. Apply structural rules precisely."
        )
        human = (
            f'Original query: "{query}"\n\n'
            f"Domain: {intent.domain} | Task: {intent.task_type}\n"
            f"Intent: {intent.primary_intent}\n"
            f"Implicit constraints: {', '.join(intent.implicit_constraints) or 'none'}\n"
            f"Missing parameters: {', '.join(intent.missing_parameters) or 'none'}\n"
            f"Payload: {json.dumps(intent.unique_payload)}\n\n"
            "Reconstruct into a complete expert pharmaceutical analytical science prompt. "
            "Return ONLY the prompt."
        )
        response = await self.chat_model.ainvoke([
            SystemMessage(content=system),
            HumanMessage(content=human),
        ])
        return response.content.strip()

    async def _medium_confidence_synthesis(self, query: str, intent: IntentObject) -> str:
        system = self._base_system(
            "APPROACH: Fractal decomposition. Resolve each component independently "
            "(role, context, task, constraints, format) then synthesise into a single expert prompt."
        )
        human = (
            f'Query: "{query}"\n'
            f"Domain: {intent.domain} | Task: {intent.task_type}\n"
            f"Intent: {intent.primary_intent}\n"
            f"Missing: {', '.join(intent.missing_parameters) or 'none'}\n\n"
            "Decompose and synthesise:\n"
            "ROLE: appropriate pharmaceutical analytical expert title\n"
            "CONTEXT: all inferable analytical context (technique, analyte, dosage form)\n"
            "TASK: specific deliverable with scope\n"
            "CONSTRAINTS: applicable ICH/USP/GMP standards and acceptance criteria\n"
            "FORMAT: structured output specification\n\n"
            "Return ONLY the final synthesised prompt."
        )
        response = await self.chat_model.ainvoke([
            SystemMessage(content=system),
            HumanMessage(content=human),
        ])
        return response.content.strip()

    async def _low_confidence_synthesis(self, query: str, intent: IntentObject) -> str:
        system = self._base_system(
            "APPROACH: Shadow Agent activated. Map to the most structurally similar known "
            "analytical scenario using first-principles reasoning. Make no domain assumptions. "
            "Build the most useful expert prompt possible from minimal signal.\n\n"
            "Known scenarios: molecular characterisation, impurity profiling, method development, "
            "chromatographic troubleshooting, SOP documentation, stability studies, dissolution testing."
        )
        human = (
            f'Vague query: "{query}"\n'
            f"Best intent read: {intent.primary_intent}\n"
            f"Domain signal: {intent.domain}\n\n"
            "Reconstruct into the most useful expert pharmaceutical analytical science prompt possible. "
            "Return ONLY the prompt."
        )
        response = await self.chat_model.ainvoke([
            SystemMessage(content=system),
            HumanMessage(content=human),
        ])
        return response.content.strip()

