def safe_int(v, default: int = 0) -> int:
if v is None:
return default
if isinstance(v, int):
return v
try:
return int(float(str(v).strip()))
except Exception:
return default

def safe_float(v, default: float = 0.0) -> float:
if v is None:
return default
if isinstance(v, float):
return v
try:
return float(str(v).strip().replace(”,”, “”))
except Exception:
return default

def safe_str(v, default: str = “”) -> str:
if v is None:
return default
return str(v).strip()

def safe_json_parse(text: str, default: Any = None) -> Any:
“”“Extract and parse JSON from a Claude response. Never raises.”””
if default is None:
default = {}
if not text:
return default
try:
return json.loads(text)
except Exception:
pass
try:
s = text.find(”{”)
e = text.rfind(”}”) + 1
if s >= 0 and e > s:
return json.loads(text[s:e])
except Exception:
pass
try:
s = text.find(”[”)
e = text.rfind(”]”) + 1
if s >= 0 and e > s:
return json.loads(text[s:e])
except Exception:
pass
return default

def safe_list_get(lst, idx, default=None):
try:
if lst and 0 <= idx < len(lst):
return lst[idx]
except Exception:
pass
return default

