def find_line(snippet: str) -> int:
    """Return 1-based line number of first occurrence of snippet."""
    for i, line in enumerate(lines, 1):
        if snippet in line:
            return i
    return -1

def find_def(name: str) -> int:
    tree = ast.parse(src)
    for node in ast.walk(tree):
        if isinstance(node, ast.FunctionDef) and node.name == name:
            return node.lineno
    return -1

