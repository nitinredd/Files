@dataclass
class RawPage:
    doc_id: str
    doc_path: str
    page_num: int
    text: str
    word_count: int = field(init=False)

    def __post_init__(self):
        self.word_count = len(self.text.split())


def extract_pdf(pdf_path: Path) -> List[RawPage]:
    import fitz
    pages = []
    doc_id = pdf_path.stem
    try:
        doc = fitz.open(str(pdf_path))
        for page_num in range(doc.page_count):
            text = doc[page_num].get_text("text").strip()
            if len(text) < 100:
                continue
            pages.append(RawPage(doc_id=doc_id, doc_path=str(pdf_path),
                                 page_num=page_num + 1, text=text))
        doc.close()
        logger.info(f"Extracted {len(pages)} non-empty pages from {pdf_path.name}")
    except Exception as e:
        logger.error(f"Failed to extract {pdf_path.name}: {e}")
        raise
    return pages


# ═══════════════════════════════════════════════════════════════
# CHUNKER
# ═══════════════════════════════════════════════════════════════

@dataclass
class Paragraph:
    paragraph_id: str
    doc_id: str
    doc_path: str
    page_num: int
    para_idx: int
    text: str
    token_estimate: int


def chunk_page(page: RawPage, target_tokens: int = 350) -> List[Paragraph]:
    raw_paras = [p.strip() for p in re.split(r'\n\s*\n', page.text) if p.strip()]
    merged, buffer = [], ""
    for para in raw_paras:
        if len(buffer.split()) + len(para.split()) < int(target_tokens * 0.6):
            buffer = (buffer + " " + para).strip()
        else:
            if buffer:
                merged.append(buffer)
            buffer = para
    if buffer:
        merged.append(buffer)

    paragraphs = []
    for idx, text in enumerate(merged):
        if len(text.split()) < 20:
            continue
        paragraphs.append(Paragraph(
            paragraph_id=f"{page.doc_id}_p{page.page_num}_para{idx}",
            doc_id=page.doc_id, doc_path=page.doc_path,
            page_num=page.page_num, para_idx=idx, text=text,
            token_estimate=int(len(text.split()) * 1.3)
        ))
    return paragraphs


def chunk_document(pages: List[RawPage]) -> List[Paragraph]:
    all_paragraphs = []
    for page in pages:
        all_paragraphs.extend(chunk_page(page))
    return all_paragraphs


