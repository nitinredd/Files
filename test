// ── REVISION HISTORY ──────────────────────────────────────────────────────────
function buildRevision(revisions) {
  revisions=Array.isArray(revisions)?revisions:[];
  var W=[Math.round(CW*0.40),0]; W[1]=CW-W[0];
  var tbl=new Table({
    width:{size:CW,type:WidthType.DXA}, columnWidths:W,
    rows:[
      new TableRow({children:[
        cell("Document and Version Number",{bold:true,fill:CLR.HDR_GREY,w:W[0],size:SZ.SM}),
