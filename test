    with fc2:
        st.markdown("**📁 Annexure Files** *(required)*")
        annexure_files = st.file_uploader(
            "PDF or JSON — one per excipient/material. "
            "PDF = Claude Vision reads EI table directly. "
            "JSON = from annexure_converter.py.",
            type=["pdf","json"], accept_multiple_files=True, key="annexures")
    with fc3:
        st.markdown("**🐟 Fishbone Diagram** *(optional)*")
        fishbone_file = st.file_uploader(
            "Upload your fishbone/Ishikawa diagram image. "
            "Leave empty → AI builds one from your product details.",
            type=["png","jpg","jpeg"], key="fishbone")
        if not fishbone_file:
            st.caption("ℹ️ Not uploaded → AI-generated diagram will appear.")

    st.markdown("---")

    btn_disabled = not (excel_file and annexure_files
                        and h_product and h_doc_no and h_dosage and h_strength and h_mdd > 0)
    if st.button("🚀 Generate Report", type="primary", disabled=btn_disabled):
        # Clear any previous run's artifacts so stale downloads don't linger
        for _k in ("docx_bytes","docx_fname","report_ready",
                   "traceability_csv","traceability_fname"):
