/**
 * generate_report.js
 * Produces a pixel-perfect TSR DOCX matching Dr. Reddy's IPDO format.
 * Called by app.py:  node generate_report.js <report_data.json> <output.docx>
 */
"use strict";
const fs   = require("fs");
const path = require("path");
const {
  Document, Packer, Paragraph, TextRun, Table, TableRow, TableCell,
  ImageRun, Header, Footer, AlignmentType, BorderStyle, WidthType,
  ShadingType, VerticalAlign, PageNumber, PageBreak, HeadingLevel,
} = require("docx");

// ─────────────────────────────────────────────────────────────────────────────
// CONSTANTS – document geometry & colours (formatting only, not product content)
// ─────────────────────────────────────────────────────────────────────────────
const PAGE_W   = 12240;  // 8.5 in × 1440 dxa
const PAGE_H   = 15840;  // 11 in
const MARGIN   = 720;    // 0.5 in
const CONTENT_W = PAGE_W - 2 * MARGIN;   // 11040 dxa ≈ 7.67 in

const CLR = {
  HEADER_DARK:  "1F3864",   // dark navy – IPDO header band
  HEADER_LIGHT: "D6DCE4",   // light blue-grey – sub-header rows
  ROW_SECTION:  "BDD7EE",   // blue section header rows (composition table)
  ROW_ALT:      "FFFFFF",   // white data rows
  BORDER:       "000000",   // black borders
  RED_BOLD:     "FF0000",   // threshold exceeded marker
};

const FONT  = "Arial";
const FONT_SM   = 14;   // 7pt in half-points
const FONT_BODY = 16;   // 8pt
const FONT_MD   = 18;   // 9pt
const FONT_LG   = 20;   // 10pt

// ─────────────────────────────────────────────────────────────────────────────
// UTILITY HELPERS
// ─────────────────────────────────────────────────────────────────────────────
const border = (sz = 4, color = CLR.BORDER) => ({ style: BorderStyle.SINGLE, size: sz, color });
const allBorders = (sz = 4) => ({
  top: border(sz), bottom: border(sz), left: border(sz), right: border(sz),
  insideHorizontal: border(sz), insideVertical: border(sz),
});
const noBorder = () => ({
  top: border(0, "FFFFFF"), bottom: border(0, "FFFFFF"),
  left: border(0, "FFFFFF"), right: border(0, "FFFFFF"),
});
const shading = (fill) => ({ fill, type: ShadingType.CLEAR, color: "auto" });
const cellMargins = () => ({ top: 40, bottom: 40, left: 80, right: 80 });

function tc(text, opts = {}) {
  const { bold = false, size = FONT_BODY, align = AlignmentType.CENTER,
          fill = null, colSpan = 1, w = 0, color = "000000" } = opts;
  return new TableCell({
    columnSpan: colSpan,
    width: w ? { size: w, type: WidthType.DXA } : undefined,
    borders: allBorders(),
    shading: fill ? shading(fill) : undefined,
    margins: cellMargins(),
    verticalAlign: VerticalAlign.CENTER,
    children: [new Paragraph({
      alignment: align,
      spacing: { before: 0, after: 0 },
      children: [new TextRun({ text: String(text), bold, size, font: FONT, color })]
    })]
  });
}

function emptyCell(fill = null) {
  return new TableCell({
    borders: allBorders(),
    shading: fill ? shading(fill) : undefined,
    margins: cellMargins(),
    children: [new Paragraph({ children: [new TextRun("")] })]
  });
}

function para(text, opts = {}) {
  const { bold = false, size = FONT_BODY, align = AlignmentType.LEFT,
          before = 40, after = 40 } = opts;
  const runs = [];
  if (Array.isArray(text)) {
    text.forEach(seg => runs.push(new TextRun({
      text: seg.text, bold: seg.bold || false, size: seg.size || FONT_BODY, font: FONT
    })));
  } else {
    runs.push(new TextRun({ text: String(text), bold, size, font: FONT }));
  }
  return new Paragraph({
    alignment: align,
    spacing: { before, after },
    children: runs,
  });
}

function heading(text, level = 1) {
  return para(text, { bold: true, size: level === 1 ? FONT_LG : FONT_MD });
}

function pageBreak() {
  return new Paragraph({ children: [new PageBreak()] });
}

function fmt(val, decimals = 4) {
  if (val === null || val === undefined || val === "") return "";
  const n = parseFloat(val);
  return isNaN(n) ? String(val) : n.toFixed(decimals);
}

// ─────────────────────────────────────────────────────────────────────────────
// PAGE HEADER (IPDO standard – appears on every page)
// ─────────────────────────────────────────────────────────────────────────────
function buildPageHeader(meta) {
  const { title = "", document_no = "", product_name = "",
          dosage_form = "", version = "", strength = "",
          department = "", market = "", protocol = "" } = meta;

  // Row 1: IPDO | Technical Summary Report | Dr. Reddy's
  const row1 = new TableRow({ children: [
    tc("IPDO", { bold: true, size: FONT_MD, align: AlignmentType.LEFT,
                 fill: CLR.HEADER_DARK, w: 1440 }),
    tc("Technical Summary Report",
       { bold: true, size: FONT_MD, align: AlignmentType.CENTER,
         fill: CLR.HEADER_DARK, colSpan: 3 }),
    tc("Dr. Reddy's", { bold: true, size: FONT_MD, align: AlignmentType.RIGHT,
                        fill: CLR.HEADER_DARK, w: 1800 }),
  ]});

  // Row 2: Title spanning left columns, right side: dept / strength / market
  const row2 = new TableRow({ children: [
    new TableCell({
      columnSpan: 3,
      borders: allBorders(4),
      shading: shading("FFFFFF"),
      margins: cellMargins(),
      children: [para([
        { text: "Title: ", bold: true, size: FONT_SM },
        { text: title, bold: false, size: FONT_SM }
      ])]
    }),
    new TableCell({
      borders: allBorders(4),
      shading: shading("FFFFFF"),
      margins: cellMargins(),
      children: [
        para([{ text: "Department: ", bold: true, size: FONT_SM },
              { text: department, size: FONT_SM }]),
        para([{ text: "Strength: ",   bold: true, size: FONT_SM },
              { text: strength,        size: FONT_SM }]),
        para([{ text: "Market: ",     bold: true, size: FONT_SM },
              { text: market,          size: FONT_SM }]),
        para([{ text: "Protocol: ",   bold: true, size: FONT_SM },
              { text: protocol,        size: FONT_SM }]),
      ]
    }),
    new TableCell({
      borders: allBorders(4),
      shading: shading("FFFFFF"),
      margins: cellMargins(),
      children: [
        para([{ text: "Dr.Reddy's", bold: true, size: FONT_SM }]),
      ]
    }),
  ]});

  // Row 3: Document No | Product Name | Dosage Form | Version
  const row3 = new TableRow({ children: [
    tc(`Document No: ${document_no}`,   { size: FONT_SM, align: AlignmentType.LEFT }),
    tc(`Product Name: ${product_name}`, { size: FONT_SM, align: AlignmentType.LEFT }),
    tc(`Dosage Form: ${dosage_form}`,   { size: FONT_SM, align: AlignmentType.LEFT }),
    tc(`Version: ${version}`,           { size: FONT_SM, align: AlignmentType.LEFT }),
    emptyCell(),
  ]});

  const tbl = new Table({
    width: { size: CONTENT_W, type: WidthType.DXA },
    columnWidths: [1440, 3600, 2160, 2160, 1680],
    rows: [row1, row2, row3],
  });

  return new Header({ children: [tbl, para("")] });
}

// ─────────────────────────────────────────────────────────────────────────────
// PAGE FOOTER
// ─────────────────────────────────────────────────────────────────────────────
function buildPageFooter() {
  const p = new Paragraph({
    alignment: AlignmentType.CENTER,
    children: [
      new TextRun({ text: "Page ", size: FONT_SM, font: FONT }),
      new TextRun({ children: [PageNumber.CURRENT], size: FONT_SM, font: FONT }),
      new TextRun({ text: " of ", size: FONT_SM, font: FONT }),
      new TextRun({ children: [PageNumber.TOTAL_PAGES], size: FONT_SM, font: FONT }),
    ]
  });
  return new Footer({ children: [p] });
}

// ─────────────────────────────────────────────────────────────────────────────
// TITLE PAGE
// ─────────────────────────────────────────────────────────────────────────────
function buildTitlePage(meta, sopFormat) {
  const box = new Table({
    width: { size: CONTENT_W, type: WidthType.DXA },
    columnWidths: [CONTENT_W],
    rows: [new TableRow({ children: [
      new TableCell({
        borders: allBorders(8),
        margins: { top: 200, bottom: 200, left: 200, right: 200 },
        children: [
          para(meta.title || "", { bold: true, size: FONT_LG + 2, align: AlignmentType.CENTER }),
          para(""),
          para(`SOP Format Number: ${sopFormat || meta.sop_format_number || ""}`,
               { align: AlignmentType.CENTER, size: FONT_BODY }),
        ]
      })
    ]})]
  });
  return [box, pageBreak()];
}

// ─────────────────────────────────────────────────────────────────────────────
// TABLE OF CONTENTS (extracted from reference or generated)
// ─────────────────────────────────────────────────────────────────────────────
function buildTOC(pages) {
  // Extract TOC from reference pages or build a generic one
  const tocEntries = [
    ["1","Abstract","3"], ["2","Objective","3"],
    ["3","Details of the study location / testing location","3"],
    ["4","Background","3"], ["5","Drug product elemental impurity risk assessment","5"],
    ["6","Summary & Conclusion","17"], ["7","Reference","19"],
    ["8","List of Annexures","19"], ["9","Revision History","19"],
  ];
  const rows = tocEntries.map(([no, title, pg]) =>
    new TableRow({ children: [
      tc(no,    { align: AlignmentType.CENTER, w: 600 }),
      tc(title, { align: AlignmentType.LEFT,   w: 8200 }),
      tc(pg,    { align: AlignmentType.CENTER, w: 1200 }),
    ]})
  );
  const tbl = new Table({
    width: { size: CONTENT_W, type: WidthType.DXA },
    columnWidths: [600, 8200, 1200],
    rows: [
      new TableRow({ children: [
        tc("S. No.", { bold: true, fill: CLR.HEADER_LIGHT, w: 600 }),
        tc("Title",  { bold: true, fill: CLR.HEADER_LIGHT, w: 8200 }),
        tc("Page#",  { bold: true, fill: CLR.HEADER_LIGHT, w: 1200 }),
      ]}),
      ...rows
    ]
  });
  return [heading("TABLE OF CONTENTS"), tbl, pageBreak()];
}

// ─────────────────────────────────────────────────────────────────────────────
// TEXT SECTIONS (1-4: Abstract, Objective, Study Location, Background)
// ─────────────────────────────────────────────────────────────────────────────
function buildTextSections(txt) {
  return [
    heading("1. Abstract"),       para(txt.abstract || ""),
    heading("2. Objective"),      para(txt.objective || ""),
    heading("3. Details of the study location / testing location"),
    para(txt.study_location || "NA"),
    heading("4. Background:"),    para(txt.background || ""),
    pageBreak(),
  ];
}

// ─────────────────────────────────────────────────────────────────────────────
// COMPOSITION TABLE (Table 1) – exact section-header structure
// ─────────────────────────────────────────────────────────────────────────────
function buildCompositionTable(sections) {
  // Column widths summing to CONTENT_W
  const COL_W = [4500, 1340, 1700, 1700, 1800]; // sums to 11040 = CONTENT_W

  const headerRow = new TableRow({ children: [
    tc("Name of Ingredient",     { bold: true, fill: CLR.HEADER_LIGHT, w: COL_W[0] }),
    tc("Compendial\nStatus",     { bold: true, fill: CLR.HEADER_LIGHT, w: COL_W[1] }),
    tc("40 mg\nmg/unit",         { bold: true, fill: CLR.HEADER_LIGHT, w: COL_W[2] }),
    tc("20 mg\nmg/unit",         { bold: true, fill: CLR.HEADER_LIGHT, w: COL_W[3] }),
    tc("10 mg\nmg/unit",         { bold: true, fill: CLR.HEADER_LIGHT, w: COL_W[4] }),
  ]});

  const dataRows = [];
  (sections || []).forEach(section => {
    // Section header row (spans all columns)
    dataRows.push(new TableRow({ children: [
      new TableCell({
        columnSpan: 5,
        borders: allBorders(4),
        shading: shading(CLR.ROW_SECTION),
        margins: cellMargins(),
        children: [para(section.name || "", { bold: true, size: FONT_BODY })]
      })
    ]}));
    // Ingredient rows
    (section.rows || []).forEach(row => {
      dataRows.push(new TableRow({ children: [
        tc(row.ingredient || "", { align: AlignmentType.LEFT, w: COL_W[0] }),
        tc(row.status || row.compendial_status || "", { w: COL_W[1] }),
        tc(row["40mg"] || row.amount_40mg || "", { w: COL_W[2] }),
        tc(row["20mg"] || row.amount_20mg || "", { w: COL_W[3] }),
        tc(row["10mg"] || row.amount_10mg || "", { w: COL_W[4] }),
      ]}));
    });
  });

  const tbl = new Table({
    width: { size: CONTENT_W, type: WidthType.DXA },
    columnWidths: COL_W,
    rows: [headerRow, ...dataRows],
  });

  return [
    heading("5. Drug product elemental impurity risk assessment"),
    para("Table 1: Quantitative and Qualitative Composition",
         { bold: true, size: FONT_BODY }),
    tbl, pageBreak(),
  ];
}

// ─────────────────────────────────────────────────────────────────────────────
// FIGURE (Fishbone or any diagram extracted from reference PDF)
// ─────────────────────────────────────────────────────────────────────────────
function buildFigure(fig) {
  if (!fig || !fig.data_b64) return [];
  const imgBuf = Buffer.from(fig.data_b64, "base64");

  // Detect format
  const type = fig.media_type && fig.media_type.includes("jpeg") ? "jpg" : "png";

  // Scale to fit content width
  const maxWPx = 600;
  const imgH   = Math.max(100, Math.round(maxWPx * 0.55));
  const img = new ImageRun({
    type,
    data:  imgBuf,
    transformation: { width: maxWPx, height: imgH },
    altText: { title: fig.figure_label || "Figure", description: fig.description || "", name: "fig" }
  });

  return [
    para(fig.figure_label || "Figure 1", { bold: true, size: FONT_BODY }),
    new Paragraph({ alignment: AlignmentType.CENTER, children: [img] }),
    para(""),
    pageBreak(),
  ];
}

// ─────────────────────────────────────────────────────────────────────────────
// ANNEXURE TABLE (Table 2 + surrounding text)
// ─────────────────────────────────────────────────────────────────────────────
function buildAnnexureSection(txt, annexureList) {
  const COL_W = [4800, 3600, 2400];
  const rows = (annexureList || []).map((ann, i) =>
    new TableRow({ children: [
      tc(ann.material || "",  { align: AlignmentType.LEFT, w: COL_W[0] }),
      tc(ann.supplier || "",  { align: AlignmentType.LEFT, w: COL_W[1] }),
      tc(ann.annexure || `Annexure ${i+1}`, { w: COL_W[2] }),
    ]})
  );

  const tbl = new Table({
    width: { size: CONTENT_W, type: WidthType.DXA },
    columnWidths: COL_W,
    rows: [
      new TableRow({ children: [
        tc("Name of Excipient / Material", { bold: true, fill: CLR.HEADER_LIGHT, w: COL_W[0] }),
        tc("Vendor",                        { bold: true, fill: CLR.HEADER_LIGHT, w: COL_W[1] }),
        tc("Title of Annexure",             { bold: true, fill: CLR.HEADER_LIGHT, w: COL_W[2] }),
      ]}),
      ...rows
    ]
  });

  return [
    para(txt.sources_intro    || "", { size: FONT_BODY }),
    para(txt.drug_substance_section || "", { size: FONT_BODY }),
    para(txt.excipient_intro  || "", { size: FONT_BODY }),
    para("Table No.2 Details of Annexures", { bold: true }),
    tbl,
    pageBreak(),
  ];
}

// ─────────────────────────────────────────────────────────────────────────────
// CALCULATION TABLE builder (Tables 5, 6, 7)
// Multi-level headers: class → element, split into Measured Conc | Total Mass
// ─────────────────────────────────────────────────────────────────────────────
function buildCalcTable(tableNum, tableData, pdeValues) {
  const { elements, rows, total_daily_intake, element_totals, pde, threshold_30pct } = tableData;
  const N = elements.length;   // number of elements
  // Column layout:
  // [0] Component  [1] Daily intake(g)  [2..N+1] Measured Conc  [N+2..2N+1] Total Mass
  // Total cols: 2 + 2N
  const COMP_W   = 2600;
  const DI_W     = 800;
  const ELEM_W   = Math.max(400, Math.floor((CONTENT_W - COMP_W - DI_W) / (2 * N)));
  const colWidths = [COMP_W, DI_W, ...Array(N).fill(ELEM_W), ...Array(N).fill(ELEM_W)];

  // Class labels for group headers
  const classLabels = {};
  elements.forEach(sym => {
    if (pdeValues[sym]) classLabels[sym] = `Class ${pdeValues[sym].class}`;
  });

  // Determine unique classes and their element spans
  const seen = [];
  elements.forEach(sym => {
    const c = pdeValues[sym] ? pdeValues[sym].class : "?";
    if (!seen.length || seen[seen.length-1].class !== c) seen.push({ class: c, count: 1 });
    else seen[seen.length-1].count++;
  });

  // ── Header rows ──────────────────────────────────────────────────────────
  // Row H1: "Component" | "Daily intake" | [Measured Conc (merged)] | [Total Mass (merged)]
  const h1 = new TableRow({ children: [
    tc("Component",               { bold: true, fill: CLR.HEADER_LIGHT, w: COMP_W }),
    tc("Daily\nintake\n(g)",      { bold: true, fill: CLR.HEADER_LIGHT, w: DI_W }),
    new TableCell({
      columnSpan: N, borders: allBorders(4), shading: shading(CLR.HEADER_LIGHT),
      margins: cellMargins(), verticalAlign: VerticalAlign.CENTER,
      children: [para("Measured Concentration (µg/g)",
                      { bold: true, align: AlignmentType.CENTER, size: FONT_SM })]
    }),
    new TableCell({
      columnSpan: N, borders: allBorders(4), shading: shading(CLR.HEADER_LIGHT),
      margins: cellMargins(), verticalAlign: VerticalAlign.CENTER,
      children: [para("Total Mass of Elemental Impurity (µg/day)",
                      { bold: true, align: AlignmentType.CENTER, size: FONT_SM })]
    }),
  ]});

  // Row H2: blank | blank | [class-span cells for Measured] | [class-span cells for Total]
  const h2Cells = [
    tc("", { w: COMP_W, fill: CLR.HEADER_LIGHT }),
    tc("", { w: DI_W,   fill: CLR.HEADER_LIGHT }),
  ];
  // For both Measured and Total sections, add class-span cells
  for (let repeat = 0; repeat < 2; repeat++) {
    seen.forEach(grp => {
      h2Cells.push(new TableCell({
        columnSpan: grp.count, borders: allBorders(4), shading: shading(CLR.HEADER_LIGHT),
        margins: cellMargins(),
        children: [para(`Class ${grp.class}`,
                        { bold: true, align: AlignmentType.CENTER, size: FONT_SM })]
      }));
    });
  }
  const h2 = new TableRow({ children: h2Cells });

  // Row H3: blank | blank | element symbols × 2
  const h3 = new TableRow({ children: [
    tc("", { w: COMP_W, fill: CLR.HEADER_LIGHT }),
    tc("", { w: DI_W,   fill: CLR.HEADER_LIGHT }),
    ...elements.map((sym, i) =>
      tc(sym, { bold: true, fill: CLR.HEADER_LIGHT, w: ELEM_W, size: FONT_SM })),
    ...elements.map((sym, i) =>
      tc(sym, { bold: true, fill: CLR.HEADER_LIGHT, w: ELEM_W, size: FONT_SM })),
  ]});

  // ── Data rows ─────────────────────────────────────────────────────────────
  const dataRows = (rows || []).map(row => {
    const cells = [
      tc(row.ingredient || "", { align: AlignmentType.LEFT, w: COMP_W, size: FONT_SM }),
      tc(fmt(row.daily_intake_g, 3), { w: DI_W, size: FONT_SM }),
      ...elements.map(sym => tc(fmt(row.measured_conc?.[sym] ?? "0", 4),
                                { w: ELEM_W, size: FONT_SM })),
      ...elements.map(sym => tc(fmt(row.total_mass?.[sym] ?? "0", 4),
                                { w: ELEM_W, size: FONT_SM })),
    ];
    return new TableRow({ children: cells });
  });

  // ── Footer rows: TOTAL | PDE | Threshold ─────────────────────────────────
  const makeFooterRow = (label, values, color = CLR.HEADER_LIGHT, isThreshold = false) => {
    const cells = [
      tc(label, { bold: true, fill: color, align: AlignmentType.LEFT, w: COMP_W, size: FONT_SM }),
      tc(label === "TOTAL (daily intake) (g/day)" ? fmt(total_daily_intake, 3) : "",
         { fill: color, w: DI_W, size: FONT_SM }),
      // Blank for measured conc section
      ...elements.map(() => tc("", { fill: color, w: ELEM_W, size: FONT_SM })),
      // Values for total mass section
      ...elements.map(sym => {
        const val = values[sym];
        const exceeded = isThreshold && element_totals[sym] !== undefined &&
                         val !== null && element_totals[sym] > val;
        return tc(
          val !== null && val !== undefined ? fmt(val, 2) : "–",
          { fill: exceeded ? "FFCCCC" : color, w: ELEM_W, size: FONT_SM,
            color: exceeded ? CLR.RED_BOLD : "000000" }
        );
      }),
    ];
    return new TableRow({ children: cells });
  };

  const footerRows = [
    makeFooterRow("TOTAL (daily intake) (g/day)", element_totals),
    makeFooterRow("PDE (µg/day)", pde),
    makeFooterRow("Threshold Limit (30% of PDE)", threshold_30pct, "FFE699", true),
  ];

  const tbl = new Table({
    width: { size: CONTENT_W, type: WidthType.DXA },
    columnWidths: colWidths,
    rows: [h1, h2, h3, ...dataRows, ...footerRows],
  });

  const classNameMap = { 5: "Class 1 and Class 2A", 6: "Class 2B", 7: "Class 3" };
  const className = classNameMap[tableNum] || "";
  return [
    para(`Table ${tableNum}: Theoretical Elemental Impurity Assessment (${className}) — Evaluation of Daily Contribution`,
         { bold: true, size: FONT_BODY }),
    tbl, para(""),
  ];
}

// ─────────────────────────────────────────────────────────────────────────────
// REVISION HISTORY TABLE
// ─────────────────────────────────────────────────────────────────────────────
function buildRevisionHistory(revisions) {
  const rows = (revisions || []).map(rev =>
    new TableRow({ children: [
      tc(rev.document_version || rev["Document and Version Number"] || "",
         { align: AlignmentType.LEFT, w: 4200 }),
      tc(rev.changes || rev["Brief details of changes"] || "",
         { align: AlignmentType.LEFT, w: CONTENT_W - 4200 }),
    ]})
  );
  const tbl = new Table({
    width: { size: CONTENT_W, type: WidthType.DXA },
    columnWidths: [4200, CONTENT_W - 4200],
    rows: [
      new TableRow({ children: [
        tc("Document and Version Number", { bold: true, fill: CLR.HEADER_LIGHT, w: 4200 }),
        tc("Brief details of changes",    { bold: true, fill: CLR.HEADER_LIGHT,
                                           w: CONTENT_W - 4200 }),
      ]}),
      ...rows
    ]
  });
  return [heading("9. Revision history:"), tbl];
}

