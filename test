        logger.error(f"Annexure {index} parse error: {ex}")
        return {"annexure_number": index, "supplier_name": "N/A", "material_name": "N/A", "elements": []}

def _flatten_docai_json(obj, depth=0) -> str:
    """Flatten Document AI JSON to readable text."""
    if depth > 8: return ""
    parts = []
    if isinstance(obj, dict):
        if "text" in obj and isinstance(obj["text"], str):
            parts.append(obj["text"])
        for v in obj.values():
            parts.append(_flatten_docai_json(v, depth+1))
    elif isinstance(obj, list):
        for item in obj:
            parts.append(_flatten_docai_json(item, depth+1))
    elif isinstance(obj, (str, int, float)):
        parts.append(str(obj))
    return " ".join(p for p in parts if p.strip())

