        checkpoint_path = DATA_DIR / "concept_extraction_checkpoint.json"
        checkpoint = {}
        if checkpoint_path.exists():
            with open(checkpoint_path) as f:
                checkpoint = json.load(f)

        remaining = [p for p in all_paras if p["paragraph_id"] not in checkpoint]
