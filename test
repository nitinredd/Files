            t = st.session_state.cost_tracker
            st.metric("Session Cost", f"Rs.{t['total_cost_inr']:.2f}")
            st.caption(f"{t['total_queries']} queries - {t['gpt4o_calls']} API calls")


def main():
    initialize_session_state()
    load_infrastructure()
    render_sidebar()

    page = st.session_state.current_page
    if page == "chat":
        render_chat_page()
    elif page == "ingest":
        render_ingestion_page()
    elif page == "graph":
        render_graph_page()
    elif page == "analytics":
        render_analytics_page()


if __name__ == "__main__":
    main()
