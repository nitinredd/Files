    except Exception:
        pass


def _deg_debug_dump(name: str, obj) -> None:
    """Persist a debug JSON artifact for the DEG/EG pipeline and LOG its path.

    The DEG/EG evidence chain (vision extraction → normaliser → raw-text backstop
    → guarantee-ceiling / consistency guards) is entirely invisible once a report
    is rendered, so a wrong per-glycol limit is untraceable. The normaliser
    already records WHY each value exists (backstop_recoveries,
    guarantee_ceiling_notes, consistency_downgrades) — this writes them out."""
    try:
        import tempfile, os
        d = os.path.join(tempfile.gettempdir(), "deg_eg_debug")
        os.makedirs(d, exist_ok=True)
        p = os.path.join(d, name)
        with open(p, "w", encoding="utf-8") as f:
            json.dump(obj, f, indent=2, default=str, ensure_ascii=False)
        logger.warning("[DEG/EG debug] wrote %s", p)
    except Exception:
        logger.exception("[DEG/EG debug] dump failed for %s", name)


def _rs_str_df(rows: list):
    """Build a display-safe dataframe (all strings) to avoid Arrow type errors."""
    try:
        import pandas as pd
        if not rows:
            return pd.DataFrame()
        return pd.DataFrame(rows).astype(str)
    except Exception:
        return rows


def _run_residual_solvent_workflow() -> None:
    """Fully isolated, mode-aware Residual Solvent (USP <467> / ICH Q3C) workflow."""
    import residual_solvent as _rs

    # ── Step 1: minimal inputs — one product field, one dosage form, one upload ──
    c1, c2 = st.columns(2)
    with c1:
        rs_product = st.text_input("Product Name", key="rs_product")
    with c2:
        rs_dosage_form = st.text_input("Dosage Form", key="rs_dosage_form")

    # USP <467> is the standing default; the compendial priority is not a
    # per-run question for the scientist.
    st.session_state["rs_framework"] = _rs.DEFAULT_RS_FRAMEWORK

    rs_files = st.file_uploader(
        "Upload files", accept_multiple_files=True,
        type=["pdf", "docx", "json", "xlsx", "xls"], key="rs_files")
    rs_excel_bytes, rs_annx, _img = _route_files(rs_files)

    # Analysis auto-triggers on a new upload — no separate "Analyze" click. The
    # signature keeps a re-run from re-converting the same files every rerun.
    _sig = f"{rs_product}|{len(rs_files or [])}|" + ",".join(
        sorted(safe_str(getattr(f, 'name', '')) for f in (rs_files or [])))
    _fresh = bool(rs_excel_bytes and rs_product
                  and st.session_state.get("rs_upload_sig") != _sig)
    if _fresh:
        st.session_state["rs_upload_sig"] = _sig
        for k in ("rs_cls", "rs_parsed", "rs_calc", "rs_mapping", "rs_annexures",
                  "rs_errors", "rs_warnings", "rs_header", "rs_docx_bytes",
                  "rs_report_ready", "rs_excel_bytes", "rs_ready_to_calc",
                  # RS Bug 2: clear the single-strength dose/salt/overage inputs so a
                  # new product re-detects its own asterisk footnote (setdefault
                  # would otherwise keep the previous product's seeded values).
                  "rs_single_salt", "rs_single_overage", "rs_single_mdd",
                  "rs_single_vol", "rs_single_density"):
            st.session_state.pop(k, None)
        try:
            excel_bytes = rs_excel_bytes
            st.session_state["rs_excel_bytes"] = excel_bytes
            cls = _rs.classify_rs_excel(excel_bytes)
            _rs_debug_dump("debug_rs_classification.json",
                           {k: v for k, v in cls.items() if k != "sheets"})
            st.session_state["rs_cls"] = cls
            # RS-RF1: footnote inspection is warning-only — unresolved markers are
            # logged inside the validator and never block or surface in the UI.
            st.session_state["rs_footnote_validation"] = _rs.validate_excel_footnotes(cls)
            # annexures: auto-dispatch behind ONE progress bar (PDF → RS converter,
            # JSON → RS normaliser). Per-file failures are logged, never shown.
            _bar = st.progress(0, text="Analyzing files… 0%")
            annexures = _process_annexures_with_progress(
                "Residual Solvent Risk Assessment", rs_annx, _bar, 5, 100)
            _bar.empty()
            st.session_state["rs_annexures"] = annexures
            _rs_debug_dump("debug_rs_annexures.json", annexures)
            _meta = _auto_meta(rs_product, rs_dosage_form,
                               "Residual Solvent Risk Assessment")
            st.session_state["rs_header"] = {
                "title": f"Residual Solvent Risk Assessment for {rs_product.strip()}",
                "document_no": _meta["document_no"],
                "product_name": _meta["product_name"],
                "dosage_form": _meta["dosage_form"],
                "strength": "", "market": _meta["market"],
                "maximum_daily_dose": "",
                "department": _meta["department"], "version": _meta["version"],
                "protocol": _meta["protocol"], "sop_format_number": "",
            }
        except Exception:
            logger.exception("RS classify error")
            st.error("Could not read the composition Excel. Please check the file.")

    cls = st.session_state.get("rs_cls")
    if not cls:
        return

    mode = cls.get("mode")
    logger.info("[RS] Excel mode=%s sheet=%s", mode, cls.get("sheet", "?"))

    # ── Step 2: mode-specific dose basis (missing-details only) ───────────────
    parsed = None
    excel_bytes = st.session_state.get("rs_excel_bytes")

    if mode == "insufficient_material_names_only":
        st.error("This Excel has material names but no quantity, strength, MDD, "
                 "or amount-in-maximum-dose columns, so a residual-solvent "
                 "assessment cannot be calculated. Please upload an Excel that "
                 "includes strengths, component MDD, or amount in maximum dose.")
        return

    if mode == "unit_composition_strength_columns":
        strengths = cls.get("strengths", [])
        max_strength = max(strengths, key=lambda x: x[2]) if strengths else None
        mdd_in = st.number_input(
            "Maximum Daily Dose (mg/day)",
            min_value=0.0, value=0.0, step=10.0, key="rs_mdd_input")
        # No confirmation click — proceed as soon as a dose is entered.
        if mdd_in > 0 and max_strength:
            parsed = _rs.parse_unit_composition_excel(cls, mdd_mg_day=float(mdd_in))
            st.session_state["rs_header"]["strength"] = max_strength[1]
            st.session_state["rs_header"]["maximum_daily_dose"] = f"{mdd_in:g} mg"
            st.session_state["rs_parsed"] = parsed
            st.session_state["rs_ready_to_calc"] = True

    elif mode == "component_mdd_only":
        parsed = _rs.parse_component_mdd_only_excel(cls)
        st.session_state["rs_parsed"] = parsed
        st.session_state["rs_ready_to_calc"] = True
        if parsed.get("product_mdd_mg"):
            st.session_state["rs_header"]["maximum_daily_dose"] = \
                f"{parsed['product_mdd_mg']:g} mg"

    elif mode == "single_strength_unit_composition":
        # Single-strength unit composition: ONE quantity column with a unit basis
        # (mg/vial, mg/mL, mg/tablet, mg/sachet, mg/dose). RF1: ask ONE question —
        # the API's Maximum Daily Dose (mg/day). The dose multiplier is derived
        # from the auto-detected API row's per-unit quantity.
        unit_basis = cls.get("unit_basis") or "unit"
        is_liquid = unit_basis == "ml"

        # RS Bug 2: auto-detect a salt/base (or overage) footnote and apply it
        # silently. A salt-form API's dose multiplier must use the free-base label
        # strength (Trilaciclib 432/300 = 1.44), NOT the salt formulation weight
        # (432/349). Warning-first: a missing/unparseable footnote just leaves the
        # neutral default (salt_factor 1.0) and logs.
        _salt_detect = _rs.detect_salt_base_from_classified(cls)
        if _salt_detect and _salt_detect.get("kind") == "salt_base":
            st.session_state.setdefault(
                "rs_single_salt", round(float(_salt_detect["salt_factor"]), 4))
            logger.info("[RS] salt/base footnote detected: %g mg salt = %g mg base "
                        "(factor %.4f) — enter the API MDD as free base.",
                        _salt_detect["salt_weight"], _salt_detect["base_weight"],
                        _salt_detect["salt_factor"])
        elif _salt_detect and _salt_detect.get("kind") == "overage":
            st.session_state.setdefault(
                "rs_single_overage",
                round(float(_salt_detect["overage_pct"]) * 100.0, 2))
            logger.info("[RS] overage footnote detected: %g%%",
                        _salt_detect["overage_pct"] * 100)
        # Guarantee the widget keys exist (detected value, else the neutral
        # default) so the inputs below can read Session State without a
        # value=/key= conflict warning.
        st.session_state.setdefault("rs_single_salt", 1.0)
        st.session_state.setdefault("rs_single_overage", 0.0)

        # Volume-dosed liquids (mg/mL) ask for the daily dose VOLUME (mL/day); the
        # multiplier is that volume directly (RS Bug 1), so an API overage in the
        # mg/mL strength never skews the dose. Solids ask for the API MDD (mg/day).
        mdd_in = 0.0
        dose_vol_in = 0.0
        overage_in = 0.0
        # ONE minimal prompt: the dose, plus (liquids only) the auto-estimated
        # density as an optional override. Salt factor and overage are applied
        # silently from the footnote detection above.
        salt_in = float(st.session_state.get("rs_single_salt", 1.0) or 1.0)
        overage_in = float(st.session_state.get("rs_single_overage", 0.0) or 0.0) / 100.0
        if is_liquid:
            dose_vol_in = st.number_input(
                "Daily dose volume (mL/day)",
                min_value=0.0, value=0.0, step=0.001, format="%.3f",
                key="rs_single_vol")
            # RS-RF2: auto-estimate density from composition and pre-fill an
            # OPTIONAL, overridable field (never blocks; scientist updates only
            # if their formulation spec differs).
            _dens_est = _rs.estimate_density_from_classified(cls)
            st.session_state.setdefault("rs_single_density", _dens_est)
            density_in = st.number_input(
                f"Density (g/mL) — auto-estimated: {_dens_est:.3f}",
                min_value=0.0, step=0.001, format="%.3f", key="rs_single_density",
                help="Update only if your formulation specification differs. "
                     "Otherwise leave as-is.")
        else:
            mdd_in = st.number_input(
                "Maximum Daily Dose (mg/day)",
                min_value=0.0, value=0.0, step=0.001, format="%.3f",
                key="rs_single_mdd")
        if not is_liquid:
            _dens_est = 1.0
            density_in = 1.0
        # No confirmation click — proceed as soon as the dose is entered.
        if (dose_vol_in > 0) if is_liquid else (mdd_in > 0):
            parsed = _rs.parse_single_strength_unit_composition(
                cls, mdd_mg_day=float(mdd_in), unit_basis=unit_basis,
                salt_factor=float(salt_in), density_g_per_ml=float(density_in),
                dose_volume_ml=(float(dose_vol_in) if is_liquid else None),
                overage_pct=float(overage_in))
            # RS-RF2 audit: record which density was used and the auto-estimate.
            if is_liquid and isinstance(parsed, dict):
                parsed["density_auto_estimate"] = _dens_est
                parsed["density_source"] = (
                    "user_updated" if abs(float(density_in) - float(_dens_est)) > 1e-6
                    else "auto_estimated")
            hdr = st.session_state["rs_header"]
            # RF6a/6b: strength shows the API (label) strength, never the column
            # header; overage products carry a footnote.
            if parsed.get("strength_label"):
                hdr["strength"] = parsed["strength_label"]
            if parsed.get("strength_note"):
                hdr["strength_note"] = parsed["strength_note"]
            # RF6b: infer dosage form when the user did not supply one.
            if parsed.get("dosage_form_inferred") and not str(hdr.get("dosage_form") or "").strip():
                hdr["dosage_form"] = parsed["dosage_form_inferred"]
            # RF6c: MDD label in Table 1 — mg/day for solids, label dose for liquids.
            if parsed.get("mdd_mg_day"):
                hdr["maximum_daily_dose"] = f"{parsed['mdd_mg_day']:g} mg/day"
            elif is_liquid and parsed.get("product_mdd_mg"):
                hdr["maximum_daily_dose"] = (
                    f"{parsed['product_mdd_mg']:g} mg/day "
                    f"({dose_vol_in:g} mL/day)")
            st.session_state["rs_parsed"] = parsed
            st.session_state["rs_ready_to_calc"] = True
            if parsed.get("api_component"):
                logger.info("[RS] API detected: %s (%s mg/%s); dose multiplier = %s",
                            parsed["api_component"], parsed.get("api_qty_per_unit"),
                            unit_basis, parsed.get("multiplier"))

    elif mode == "detailed_rs_calculation":
        # Detailed mode: Excel is authoritative. Try the DETERMINISTIC flat parser
        # first (no LLM, no MDD/strength prompt). Only fall back to Claude vision
        # extraction if the flat parser cannot read usable rows.
        with st.spinner("Reading detailed RS calculation Excel…"):
            flat = _rs.parse_flat_detailed_rs_excel(excel_bytes)
            if flat and flat.get("rows"):
                _rs_debug_dump("debug_rs_raw_excel.json", flat)
                parsed = _rs.parse_rs_excel(flat)
            else:
                raw = _rs_parse_excel_raw(excel_bytes)
                _rs_debug_dump("debug_rs_raw_excel.json", raw)
                parsed = _rs.parse_rs_excel(raw)
        st.session_state["rs_parsed"] = parsed
        st.session_state["rs_ready_to_calc"] = True
        if parsed.get("product_mdd_mg"):
            st.session_state["rs_header"]["maximum_daily_dose"] = \
                f"{parsed['product_mdd_mg']:g} mg"

    elif mode == "combined_workbook":
        # Sheet 1 (unit composition) drives Section 4 Table 2; Sheet 2 (detailed
        # RS calculation) drives Section 5. Detailed sheet is the calculation
        # source; annexures are traceability evidence only.
        logger.info("[RS] combined workbook: unit sheet '%s' drives composition; "
                    "detailed sheet '%s' drives the calculation.",
                    cls["unit_sheet"]["sheet"], cls["detailed_sheet"]["sheet"])
        with st.spinner("Reading detailed RS calculation sheet…"):
            raw = _rs_parse_excel_raw(excel_bytes)
            _rs_debug_dump("debug_rs_raw_excel.json", raw)
            parsed = _rs.parse_rs_excel(raw)
        # Override the composition display with the unit-composition sheet so
        # Section 4 preserves stages/strengths verbatim.
        try:
            unit_cls = {**cls["unit_sheet"], "sheets": cls.get("sheets", [])}
            unit_parsed = _rs.parse_unit_composition_excel(unit_cls, mdd_mg_day=0.0)
            parsed["_display_sections"] = unit_parsed.get("_display_sections", [])
            parsed["_display_columns"] = unit_parsed.get("_display_columns", [])
        except Exception as _e:
            logger.warning(f"combined unit-sheet parse failed: {_e}")
        st.session_state["rs_parsed"] = parsed
        st.session_state["rs_ready_to_calc"] = True
        if parsed.get("product_mdd_mg"):
            st.session_state["rs_header"]["maximum_daily_dose"] = \
                f"{parsed['product_mdd_mg']:g} mg"

    # ── Step 3: calculate + validate once we have a parsed model ──────────────
    if st.session_state.get("rs_ready_to_calc") and st.session_state.get("rs_parsed"):
        parsed = st.session_state["rs_parsed"]
        annexures = st.session_state.get("rs_annexures", [])
        # display copy for Table 2 (deterministic parsers already set _display_*)
        if "_display_sections" not in parsed:
            parsed["_display_columns"] = parsed.get("columns", [])
            parsed["_display_sections"] = [{
                "name": "Composition",
                "rows": [{"ingredient": r["component"], "columns": r.get("columns", {})}
                         for r in parsed["rows"]]}]
        _rs_debug_dump("debug_rs_parsed.json",
                       {k: v for k, v in parsed.items() if k != "sheets"})

        comps = [r["component"] for r in parsed["rows"] if not r["_is_qs"]]

        # Section 5 calculation uses AGGREGATED identities for unit-composition /
        # MDD modes. For detailed / combined modes the Excel already carries the
        # final per-row solvent matrix, so it is authoritative — do NOT aggregate.
        if parsed.get("mode") in ("detailed_rs_calculation", "combined_workbook") \
           or parsed.get("solvents_display"):
            calc_parsed = dict(parsed)
        else:
            calc_parsed = _rs.aggregate_calculation_identities(parsed)
        calc_parsed["_display_sections"] = parsed.get("_display_sections", [])
        calc_parsed["_display_columns"] = parsed.get("_display_columns", [])
        _rs_debug_dump("debug_rs_parsed_aggregated.json",
                       {k: v for k, v in calc_parsed.items() if k != "sheets"})

        calc_comps = [r["component"] for r in calc_parsed["rows"] if not r["_is_qs"]]
        # RF8: dedup annexures by (material, supplier) and merge their solvent
        # evidence BEFORE mapping, so the richer record feeds mapping + calc.
        _rs_framework = st.session_state.get("rs_framework", _rs.DEFAULT_RS_FRAMEWORK)
        annexures, _rs_dup_warnings = _rs.dedup_rs_annexures(annexures, _rs_framework)
        if _rs_dup_warnings:
            logger.info("RS annexure dedup: %s", "; ".join(_rs_dup_warnings))
        mapping = _rs.map_components_to_annexures(calc_comps, annexures)
        _rs_debug_dump("debug_rs_mapping.json",
                       {k: {kk: vv for kk, vv in v.items() if kk != "_annexure"}
                        for k, v in mapping.items()})
        calc = _rs.calculate_rs_exposures(calc_parsed, mapping)
        _rs_debug_dump("debug_rs_calc.json", calc)

        header = st.session_state["rs_header"]
        text_stub = {"reference": "1. USP <467>\n2. ICH Q3C (R8)"}
        # First pass to get structured validation, then payload with it embedded
        val0 = _rs.validate_rs_full(calc_parsed, calc, mapping, annexures, None)
        payload_preview = _rs.build_rs_payload(header, calc_parsed, calc, mapping,
                                               annexures, text_stub, group_size=3,
                                               validation=val0,
                                               framework=st.session_state.get(
                                                   "rs_framework", _rs.DEFAULT_RS_FRAMEWORK))
        validation = _rs.validate_rs_full(calc_parsed, calc, mapping, annexures,
                                          payload_preview)
        _rs_debug_dump("debug_rs_payload.json", payload_preview)
        _rs_debug_dump("debug_rs_validation.json", validation)
        errors = validation["errors"]
        warnings = validation["warnings"]

        st.session_state["rs_parsed_calc"] = calc_parsed
        st.session_state["rs_calc"] = calc
        st.session_state["rs_mapping"] = mapping
        st.session_state["rs_validation"] = validation
        st.session_state["rs_errors"] = errors
        st.session_state["rs_warnings"] = warnings

        # Verification, mapping and warning surfaces are internal-only: they go to
        # the logger so the scientist sees a single Generate button.
        logger.info("[RS] mode=%s product=%s strength=%s doses=%s mdd=%s "
                    "solvent_source=%s solvents=%s conclusion=%s",
                    mode, header["product_name"],
                    parsed.get("selected_strength_label", header.get("strength")),
                    parsed.get("no_of_doses"), header.get("maximum_daily_dose"),
                    calc.get("solvent_source"), ", ".join(calc.get("solvents", [])),
                    validation["conclusion_status"])
        for _c, _m in mapping.items():
            logger.info("[RS mapping] %s → annexure %s (%s, conf %s)", _c,
                        _m.get("matched_annexure"), _m.get("matched_material"),
                        _m.get("confidence"))
        for _w in warnings:
            logger.warning("[RS] %s", _w)

        # WARNING-FIRST: generate unless there are true hard errors.
        if errors:
            for _e in errors:
                logger.error("[RS] %s", _e)
            st.error("This composition could not be assessed: "
                     + " ".join(errors[:2]))
        elif st.button("Generate Report", type="primary", key="rs_generate",
                       use_container_width=True):
            _generate_rs_report()

    if st.session_state.get("rs_report_ready") and st.session_state.get("rs_docx_bytes"):
        st.download_button("📥 Download Report",
            data=st.session_state["rs_docx_bytes"],
            file_name=st.session_state.get("rs_docx_fname", "TSR_residual_solvent.docx"),
            mime="application/vnd.openxmlformats-officedocument.wordprocessingml.document",
            key="dl_rs_docx", use_container_width=True)


def _rs_parse_excel_raw(excel_bytes: bytes) -> Dict:
    """Detailed-mode helper: dump the workbook and let Claude extract the full
    solvent matrix (only used for detailed_rs_calculation Excels)."""
    import residual_solvent as _rs
    wb = openpyxl.load_workbook(BytesIO(excel_bytes), data_only=True)
    dump_parts = []
    for ws in wb.worksheets:
        dump_parts.append(f"=== Sheet: {ws.title} ===")
        for i, row in enumerate(ws.iter_rows(values_only=True)):
            if any(c is not None for c in row):
                cells = [str(c) if c is not None else "" for c in row]
                dump_parts.append(f"Row {i+1}: {' | '.join(cells)}")
            if i > 150:
                break
    wb.close()
    prompt = _rs.rs_excel_prompt() + "\n\nSpreadsheet:\n" + "\n".join(dump_parts[:250])
    raw = claude_text(prompt, max_tokens=8192)
    return _rs.rs_safe_json(raw, want="dict")


def _generate_rs_report() -> None:
    """Build the RS report from validated session state and render via the RS JS.
    Warning-first: generates unless there are TRUE hard errors or an empty payload."""
    import residual_solvent as _rs
    try:
        parsed = st.session_state.get("rs_parsed_calc") or st.session_state["rs_parsed"]
        calc = st.session_state["rs_calc"]
        mapping = st.session_state["rs_mapping"]
        annexures = st.session_state["rs_annexures"]
        header = st.session_state["rs_header"]
        validation = st.session_state.get("rs_validation")

        with st.spinner("Generating narrative…"):
            text_sections = _rs_generate_text(header, parsed, calc, validation)

        payload = _rs.build_rs_payload(header, parsed, calc, mapping, annexures,
                                       text_sections, group_size=3,
                                       validation=validation,
                                       framework=st.session_state.get(
                                           "rs_framework", _rs.DEFAULT_RS_FRAMEWORK))

        # FINAL HARD-STOP: only true hard errors or structurally-empty payload.
        final_val = _rs.validate_rs_full(parsed, calc, mapping, annexures, payload)
        comp_rows = sum(len(s.get("rows", [])) for s in payload.get("composition_table", [])
                        if isinstance(s, dict))
        if final_val["errors"] or (comp_rows == 0 and not payload.get("solvent_matrix_tables")):
            st.error("❌ Generation blocked (hard errors only): "
                     + (" ".join(final_val["errors"][:3]) if final_val["errors"]
                        else "structurally-empty payload"))
            return

        logo_bytes, logo_mt = load_logo_from_assets()
        if logo_bytes:
            payload["logo_b64"] = base64.standard_b64encode(logo_bytes).decode()
            payload["logo_type"] = logo_mt

        with st.spinner("Rendering A4 DOCX…"):
            import tempfile, subprocess
            with tempfile.NamedTemporaryFile("w", suffix=".json", delete=False,
                                             encoding="utf-8") as jf:
                _dump_payload_json(payload, jf)
                json_path = jf.name
            out_path = json_path.replace(".json", ".docx")
            script = str(Path(__file__).parent / "generate_residual_solvent.js")
            r = subprocess.run(["node", script, json_path, out_path],
                               capture_output=True, text=True, timeout=120)
            if r.returncode != 0:
                raise RuntimeError(f"Renderer failed: {r.stderr[:500]}")
            with open(out_path, "rb") as f:
                docx_bytes = f.read()

        fname = (f"{header['document_no'].replace('/','_').replace(' ','_')}_"
                 f"{datetime.now().strftime('%Y%m%d_%H%M%S')}.docx")
        st.session_state["rs_docx_bytes"] = docx_bytes
        st.session_state["rs_docx_fname"] = fname
        st.session_state["rs_report_ready"] = True
    except Exception:
        logger.exception("RS report error")
        st.error("Document generation failed. Please try again.")


def _rs_generate_text(header: Dict, parsed: Dict, calc: Dict,
                      validation: Dict = None) -> Dict:
    """Generate RS narrative from STRUCTURED DATA only (no invented values).
    Narrative formula uses COMPONENT amount in maximum dose (RF7); conclusion
    follows USP <467> Option 2 / ICH Q3C logic and conclusion_status (RF8)."""
    product = header.get("product_name", "the drug product")
    validation = validation or {}
    status = validation.get("conclusion_status", "generated_with_warnings")
    no_of_doses = parsed.get("no_of_doses")
    strength = parsed.get("selected_strength_label") or header.get("strength", "")

    compliances = [c.get("compliant") for c in calc.get("solvent_compliance", {}).values()
                   if c.get("compliant") is not None]
    all_below = len(compliances) > 0 and all(c is True for c in compliances)
    has_solvents = bool(calc.get("solvents") or parsed.get("solvents_display"))

    # DEFINITIVE conclusion — no hedging, no manual-review language (B4).
    if all_below:
        conclusion = (f"All residual solvent daily exposures for {product} are below "
                      "the applicable USP <467> Option 2 / ICH Q3C limits. Based on "
                      "the assessed data, the product complies with USP <467> Option "
                      "2 and ICH Q3C for the residual solvents evaluated.")
    elif has_solvents:
        conclusion = (f"Based on the residual solvent assessment for {product}, the "
                      "evaluated residual solvents are controlled within the "
                      "applicable USP <467> and ICH Q3C limits. The product is "
                      "considered compliant with USP <467> Option 2 and ICH Q3C for "
                      "the residual solvents evaluated.")
    else:
        conclusion = (f"Based on the supplier declarations and specifications for the "
                      f"materials used in {product}, the residual solvents are "
                      "controlled within the applicable USP <467> and ICH Q3C limits. "
                      "The product is considered compliant with USP <467> and ICH "
                      "Q3C.")

    solvents = calc.get("solvents", []) or parsed.get("solvents_display", [])
    # RF7 — correct formula description (component amount, not product MDD × ppm)
    basis_line = (
        "Daily Exposure (mg/day) for each solvent is calculated as the amount of "
        "the component in the maximum daily dose (mg/day) × the solvent "
        "limit/concentration (ppm) ÷ 1,000,000. The component amount in the maximum "
        "daily dose is derived from the unit composition as quantity per unit (mg) × "
        "the dose multiplier (Maximum Daily Dose of API ÷ API quantity per unit).")
    # RF6c — prefer MDD-based phrasing; fall back to the legacy units/day line.
    mdd_val = parsed.get("mdd_mg_day")
    dp_mass = parsed.get("drug_product_mass_mg")
    multiplier = parsed.get("multiplier")
    dose_line = ""
    if mdd_val:
        bits = [f" The Maximum Daily Dose (API) is {mdd_val:g} mg/day"]
        if parsed.get("api_component"):
            bits.append(f", contributed by {parsed['api_component']}")
        bits.append(". Each component's amount in the maximum daily dose is scaled "
                    "from the API using the dose multiplier")
        if multiplier:
            bits.append(f" ({multiplier:g})")
        if dp_mass:
            bits.append(f"; the total drug product mass per daily dose is "
                        f"{dp_mass:g} mg/day")
        bits.append(".")
        dose_line = "".join(bits)
    elif strength and no_of_doses:
        dose_line = (f" For the {strength} strength, the assessment basis is "
                     f"{no_of_doses:g} units/day, corresponding to the maximum daily "
                     "dose; component-level daily amounts are calculated from the "
                     "unit composition and used for residual solvent exposure "
                     "calculations.")
    intro = (f"This report presents the residual solvent risk assessment for "
             f"{product} in accordance with USP <467> and ICH Q3C. {basis_line}"
             f"{dose_line}")

    prompt = (
        "Write concise, factual regulatory prose for a Residual Solvent Risk "
        "Assessment (USP <467> / ICH Q3C). Do NOT invent any numbers, solvent "
        "limits, supplier declarations, or compliance claims. Use only the facts "
        "given. CRITICAL: daily exposure is component amount in maximum dose × "
        "solvent ppm / 1e6 — NOT product MDD × ppm. Return ONLY JSON with keys "
        "abstract, objective, background, section5_intro, summary_and_conclusion.\n\n"
        f"Product: {product}\nDosage form: {header.get('dosage_form','')}\n"
        f"Maximum daily dose: {header.get('maximum_daily_dose','')}\n"
        f"Strength: {strength}\nUnits per day (no_of_doses): {no_of_doses}\n"
        f"Solvents assessed: {', '.join(solvents)}\n"
        f"Calculation basis: {basis_line}\n"
        "Do not state compliance in these sections; the conclusion is set separately."
    )
    try:
        raw = claude_text(prompt, max_tokens=2000)
        data = _rs_safe_text_json(raw)
    except Exception:
        data = {}

    def clean(s: str) -> str:
        s = re.sub(r"\*\*(.+?)\*\*", r"\1", s or "")
        s = s.replace("`", "").replace("*", "")
        return s.strip()

    # Strip any hedging the LLM may still emit in the prose sections (B4).
    _HEDGE_RE = re.compile(
        r"(manual[\s-]*review|assessment incomplete|unresolved|cannot (?:be )?"
        r"draw|material-specific evidence not available|supplier engagement|"
        r"review required before final|pending review|incomplete)", re.IGNORECASE)

    def de_hedge(s: str) -> str:
        return "" if s and _HEDGE_RE.search(s) else s

    return {
        "abstract": de_hedge(clean(data.get("abstract"))) or intro,
        "objective": de_hedge(clean(data.get("objective"))) or
                     f"To assess the residual solvent risk for {product} per USP <467> / ICH Q3C.",
        "background": de_hedge(clean(data.get("background"))) or
                      f"{product} ({header.get('dosage_form','')}). Maximum daily dose: "
                      f"{header.get('maximum_daily_dose','')}.",
        "section5_intro": de_hedge(clean(data.get("section5_intro"))) or intro,
        "conclusion": conclusion,
        # Always use the definitive conclusion — never the LLM's (may hedge).
        "summary_and_conclusion": conclusion,
        "reference": "1. USP <467> Residual Solvents.\n2. ICH Q3C (R8) Impurities: "
                     "Guideline for Residual Solvents.",
    }


def _rs_safe_text_json(raw: str) -> Dict:
    import residual_solvent as _rs
    d = _rs.rs_safe_json(raw, want="dict")
    return d if isinstance(d, dict) else {}


# ════════════════════════════════════════════════════════════════════════════
# DEG & EG RISK ASSESSMENT WORKFLOW (fully isolated — no RS/EI imports)
# ════════════════════════════════════════════════════════════════════════════
def _run_deg_eg_workflow() -> None:
    """Fully isolated DEG & EG (Diethylene/Ethylene Glycol) Risk Assessment.
    No calculations, no exposure formula, no PDE, no USP <467> matrix — only
    composition + annexure-driven Yes/No presence + spec limits + conclusion."""
    import deg_eg as _de

    # ── Step 1: product name + one upload widget ──────────────────────────────
    de_product = st.text_input("Product Name", key="de_product")
    de_files = st.file_uploader(
        "Upload files", accept_multiple_files=True,
        type=["pdf", "docx", "json", "xlsx", "xls"], key="de_files")
    de_excel_bytes, de_annx, _img = _route_files(de_files)

    # Analysis auto-triggers on a new upload — no separate "Analyze" click.
    _sig = f"{de_product}|" + ",".join(
        sorted(safe_str(getattr(f, "name", "")) for f in (de_files or [])))
    if de_excel_bytes and de_product and st.session_state.get("de_upload_sig") != _sig:
        st.session_state["de_upload_sig"] = _sig
        for k in ("de_composition", "de_assessment", "de_mapping", "de_annexures",
                  "de_validation", "de_meta", "de_docx_bytes", "de_report_ready",
                  "de_fname"):
            st.session_state.pop(k, None)
        try:
            composition = _de.parse_deg_eg_composition(de_excel_bytes)
            st.session_state["de_composition"] = composition

            # annexures: auto-dispatch behind ONE progress bar.
            _bar = st.progress(0, text="Analyzing files… 0%")
            annexures = _process_annexures_with_progress(
                "DEG & EG Risk Assessment", de_annx, _bar, 5, 100)
            _bar.empty()
            st.session_state["de_annexures"] = annexures
            _deg_debug_dump("debug_deg_eg_annexures.json", annexures)
            # Per-glycol evidence provenance — the only place the DEG vs EG
            # decision is auditable after the fact.
            for _a in annexures:
                if not isinstance(_a, dict):
                    continue
                _ev = _a.get("deg_eg_evidence") or {}
                logger.warning(
                    "[DEG/EG evidence] %s | DEG present=%s limit=%r source=%s "
                    "|| EG present=%s limit=%r source=%s || recoveries=%s "
                    "gc_notes=%s downgrades=%s",
                    _a.get("material_name") or _a.get("filename"),
                    _ev.get("deg_present"), _ev.get("deg_specification_limit"),
                    _ev.get("deg_source"),
                    _ev.get("eg_present"), _ev.get("eg_specification_limit"),
                    _ev.get("eg_source"),
                    _a.get("backstop_recoveries"), _a.get("guarantee_ceiling_notes"),
                    _a.get("consistency_downgrades"))

            _meta = _auto_meta(de_product, "", "DEG & EG Risk Assessment")
            _meta["title"] = ("Risk Assessment of Diethylene Glycol and "
                              "Ethylene Glycol")
            _meta["approved_date"] = ""
            st.session_state["de_meta"] = _meta
        except Exception:
            logger.exception("DEG/EG analyze error")
            st.error("Could not read the composition Excel. Please check the file.")

    composition = st.session_state.get("de_composition")
    if not composition:
        return

    if composition.get("_error"):
        logger.error("DEG/EG composition parse failed: %s",
                     composition.get("error", "unknown error"))
        st.error("The composition Excel could not be parsed. Please check the file.")
        return

    annexures = st.session_state.get("de_annexures", [])
    meta = st.session_state["de_meta"]

    # ── Map materials → annexures (reused identity resolver, no confirmation) ──
    materials = composition.get("materials", [])
    mat_names = [m["name"] for m in materials if not m.get("is_qs")]
    mapping = _de.map_materials_to_annexures(mat_names, annexures)
    assessment = _de.build_assessment(materials, mapping)
    validation = _de.validate_deg_eg(composition, assessment, None)

    st.session_state["de_mapping"] = mapping
    st.session_state["de_assessment"] = assessment
    st.session_state["de_validation"] = validation

    # Verification / mapping / warnings are internal-only — logger, never UI.
    logger.info("[DEG/EG] product=%s materials=%d annexures=%d conclusion=%s "
                "detail_tables=%d", meta["product_name"], len(mat_names),
                len(annexures), validation["conclusion_status"],
                len(assessment.get("detail_tables") or []))
    for _c, _m in mapping.items():
        logger.info("[DEG/EG mapping] %s → annexure %s (%s, conf %s)", _c,
                    _m.get("matched_annexure"), _m.get("matched_material"),
                    _m.get("confidence"))
    for _w in validation.get("warnings", []):
        logger.warning("[DEG/EG] %s", _w)

    # WARNING-FIRST: generate unless true hard errors.
    if validation["errors"]:
        for _e in validation["errors"]:
            logger.error("[DEG/EG] %s", _e)
        st.error("This composition could not be assessed: "
                 + " ".join(validation["errors"][:2]))
    elif st.button("Generate Report", type="primary", key="de_generate",
                   use_container_width=True):
        _generate_deg_eg_report()

    if st.session_state.get("de_report_ready") and st.session_state.get("de_docx_bytes"):
        st.download_button("📥 Download Report",
                           data=st.session_state["de_docx_bytes"],
                           file_name=st.session_state.get("de_fname",
                                                          "deg_eg_report.docx"),
                           mime="application/vnd.openxmlformats-officedocument."
                                "wordprocessingml.document",
                           key="de_download", use_container_width=True)


def _generate_deg_eg_report() -> None:
    """Build the DEG/EG report from session state and render via generate_deg_eg.js.
    Warning-first: generates unless hard errors or a structurally-empty payload."""
    import deg_eg as _de
    try:
        composition = st.session_state["de_composition"]
        assessment = st.session_state["de_assessment"]
        validation = st.session_state["de_validation"]
        meta = st.session_state["de_meta"]

        with st.spinner("Generating narrative…"):
            text_sections = _deg_eg_generate_text(meta, composition, assessment,
                                                  validation)

        payload = _de.build_deg_eg_payload(meta, composition, assessment,
                                           text_sections, validation)

        # FINAL HARD-STOP: only true hard errors or structurally-empty payload.
        final_val = _de.validate_deg_eg(composition, assessment, payload)
        comp_rows = sum(len(s.get("rows", [])) for s in payload.get("composition", [])
                        if isinstance(s, dict))
        if final_val["errors"] or comp_rows == 0:
            st.error("❌ Generation blocked (hard errors only): "
                     + (" ".join(final_val["errors"][:3]) if final_val["errors"]
                        else "structurally-empty payload"))
            return

        logo_bytes, logo_mt = load_logo_from_assets()
        if logo_bytes:
            payload["logo_b64"] = base64.standard_b64encode(logo_bytes).decode()
            payload["logo_type"] = logo_mt

        with st.spinner("Rendering A4 DOCX…"):
            import tempfile, subprocess
            with tempfile.NamedTemporaryFile("w", suffix=".json", delete=False,
                                             encoding="utf-8") as jf:
                _dump_payload_json(payload, jf)
                json_path = jf.name
            out_path = json_path.replace(".json", ".docx")
            script = str(Path(__file__).parent / "generate_deg_eg.js")
            r = subprocess.run(["node", script, json_path, out_path],
                               capture_output=True, text=True, timeout=120)
            if r.returncode != 0:
                raise RuntimeError(f"Renderer failed: {r.stderr[:500]}")
            with open(out_path, "rb") as f:
                docx_bytes = f.read()

        fname = (f"{meta['document_no'].replace('/','_').replace(' ','_')}_"
                 f"{datetime.now().strftime('%Y%m%d_%H%M%S')}.docx")
        st.session_state["de_docx_bytes"] = docx_bytes
        st.session_state["de_fname"] = fname
        st.session_state["de_report_ready"] = True
        st.success("✅ DEG & EG report generated.")
    except Exception as e:
        st.error(f"Generation failed: {e}")
        logger.exception("DEG/EG generate error")


# FDA high-risk excipients for DEG/EG (Glycerin, Propylene Glycol, sugar alcohols
# and other hydrogenation-derived / polyol excipients). Matched as substrings on
# the normalized material name.
_DEG_EG_FDA_HIGH_RISK = (
    "glycerin", "glycerine", "glycerol", "propylene glycol", "maltitol",
    "sorbitol", "neosorb", "sorbogem", "mannitol", "pearlitol",
    "hydrogenated starch hydrolysate", "hsh", "polysorbate", "tween",
    "polyethylene glycol", "peg", "macrogol", "polyethylene oxide",
    "hydrogenated castor oil",
)
_DEG_EG_SUGAR_ALCOHOLS = (
    "mannitol", "pearlitol", "sorbitol", "neosorb", "maltitol", "xylitol",
    "isomalt", "lactitol", "erythritol", "hydrogenated",
)


def _deg_eg_observations(observation_items: List[Dict]) -> str:
    """Deterministic Observations prose that, for EVERY material carrying DEG/EG
    evidence (confirmed OR vendor guarantee ceiling), states FDA high-risk
    membership, the vendor mechanism (from CoA raw_text where present), and the
    control strategy (specification + per-batch testing, or guarantee ceiling
    below the USP <469> Option 1 limit). RF6 / opening Fix 5."""
    if not observation_items:
        return ""
    sents: List[str] = []
    for it in observation_items:
        name = it.get("name", "")
        nlow = name.lower()
        glycols = []
        if it.get("deg_present") == "Yes" or it.get("deg_guarantee_ceiling"):
            glycols.append("Diethylene Glycol")
        if it.get("eg_present") == "Yes" or it.get("eg_guarantee_ceiling"):
            glycols.append("Ethylene Glycol")
        gtxt = " and ".join(glycols) or "DEG/EG"
        # Label each limit with its own glycol. An unlabelled join reads as if a
        # single limit covered both, which is wrong whenever only one glycol is
        # actually controlled (Polysorbate 80: EG only).
        limit = "; ".join([f"{lbl}: {v}" for lbl, v in
                           (("DEG", safe_str(it.get("deg_limit"))),
                            ("EG", safe_str(it.get("eg_limit")))) if v])
        rt = (it.get("raw_text") or "").lower()
        mlow = (it.get("matched_material") or "").lower()
        is_sugar_alcohol = any(h in nlow or h in mlow for h in _DEG_EG_SUGAR_ALCOHOLS)
        # Prefer the authoritative FDA high-risk flag set by the mapper; fall back
        # to a name/matched-material substring match.
        is_fda = (bool(it.get("high_risk_deg_eg"))
                  or any(h in nlow or h in mlow for h in _DEG_EG_FDA_HIGH_RISK)
                  or is_sugar_alcohol)
        # Vendor mechanism — prefer the CoA raw_text, else infer for polyols.
        if "hydrogenation" in rt or "hydrogenated" in rt:
            mech = " as a by-product of the hydrogenation manufacturing process"
        elif "by-product" in rt or "byproduct" in rt or "residue" in rt:
            mech = " as a manufacturing by-product"
        elif is_sugar_alcohol:
            mech = (" as a potential by-product of the catalytic hydrogenation "
                    "step used to manufacture sugar alcohols")
        else:
            mech = ""
        # FDA high-risk framing.
        if is_sugar_alcohol:
            fda_clause = (" This material falls under the FDA high-risk category "
                          "for DEG/EG (grouped with D-Sorbitol and other "
                          "hydrogenation-derived sugar alcohols).")
        elif is_fda:
            fda_clause = (f" {name} is recognised as an FDA high-risk excipient for "
                          "DEG/EG.")
        else:
            fda_clause = ""
        if it.get("guarantee_ceiling"):
            ceil = (f" The vendor guarantees the residual level below the USP <469> "
                    f"Option 1 limit"
                    + (f" ({limit})" if limit else "")
                    + "; the by-product is not quantified per batch and is "
                    "therefore not confirmed present.")
            sents.append(f"{name}: {gtxt} may occur{mech}.{fda_clause}{ceil}")
        else:
            ctrl = (f" The presence is confirmed and controlled by specification"
                    + (f" ({limit})" if limit else "")
                    + " with routine per-batch testing; the residual level is "
                    "within the applicable specification limit.")
            sents.append(f"{name} was identified as a potential source of "
                         f"{gtxt}{mech}.{fda_clause}{ctrl}")
    return " ".join(sents)


def _deg_eg_generate_text(meta: Dict, composition: Dict, assessment: Dict,
                          validation: Dict) -> Dict:
    """Generate DEG/EG narrative from STRUCTURED DATA only (no invented numbers).
    Presence is strictly Yes/No, so the conclusion is always DEFINITIVE — no
    regulatory hedging, no 'manual review', no 'Unknown'."""
    product = meta.get("product_name", "the drug product")
    status = validation.get("conclusion_status", "no_risk")
    at = assessment.get("assessment_table", [])
    positives = [r for r in at if r["deg_present"] == "Yes" or r["eg_present"] == "Yes"]

    if status == "positive_controlled" and positives:
        pos_names = ", ".join(sorted({r["ingredient"] for r in positives}))
        spec_bits = "; ".join(sorted({r["specification_limit"] for r in positives
                                      if r.get("specification_limit")
                                      and r["specification_limit"] != "Not applicable"}))
        spec_clause = (f" The presence is controlled through specification "
                       f"({spec_bits})." if spec_bits
                       else " The presence is controlled through specification.")
        conclusion = (f"Based on the overall assessment, Diethylene Glycol and/or "
                      f"Ethylene Glycol may be present in {pos_names}.{spec_clause} "
                      "As the residual levels are controlled through specification, "
                      "there is no requirement of additional drug product testing for "
                      "DEG and EG.")
    else:
        conclusion = (f"Based on the overall assessment, there is no potential risk "
                      f"of Diethylene Glycol and Ethylene Glycol in {product}. Hence, "
                      "there is no requirement of drug product testing for DEG and "
                      "EG.")

    intro = (f"This report presents a theoretical risk assessment for the potential "
             f"presence of Diethylene Glycol (DEG) and Ethylene Glycol (EG) in the "
             f"API and excipients used in {product}. The assessment is based on "
             "Certificates of Analysis, in-house specifications, and applicable "
             "regulatory guidance (USP <469>, USFDA guidance). No exposure "
             "calculations are performed; the assessment establishes presence "
             "(Yes/No) and applicable specification limits per material.")

    risk_intro = ("API and excipients were assessed for the potential presence of "
                  "Diethylene Glycol and Ethylene Glycol based on the COAs received "
                  "from the respective manufacturers, in-house specifications, and "
                  "applicable regulatory guidance. Summary of outcome is tabulated "
                  "below.")

    prompt = (
        "Write concise, factual, DEFINITIVE regulatory prose for a Diethylene "
        "Glycol (DEG) & Ethylene Glycol (EG) Risk Assessment. Do NOT invent numeric "
        "DEG/EG limits. Do NOT use any hedging language such as 'manual review', "
        "'assessment incomplete', 'unresolved', 'cannot conclude', 'Unknown', or "
        "'supplier engagement needed'. Every material has a definitive Yes or No "
        "outcome. There are NO exposure calculations. Return ONLY JSON with keys "
        "abstract, objective, background, observations, post_assessment_narrative.\n\n"
        f"Product: {product}\nDosage form: {meta.get('dosage_form','')}\n"
        f"Strength: {meta.get('strength','')}\n"
        f"Total materials assessed: {len(at)}\n"
        f"Materials with DEG/EG presence = Yes: {len(positives)}\n"
        "DEG/EG presence is evidenced from CoA / specification / USP <469>; generic "
        "policy statements are NOT material-specific limits.\n"
        "Do not state the final conclusion in these sections; it is set separately."
    )
    try:
        raw = claude_text(prompt, max_tokens=2000)
        data = _rs_safe_text_json(raw)
    except Exception:
        data = {}

    def clean(s: str) -> str:
        s = re.sub(r"\*\*(.+?)\*\*", r"\1", s or "")
        s = s.replace("`", "").replace("*", "")
        return s.strip()

    # Guard: strip any hedging the LLM may still emit.
    _HEDGE_RE = re.compile(
        r"(manual[\s-]*review|assessment incomplete|unresolved|cannot (?:be )?"
        r"draw|material-specific evidence not available|supplier engagement|"
        r"USP <469> testing required|unknown)", re.IGNORECASE)

    def de_hedge(s: str) -> str:
        return "" if s and _HEDGE_RE.search(s) else s

    pos_count = len(positives)
    obs_items = assessment.get("observation_items", []) or []
    gc_count = sum(1 for it in obs_items if it.get("guarantee_ceiling"))
    # Summary lead sentence, then the mandatory per-material mechanism narrative.
    lead = (
        f"Of {len(at)} material(s) assessed, {pos_count} showed the confirmed "
        "presence of Diethylene Glycol and/or Ethylene Glycol controlled through "
        f"specification"
        + (f", {gc_count} carried a vendor guarantee ceiling below the applicable "
           "regulatory limit (not confirmed present)" if gc_count else "")
        + f", and the remaining material(s) showed no potential DEG/EG risk."
        if (pos_count or gc_count) else
        f"All {len(at)} assessed material(s) showed no potential presence of "
        "Diethylene Glycol or Ethylene Glycol.")
    mechanism_narrative = _deg_eg_observations(obs_items)
    default_obs = (lead + " " + mechanism_narrative).strip() if mechanism_narrative \
        else lead

    return {
        "abstract": de_hedge(clean(data.get("abstract"))) or intro,
        "objective": de_hedge(clean(data.get("objective"))) or
                     (f"To assess the potential risk of Diethylene Glycol and "
                      f"Ethylene Glycol presence in the API and excipients of "
                      f"{product}."),
        "study_location": "Theoretical assessment",
        "background": de_hedge(clean(data.get("background"))) or
                      (f"{product} ({meta.get('dosage_form','')}). Diethylene Glycol "
                       "and Ethylene Glycol are known contaminants associated with "
                       "certain glycerin/glycol-based excipients and require risk "
                       "evaluation per regulatory guidance."),
        "risk_analysis_intro": risk_intro,
        "post_assessment_narrative": de_hedge(clean(data.get("post_assessment_narrative"))) or "",
        # When any material carries DEG/EG evidence, the deterministic mechanism
        # narrative is authoritative (guarantees FDA-risk + mechanism + control
        # content the LLM may omit). Only fall back to the LLM prose when there is
        # nothing to explain.
        "observations": (default_obs if obs_items
                         else (de_hedge(clean(data.get("observations"))) or default_obs)),
        "summary_conclusion": conclusion,
        "reference": [
            "USP General Chapter <469> Ethylene Glycol, Diethylene Glycol, and "
            "Triethylene Glycol in Ethoxylated Substances.",
            "USFDA Guidance for Industry — Testing of Glycerin, Propylene Glycol, "
            "and other high-risk excipients for Diethylene Glycol and Ethylene "
            "Glycol.",
        ],
    }


def _benoc_read_rows(upload) -> List[Dict]:
    """Read an OPTIONAL BE NOC gap-fill Excel/CSV upload into a list of
    {lower_header: value} dict rows. Tolerant: the first non-empty row is the
    header. Returns [] on any failure — a bad upload never blocks generation."""
    try:
        data = upload.getvalue()
        name = (getattr(upload, "name", "") or "").lower()
        if name.endswith(".csv"):
            import csv
            from io import StringIO
            text = data.decode("utf-8-sig", "replace")
            grid = [r for r in csv.reader(StringIO(text))]
        else:
            wb = openpyxl.load_workbook(BytesIO(data), data_only=True)
            ws = wb.active
            grid = [["" if c is None else str(c) for c in row]
                    for row in ws.iter_rows(values_only=True)]
        grid = [r for r in grid if any(str(c).strip() for c in r)]
        if not grid:
            return []
        headers = [str(h).strip().lower() for h in grid[0]]
        rows: List[Dict] = []
        for r in grid[1:]:
            row = {}
            for i, h in enumerate(headers):
                if h:
                    row[h] = (str(r[i]).strip() if i < len(r) and r[i] is not None else "")
            if any(row.values()):
                rows.append(row)
        return rows
    except Exception:
        logger.exception("BE NOC gap-fill tabular read failed")
        return []


def _benoc_pick(row: Dict, *needles: str) -> str:
    for n in needles:
        for h, v in row.items():
            if n in h:
                return v
    return ""


def _benoc_map_composition(rows: List[Dict]) -> List[Dict]:
    """Map optional composition rows into the multi-stage composition shape."""
    stages: Dict[str, List[Dict]] = {}
    order: List[str] = []
    for row in rows:
        ing = _benoc_pick(row, "ingredient", "material", "name")
        if not ing:
            continue
        stage = _benoc_pick(row, "stage")
        key = stage or "__default__"
        if key not in stages:
            stages[key] = []
            order.append(key)
        stages[key].append({
            "ingredient": ing,
            "role": _benoc_pick(row, "role", "function"),
            "mg_per_tab": _benoc_pick(row, "mg", "quantity", "amount", "qty"),
        })
    return [{"stage_name": ("" if s == "__default__" else s), "rows": stages[s]}
            for s in order]


def _benoc_map_equipment(rows: List[Dict]) -> List[Dict]:
    out: List[Dict] = []
    for i, row in enumerate(rows, 1):
        nm = _benoc_pick(row, "equipment", "name")
        if not nm:
            continue
        out.append({"sno": _benoc_pick(row, "sno", "s.no", "sr") or str(i),
                    "name": nm,
                    "make_model": _benoc_pick(row, "make", "model")})
    return out


def _benoc_map_dissolution(rows: List[Dict]) -> Dict:
    pts: List[Dict] = []
    for row in rows:
        t = _benoc_pick(row, "time", "minute", "min")
        if not t:
            continue
        pts.append({
            "time": t,
            "ref_pct_dr": _benoc_pick(row, "ref %dr", "reference %dr", "ref_pct_dr",
                                      "reference dr", "ref dr"),
            "ref_pct_rsd": _benoc_pick(row, "ref %rsd", "reference %rsd", "ref_pct_rsd",
                                       "ref rsd"),
            "test_pct_dr": _benoc_pick(row, "test %dr", "test_pct_dr", "test dr"),
            "test_pct_rsd": _benoc_pick(row, "test %rsd", "test_pct_rsd", "test rsd"),
        })
    if not pts:
        return {}
    return {"tables": [{"caption": "Comparative Dissolution Profile",
                        "x_axis_label": "Time (minutes)", "data_points": pts}]}


