# SQLITE — GROUND TRUTH PARAGRAPH STORE
# ═══════════════════════════════════════════════════════════════

def _db_conn():
    conn = sqlite3.connect(str(SQLITE_DB_PATH))
    conn.row_factory = sqlite3.Row
    return conn


def initialize_db():
    with _db_conn() as conn:
        conn.execute("""
            CREATE TABLE IF NOT EXISTS paragraphs (
                paragraph_id TEXT PRIMARY KEY,
                doc_id TEXT NOT NULL,
                doc_path TEXT NOT NULL,
                page_num INTEGER NOT NULL,
                para_idx INTEGER NOT NULL,
                text TEXT NOT NULL,
                token_estimate INTEGER,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            )
        """)
        conn.execute("""
            CREATE TABLE IF NOT EXISTS documents (
                doc_id TEXT PRIMARY KEY,
                filename TEXT NOT NULL,
                page_count INTEGER,
                paragraph_count INTEGER,
                indexed_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            )
        """)
        conn.execute("""
            CREATE TABLE IF NOT EXISTS claim_cache (
                cache_key TEXT PRIMARY KEY,
                verdict TEXT NOT NULL,
                confidence REAL NOT NULL,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            )
        """)
        conn.execute("CREATE INDEX IF NOT EXISTS idx_para_doc ON paragraphs(doc_id)")
        conn.commit()


def db_store_paragraph(para) -> bool:
    try:
        with _db_conn() as conn:
            conn.execute("""
                INSERT OR REPLACE INTO paragraphs
                (paragraph_id, doc_id, doc_path, page_num, para_idx, text, token_estimate)
                VALUES (?, ?, ?, ?, ?, ?, ?)
            """, (para.paragraph_id, para.doc_id, para.doc_path,
                  para.page_num, para.para_idx, para.text, para.token_estimate))
            conn.commit()
        return True
    except Exception as e:
        logger.error(f"Failed to store paragraph {para.paragraph_id}: {e}")
        return False


def db_get_paragraph(paragraph_id: str) -> Optional[Dict]:
    """Tier 1 verification check. Returns None if paragraph_id not in corpus."""
    with _db_conn() as conn:
        row = conn.execute(
            "SELECT * FROM paragraphs WHERE paragraph_id = ?", (paragraph_id,)
        ).fetchone()
        return dict(row) if row else None


def db_get_all_paragraphs() -> List[Dict]:
    with _db_conn() as conn:
        rows = conn.execute(
            "SELECT * FROM paragraphs ORDER BY doc_id, page_num, para_idx"
        ).fetchall()
        return [dict(r) for r in rows]


def db_get_corpus_stats() -> Dict:
    with _db_conn() as conn:
        para_count = conn.execute("SELECT COUNT(*) FROM paragraphs").fetchone()[0]
        doc_count = conn.execute("SELECT COUNT(*) FROM documents").fetchone()[0]
        docs = conn.execute(
            "SELECT doc_id, filename, page_count, paragraph_count, indexed_at FROM documents"
        ).fetchall()
        return {
            "paragraph_count": para_count,
            "document_count": doc_count,
            "documents": [dict(d) for d in docs]
        }


def db_store_document(doc_id: str, filename: str, page_count: int, paragraph_count: int):
    with _db_conn() as conn:
        conn.execute("""
            INSERT OR REPLACE INTO documents (doc_id, filename, page_count, paragraph_count)
            VALUES (?, ?, ?, ?)
        """, (doc_id, filename, page_count, paragraph_count))
        conn.commit()


def db_get_cached_claim(cache_key: str) -> Optional[Dict]:
    with _db_conn() as conn:
        row = conn.execute(
            "SELECT * FROM claim_cache WHERE cache_key = ?", (cache_key,)
        ).fetchone()
