<script>
// ── GRAPH DATA ──────────────────────────────────────────────────
const graphData = {
  nodes: [
    { id: "van-deemter",       label: "Van Deemter\nEquation",   category: "equation",   size: 22, active: true  },
    { id: "plate-height",      label: "Plate Height\n(H)",       category: "parameter",  size: 18, active: true  },
    { id: "band-broadening",   label: "Band\nBroadening",        category: "phenomenon", size: 16, active: true  },
    { id: "eddy-diffusion",    label: "Eddy\nDiffusion",         category: "phenomenon", size: 14, active: true  },
    { id: "column-efficiency", label: "Column\nEfficiency",      category: "parameter",  size: 18, active: true  },
    { id: "resolution",        label: "Resolution\n(Rs)",        category: "parameter",  size: 16, active: true  },
    { id: "hplc",              label: "HPLC",                    category: "technique",  size: 20, active: true  },
    { id: "uhplc",             label: "UHPLC",                   category: "technique",  size: 15, active: true  },
    { id: "column-optimization", label: "Column\nOptimization",  category: "parameter",  size: 14, active: true  },
    { id: "mobile-phase",      label: "Mobile\nPhase",           category: "parameter",  size: 14, active: false },
    { id: "stationary-phase",  label: "Stationary\nPhase",       category: "equipment",  size: 14, active: false },
    { id: "flow-rate",         label: "Flow Rate",               category: "parameter",  size: 13, active: false },
    { id: "theoretical-plates","label": "Theoretical\nPlates",   category: "parameter",  size: 15, active: true  },
    { id: "peak-width",        label: "Peak Width",              category: "phenomenon", size: 12, active: false },
  ],
  links: [
    { source: "van-deemter",    target: "plate-height",       label: "CALCULATES"   },
    { source: "van-deemter",    target: "band-broadening",    label: "DESCRIBES"    },
    { source: "van-deemter",    target: "eddy-diffusion",     label: "INCLUDES"     },
    { source: "plate-height",   target: "column-efficiency",  label: "DETERMINES"   },
    { source: "column-efficiency", target: "resolution",      label: "AFFECTS"      },
    { source: "hplc",           target: "van-deemter",        label: "USES"         },
    { source: "uhplc",          target: "hplc",               label: "EXTENDS"      },
    { source: "uhplc",          target: "column-optimization","label": "ENABLES"    },
    { source: "column-efficiency", target: "theoretical-plates", label: "MEASURED_BY" },
    { source: "band-broadening", target: "peak-width",        label: "CAUSES"       },
    { source: "flow-rate",      target: "van-deemter",        label: "INPUT_TO"     },
    { source: "mobile-phase",   target: "flow-rate",          label: "DETERMINES"   },
    { source: "stationary-phase", target: "eddy-diffusion",   label: "CAUSES"       },
    { source: "resolution",     target: "peak-width",         label: "DEPENDS_ON"   },
  ]
};

const categoryColors = {
  equation:   "#2563EB",
  parameter:  "#059669",
  technique:  "#7C3AED",
  phenomenon: "#F59E0B",
  equipment:  "#DC2626",
};

// ── RENDER GRAPH ────────────────────────────────────────────────
function renderGraph() {
  const container = document.getElementById('graph-canvas');
  const W = container.clientWidth || 320;
  const H = container.clientHeight || 400;

  d3.select('#graph-canvas').selectAll('*').remove();

  const svg = d3.select('#graph-canvas')
    .attr('width', W)
    .attr('height', H);

  // Defs: arrow markers
  const defs = svg.append('defs');
  Object.entries(categoryColors).forEach(([cat, color]) => {
    defs.append('marker')
      .attr('id', `arrow-${cat}`)
      .attr('viewBox', '0 -4 8 8')
      .attr('refX', 20).attr('refY', 0)
      .attr('markerWidth', 5).attr('markerHeight', 5)
      .attr('orient', 'auto')
      .append('path')
      .attr('d', 'M0,-4L8,0L0,4')
      .attr('fill', color)
      .attr('opacity', 0.6);
  });

  const g = svg.append('g');

  // Zoom
  svg.call(d3.zoom()
    .scaleExtent([0.4, 3])
    .on('zoom', e => g.attr('transform', e.transform))
  );

  const simulation = d3.forceSimulation(graphData.nodes)
    .force('link', d3.forceLink(graphData.links).id(d => d.id).distance(70).strength(0.5))
    .force('charge', d3.forceManyBody().strength(-200))
    .force('center', d3.forceCenter(W / 2, H / 2))
    .force('collision', d3.forceCollide().radius(d => d.size + 14));

  // Links
  const link = g.append('g').selectAll('line')
    .data(graphData.links).enter().append('line')
    .attr('stroke', d => {
      const src = graphData.nodes.find(n => n.id === (d.source.id || d.source));
      return src ? categoryColors[src.category] : '#334155';
    })
    .attr('stroke-opacity', d => {
      const src = graphData.nodes.find(n => n.id === (d.source.id || d.source));
      const tgt = graphData.nodes.find(n => n.id === (d.target.id || d.target));
      return (src?.active && tgt?.active) ? 0.5 : 0.15;
    })
    .attr('stroke-width', 1.2)
    .attr('marker-end', d => {
      const src = graphData.nodes.find(n => n.id === (d.source.id || d.source));
      return src ? `url(#arrow-${src.category})` : 'none';
    });

  // Node groups
  const nodeG = g.append('g').selectAll('g')
    .data(graphData.nodes).enter().append('g')
    .attr('cursor', 'pointer')
    .call(d3.drag()
      .on('start', (e, d) => { if (!e.active) simulation.alphaTarget(0.3).restart(); d.fx = d.x; d.fy = d.y; })
      .on('drag',  (e, d) => { d.fx = e.x; d.fy = e.y; })
      .on('end',   (e, d) => { if (!e.active) simulation.alphaTarget(0); d.fx = null; d.fy = null; })
    )
    .on('mouseover', (e, d) => showTooltip(e, d))
    .on('mousemove', (e) => moveTooltip(e))
    .on('mouseout', hideTooltip)
    .on('click', (e, d) => nodeClick(d));

  // Glow for active nodes
  nodeG.filter(d => d.active).append('circle')
    .attr('r', d => d.size + 6)
    .attr('fill', d => categoryColors[d.category])
    .attr('opacity', 0.08);

  // Main circle
  nodeG.append('circle')
    .attr('r', d => d.size)
    .attr('fill', d => d.active ? categoryColors[d.category] : '#1e2d45')
    .attr('stroke', d => categoryColors[d.category])
    .attr('stroke-width', d => d.active ? 2 : 1)
    .attr('stroke-opacity', d => d.active ? 1 : 0.4)
    .attr('opacity', d => d.active ? 1 : 0.4);

  // Labels
  nodeG.each(function(d) {
    const el = d3.select(this);
    const lines = d.label.split('\n');
    const fontSize = d.size > 16 ? 9 : 8;
    lines.forEach((line, i) => {
      el.append('text')
        .attr('text-anchor', 'middle')
        .attr('dy', `${(i - (lines.length - 1) / 2) * (fontSize + 2)}px`)
        .attr('y', 0)
        .attr('fill', d.active ? 'white' : '#475569')
        .attr('font-size', fontSize)
        .attr('font-family', 'DM Sans, sans-serif')
        .attr('font-weight', d.active ? 600 : 400)
        .attr('pointer-events', 'none')
        .text(line);
    });
  });

  simulation.on('tick', () => {
    link
      .attr('x1', d => d.source.x).attr('y1', d => d.source.y)
      .attr('x2', d => d.target.x).attr('y2', d => d.target.y);
    nodeG.attr('transform', d => `translate(${d.x},${d.y})`);
  });

  window._simulation = simulation;
  window._nodeG = nodeG;
}

// ── TOOLTIP ─────────────────────────────────────────────────────
function showTooltip(e, d) {
  const tt = document.getElementById('node-tooltip');
  document.getElementById('tt-name').textContent = d.label.replace('\n', ' ');
  document.getElementById('tt-cat').textContent = d.category.toUpperCase();
  tt.classList.add('show');
  moveTooltip(e);
}

function moveTooltip(e) {
  const tt = document.getElementById('node-tooltip');
  tt.style.left = (e.clientX + 12) + 'px';
  tt.style.top  = (e.clientY - 10) + 'px';
}

function hideTooltip() {
  document.getElementById('node-tooltip').classList.remove('show');
}

// ── NODE CLICK → show citation ───────────────────────────────────
const nodeCitations = {
  "van-deemter":       { source: "Snyder & Kirkland — Introduction to Modern LC · Page 88 · Paragraph 2", text: "The Van Deemter equation H = A + B/u + Cu represents the sum of three independent contributions to band broadening: eddy diffusion (A), longitudinal diffusion (B/u), and resistance to mass transfer (Cu). The optimal mobile phase velocity that minimises H is found at the minimum of this curve." },
  "plate-height":      { source: "Meyer — Practical HPLC · Page 134 · Paragraph 1",                       text: "Plate height H, also known as the height equivalent to a theoretical plate (HETP), is a measure of the efficiency of a chromatographic column. A smaller value of H indicates a more efficient separation with less band broadening per unit length of column." },
  "column-efficiency": { source: "Neue — HPLC Columns Theory · Page 201 · Paragraph 3",                   text: "Column efficiency N is calculated as N = L/H, where L is the column length and H is the plate height. High efficiency columns with small plate heights and large numbers of theoretical plates produce narrower peaks and better resolution." },
  "hplc":              { source: "Snyder & Kirkland — Introduction to Modern LC · Page 12 · Paragraph 1",  text: "High-performance liquid chromatography (HPLC) is a chromatographic technique used to separate, identify, and quantify each component in a mixture. It relies on pumps to pass a pressurised liquid solvent containing the sample mixture through a column filled with solid adsorbent material." },
  "uhplc":             { source: "Snyder & Kirkland — Introduction to Modern LC · Page 91 · Paragraph 1",  text: "Ultra-high performance liquid chromatography (UHPLC) employs sub-2µm stationary phase particles, which shift the Van Deemter minimum to higher linear velocities. This allows faster flow rates without sacrificing chromatographic efficiency, reducing analysis time substantially." },
  "resolution":        { source: "Meyer — Practical HPLC · Page 138 · Paragraph 2",                       text: "Resolution Rs between two adjacent peaks is defined as the ratio of the separation between peak maxima to the average peak width at base. Resolution is a function of selectivity, retention, and efficiency — all three must be optimised for adequate separation." },
};

function nodeClick(d) {
  const cite = nodeCitations[d.id];
  if (!cite) return;
  const popup = document.getElementById('citation-popup');
  document.getElementById('popup-source').textContent = cite.source;
  document.getElementById('popup-text').textContent = cite.text;
  popup.style.top = '80px';
  popup.style.right = '336px';
  popup.classList.add('show');
}

// ── INLINE CITATIONS ─────────────────────────────────────────────
const citations = [
  { source: "Snyder & Kirkland — Introduction to Modern LC · Page 88 · Paragraph 2", text: "The Van Deemter equation H = A + B/u + Cu represents the sum of three independent contributions to band broadening: eddy diffusion (A), longitudinal diffusion (B/u), and resistance to mass transfer (Cu)." },
  { source: "Meyer — Practical HPLC · Page 134 · Paragraph 1",                       text: "The A term accounts for eddy diffusion arising from the multiple flow paths available to solute molecules as they pass through the irregularly packed bed of stationary phase particles." },
  { source: "Neue — HPLC Columns Theory · Page 201 · Paragraph 3",                   text: "Column efficiency N = L/H, where L is the column length in millimetres and H is the plate height. A larger N indicates a more efficient column capable of producing sharper, better-resolved peaks." },
  { source: "Snyder & Kirkland — Introduction to Modern LC · Page 91 · Paragraph 1",  text: "Sub-2µm particle columns exhibit a Van Deemter minimum at significantly higher linear velocities than conventional 5µm columns, enabling UHPLC operation at high flow rates without loss of efficiency." },
  { source: "Meyer — Practical HPLC · Page 138 · Paragraph 2",                       text: "Operating at flow rates significantly above or below the Van Deemter optimum results in measurable efficiency loss, manifesting as increased peak width and reduced resolution between adjacent peaks." },
];

function showCitation(i) {
  const popup = document.getElementById('citation-popup');
  document.getElementById('popup-source').textContent = citations[i].source;
  document.getElementById('popup-text').textContent = citations[i].text;
  const rect = event.target.getBoundingClientRect();
  popup.style.top  = (rect.bottom + 8) + 'px';
  popup.style.left = Math.min(rect.left, window.innerWidth - 300) + 'px';
  popup.style.right = 'auto';
  popup.classList.add('show');
  event.stopPropagation();
}

function hideCitation() {
  document.getElementById('citation-popup').classList.remove('show');
}

document.addEventListener('click', e => {
  if (!e.target.closest('.citation-popup') && !e.target.classList.contains('inline-cite')) {
    hideCitation();
  }
});

// ── CLAIM HIGHLIGHT ──────────────────────────────────────────────
function highlightClaim(el, i) {
  document.querySelectorAll('.claim-row').forEach(r => r.classList.remove('active'));
  el.classList.add('active');
  showCitation(i);
}

// ── CONCEPT HIGHLIGHT ────────────────────────────────────────────
document.querySelectorAll('.concept-highlight').forEach(el => {
  el.addEventListener('click', () => {
    const nodeId = el.dataset.node;
    const node = graphData.nodes.find(n => n.id === nodeId);
    if (node) nodeClick(node);
  });
});

// ── MODE TOGGLE ──────────────────────────────────────────────────
function setMode(mode, btn) {
  document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

// ── QUERY SUBMIT ─────────────────────────────────────────────────
function handleKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); submitQuery(); }
}

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 100) + 'px';
}

function submitQuery() {
  const input = document.getElementById('query-input');
  const q = input.value.trim();
  if (!q) return;

  document.getElementById('current-query').textContent = q;
  input.value = '';
  input.style.height = 'auto';

  const area = document.getElementById('answer-area');
  const block = document.getElementById('answer-block');
  block.innerHTML = `<div class="thinking"><div class="thinking-dots"><span></span><span></span><span></span></div> Decomposing query · Searching FAISS · Traversing Neo4j...</div>`;

  setTimeout(() => {
    block.innerHTML = `
      <div class="answer-header">
        <div class="answer-source">
          <span class="model-tag">GPT-4o · Hybrid</span>
          <span class="model-tag" style="background:rgba(5,150,105,0.12);color:#34D399;border-color:rgba(5,150,105,0.2)">Neo4j 2-hop</span>
        </div>
        <div class="verification-summary">✓ Processing claims...</div>
      </div>
      <div class="answer-text">
        <p>Retrieving and verifying answer from your HPLC corpus. All claims are being verified against source paragraphs using the DeBERTa NLI firewall.</p>
        <div class="thinking" style="margin-top:8px"><div class="thinking-dots"><span></span><span></span><span></span></div> Verifying 4 claims...</div>
      </div>`;
  }, 1800);
}

// ── UPLOAD ───────────────────────────────────────────────────────
function triggerUpload() {
  const input = document.createElement('input');
  input.type = 'file';
  input.accept = 'image/*';
  input.onchange = e => {
    const file = e.target.files[0];
    if (file) {
      document.getElementById('query-input').value = `[Chromatogram: ${file.name}] `;
      document.getElementById('query-input').focus();
    }
  };
  input.click();
}

// ── HISTORY NAV ──────────────────────────────────────────────────
function loadQuery(i) {
  document.querySelectorAll('.history-item').forEach((el, j) => {
    el.classList.toggle('active', i === j);
  });
}

// ── GRAPH CONTROLS ───────────────────────────────────────────────
function resetGraph() {
  d3.select('#graph-canvas').transition().duration(500)
    .call(d3.zoom().transform, d3.zoomIdentity);
}

function expandGraph() {
  if (window._simulation) {
    window._simulation.alpha(0.5).restart();
  }
}

// ── INIT ─────────────────────────────────────────────────────────
window.addEventListener('load', () => {
  renderGraph();
  window.addEventListener('resize', renderGraph);
});
</script>

