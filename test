def generate_report(annexure_data: List[dict],
                    excel_data: dict,
                    obs_text: str,
                    conc_text: str) -> BytesIO:
    doc = Document()

    # Page setup: A4, 1-inch margins
    for section in doc.sections:
        section.page_width  = Inches(8.5)
        section.page_height = Inches(11)
        section.left_margin   = Inches(0.75)
        section.right_margin  = Inches(0.75)
        section.top_margin    = Inches(1.2)
        section.bottom_margin = Inches(0.75)

    # Default paragraph style
    style = doc.styles["Normal"]
    style.font.name  = "Arial"
    style.font.size  = Pt(9)

    add_page_header(doc)
    add_page_footer(doc)

    # Build all sections
    build_title_page(doc)
    build_toc(doc)
    build_abstract_section(doc)
    build_composition_table(doc, excel_data)
    build_fishbone_diagram(doc)
    build_sources_and_excipient_section(doc, annexure_data)
    build_manufacturing_section(doc)
    build_mdd_tables(doc)
    build_calculation_tables(doc, excel_data)
    build_observations(doc, obs_text, conc_text)
    build_annexure_list(doc)
    build_revision_history(doc)
    build_signature_page(doc)

    buf = BytesIO()
    doc.save(buf)
    buf.seek(0)
    return buf


