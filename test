def _rs_norm(text: str) -> str:
    s = _s(text).lower()
    s = s.replace("\u00ae", " ").replace("\u2122", " ").replace("&", " and ")
    s = re.sub(r"[^a-z0-9]+", " ", s)
    return re.sub(r"\s+", " ", s).strip()


def _rs_canonical_tokens(text: str) -> set:
    """Identity tokens with noise removed. Generic suffix tokens are KEPT here
    but down-weighted later; pure-noise tokens are dropped."""
    out = set()
    for t in _rs_norm(text).split():
        if len(t) <= 1 or t in _RS_NOISE:
            continue
        out.add(t)
    return out


def _rs_strip_descriptor_phrases(text: str) -> str:
    """String-level strip of specification / grade / pharmacopoeia / purity
    phrases before identity normalization. Product-agnostic."""
    if not text:
        return ""
    s = _s(text)
    s = _RS_DESCRIPTOR_PHRASE_RE.sub(" ", s)
    s = _RS_PURITY_DESCRIPTORS_RE.sub(" ", s)
    return re.sub(r"\s+", " ", s).strip()


def _rs_paren_tokens(text: str) -> set:
    extras: set = set()
    for m in re.finditer(r"\(([^)]+)\)", _s(text)):
        for t in _rs_norm(m.group(1)).split():
            if len(t) > 1 and t not in _RS_NOISE:
                extras.add(t)
    return extras


def _rs_extras_from_name(text: str) -> set:
    extras: set = set()
    low = _s(text).lower()
    for sfx in _RS_SALT_SUFFIXES + _RS_HYDRATE_SUFFIXES:
        if re.search(rf"\b{re.escape(sfx)}\b", low):
            extras.add(sfx)
    for m in _RS_PURITY_DESCRIPTORS_RE.finditer(text):
        extras.add(re.sub(r"\s+", "_", m.group(0).lower().strip()))
    return extras


def _rs_identity_norm(text: str) -> str:
    """Fully-stripped normalized identity STRING for exact-match tests.
    Same rules as deg_eg._identity_norm: strips paren content, descriptor
    phrases, salt / hydrate suffixes, purity descriptors, noise, and standalone
    digits. Product-agnostic \u2014 never touches chemistry identity words."""
    if not text:
        return ""
    s = _s(text)
    s = re.sub(r"\([^)]*\)", " ", s)
    s = _rs_strip_descriptor_phrases(s)
    for sfx in _RS_SALT_SUFFIXES + _RS_HYDRATE_SUFFIXES:
        s = re.sub(rf"\b{re.escape(sfx)}\b", " ", s, flags=re.IGNORECASE)
    tokens = []
    for t in _rs_norm(s).split():
        if t in _RS_NOISE or t.isdigit() or len(t) <= 1:
            continue
        tokens.append(t)
    return " ".join(sorted(set(tokens)))


def _rs_filename_derived_name(filename: str) -> str:
    """Strip filename to a plausible material subject. Same rules as
    deg_eg._filename_derived_name \u2014 kept isolated to avoid a cross-module dep."""
    if not filename:
        return ""
    s = _s(filename)
    s = re.sub(r"\.(pdf|json|docx?|xlsx?|png|jpe?g|tiff?)$", "", s, flags=re.IGNORECASE)
    s = re.sub(r"[\(\[]?\s*annexure[\s_\-]*\d+\s*[\)\]]?", " ", s, flags=re.IGNORECASE)
    s = re.sub(r"\b(RCQR|RCRR|GRN|AR|ATR|SAP)[\-_ ]?\d{2,}\b", " ", s, flags=re.IGNORECASE)
    s = re.sub(r"[_\-]+", " ", s)
    s = re.sub(r"\b\d{4}[\-/]\d{2}[\-/]\d{2}\b", " ", s)
    s = re.sub(r"\b\d{2}[\-/]\d{2}[\-/]\d{4}\b", " ", s)
    s = re.sub(r"\b\d{8,}\b", " ", s)
    _docwords = (r"coa|certificate\s+of\s+analysis|specification|spec|declaration|"
                 r"statement|sds|msds|regulatory|quality|residual\s+solvents?|"
                 r"annexure|monograph|information|report|final|copy")
    s = re.sub(r"\b(" + _docwords + r")\b", " ", s, flags=re.IGNORECASE)
    s = re.sub(r"\s+", " ", s).strip(" -\u2013:_")
    if not s or re.fullmatch(r"[\d\s.]+", s):
        return ""
    return s


def _rs_detect_family(text: str) -> Tuple[str, str]:
    """Return (family, family_key) if any alias appears in the text, else ('','')."""
    norm = _rs_norm(text)
    norm_padded = f" {norm} "
    best = ("", "")
    best_len = 0
    for alias, fam in _RS_ALIAS_TO_FAMILY.items():
        a = _rs_norm(alias)
        if not a:
            continue
        if f" {a} " in norm_padded:
            if len(a) > best_len:        # prefer the most specific (longest) alias
                best = (fam, _RS_ALIAS_TO_KEY[alias])
                best_len = len(a)
    return best


def _rs_strip_descriptor_name(name: str) -> str:
    """Recover the material subject from a '<descriptor> for <material>' phrase."""
    return rs_strip_descriptor(name)


def _rs_identity(text: str) -> Dict[str, Any]:
    """Build an identity record for a component or annexure source string."""
    raw = _s(text)
    stripped = _rs_strip_descriptor_name(raw) or raw
    stripped = _rs_strip_descriptor_phrases(stripped)
    fam, fam_key = _rs_detect_family(stripped)
    toks = _rs_canonical_tokens(stripped)
    # Fold paren-content and salt/hydrate extras into the token pool for
    # containment / overlap tiers.
    toks |= _rs_paren_tokens(raw)
    toks |= _rs_extras_from_name(raw)
    fam_tokens = set()
    if fam:
        fam_tokens = _rs_canonical_tokens(fam)
    return {
        "raw": raw, "norm": _rs_norm(stripped),
        "tokens": toks, "family": fam, "family_key": fam_key,
        "family_tokens": fam_tokens,
        "identity_norm": _rs_identity_norm(raw),
    }


def _rs_distinctive(tokens: set) -> set:
    return {t for t in tokens if t not in _RS_GENERIC_TOKENS}


def _rs_pair_blocked(fam_a: str, fam_b: str) -> bool:
    if not fam_a or not fam_b or fam_a == fam_b:
        return False
    for x, y in _RS_NEGATIVE_FAMILY_PAIRS:
        if {fam_a, fam_b} == {x, y}:
            return True
    return False


def _rs_pool_identity(ann: Dict) -> Dict[str, Any]:
    """Pool identity from material_name, candidates, filename-derived name,
    title, supplier. Also emit per-source normalized identity strings for
    Tier 1/2 exact-match tests."""
    primary = _s(ann.get("material_name"))
    candidates = [_s(c) for c in (ann.get("material_name_candidates") or []) if _s(c)]
    filename_derived = _rs_filename_derived_name(_s(ann.get("filename")))
    title = _s(ann.get("document_title"))
    supplier = _s(ann.get("supplier_name"))

    kinded: List[Tuple[str, str]] = []
    if primary:
        kinded.append(("material_name", primary))
    for c in candidates:
        kinded.append(("candidate", c))
    if filename_derived:
        kinded.append(("filename", filename_derived))
    if title:
        kinded.append(("title", title))
    if supplier:
        kinded.append(("supplier", supplier))

    tokens: set = set()
    fam, fam_key = "", ""
    identity_norms: List[Tuple[str, str]] = []
    for kind, s in kinded:
        idd = _rs_identity(s)
        tokens |= idd["tokens"]
        tokens |= idd["family_tokens"]
        if idd["family"] and not fam:
            fam, fam_key = idd["family"], idd["family_key"]
        n = idd.get("identity_norm", "")
        if n:
            identity_norms.append((kind, n))

    return {"tokens": tokens, "family": fam, "family_key": fam_key,
            "sources": [s for _k, s in kinded],
            "identity_norms": identity_norms,
            "filename_derived": filename_derived}


def _rs_score(comp_id: Dict[str, Any], ann_id: Dict[str, Any]) -> Tuple[float, str]:
    """Sequential-tier identity similarity in [0,1] with a reason. Never
    short-circuits at 0 for a missing family — token-based tiers always run so
    any molecule is scorable without pre-registration.

    Tier 1 (0.99): exact normalized match to annexure material_name
    Tier 2 (0.99): exact normalized match to any candidate
    Tier 3 (0.97): recognised family alias match
    Tier 4 (0.90): distinctive-token containment (either direction)
    Tier 5 (0.50–0.85): Jaccard + distinctive overlap fallback
    Tier 6 (0.95): exact normalized match to filename-derived name

    Negative family pairs are always blocked (0.0).
    """
    cfam, afam = comp_id.get("family", ""), ann_id.get("family", "")
    if _rs_pair_blocked(cfam, afam):
        return 0.0, f"blocked negative pair {cfam} vs {afam}"

    c_norm = comp_id.get("identity_norm", "")
    identity_norms: List[Tuple[str, str]] = ann_id.get("identity_norms", [])

    # Tier 1 & 2: exact normalized match against material_name or any candidate.
    if c_norm:
        for kind, a_norm in identity_norms:
            if a_norm and c_norm == a_norm and kind in ("material_name", "candidate"):
                return 0.99, f"exact normalized match to {kind}"
        # Tier 6: filename-derived name exact
        for kind, a_norm in identity_norms:
            if kind == "filename" and a_norm and c_norm == a_norm:
                return 0.95, "exact match to filename-derived name"

    # Tier 3: recognised family alias match
    if cfam and afam and cfam == afam:
        return 0.97, f"family match: {cfam}"

    # Partial family match retained — one family name contained in the other AND
    # at least one shared non-generic token. Handles Yellow Iron Oxide ↔ Iron
    # Oxide, Anhydrous Citric Acid ↔ Citric Acid, Purified Talc ↔ Talc.
    if cfam and afam and cfam != afam:
        cfam_toks = set(cfam.split())
        afam_toks = set(afam.split())
        if cfam_toks <= afam_toks or afam_toks <= cfam_toks:
            shared_distinct = (_rs_distinctive(cfam_toks)
                               & _rs_distinctive(afam_toks))
            if shared_distinct:
                return 0.90, f"partial family match: {cfam} ~ {afam}"

    ctoks = comp_id.get("tokens", set()) | comp_id.get("family_tokens", set())
    atoks = ann_id.get("tokens", set())
    if not ctoks or not atoks:
        return 0.0, "no tokens"

    inter = ctoks & atoks
    union = ctoks | atoks
    jaccard = len(inter) / len(union) if union else 0.0

    dist_c = _rs_distinctive(ctoks)
    dist_a = _rs_distinctive(atoks)
    dist_inter = dist_c & dist_a
    dist_union = dist_c | dist_a
    dist_overlap = len(dist_inter) / len(dist_union) if dist_union else 0.0

    # Tier 4: distinctive-token containment
    if dist_c and dist_a and dist_inter:
        smaller, larger = ((dist_c, dist_a) if len(dist_c) <= len(dist_a)
                           else (dist_a, dist_c))
        if smaller and smaller <= larger:
            return 0.90, f"distinctive token containment {sorted(smaller)}"

    contain = 0.0
    if dist_c and dist_a:
        smaller, larger = ((dist_c, dist_a) if len(dist_c) <= len(dist_a)
                           else (dist_a, dist_c))
        if smaller:
            contain = len(smaller & larger) / len(smaller)

    if not dist_inter:
        return round(0.12 * jaccard, 4), "generic-only overlap"

    # Tier 5: Jaccard + distinctive overlap fallback (0.50–0.85 typical)
    score = 0.30 * jaccard + 0.40 * dist_overlap + 0.30 * contain
    return round(min(0.85, max(0.0, score)), 4), \
        f"distinctive overlap {sorted(dist_inter)}"


def map_components_to_annexures(components: List[str],
                                annexures: List[Dict]) -> Dict[str, Dict]:
    """
    Resolve each Excel component to an RS annexure using the ported identity
    resolver: descriptor stripping, identity pooling, family/brand recognition,
    distinctive-token scoring, negative-pair protection, confidence + needs-
    confirmation. Product-agnostic; no one-off product mappings.
    """
    ann_records = []
    for ann in annexures:
        if isinstance(ann, dict) and not ann.get("_error"):
            ann_records.append((ann, _rs_pool_identity(ann)))

    result: Dict[str, Dict] = {}
    for comp in components:
        comp_id = _rs_identity(comp)
        best = None
        best_score = 0.0
        best_reason = ""
        runner = 0.0
        for ann, ann_id in ann_records:
            score, reason = _rs_score(comp_id, ann_id)
            if score > best_score:
                runner = best_score
                best_score, best, best_reason = score, ann, reason
            elif score > runner:
                runner = score

        if best is not None and best_score >= 0.85:
            confidence = round(best_score, 2)
            result[comp] = {
                "matched_annexure": best.get("annexure_number"),
                "matched_material": best.get("material_name", ""),
                "confidence": confidence,
                "match_reason": best_reason,
                "evidence_fields": ["material_name", "material_name_candidates",
                                    "document_title", "supplier_name", "filename"],
                "needs_confirmation": False,
                "validation_flags": [],
                "_annexure": best,
            }
        elif best is not None and best_score >= 0.60:
            confidence = round(best_score, 2)
            result[comp] = {
                "matched_annexure": best.get("annexure_number"),
                "matched_material": best.get("material_name", ""),
                "confidence": confidence,
                "match_reason": best_reason,
                "evidence_fields": ["material_name", "material_name_candidates",
                                    "document_title", "supplier_name", "filename"],
                "needs_confirmation": False,
                "validation_flags": [],
                "_annexure": best,
            }
        else:
            result[comp] = {
                "matched_annexure": None, "matched_material": "",
                "confidence": 0.0,
                "match_reason": (f"no confident identity match (best {best_score:.2f})"
                                 if best is not None else "no candidates"),
                "evidence_fields": [], "needs_confirmation": True,
                "validation_flags": ["unresolved"], "_annexure": None,
            }

    # Cluster enrichment: for a material documented by MORE THAN ONE annexure
    # (e.g. Trilaciclib 2HCl RS declaration + a separate TFA declaration, or a
    # Chlorobutanol CoA + declaration), replace the mapped annexure with a
    # cluster-merged copy so the pooled solvent UNIVERSE + best code/supplier/spec
    # flow through every downstream consumer unchanged. A size-1 cluster is a
    # no-op (the mapped object is left exactly as-is) — RS baselines untouched.
    try:
        import annexure_identity_clustering as _AC
        _clusters = _AC.cluster_annexures_by_identity(annexures)
        _cl_by_id = {id(a): cl for cl in _clusters
                     for a in cl.get("annexures", []) if isinstance(a, dict)}
    except Exception:
        _cl_by_id = {}
    for _comp, _mp in result.items():
        _best = _mp.get("_annexure")
        if not isinstance(_best, dict):
            continue
        _cl = _cl_by_id.get(id(_best))
        _mp["_cluster"] = _cl
        if _cl and _cl.get("cluster_size", 1) > 1:
            _merged = merge_rs_evidence(_cl)
            _enriched = dict(_best)
            _enriched["solvents"] = _merged["solvents"]
            if not _s(_enriched.get("material_code")) and _merged["material_code"]:
                _enriched["material_code"] = _merged["material_code"]
            if not _s(_enriched.get("supplier_name")) and _merged["supplier"]:
                _enriched["supplier_name"] = _merged["supplier"]
            if not _s(_enriched.get("drl_specification_no")) and _merged["drl_spec_no"]:
                _enriched["drl_specification_no"] = _merged["drl_spec_no"]
            if _merged["negative_declaration"]:
                _enriched["negative_declaration"] = True
            _mp["_annexure"] = _enriched
    return result


