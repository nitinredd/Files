def parse_excel(excel_bytes: bytes) -> dict:
    """
    Parse the uploaded Excel file.
    Returns a dict with keys:
      composition  – list of rows for Table 1
      class1_2a    – rows for Table 5
      class2b      – rows for Table 6
      class3       – rows for Table 7
    
    Expected sheet layout (configure SHEET_NAMES below to match your file):
    """
    COMPOSITION_SHEET = "Composition"   # Sheet tab name – adjust if different
    CALC_SHEET        = "Calculations"  # Sheet with Tables 5-7  – adjust if needed

    wb = openpyxl.load_workbook(BytesIO(excel_bytes), data_only=True)
    result = {
        "composition": [],
        "class1_2a":   [],
        "class2b":     [],
        "class3":      [],
        "raw_sheets":  wb.sheetnames,
    }

    # ── Composition Table ──────────────────────────────────────────────────
    if COMPOSITION_SHEET in wb.sheetnames:
        ws = wb[COMPOSITION_SHEET]
        rows = list(ws.iter_rows(values_only=True))
        # Skip header row, collect non-empty rows
        for row in rows[1:]:
            if any(c is not None for c in row):
                result["composition"].append([str(c) if c is not None else "" for c in row])
    else:
        # Try first sheet as fallback
        ws = wb.worksheets[0]
        rows = list(ws.iter_rows(values_only=True))
        for row in rows[1:]:
            if any(c is not None for c in row):
                result["composition"].append([str(c) if c is not None else "" for c in row])

    # ── Calculation Tables ────────────────────────────────────────────────
    for sheet_name, key in [("Class1_2A", "class1_2a"),
                              ("Class2B",   "class2b"),
                              ("Class3",    "class3")]:
        if sheet_name in wb.sheetnames:
            ws = wb[sheet_name]
            rows = list(ws.iter_rows(values_only=True))
            result[key] = [[str(c) if c is not None else "" for c in row]
                           for row in rows if any(c is not None for c in row)]

    wb.close()
    return result


