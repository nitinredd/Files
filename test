- Class 2B total EI exposures: {json.dumps({sym: calc_tables['class2b']['element_totals'].get(sym) for sym in TABLE6_ELEMENTS}, indent=2)}
- Class 3 total EI exposures: {json.dumps({sym: calc_tables['class3']['element_totals'].get(sym) for sym in TABLE7_ELEMENTS}, indent=2)}
- ICH Q3D Class 1+2A PDEs: {json.dumps({sym: ICH_PDE[sym]['pde'] for sym in TABLE5_ELEMENTS})}
- MDD sachets: {comp_data.get("mdd_sachets", 6)}, MDD strength: {comp_data.get("mdd_strength","40mg")}

Any elements crossing 30% PDE:
{json.dumps({sym: {"total": calc_tables['class1_2a']['element_totals'].get(sym,0),
                   "pde30": ICH_PDE[sym]['pde']*0.3 if ICH_PDE[sym]['pde'] else None}
             for sym in TABLE5_ELEMENTS
             if ICH_PDE[sym]['pde'] and
             calc_tables['class1_2a']['element_totals'].get(sym,0) > ICH_PDE[sym]['pde']*0.3}, indent=2)}

Generate the following sections as JSON. Be specific, factual, and consistent with ICH Q3D regulatory language.
Return ONLY this JSON:
{{
  "abstract": "...",
  "objective": "...",
  "study_location": "NA",
  "background": "...",
  "sources_intro": "...",
  "drug_substance_section": "...",
  "excipient_intro": "...",
  "manufacturing_section": "...",
  "container_closure_section": "...",
  "utilities_section": "...",
  "control_strategy": "...",
  "observation": "...",
  "conclusion": "..."
}}"""

    raw = claude_text(prompt, max_tokens=6000)
    try:
        s = raw.find("{"); e = raw.rfind("}") + 1
        return json.loads(raw[s:e])
    except Exception as ex:
        logger.error(f"Text generation error: {ex}")
        # Return basic sections if parsing fails
        return {k: "" for k in ["abstract","objective","study_location","background",
                                 "sources_intro","drug_substance_section","excipient_intro",
                                 "manufacturing_section","container_closure_section",
                                 "utilities_section","control_strategy","observation","conclusion"]}

# ─────────────────────────────────────────────────────────────────────────────
# STEP 6 – ASSEMBLE report_data.json → call Node.js
# ─────────────────────────────────────────────────────────────────────────────

def assemble_and_generate(
    ref_structure: Dict,
    page_images: List[bytes],
    figure_pages: List[Dict],
    embedded_images: Dict[int, List[bytes]],
    annexure_data: List[Dict],
    comp_data: Dict,
    calc_tables: Dict,
    text_sections: Dict,
) -> bytes:
    """
    Build the report_data.json and call generate_report.js to produce the DOCX.
    Returns DOCX bytes.
    """
    # Encode figure images as base64
    figures_b64 = []
    for fig in figure_pages:
        pi = fig["page_index"]
        # Try embedded image first; fall back to full-page raster
        if pi in embedded_images and embedded_images[pi]:
            img_bytes = embedded_images[pi][0]
        elif pi < len(page_images):
            img_bytes = page_images[pi]
        else:
            continue
        figures_b64.append({
            "page_index":   pi,
            "description":  fig.get("description", ""),
            "figure_label": fig.get("figure_label", "Figure 1"),
            "data_b64":     base64.standard_b64encode(img_bytes).decode(),
        })

    # Build annexure list for Table 8
    annexure_list = []
    for ann in annexure_data:
        annexure_list.append({
            "material":  ann.get("material_name", "N/A"),
            "supplier":  ann.get("supplier_name", "N/A"),
            "annexure":  f"Annexure {ann.get('annexure_number', '?')}",
        })

    report_data = {
        "meta":            ref_structure.get("meta", {}),
        "text_sections":   text_sections,
        "composition":     comp_data.get("sections", []),
        "annexure_list":   annexure_list,
        "calc_tables":     calc_tables,
        "revision_history":ref_structure.get("revision_history", []),
        "signatures":      ref_structure.get("signatures", []),
        "figures":         figures_b64,
        "pde_values":      {sym: ICH_PDE[sym] for sym in ICH_PDE},
    }

    # Write JSON and call Node.js
    with tempfile.TemporaryDirectory() as tmpdir:
        json_path  = Path(tmpdir) / "report_data.json"
        docx_path  = Path(tmpdir) / "report.docx"
        js_script  = Path(__file__).parent / "generate_report.js"

        with open(json_path, "w", encoding="utf-8") as f:
            json.dump(report_data, f, ensure_ascii=False)

        result = subprocess.run(
            ["node", str(js_script), str(json_path), str(docx_path)],
            capture_output=True, text=True, timeout=120
        )
        if result.returncode != 0:
            raise RuntimeError(f"Node.js error:\n{result.stderr}")

        return docx_path.read_bytes()


