def rasterize_pdf_pages(pdf_bytes: bytes, dpi: int = 200) -> List[bytes]:
    """Render every PDF page to an RGB PNG."""
    doc = fitz.open(stream=pdf_bytes, filetype="pdf")
    pages: List[bytes] = []
    mat = fitz.Matrix(dpi / 72, dpi / 72)
    for page in doc:
        pix = page.get_pixmap(matrix=mat, alpha=False, colorspace=fitz.csRGB)
        pages.append(pix.tobytes("png"))
    doc.close()
    return pages


def extract_figure_from_page(pdf_bytes: bytes, page_index: int,
                              dpi: int = 200) -> bytes:
    """
    Rasterize one page and crop out the top 38% (IPDO header + caption row),
    returning only the diagram area as an RGB PNG.
    """
    doc = fitz.open(stream=pdf_bytes, filetype="pdf")
    try:
        page = doc.load_page(page_index)
        rect = page.rect
        crop = fitz.Rect(
            rect.x0 + rect.width  * 0.02,
            rect.y0 + rect.height * 0.38,  # skip top 38%
            rect.x1 - rect.width  * 0.02,
            rect.y1 - rect.height * 0.03,
        )
        mat = fitz.Matrix(dpi / 72, dpi / 72)
        pix = page.get_pixmap(
            matrix=mat, alpha=False, colorspace=fitz.csRGB, clip=crop,
        )
        return pix.tobytes("png")
    finally:
        doc.close()


