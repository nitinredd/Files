# ── Safe utilities ────────────────────────────────────────────────────────────
def safe_int(v: Any, default: int = 0) -> int:
    if isinstance(v, int): return v
    try: return int(float(str(v).strip()))
    except: return default

def safe_float(v: Any, default: float = 0.0) -> float:
    if isinstance(v, float): return v
    try: return float(str(v).strip().replace(",",""))
    except: return default

def safe_str(v: Any, default: str = "") -> str:
    return str(v).strip() if v is not None else default


# ════════════════════════════════════════════════════════════════════════════
# JSON SAFETY (shared by all four workflows)
# Identity clustering, dedup tracking and footnote parsing all use sets/
# frozensets internally for O(1) lookups. Those must never reach json.dump.
# Sets are converted at the payload boundary (_sanitize_payload); _json_safe
# is the last-resort net so a renderer hand-off can never die on a stray type.
# ════════════════════════════════════════════════════════════════════════════
def _json_safe(o: Any) -> Any:
    """json.dump(default=...) fallback for types the encoder can't handle."""
    if isinstance(o, (set, frozenset)):
        return sorted((_json_safe(v) for v in o), key=str)
    if hasattr(o, "isoformat"):                       # datetime / date
        try:
            return o.isoformat()
        except Exception:
            return str(o)
    return str(o)


def _sanitize_payload(obj: Any) -> Any:
    """Recursively convert sets/tuples to lists so a payload is JSON-safe.
    Applied once per generation, immediately before the renderer hand-off."""
    if isinstance(obj, (set, frozenset)):
        return sorted((_sanitize_payload(v) for v in obj), key=str)
    if isinstance(obj, dict):
        # json.dump's default= hook never fires for KEYS, so a tuple/set key
        # would still raise. Coerce anything the encoder can't key on.
        return {(k if isinstance(k, (str, int, float, bool)) or k is None
                 else str(k)): _sanitize_payload(v)
                for k, v in obj.items()}
    if isinstance(obj, (list, tuple)):
        return [_sanitize_payload(v) for v in obj]
    return obj


def _dump_payload_json(payload: Any, fh) -> None:
    """Single serialization entry point for every workflow's renderer hand-off."""
    json.dump(_sanitize_payload(payload), fh, ensure_ascii=False,
              default=_json_safe)


def safe_json_parse(text: str, default: Any = None) -> Any:
    if default is None: default = {}
    if not text: return default
    for fn in [
        lambda t: json.loads(t),
        lambda t: json.loads(t[t.find("{"):t.rfind("}")+1]),
        lambda t: json.loads(t[t.find("["):t.rfind("]")+1]),
    ]:
        try: return fn(text)
        except: pass
    return default

def safe_list_get(lst: Any, idx: int, default: Any = None) -> Any:
    try:
        if lst and 0 <= idx < len(lst): return lst[idx]
    except: pass
    return default

def safe_calc_table(calc_tables: Optional[Dict], key: str) -> Dict:
    empty = {"elements":[],"rows":[],"total_daily_intake":0.0,
             "element_totals":{},"pde":{},"threshold_30pct":{}}
    if not calc_tables or not isinstance(calc_tables, dict): return dict(empty)
    t = calc_tables.get(key)
    if not t or not isinstance(t, dict): return dict(empty)
    out = dict(empty); out.update(t); return out


