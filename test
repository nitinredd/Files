#SandDissolve
import { useEffect, useRef } from 'react'

/**
 * SandDissolve — canvas-based per-pixel particle physics dissolution.
 * Renders text on an offscreen canvas, samples pixels, and animates
 * them as particles swept left-to-right across the full viewport.
 *
 * Props:
 *   text       — the string that was in the textarea
 *   sourceRect — DOMRect of the textarea area (for particle start positions)
 *   onComplete — called when all particles have faded out
 */
export default function SandDissolve({ text, sourceRect, onComplete }) {
  const canvasRef = useRef(null)

  useEffect(() => {
    if (!text || !sourceRect) return

    let rafId = null
    let cancelled = false

    const init = async () => {
      // Wait for fonts so canvas text rendering matches the textarea
      await document.fonts.ready
      if (cancelled) return

      const canvas = canvasRef.current
      if (!canvas) return

      canvas.width = window.innerWidth
      canvas.height = window.innerHeight
      const ctx = canvas.getContext('2d')

      // ── Render text onto offscreen canvas ──────────────────────────────────
      const { left, top, width, height } = sourceRect
      const offW = Math.max(1, Math.floor(width))
      const offH = Math.max(1, Math.floor(height))

      const offscreen = document.createElement('canvas')
      offscreen.width = offW
      offscreen.height = offH
      const offCtx = offscreen.getContext('2d')

      offCtx.fillStyle = '#FFFFFF'
      offCtx.fillRect(0, 0, offW, offH)

      offCtx.font = "400 16px 'DM Sans', sans-serif"
      offCtx.fillStyle = '#0F172A'
      offCtx.textBaseline = 'top'

      const padding = 0
      const lineHeight = 26
      const maxWidth = offW - padding * 2
      const words = text.split(' ')
      let line = ''
      let y = 0

      for (let i = 0; i < words.length; i++) {
        const testLine = line + (line ? ' ' : '') + words[i]
        if (offCtx.measureText(testLine).width > maxWidth && line !== '') {
          offCtx.fillText(line, padding, y)
          line = words[i]
          y += lineHeight
          if (y + lineHeight > offH) break
        } else {
          line = testLine
        }
      }
      if (line && y + lineHeight <= offH + lineHeight) {
        offCtx.fillText(line, padding, y)
      }

      // ── Sample pixels → build particle array ───────────────────────────────
      const imgData = offCtx.getImageData(0, 0, offW, offH)
      const pxData = imgData.data
      const step = 3
      const particles = []

      for (let py = 0; py < offH; py += step) {
        for (let px = 0; px < offW; px += step) {
          const idx = (py * offW + px) * 4
          const r = pxData[idx]
          const g = pxData[idx + 1]
          const b = pxData[idx + 2]
          const a = pxData[idx + 3]

          // Skip transparent and near-white (background) pixels
          if (a < 20) continue
          if (r > 230 && g > 230 && b > 230) continue

          // Left-to-right staggered delay (0 → 400ms sweep)
          const delay = (px / offW) * 400

          particles.push({
            x: left + px,
            y: top + py,
            vx: 1.5 + Math.random() * 2.5,
            vy: -(0.5 + Math.random() * 1.5),
            opacity: 1,
            r, g, b,
            size: 1.5 + Math.random() * 1.5,
            delay,
            active: false,
          })
        }
      }

      if (particles.length === 0) {
        if (!cancelled) onComplete?.()
        return
      }

      // ── Animation loop ─────────────────────────────────────────────────────
      let startTime = null

      const animate = (ts) => {
        if (cancelled) return
        if (!startTime) startTime = ts
        const elapsed = ts - startTime

        ctx.clearRect(0, 0, canvas.width, canvas.height)

        let anyAlive = false

        for (const p of particles) {
          if (!p.active) {
            if (elapsed >= p.delay) {
              p.active = true
            } else {
              // Stationary — draw at original position
              anyAlive = true
              ctx.globalAlpha = p.opacity
              ctx.fillStyle = `rgb(${p.r},${p.g},${p.b})`
              ctx.fillRect(p.x, p.y, p.size, p.size)
              continue
            }
          }

          // Physics
          p.vx *= 0.97         // air resistance
          p.vy += 0.12         // gravity
          p.x += p.vx
          p.y += p.vy
          p.opacity -= 0.018

          if (p.opacity > 0) {
            anyAlive = true
            ctx.globalAlpha = Math.max(0, p.opacity)
            ctx.fillStyle = `rgb(${p.r},${p.g},${p.b})`
            ctx.fillRect(p.x, p.y, p.size, p.size)
          }
        }

        ctx.globalAlpha = 1

        if (!anyAlive) {
          ctx.clearRect(0, 0, canvas.width, canvas.height)
          if (!cancelled) onComplete?.()
          return
        }

        rafId = requestAnimationFrame(animate)
      }

      rafId = requestAnimationFrame(animate)
    }

    init()

    return () => {
      cancelled = true
      if (rafId) cancelAnimationFrame(rafId)
    }
  }, [text, sourceRect, onComplete])

  return <canvas ref={canvasRef} className="dissolve-canvas" />
}
