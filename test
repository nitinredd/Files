# Document-descriptor stripping (reuse the RS-specific list)
_RS_DOC_DESCRIPTORS = [
    "product quality statement", "quality and regulatory information summary",
    "product regulatory information", "regulatory information", "safety data sheet",
    "material characterization", "material characterisation", "residual solvents statement",
    "residual solvent statement", "certificate of analysis", "specification",
    "technical data sheet", "quality statement", "declaration", "statement",
    "insights from the experts", "residual solvents", "residual solvent",
]
_RS_CONNECTORS = (" for ", " of ", " on ", ":", " - ", " – ", " re ")


def rs_strip_descriptor(name: str) -> str:
    if not name:
        return ""
    s = " ".join(_s(name).split())
    low = s.lower()
    for desc in _RS_DOC_DESCRIPTORS:
        if low.startswith(desc):
            rest = s[len(desc):]
            rl = rest.lower()
            for conn in _RS_CONNECTORS:
                if rl.startswith(conn):
                    subj = rest[len(conn):].strip(" :-–").strip()
                    sl = subj.lower()
                    if sl in _RS_DOC_DESCRIPTORS or \
                       any(sl.startswith(d) for d in _RS_DOC_DESCRIPTORS) or \
                       "insights" in sl or "experts" in sl:
                        return ""
                    return subj
            if not rest.strip(" :-–"):
                return ""
    if low in _RS_DOC_DESCRIPTORS:
        return ""
    return s


def _percent_to_ppm(v: float) -> float:
    return v * 10000.0       # 0.5% → 5000 ppm


def _convert_to_ppm(raw_value: Any, raw_unit: str) -> Optional[float]:
    v = _num_or_none(raw_value)
    if v is None:
        return None
    u = (raw_unit or "").strip().lower()
    if u in ("%", "percent", "w/w%", "percentage"):
        return _percent_to_ppm(v)
    if u in ("ppm", "mg/kg", "µg/g", "ug/g", "mg/l", ""):
        return v
    if u in ("ppb", "µg/kg", "ug/kg"):
        return v / 1000.0
    return v


def _infer_material_from_filename(filename: str) -> str:
    """Infer a material name from an annexure filename as a STRICT LAST RESORT.
    Strips: extension, '(Annexure N)' / '_annexure_N' patterns, SAP/GRN prefixes
    (RCQR/RCRR/GRN + digits), dates (YYYY-MM-DD or DDMMYYYY), long numeric IDs
    (6+ digits), and document-type words. Returns '' if nothing meaningful remains.
    Example: 'Citric acid (Annexure 14).pdf' → 'Citric acid'."""
    if not filename:
        return ""
    s = _s(filename)
    s = re.sub(r"\.(pdf|json|docx?|xlsx?|png|jpe?g|tiff?)$", "", s, flags=re.IGNORECASE)
    # "(Annexure 14)" or "_annexure_14" or "annexure-14"
    s = re.sub(r"[\(\[]?\s*annexure[\s_\-]*\d+\s*[\)\]]?", " ", s, flags=re.IGNORECASE)
    # SAP/GRN/AR style prefixes: RCQR00022, RCRR123, GRN456
    s = re.sub(r"\b(RCQR|RCRR|GRN|AR|ATR|SAP)[\-_ ]?\d{2,}\b", " ", s, flags=re.IGNORECASE)
    # separators → spaces (before numeric strips so _-bounded IDs are seen)
    s = re.sub(r"[_\-]+", " ", s)
    # dates YYYY-MM-DD, DD-MM-YYYY, DDMMYYYY, YYYYMMDD
    s = re.sub(r"\b\d{4}[\-/]\d{2}[\-/]\d{2}\b", " ", s)
    s = re.sub(r"\b\d{2}[\-/]\d{2}[\-/]\d{4}\b", " ", s)
    s = re.sub(r"\b\d{8}\b", " ", s)
    # long numeric IDs (6+ digits)
    s = re.sub(r"\b\d{6,}\b", " ", s)
    # strip document-type words
    _docwords = (r"coa|certificate\s+of\s+analysis|specification|spec|declaration|"
                 r"statement|sds|msds|regulatory|quality|residual\s+solvents?|"
                 r"annexure|monograph|information|report|final|copy")
    s = re.sub(r"\b(" + _docwords + r")\b", " ", s, flags=re.IGNORECASE)
    s = re.sub(r"\s+", " ", s).strip(" -–:_")
    # strip a leading connector left over from "... declaration of <material>"
    s = re.sub(r"^(?:of|for|on|re|the)\s+", "", s, flags=re.IGNORECASE).strip()
    # reject if what remains is empty or a pure number
    if not s or re.fullmatch(r"[\d\s.]+", s):
        return ""
    return s


# ── BDL / spec-limit / policy / dedup helpers (RS RF3, RF14, RF15) ────────────
# Below-detection markers: the result is not a number, so a per-batch actual is
# unavailable — the spec limit (NMT) is used for a worst-case exposure (RF15).
_RS_BDL_VALUES = {
    "bdl", "bql", "nd", "not detected", "notdetected", "< lod", "<lod",
    "< loq", "<loq", "below detection", "below detection limit",
    "below quantification", "below quantitation", "not quantifiable", "absent",
}
# Numeric spec limit inside free text: "NMT 5000 ppm", "Not more than 600 ppm",
# "≤ 3000 ppm", "limit 5000 ppm", "0.5 %". Trailing form "5000 ppm max" too.
_RS_NMT_TEXT_RE = re.compile(
    r"(?:nmt|not\s+more\s+than|max(?:imum)?|≤|<=|limit(?:\s+of)?|spec(?:ification)?"
    r"(?:\s+limit)?)\s*[:=]?\s*(\d+(?:\.\d+)?)\s*(ppm|%|mg/kg)?",
    re.IGNORECASE)
_RS_NMT_TRAILING_RE = re.compile(
    r"(\d+(?:\.\d+)?)\s*(ppm|%)\s*(?:max|maximum)\b", re.IGNORECASE)

# Regulatory-context phrases: a number appearing next to these is a guideline
# REFERENCE, not a material limit (policy-letter false extraction — RF3).
_RS_POLICY_CONTEXT_RE = re.compile(
    r"pde\s+value|permitted\s+daily\s+exposure|concentration\s+limit\s+of|"
    r"based\s+on\s+information\s+of\s+usp|will\s+not\s+be\s+implemented|"
    r"reverted\s+back|the\s+guideline\s+states|ich\s*q3c|edqm|"
    r"in\s+accordance\s+with\s+the\s+above|as\s+per\s+the\s+(?:above\s+)?guideline",
    re.IGNORECASE)
# Generic policy-letter titles (no specific material qualifier).
_RS_POLICY_TITLE_RE = re.compile(
    r"^(residual\s+solvents?|ich\s*q3c|regulatory\s+(?:information|update|position)|"
    r"quality\s+(?:and\s+regulatory\s+)?(?:information|statement)|policy)\b",
    re.IGNORECASE)


def _extract_nmt_ppm_from_text(text: str) -> Optional[float]:
    """Pull a spec limit (worst-case, largest) in ppm from free text, converting
    percentages (0.5 % → 5000 ppm). Returns None when no NMT-style number found."""
    if not text:
        return None
    best: Optional[float] = None
    for rx, unit_grp in ((_RS_NMT_TEXT_RE, 2), (_RS_NMT_TRAILING_RE, 2)):
        for m in rx.finditer(text):
            try:
                val = float(m.group(1))
            except (TypeError, ValueError):
                continue
            unit = (m.group(unit_grp) or "ppm").lower()
            ppm = _percent_to_ppm(val) if unit == "%" else val
            if best is None or ppm > best:
                best = ppm
    return best


def _rs_is_policy_context(raw_text: str) -> bool:
    return bool(raw_text) and bool(_RS_POLICY_CONTEXT_RE.search(raw_text))


# ── RS content-ppm classifier (Categories A–G) ────────────────────────────────
# The vendor CoA converter emits an inconsistent converted_ppm when a statement
# carries BOTH a batch-actual value and a spec limit (a "159 - 5000" range, an
# "Actual | NMT" column pair, etc.) — sometimes it keeps the actual, sometimes
# the spec. This classifier makes converted_ppm DETERMINISTIC from raw text alone
# (vendor / product / compendium-agnostic):
#   A spec-limit only      → converted = the spec limit            (evidence "nmt")
#   B batch-actual only    → converted = the measured value        (evidence actual)
#   C actual + spec (range)→ converted = spec (worst-case); actual preserved
#   D BDL/BQL/ND + spec    → converted = spec (worst-case, BDL note)
#   E BDL/BQL/ND, no spec  → converted = None (needs review)
#   F negative declaration → handled by the caller (converted = 0)
#   G ambiguous            → converted = None (needs review)
# A batch actual is ≤ its spec by definition, so taking the spec never understates
# exposure. The smaller (actual) value is preserved for the audit trail.
_RS_BDL_TEXT_RE = re.compile(
    r"\b(bdl|bql|\bnd\b|not\s+detected|below\s+(?:detection|quantr?[ai]tation|"
    r"quantification)|<\s*lo[dq])\b", re.IGNORECASE)
# Two numbers joined by a range/pair delimiter (-, –, to, <, |, /, ~), the 2nd
# optionally prefixed by </NMT/"not more than". Anchored on digits so a solvent
# name like "1,4-Dioxane" (no digit after the hyphen) does not false-match.
_RS_RANGE_PAIR_RE = re.compile(
    r"(\d+(?:\.\d+)?)\s*(?:ppm|%|mg/kg)?\s*(?:-|–|—|<|\||/|~|to|~to)\s*"
    r"(?:<|≤|<=|nmt\s+|not\s+more\s+than\s+)?\s*(\d+(?:\.\d+)?)",
    re.IGNORECASE)


def _rs_text_is_bdl(text: str) -> bool:
    return bool(text) and bool(_RS_BDL_TEXT_RE.search(text))


def _classify_solvent_ppm(raw_value: Any, raw_unit: str, raw_text: str,
                          is_bdl: bool = False) -> Dict[str, Any]:
    """Classify a solvent statement into Categories A–G and return
    {converted_ppm, actual_measured_ppm, spec_limit_ppm, category,
     calculation_basis, note}. Decides on text content only."""
    unit = (_s(raw_unit) or "").strip().lower()
    blob = f"{_s(raw_value)} {_s(raw_text)}".strip()

    def _to_ppm(v: float, u: Optional[str] = None) -> float:
        uu = (u or unit or "ppm").lower()
        if uu in ("%", "percent", "percentage", "w/w%"):
            return _percent_to_ppm(v)
        if uu in ("ppb", "µg/kg", "ug/kg"):
            return v / 1000.0
        return v  # ppm, mg/kg, µg/g, mg/l, none

    out = {"converted_ppm": None, "actual_measured_ppm": None,
           "spec_limit_ppm": None, "category": "G",
           "calculation_basis": "ambiguous", "note": ""}

    is_bdl = is_bdl or _rs_text_is_bdl(raw_text)
    nmt_ppm = _extract_nmt_ppm_from_text(blob)     # largest NMT-context number
    has_pct = "%" in blob

    # Category C — a numeric range (actual … spec). Worst-case = the larger value;
    # the smaller is the batch actual. Skipped when both sides are equal.
    m = _RS_RANGE_PAIR_RE.search(blob)
    if m and not is_bdl:
        try:
            a = _to_ppm(float(m.group(1)), "%" if has_pct else None)
            b = _to_ppm(float(m.group(2)), "%" if has_pct else None)
        except (TypeError, ValueError):
            a = b = None
        if a is not None and b is not None and a != b:
            lo, hi = sorted((a, b))
            out.update({"converted_ppm": hi, "actual_measured_ppm": lo,
                        "spec_limit_ppm": hi, "category": "C",
                        "calculation_basis": "nmt_with_batch_actual",
                        "note": "range: spec limit taken for worst-case exposure; "
                                "batch actual preserved"})
            return out

    # Categories D / E — below-detection result.
    if is_bdl:
        if nmt_ppm is not None:
            out.update({"converted_ppm": nmt_ppm, "spec_limit_ppm": nmt_ppm,
                        "category": "D", "calculation_basis": "nmt_conservative_bdl",
                        "note": "BDL result; using spec limit for worst-case exposure"})
        else:
            out.update({"category": "E", "calculation_basis": "unresolved_bdl",
                        "note": "BDL result with no spec limit; manual review"})
        return out

    primary = _convert_to_ppm(raw_value, raw_unit)   # the value the model emitted

    # Category A — a spec limit is present (NMT/≤/limit wording).
    if nmt_ppm is not None:
        actual = primary if (primary is not None and primary < nmt_ppm) else None
        out.update({"converted_ppm": nmt_ppm, "spec_limit_ppm": nmt_ppm,
                    "actual_measured_ppm": actual, "category": "A",
                    "calculation_basis": "nmt_conservative",
                    "note": ("spec limit; lower actual preserved"
                             if actual is not None else "spec limit")})
        return out

    # Category B — a single measured value with no spec context.
    if primary is not None:
        out.update({"converted_ppm": primary, "actual_measured_ppm": primary,
                    "category": "B", "calculation_basis": "batch_actual",
                    "note": "measured content (no spec limit in text)"})
        return out

    # Category G — nothing numeric could be resolved.
    return out


# RS Bug 3: compendial-variant detection for same-solvent dedup. A USP <467>
# assessment must prefer the USP/NF limit when an annexure lists the same solvent
# under several compendia (e.g. Acetone: EP NMT 1000 ppm vs USP/NF NMT 5000 ppm).
# Priority USP/NF > Ph.Eur/EP > JP > ASMF/in-house/other. Detected from the
# solvent name + its evidence raw_text; absence of any descriptor scores 0 so it
# never perturbs the existing worst-case ranking (no regression for annexures
# that do not tag a compendium).
_COMPENDIAL_USP_RE = re.compile(
    r"\b(usp(?:\s*[/\-]?\s*nf)?|u\.?s\.?p\.?|national\s+formulary|nf)\b", re.IGNORECASE)
_COMPENDIAL_EP_RE = re.compile(
    r"\b(ph\.?\s*eur\.?|eur\.?\s*ph\.?|european\s+pharmacop(?:o)?eia|ep)\b", re.IGNORECASE)
_COMPENDIAL_JP_RE = re.compile(
    r"\b(jp|japanese\s+pharmacop(?:o)?eia)\b", re.IGNORECASE)
_COMPENDIAL_OTHER = ("asmf", "in-house", "in house", "dmf", "cep")

# RS Bug 1: the priority order among compendial variants depends on the project's
# assessment framework (chosen at project start; USP <467> is the default and the
# US-market default). Each framework maps a detected compendium category to a
# rank (higher = preferred). Category "OTHER" = ASMF/in-house/DMF/CEP. A missing
# category scores 0 so it never perturbs the worst-case ppm ranking (no
# regression for annexures that do not tag a compendium).
DEFAULT_RS_FRAMEWORK = "USP <467>"
_RS_FRAMEWORK_PRIORITY: Dict[str, Dict[str, int]] = {
    # USP <467> / plain USP / ICH Q3C: USP/NF > Ph.Eur/EP > JP > ASMF/other
    "USP <467>": {"USP": 4, "EP": 3, "JP": 2, "OTHER": 1},
    "USP":       {"USP": 4, "EP": 3, "JP": 2, "OTHER": 1},
    "ICH Q3C":   {"USP": 4, "EP": 3, "JP": 2, "OTHER": 1},
    # Ph.Eur: Ph.Eur/EP > USP/NF > JP > ASMF/other
    "Ph.Eur":    {"EP": 4, "USP": 3, "JP": 2, "OTHER": 1},
    # JP: JP > USP/NF > Ph.Eur > ASMF/other
    "JP":        {"JP": 4, "USP": 3, "EP": 2, "OTHER": 1},
}


def normalize_rs_framework(framework: Optional[str]) -> str:
    """Map free-text project metadata to a known framework key, else the default."""
    f = _s(framework).strip().lower()
    if not f:
        return DEFAULT_RS_FRAMEWORK
    if "ph" in f and "eur" in f:
        return "Ph.Eur"
    if f in ("ep", "pheur", "ph eur", "european pharmacopoeia"):
        return "Ph.Eur"
    if f == "jp" or "japan" in f:
        return "JP"
    if "ich" in f or "q3c" in f:
        return "ICH Q3C"
    if "usp" in f or "467" in f or "nf" in f:
        return "USP <467>"
    return DEFAULT_RS_FRAMEWORK


def _compendium_category(sv: Dict) -> Optional[str]:
    """Detect which compendium an entry is tagged with, else None."""
    blob = (_s(sv.get("solvent_name")) + " " + _s(sv.get("raw_text"))).lower()
    if not blob.strip():
        return None
    if _COMPENDIAL_USP_RE.search(blob):
        return "USP"
    if _COMPENDIAL_EP_RE.search(blob):
        return "EP"
    if _COMPENDIAL_JP_RE.search(blob):
        return "JP"
    if any(t in blob for t in _COMPENDIAL_OTHER):
        return "OTHER"
    return None


def _compendial_rank(sv: Dict, framework: str = DEFAULT_RS_FRAMEWORK) -> int:
    """Higher = preferred for the given assessment framework. 0 = no compendial
    descriptor (falls through to the worst-case ppm ranking, preserving legacy
    behaviour). Default USP <467> reproduces the original USP/NF>EP>JP>other order."""
    cat = _compendium_category(sv)
    if cat is None:
        return 0
    table = _RS_FRAMEWORK_PRIORITY.get(framework, _RS_FRAMEWORK_PRIORITY[DEFAULT_RS_FRAMEWORK])
    return table.get(cat, 0)


# RS RF3: an NMT specification limit outranks a batch-actual test result for a
# worst-case USP <467> exposure (a batch actual is ≤ its spec by definition, so
# using it under-states exposure). Detect a batch-actual entry from its evidence
# type / column label / wording.
_RS_BATCH_ACTUAL_RE = re.compile(
    r"\b(test\s+result|batch\s+(?:result|actual|analysis|value)|actual\s+"
    r"(?:value|result|content)|analysis\s+result|as\s+found|found\s*[:=]|"
    r"observed|result\s*[:=])\b", re.IGNORECASE)
_RS_SPEC_WORDING_RE = re.compile(
    r"\b(nmt|not\s+more\s+than|≤|<=|max(?:imum)?|limit|specification|spec)\b",
    re.IGNORECASE)


def _is_batch_actual(sv: Dict) -> bool:
    """True when a solvent entry is a measured batch RESULT rather than a spec
    limit. Spec-limit evidence types and NMT/limit wording are never batch
    actuals; explicit result wording (or a plain measured value) is."""
    et = _s(sv.get("evidence_type")).lower()
    if et in ("nmt", "numerical_limit", "percentage_limit", "controlled_by_spec"):
        return False
    blob = (_s(sv.get("solvent_name")) + " " + _s(sv.get("raw_text"))).lower()
    if _RS_SPEC_WORDING_RE.search(blob):
        return False
    if _RS_BATCH_ACTUAL_RE.search(blob):
        return True
    return et in ("coa_statement", "batch_result", "result", "measured", "actual")


def _dedup_rs_solvents(solvents: List[Dict],
                       framework: str = DEFAULT_RS_FRAMEWORK) -> List[Dict]:
    """Collapse duplicate solvent rows (RF14). Group by canonical name (non-USP by
    lowercased raw name). Keep ONE representative per group: prefer the
    framework's highest-priority compendial variant (default USP <467> → USP/NF
    first — RS Bug 1/3); when no compendium is tagged, fall back to worst-case —
    an entry that carries a converted ppm, then the LARGEST ppm (spec limit ≥
    batch actual → conservative), then NMT source, then highest confidence.
    Confidence is carried as the group max so no evidence strength is lost."""
    groups: Dict[str, List[Dict]] = {}
    order: List[str] = []
    for sv in solvents:
        canon = sv.get("canonical")
        key = canon if canon else ("~" + _s(sv.get("solvent_name")).lower())
        if key not in groups:
            groups[key] = []
            order.append(key)
        groups[key].append(sv)
    out: List[Dict] = []
    for key in order:
        grp = groups[key]
        if len(grp) == 1:
            out.append(grp[0])
            continue

        def _rank(sv: Dict):
            ppm = sv.get("converted_ppm")
            has_ppm = ppm is not None
            return (
                not _is_batch_actual(sv),      # RF3: NMT spec beats batch actual
                _compendial_rank(sv, framework),  # RS Bug 1: framework priority
                has_ppm,
                float(ppm) if has_ppm else -1.0,
                sv.get("evidence_type") == "nmt",
                _f(sv.get("confidence", 0.0)),
            )
        win = max(grp, key=_rank)
        best = dict(win)
        best["confidence"] = max(_f(s.get("confidence", 0.0)) for s in grp)
        # Preserve the superseded entries (e.g. batch actuals) for the audit trail
        # (RF3) without letting them drive the exposure calculation.
        supers = [{"solvent_name": s.get("solvent_name"),
                   "converted_ppm": s.get("converted_ppm"),
                   "evidence_type": s.get("evidence_type"),
                   "raw_text": _s(s.get("raw_text"))[:200]}
                  for s in grp if s is not win]
        if supers:
            best["_superseded"] = supers
        out.append(best)
    return out


def _annexure_richness(ann: Dict) -> Tuple[int, int, float]:
    """Rank an annexure record by evidence richness for dedup (RF8): number of
    solvent entries first, then how many carry a numeric ppm, then the best
    confidence. Used to keep the fuller record when two dedupe to the same key."""
    solv = ann.get("solvents") or []
    numeric = sum(1 for s in solv if s.get("converted_ppm") is not None)
    conf = max((_f(s.get("confidence", 0.0)) for s in solv), default=0.0)
    return (len(solv), numeric, conf)


def _pick_richer_annexure(a: Dict, b: Dict) -> Dict:
    return a if _annexure_richness(a) >= _annexure_richness(b) else b


def dedup_rs_annexures(annexures: List[Dict],
                       framework: str = DEFAULT_RS_FRAMEWORK) -> Tuple[List[Dict], List[str]]:
    """Dedup annexures by (normalized material, normalized supplier) BEFORE
    mapping (RF8), so the merged/richer record feeds both the mapper and the
    exposure calc — no solvent evidence is lost. Records with no resolved
    material never merge. Returns (deduped, dup_warnings)."""
    deduped: List[Dict] = []
    key_to_idx: Dict[Tuple[str, ...], int] = {}
    warnings: List[str] = []
    for ann in annexures:
        if not isinstance(ann, dict) or ann.get("_error"):
            deduped.append(ann)
            continue
        mat = _rs_norm(_s(ann.get("material_name")))
        sup = _rs_norm(_s(ann.get("supplier_name")))
        key = (mat, sup) if mat else ("~unresolved", str(ann.get("annexure_number")))
        if mat and key in key_to_idx:
            idx = key_to_idx[key]
            kept = deduped[idx]
            merged = _dedup_rs_solvents(
                (kept.get("solvents") or []) + (ann.get("solvents") or []), framework)
            winner = dict(_pick_richer_annexure(kept, dict(ann)))
            winner["solvents"] = merged
            if any(s.get("converted_ppm") is not None for s in merged):
                winner["negative_declaration"] = False
            mf = list(kept.get("_merged_from", []))
            for num in (kept.get("annexure_number"), ann.get("annexure_number")):
                if (num is not None and num != winner.get("annexure_number")
                        and num not in mf):
                    mf.append(num)
            if mf:
                winner["_merged_from"] = mf
            deduped[idx] = winner
            warnings.append(
                f"Duplicate annexure for '{_s(ann.get('material_name'))}' / "
                f"'{_s(ann.get('supplier_name'))}' (Annexure "
                f"{ann.get('annexure_number','?')}) merged; solvent evidence combined.")
        else:
            key_to_idx[key] = len(deduped)
            deduped.append(dict(ann))
    return deduped, warnings


# Tabular CoAs label a solvent row by peak/impurity id with the real chemical in
# parentheses: "Impurity B (Acetone)" / "RS-3 (Chloroform)" (RF12). When the
# outer label is a generic peak/impurity tag, use the parenthesized chemical.
_RS_PAREN_NAME_RE = re.compile(r"\(([^)]+)\)")
_RS_PEAK_LABEL_RE = re.compile(
    r"^\s*(?:impurit(?:y|ies)|imp|peak|rs|rrt|residual\s+solvents?|solvent|"
    r"unknown|compound|component|[a-z])\b", re.IGNORECASE)


def _rs_clean_solvent_name(sname: str) -> str:
    """Prefer the parenthesized chemical name when the row label is a generic
    peak/impurity tag ('Impurity B (Acetone)' → 'Acetone'). Names that already
    lead with a real chemical ('Isopropyl alcohol (IPA)') are left intact."""
    s = _s(sname)
    if not s or "(" not in s:
        return s
    if _RS_PEAK_LABEL_RE.match(s):
        m = _RS_PAREN_NAME_RE.search(s)
        if m and m.group(1).strip():
            return m.group(1).strip()
    return s


def process_rs_annexure(obj: Any, index: int,
                        framework: str = DEFAULT_RS_FRAMEWORK) -> Dict:
    """
    Normalise one converted RS annexure into a CONSISTENT top-level object,
    even when no solvent table / no numerical values are present, or when the
    model returned a list (schema_repaired). Never raises.

    framework selects the compendial dedup priority (RS Bug 1); it defaults to
    USP <467>, which reproduces the original behaviour.
    """
    default: Dict = {
        "annexure_number": index,
        "supplier_name": "",
        "material_name": "",
        "material_name_candidates": [],
        "material_name_source": "body",
        "needs_material_confirmation": False,
        "document_title": "",
        "annexure_type": "other",
        "solvents": [],
        "negative_declaration": False,
        "schema_repaired": False,
        "_error": False,
    }

    if not isinstance(obj, dict):
        if isinstance(obj, list):
            d = dict(default)
            d["extracted_items"] = obj
            d["schema_repaired"] = True
            logger.warning(f"RS annexure {index}: root was a list — wrapped.")
            return d
        d = dict(default)
        d["_error"] = True
        d["extraction_notes"] = f"Malformed annexure: got {type(obj).__name__}."
        return d

    out = dict(default)
    # Honor an explicit upstream error (e.g. PDF rasterization failure) so the
    # structured error object propagates instead of being reset to a clean record.
    if obj.get("_error"):
        out["_error"] = True
        out["extraction_notes"] = _s(obj.get("extraction_notes")) or "Extraction failed."
        return out
    for fld in ("supplier_name", "material_name", "document_title", "annexure_type",
                "raw_text", "filename"):
        if obj.get(fld) is not None:
            out[fld] = _s(obj.get(fld))
    cands = obj.get("material_name_candidates", [])
    if isinstance(cands, list):
        out["material_name_candidates"] = [_s(c) for c in cands if _s(c)]
    if obj.get("schema_repaired"):
        out["schema_repaired"] = True
    if obj.get("extracted_items") is not None:
        out["extracted_items"] = obj.get("extracted_items")

    # Material-name: strip document descriptors, recover from candidates
    out["material_name"] = rs_strip_descriptor(out["material_name"])
    out["material_name_candidates"] = [
        c for c in (rs_strip_descriptor(x) for x in out["material_name_candidates"]) if c
    ]
    if not out["material_name"] and out["material_name_candidates"]:
        out["material_name"] = out["material_name_candidates"][0]
    if not out["material_name"] and out["document_title"]:
        recovered = rs_strip_descriptor(out["document_title"])
        if recovered:
            out["material_name"] = recovered

    # STRICT filename fallback (B3): only when ALL body-based paths yielded
    # nothing. Never overrides a valid body-extracted material_name. Fixes the
    # case where the body/title is generic ("Residual Solvents") but the filename
    # names the material — e.g. "Citric acid (Annexure 14).pdf" → "Citric acid".
    if not out["material_name"]:
        inferred = _infer_material_from_filename(_s(obj.get("filename")))
        if inferred:
            out["material_name"] = inferred
            out["material_name_source"] = "filename_inferred"
            out["needs_material_confirmation"] = True
    else:
        out.setdefault("material_name_source", "body")

    out["negative_declaration"] = bool(obj.get("negative_declaration"))

    # Is this a generic regulatory/policy letter (no specific material subject)?
    # Numbers in such a document are guideline references, not material limits.
    # Require a genuinely UNRESOLVED material — a filename-inferred material with
    # real per-batch data must NOT be cleared (that is a real CoA, not a policy
    # letter). Stray policy-context numbers are still rejected per-solvent below.
    doc_title = out.get("document_title", "")
    is_policy_letter = (not out["material_name"]) and bool(
        _RS_POLICY_TITLE_RE.search(doc_title))

    # Normalise solvent evidence
    solvents_in = obj.get("solvents", [])
    norm_solvents: List[Dict] = []
    declaration_scopes: List[Dict] = []
    if isinstance(solvents_in, list):
        for sv in solvents_in:
            if not isinstance(sv, dict):
                continue
            sname = _rs_clean_solvent_name(_s(sv.get("solvent_name")))
            etype = _s(sv.get("evidence_type")) or "ambiguous"
            raw_value = sv.get("raw_value")
            raw_unit = _s(sv.get("raw_unit"))
            raw_text = _s(sv.get("raw_text"))
            # Resolve once. A vendor/specialty solvent (class None — e.g. TFA)
            # still gets a canonical name so its abbreviation and full name merge
            # into ONE entry (RS Bug 4), but is treated as non-USP below.
            sinfo = RSM.get_solvent_info(sname) if sname else None
            canon = sinfo["canonical_name"] if sinfo else None

            # (a) Generic category / declaration-scope phrases are NOT solvents
            # (Class 1/2/3, OVI, "residual solvents", water) → scope evidence.
            if not sname or is_generic_solvent_category(sname):
                declaration_scopes.append({
                    "scope_text": sname,
                    "raw_text": raw_text or sname,
                    "evidence_type": etype if etype in (
                        "negative_declaration", "no_source", "controlled_by_spec",
                        "coa_statement") else "declaration_scope",
                    "page": sv.get("page", 1),
                })
                continue

            # (b) RF3: a real solvent name whose evidence is a policy/guideline
            # reference (PDE value, ICH Q3C discussion) is NOT a material limit.
            if etype == "policy_statement" or _rs_is_policy_context(raw_text):
                declaration_scopes.append({
                    "scope_text": sname,
                    "raw_text": raw_text or sname,
                    "evidence_type": "policy_statement",
                    "page": sv.get("page", 1),
                })
                continue

            # Convert to ppm via the deterministic A–G classifier so a statement
            # carrying BOTH a batch actual and a spec limit (a "159 - 5000" range,
            # an "Actual | NMT" pair, or a BDL result) always resolves to the same
            # worst-case value regardless of vendor/CoA format. The smaller actual
            # is preserved for audit. (Sofosbuvir/Velpatasvir extraction fix.)
            converted_ppm = None
            calc_basis = etype
            audit_note = ""
            actual_ppm = None
            spec_ppm = None
            rv_norm = _s(raw_value).strip().lower()
            is_bdl = (rv_norm in _RS_BDL_VALUES) or _rs_text_is_bdl(raw_text)
            if etype in ("numerical_limit", "percentage_limit", "nmt"):
                cls = _classify_solvent_ppm(raw_value, raw_unit, raw_text, is_bdl)
                converted_ppm = cls["converted_ppm"]
                actual_ppm = cls["actual_measured_ppm"]
                spec_ppm = cls["spec_limit_ppm"]
                calc_basis = cls["calculation_basis"] or calc_basis
                audit_note = cls["note"]
            elif etype in ("negative_declaration", "no_source"):
                calc_basis = "negative_declaration"
            # BDL under a non-numeric etype: still recover the spec limit from text.
            if converted_ppm is None and is_bdl:
                nmt_ppm = _extract_nmt_ppm_from_text(raw_text)
                if nmt_ppm is not None:
                    converted_ppm = nmt_ppm
                    spec_ppm = nmt_ppm
                    calc_basis = "nmt_conservative_bdl"
                    audit_note = ("BDL result; using spec limit for worst-case "
                                  "exposure")

            # Non-USP = not an ICH Q3C-classed solvent. A vendor solvent (class
            # None) resolves to a canonical name but is still non-USP, so the RF2
            # numeric-evidence gate below (and NA limit display) still applies.
            is_non_usp = (sinfo is None) or (sinfo.get("class") is None)
            entry = {
                "solvent_name": sname,
                "canonical": canon,
                "is_non_usp_solvent": is_non_usp,
                "raw_text": raw_text,
                "raw_value": raw_value,
                "raw_unit": raw_unit,
                "converted_ppm": converted_ppm,
                "evidence_type": etype,
                "calculation_basis": calc_basis,
                "page": sv.get("page", 1),
                "confidence": _f(sv.get("confidence", 0.6)) or 0.6,
            }
            if audit_note:
                entry["audit_note"] = audit_note
            # Audit trail: preserve both the batch actual and the spec limit so a
            # reviewer can see the worst-case selection (RS content-extraction fix).
            if actual_ppm is not None:
                entry["actual_measured_ppm"] = actual_ppm
            if spec_ppm is not None:
                entry["spec_limit_ppm"] = spec_ppm

            # RF2: keep a NON-USP solvent only when it carries numeric evidence
            # (CPME 1500 ppm, TFA 3400 ppm). A non-USP name with no number is a
            # declaration scope, not a calculation column.
            if is_non_usp and converted_ppm is None:
                declaration_scopes.append({
                    "scope_text": sname,
                    "raw_text": raw_text or sname,
                    "evidence_type": "declaration_scope",
                    "page": sv.get("page", 1),
                })
                continue
            norm_solvents.append(entry)

    # RF14: collapse duplicate rows (Methanol × 5 → one worst-case entry).
    norm_solvents = _dedup_rs_solvents(norm_solvents, framework)
    out["solvents"] = norm_solvents
    out["declaration_scopes"] = declaration_scopes

    # RF3: a generic policy letter must not contribute material-specific limits.
    # Everything it carried becomes scope evidence and its flag stays false.
    if is_policy_letter and norm_solvents:
        for sv in norm_solvents:
            declaration_scopes.append({
                "scope_text": sv.get("solvent_name", ""),
                "raw_text": sv.get("raw_text", ""),
                "evidence_type": "policy_statement",
                "page": sv.get("page", 1),
            })
        norm_solvents = []
        out["solvents"] = []
        out["declaration_scopes"] = declaration_scopes

    # RF4: negative_declaration is the GLOBAL "no residual solvents present" flag.
    # It is true ONLY when there are no numeric solvent limits. Any numeric limit
    # forces it false; per-class negatives live in declaration_scopes, not here.
    has_numeric = any(sv.get("converted_ppm") is not None for sv in norm_solvents)
    if has_numeric or is_policy_letter:
        out["negative_declaration"] = False
    elif not norm_solvents and (
            out["negative_declaration"]
            or any(sc.get("evidence_type") in ("negative_declaration", "no_source")
                   for sc in declaration_scopes)
            or "not used" in out.get("raw_text", "").lower()
            or "water is the only" in out.get("raw_text", "").lower()):
        out["negative_declaration"] = True
    else:
        out["negative_declaration"] = False
    return out


