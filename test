// ============================================================================
// COMPOSITION TABLE  (Table 1)
// ============================================================================
function buildCompositionTable(sections, columns) {
  columns = (Array.isArray(columns) && columns.length) ? columns : [
    { key: "ingredient", label: "Name of Ingredient" },
    { key: "status",     label: "Compendial Status" },
    { key: "40mg",       label: "40 mg mg/unit" },
    { key: "20mg",       label: "20 mg mg/unit" },
    { key: "10mg",       label: "10 mg mg/unit" },
  ];

  var fixed = 0;
  var weights = columns.map(function (c) {
    var key = String((c && c.key) || "").toLowerCase();
    if (key === "ingredient") return 3.0;
    if (key === "function") return 1.4;
    if (key === "material_code") return 1.2;
    return 1.0;
  });
  for (var wi = 0; wi < weights.length; wi++) fixed += weights[wi];
  var W = weights.map(function (w) { return Math.max(650, Math.round(CW * w / fixed)); });
  var wSum = W.reduce(function (a, b) { return a + b; }, 0);
  W[W.length - 1] += (CW - wSum);

  var hdrRow = new TableRow({
    children: columns.map(function (col, idx) {
      return mkCell(String((col && col.label) || (col && col.key) || ""),
                    { bold: true, fill: COLOR.HEADER_GREY, w: W[idx], size: SZ.SM });
    }),
  });

  var dataRows = [];
  var sArr = Array.isArray(sections) ? sections : [];
  for (var si = 0; si < sArr.length; si++) {
    var sec = sArr[si];
    if (!sec || typeof sec !== "object") continue;
    // Blue section-header row spanning all 5 columns
    dataRows.push(new TableRow({
      children: [new TableCell({
        columnSpan: columns.length, borders: allBorders(4), shading: cellShade(COLOR.SECTION_BLUE),
        margins: cm(),
        children: [leftPara(sec.name || "", true, SZ.SM)],
      })],
    }));
    var rArr = Array.isArray(sec.rows) ? sec.rows : [];
    for (var ri = 0; ri < rArr.length; ri++) {
      var row = rArr[ri];
      if (!row || typeof row !== "object") continue;
      dataRows.push(new TableRow({
        children: columns.map(function (col, idx) {
          var key = (col && col.key) || "";
          var val = row[key];
          if (key === "ingredient") val = row.ingredient || row.name || "";
          if (key === "status") val = row.status || row.compendial_status || "";
          if (key === "function") val = row.function || row.role || "";
          if (key === "material_code") val = row.material_code || row.code || "";
          return mkCellL(String(val == null ? "" : val), { w: W[idx], size: SZ.SM });
        }),
      }));
    }
  }

  var tbl = new Table({
    width: { size: CW, type: WidthType.DXA },
    columnWidths: W,
    rows: [hdrRow].concat(dataRows),
  });

  return [
    sectionHeading("5. Drug product elemental impurity risk assessment"),
    leftPara("Table 1: Quantitative and Qualitative Composition", true, SZ.SM),
    tbl,
    pgBreak(),
  ];
}


// ============================================================================
// FIGURE  (38% top already cropped in app.py — only diagram arrives here)
// ============================================================================
function buildFigure(fig) {
  if (!fig || !fig.data_b64 || typeof fig.data_b64 !== "string"
      || fig.data_b64.length < 100) {
    return [];
  }
  var imgBuf;
  try {
    imgBuf = Buffer.from(fig.data_b64, "base64");
    if (imgBuf.length < 500) return [];
  } catch (e) { return []; }

  var imgType = (fig.media_type || "").indexOf("jpeg") >= 0 ? "jpg" : "png";
  // After 38% top crop and 10% bottom crop, the remaining diagram is ~52% of page height
  // Adjust aspect ratio to match the cropped rectangle dimensions
  var imgW    = 560;
  var imgH    = Math.round(imgW * 0.52);

  var img = new ImageRun({
    type: imgType, data: imgBuf, transformation: { width: imgW, height: imgH },
  });

  return [
    leftPara(fig.figure_label || "Figure 1", true, SZ.SM),
    new Paragraph({
      alignment: AlignmentType.CENTER, spacing: { before: 40, after: 40 },
      children: [img],
    }),
    blankPara(),
    pgBreak(),
  ];
}


