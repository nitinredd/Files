import { useState, useRef } from 'react'

/**
 * PromptInput — the central input card.
 * Shown during INPUT state and re-used (modified) during DISSOLVING state.
 *
 * Props:
 *   onSubmit(text, rect)  — called with the query text and the textarea's
 *                           DOMRect (used by SandDissolve for particle origin)
 *   isDissolving          — renders the dissolving variant
 *   progressPercent       — 0-100 for the top progress bar
 *   progressStatus        — cycling status label shown below the card
 */
export default function PromptInput({
  onSubmit,
  isDissolving = false,
  progressPercent = 0,
  progressStatus = '',
}) {
  const [value, setValue] = useState('')
  const textareaWrapRef = useRef(null)

  const handleSubmit = () => {
    const trimmed = value.trim()
    if (!trimmed || isDissolving) return
    const rect = textareaWrapRef.current?.getBoundingClientRect() ?? null
    onSubmit(trimmed, rect)
  }

  const handleKeyDown = (e) => {
    if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) handleSubmit()
  }

  return (
    <div className="input-state">
      {/* Hero */}
      <div className="hero-area">
        <h1 className="hero-headline">Your prompt, perfected.</h1>
        <p className="hero-sub">
          Designed for Analytical Scientists. Type anything — even rough notes.
          Prompt Coach reconstructs it into precision.
        </p>
      </div>

      {/* Card */}
      <div className="input-card">
        {/* Progress bar — visible only when dissolving */}
        {isDissolving && (
          <div className="card-progress-bar">
            <div
              className="card-progress-fill"
              style={{
                width: `${progressPercent}%`,
                transition:
                  progressPercent === 0
                    ? 'none'
                    : progressPercent >= 100
                    ? 'width 200ms ease'
                    : 'width 2000ms ease-out',
              }}
            />
          </div>
        )}

        {/* Textarea capture zone */}
        <div ref={textareaWrapRef} className="textarea-wrap">
          <textarea
            className="prompt-textarea"
            placeholder="e.g. check my hplc method for impurities"
            value={value}
            onChange={(e) => setValue(e.target.value)}
            onKeyDown={handleKeyDown}
            disabled={isDissolving}
            aria-label="Enter your analytical science prompt"
            spellCheck="false"
          />
        </div>

        <div className="card-divider" />

        {/* Footer */}
        {!isDissolving ? (
          <div className="card-footer">
            <span className="card-hint">Ctrl + Enter to reconstruct</span>
            <button
              className="reconstruct-btn"
              onClick={handleSubmit}
              disabled={!value.trim()}
            >
              RECONSTRUCT
            </button>
          </div>
        ) : (
          <div className="card-footer">
            <span className="card-hint" style={{ opacity: 0 }}>·</span>
            <button className="reconstruct-btn loading" disabled>
              <span className="spinner" />
              Reconstructing
            </button>
          </div>
        )}
      </div>

      {/* Status text — below card during dissolving */}
      <div className="status-cycling-wrap" aria-live="polite">
        {isDissolving && (
          <span className="status-cycling" key={progressStatus}>
            {progressStatus}
          </span>
        )}
      </div>
    </div>
  )
}
