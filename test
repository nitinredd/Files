# 2. ANNEXURE CONVERTER — solvent declarations (consistent schema, evidence typing)
# ════════════════════════════════════════════════════════════════════════════
def rs_annexure_prompt() -> str:
    return (
        "You are reading a pharmaceutical annexure for a RESIDUAL SOLVENT risk "
        "assessment (USP <467> / ICH Q3C). The document may be a supplier "
        "declaration, COA, specification, regulatory statement, or SDS.\n\n"
        "Identify the MATERIAL the document is about, distinguishing it from the "
        "DOCUMENT TYPE. Generic phrases like 'Product Quality Statement', "
        "'Quality and Regulatory Information Summary', 'Product Regulatory "
        "Information', 'Safety Data Sheet', 'Material Characterization', 'Residual "
        "Solvents Statement', 'Regulatory Information' are document types, NOT "
        "material names. The material is the SUBJECT, usually found after patterns "
        "like 'for:', 'Product Name:', 'Product identifier:', 'Subject:', 'RE:', "
        "'Product / Manufacturing plant:', 'Supplier product number and name:'.\n\n"
        "Extract solvent evidence. Solvent statements may be numeric (NMT X ppm, "
        "X ppm, X%), BDL/ND, or textual ('solvents listed in USP <467> are not "
        "used', 'water is the only solvent used', 'no source for residual "
        "solvents', 'testing not required because solvent is not used', 'ethyl "
        "alcohol may be present up to 0.5% maximum', 'controlled by vendor "
        "specification').\n\n"
        "IMPORTANT: A solvent_name must be a SPECIFIC chemical solvent (e.g. "
        "Ethanol, Methanol, Acetone, Toluene, Isopropyl alcohol, Ethylene glycol, "
        "1,4-Dioxane, Heptane). NEVER put a category or declaration scope as a "
        "solvent_name — phrases like 'Class 1/2/3 solvents', 'Class I/II/III "
        "solvents', 'OVI', 'Organic Volatile Impurities', 'other residual "
        "solvents', 'residual solvents', 'ICH Q3C solvents', 'USP <467> solvents', "
        "'solvents listed in USP <467>', and 'water' are scopes, NOT solvents. "
        "Record those only via negative_declaration=true and raw_text.\n\n"
        "Return ONLY valid JSON (an OBJECT, never a bare array):\n"
        "{\n"
        '  "supplier_name": "",\n'
        '  "material_name": "",\n'
        '  "material_name_candidates": [],\n'
        '  "document_title": "",\n'
        '  "annexure_type": "supplier_declaration | coa | specification | sds | statement | other",\n'
        '  "solvents": [\n'
        '    {"solvent_name":"", "raw_text":"", "raw_value":"", "raw_unit":"ppm|%|none",\n'
        '     "evidence_type":"numerical_limit|percentage_limit|nmt|negative_declaration|'
        'no_source|controlled_by_spec|coa_statement|ambiguous", "page":1}\n'
        "  ],\n"
        '  "negative_declaration": false,\n'
        '  "raw_text": ""\n'
        "}"
    )


# Document-descriptor stripping (reuse the RS-specific list)
_RS_DOC_DESCRIPTORS = [
    "product quality statement", "quality and regulatory information summary",
    "product regulatory information", "regulatory information", "safety data sheet",
    "material characterization", "material characterisation", "residual solvents statement",
    "residual solvent statement", "certificate of analysis", "specification",
    "technical data sheet", "quality statement", "declaration", "statement",
    "insights from the experts",
]
_RS_CONNECTORS = (" for ", " of ", " on ", ":", " - ", " – ", " re ")


def rs_strip_descriptor(name: str) -> str:
    if not name:
        return ""
    s = " ".join(_s(name).split())
    low = s.lower()
    for desc in _RS_DOC_DESCRIPTORS:
        if low.startswith(desc):
            rest = s[len(desc):]
            rl = rest.lower()
            for conn in _RS_CONNECTORS:
                if rl.startswith(conn):
                    subj = rest[len(conn):].strip(" :-–").strip()
                    sl = subj.lower()
                    if sl in _RS_DOC_DESCRIPTORS or \
                       any(sl.startswith(d) for d in _RS_DOC_DESCRIPTORS) or \
                       "insights" in sl or "experts" in sl:
                        return ""
                    return subj
            if not rest.strip(" :-–"):
                return ""
    if low in _RS_DOC_DESCRIPTORS:
        return ""
    return s


def _percent_to_ppm(v: float) -> float:
    return v * 10000.0       # 0.5% → 5000 ppm


def _convert_to_ppm(raw_value: Any, raw_unit: str) -> Optional[float]:
    v = _num_or_none(raw_value)
    if v is None:
        return None
    u = (raw_unit or "").strip().lower()
    if u in ("%", "percent", "w/w%", "percentage"):
        return _percent_to_ppm(v)
    if u in ("ppm", "mg/kg", "µg/g", "ug/g", "mg/l", ""):
        return v
    if u in ("ppb", "µg/kg", "ug/kg"):
        return v / 1000.0
    return v


def process_rs_annexure(obj: Any, index: int) -> Dict:
    """
    Normalise one converted RS annexure into a CONSISTENT top-level object,
    even when no solvent table / no numerical values are present, or when the
    model returned a list (schema_repaired). Never raises.
    """
    default: Dict = {
        "annexure_number": index,
        "supplier_name": "",
        "material_name": "",
        "material_name_candidates": [],
        "document_title": "",
        "annexure_type": "other",
        "solvents": [],
        "negative_declaration": False,
        "schema_repaired": False,
        "_error": False,
    }

    if not isinstance(obj, dict):
        if isinstance(obj, list):
            d = dict(default)
            d["extracted_items"] = obj
            d["schema_repaired"] = True
            logger.warning(f"RS annexure {index}: root was a list — wrapped.")
            return d
        d = dict(default)
        d["_error"] = True
        d["extraction_notes"] = f"Malformed annexure: got {type(obj).__name__}."
        return d

    out = dict(default)
    # Honor an explicit upstream error (e.g. PDF rasterization failure) so the
    # structured error object propagates instead of being reset to a clean record.
    if obj.get("_error"):
        out["_error"] = True
        out["extraction_notes"] = _s(obj.get("extraction_notes")) or "Extraction failed."
        return out
    for fld in ("supplier_name", "material_name", "document_title", "annexure_type",
                "raw_text", "filename"):
        if obj.get(fld) is not None:
            out[fld] = _s(obj.get(fld))
    cands = obj.get("material_name_candidates", [])
    if isinstance(cands, list):
        out["material_name_candidates"] = [_s(c) for c in cands if _s(c)]
    if obj.get("schema_repaired"):
        out["schema_repaired"] = True
    if obj.get("extracted_items") is not None:
        out["extracted_items"] = obj.get("extracted_items")

    # Material-name: strip document descriptors, recover from candidates
    out["material_name"] = rs_strip_descriptor(out["material_name"])
    out["material_name_candidates"] = [
        c for c in (rs_strip_descriptor(x) for x in out["material_name_candidates"]) if c
    ]
    if not out["material_name"] and out["material_name_candidates"]:
        out["material_name"] = out["material_name_candidates"][0]
    if not out["material_name"] and out["document_title"]:
        recovered = rs_strip_descriptor(out["document_title"])
        if recovered:
            out["material_name"] = recovered

    out["negative_declaration"] = bool(obj.get("negative_declaration"))

    # Normalise solvent evidence
    solvents_in = obj.get("solvents", [])
    norm_solvents: List[Dict] = []
    declaration_scopes: List[Dict] = []
    if isinstance(solvents_in, list):
        for sv in solvents_in:
            if not isinstance(sv, dict):
                continue
            sname = _s(sv.get("solvent_name"))
            etype = _s(sv.get("evidence_type")) or "ambiguous"
            raw_value = sv.get("raw_value")
            raw_unit = _s(sv.get("raw_unit"))

            # Red Flag 1: generic category / declaration-scope phrases are NOT
            # solvents. Capture them as declaration_scope evidence and skip them
            # as calculation columns. A real canonical solvent is REQUIRED.
            canon = RSM.resolve_solvent(sname) if sname else None
            if is_generic_solvent_category(sname) or not canon:
                declaration_scopes.append({
                    "scope_text": sname,
                    "raw_text": _s(sv.get("raw_text")) or sname,
                    "evidence_type": etype if etype in (
                        "negative_declaration", "no_source", "controlled_by_spec",
                        "coa_statement") else "declaration_scope",
                    "page": sv.get("page", 1),
                })
                # A class/category "not used" statement is a negative declaration
                rt = (_s(sv.get("raw_text")) + " " + sname).lower()
                if etype in ("negative_declaration", "no_source") or \
                   "not used" in rt or "not present" in rt or "no residual" in rt:
                    out["negative_declaration"] = True
                continue

            converted_ppm = None
            calc_basis = etype
            if etype in ("numerical_limit", "percentage_limit", "nmt"):
                converted_ppm = _convert_to_ppm(raw_value, raw_unit)
                calc_basis = ("percentage" if etype == "percentage_limit"
                              else ("nmt_conservative" if etype == "nmt" else "numerical"))
            elif etype in ("negative_declaration", "no_source"):
                converted_ppm = None        # never invent a number
                calc_basis = "negative_declaration"
            norm_solvents.append({
                "solvent_name": sname,
                "canonical": canon,
                "raw_text": _s(sv.get("raw_text")),
                "raw_value": raw_value,
                "raw_unit": raw_unit,
                "converted_ppm": converted_ppm,
                "evidence_type": etype,
                "calculation_basis": calc_basis,
                "page": sv.get("page", 1),
                "confidence": _f(sv.get("confidence", 0.6)) or 0.6,
            })
    out["solvents"] = norm_solvents
    out["declaration_scopes"] = declaration_scopes

    # A negative declaration with no real solvents is a valid no-use evidence object
    if not norm_solvents and (out["negative_declaration"] or declaration_scopes or
                              "not used" in out.get("raw_text", "").lower() or
                              "water is the only" in out.get("raw_text", "").lower()):
        out["negative_declaration"] = True
    return out


