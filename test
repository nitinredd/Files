# NEO4J CLIENT
# ═══════════════════════════════════════════════════════════════

class Neo4jClient:
    def __init__(self):
        self.driver = None
        try:
            from neo4j import GraphDatabase
            self.driver = GraphDatabase.driver(NEO4J_URI, auth=(NEO4J_USER, NEO4J_PASSWORD))
            self.driver.verify_connectivity()
            logger.info("Neo4j connected")
        except Exception as e:
            logger.warning(f"Neo4j unavailable: {e}. Graph features disabled.")

    @property
    def is_connected(self) -> bool:
        return self.driver is not None

    def create_schema(self):
        if not self.is_connected:
            return
        with self.driver.session() as s:
            s.run("CREATE CONSTRAINT IF NOT EXISTS FOR (p:Paragraph) REQUIRE p.paragraph_id IS UNIQUE")
            s.run("CREATE CONSTRAINT IF NOT EXISTS FOR (d:Document) REQUIRE d.doc_id IS UNIQUE")
            s.run("CREATE CONSTRAINT IF NOT EXISTS FOR (c:Concept) REQUIRE c.name IS UNIQUE")
            s.run("CREATE INDEX IF NOT EXISTS FOR (c:Concept) ON (c.category)")

    def store_paragraph(self, paragraph_id: str, doc_id: str, page_num: int, text_preview: str):
        if not self.is_connected:
            return
        with self.driver.session() as s:
            s.run("""
                MERGE (d:Document {doc_id: $doc_id})
                MERGE (p:Paragraph {paragraph_id: $paragraph_id})
                SET p.page_num = $page_num, p.text_preview = $text_preview
                MERGE (d)-[:CONTAINS]->(p)
            """, doc_id=doc_id, paragraph_id=paragraph_id,
                page_num=page_num, text_preview=text_preview[:200])

    def store_concepts(self, paragraph_id: str, concepts: List[Dict], relationships: List[Dict]):
        if not self.is_connected or not concepts:
            return
        with self.driver.session() as s:
            for concept in concepts:
                s.run("""
                    MERGE (c:Concept {name: $name})
                    SET c.category = $category
                    WITH c
                    MATCH (p:Paragraph {paragraph_id: $paragraph_id})
                    MERGE (p)-[:MENTIONS]->(c)
                """, name=concept["name"], category=concept.get("category", "unknown"),
                    paragraph_id=paragraph_id)
            for rel in relationships:
                s.run("""
                    MERGE (c1:Concept {name: $from_name})
                    MERGE (c2:Concept {name: $to_name})
                    MERGE (c1)-[:RELATES_TO {relation: $relation}]->(c2)
                """, from_name=rel["from"], to_name=rel["to"],
                    relation=rel.get("relation", "RELATED"))

    def get_related_paragraphs(self, paragraph_ids: List[str]) -> List[str]:
        """2-hop concept traversal: direct neighbours + related-concept neighbours."""
        if not self.is_connected or not paragraph_ids:
            return []
        with self.driver.session() as s:
            r1 = s.run("""
                MATCH (p:Paragraph)-[:MENTIONS]->(c:Concept)<-[:MENTIONS]-(rel:Paragraph)
                WHERE p.paragraph_id IN $ids AND NOT rel.paragraph_id IN $ids
                RETURN DISTINCT rel.paragraph_id AS para_id LIMIT 10
            """, ids=paragraph_ids)
            direct = [r["para_id"] for r in r1]

            r2 = s.run("""
                MATCH (p:Paragraph)-[:MENTIONS]->(c:Concept)-[:RELATES_TO]->(c2:Concept)
                      <-[:MENTIONS]-(rel:Paragraph)
                WHERE p.paragraph_id IN $ids AND NOT rel.paragraph_id IN $ids
                RETURN DISTINCT rel.paragraph_id AS para_id LIMIT 10
            """, ids=paragraph_ids)
            indirect = [r["para_id"] for r in r2]

        return list(dict.fromkeys(direct + indirect))[:15]

    def get_graph_stats(self) -> Dict:
        if not self.is_connected:
            return {}
        with self.driver.session() as s:
            return {
                "documents": s.run("MATCH (d:Document) RETURN count(d) AS n").single()["n"],
                "paragraphs": s.run("MATCH (p:Paragraph) RETURN count(p) AS n").single()["n"],
                "concepts": s.run("MATCH (c:Concept) RETURN count(c) AS n").single()["n"],
                "relationships": s.run("MATCH ()-[r:RELATES_TO]->() RETURN count(r) AS n").single()["n"],
            }

    def get_graph_data(self) -> Dict:
        if not self.is_connected:
            return {"nodes": [], "edges": []}
        with self.driver.session() as s:
            result = s.run("""
                MATCH (d:Document)-[:CONTAINS]->(p:Paragraph)
                RETURN d.doc_id AS document, count(p) AS paragraph_count
            """)
            return {"nodes": [dict(r) for r in result], "edges": []}

    def close(self):
        if self.driver:
            self.driver.close()


