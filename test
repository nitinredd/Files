    body_rows = docai_like.get("tables", [{}])[0].get("bodyRows", [])

    # ── Fallback: if first pass got nothing, try a broader prompt ──
    if not body_rows:
        logger.warning(f"No EI rows on first pass for {file_name}. Attempting fallback…")
        for page_index in range(page_count):
            pix = doc.load_page(page_index).get_pixmap(
                matrix=mat, alpha=False, colorspace=fitz.csRGB)
            image_bytes = pix.tobytes("png")
            fallback_prompt = (
                "This is a supplier certificate or annexure. "
                "Extract ALL elemental impurity data you find, no matter how the table is labelled. "
                "Columns may include: Element, Symbol, Result, Concentration, LOD, Limit, Spec, "
                "ICH Class, Measured, etc. "
                "If a row mentions an element and a number, capture it. "
                "Return ONLY this JSON (example):\n"
                '{"tables":[{"rows":[{"symbol":"Pb","element":"Lead",'
                '"concentration_value":0.3,"concentration_unit":"ppm",'
                '"analytical_method":"","intentionally_added":"","listed_in_coa":"",'
                '"data_status":"reported","comments":""}]}]}'
            )
            raw = claude_vision(image_bytes, fallback_prompt, max_tokens=6000)
            parsed = safe_json_parse(raw, {})
            rows = _iter_pdf_extracted_rows(parsed)
            if rows:
                extracted_rows.extend(rows)
                # Re‑build docai_like with the newly found rows
                docai_like = _rows_to_docai_like_json(
                    extracted_rows, metadata, file_name, file_sha256,
                    page_count, page_extractions)
                body_rows = docai_like.get("tables", [{}])[0].get("bodyRows", [])
                if body_rows:
                    logger.info(f"Fallback found {len(body_rows)} rows for {file_name}")
                    break

        if not body_rows:
            logger.warning(f"Fallback also failed for {file_name}. Marking as empty.")
            docai_like["_extraction_error"] = "No table rows found after two attempts."

    # ── Cache only if we actually found something ──
    if body_rows:
        try:
            cache_path.write_text(json.dumps(docai_like, ensure_ascii=False, indent=2),
                                  encoding="utf-8")
        except Exception as e:
            logger.warning(f"Annexure cache write failed for {file_name}: {e}")
    else:
        # Ensure any previous cache for this file is NOT used next time
        cache_path.unlink(missing_ok=True)

    return docai_like
