def _parse_conc(val) -> float:
    """Parse a concentration value to float µg/g."""
    if val is None: return 0.0
    if isinstance(val, (int, float)): return max(0.0, float(val))
    s = str(val).strip().lower()
    if s in ("", "na", "nd", "blq", "bdl"): return 0.05  # use LOQ as conservative
    # strip units
    s = re.sub(r"(ppm|ug/g|µg/g|μg/g)", "", s).strip()
    try: return float(s)
    except: return 0.0

def _parse_amount(val) -> float:
    """Parse ingredient amount in mg to float."""
    if val is None: return 0.0
    s = str(val).strip().lower()
    if s in ("", "q.s.", "qs", "na"): return 0.0
    try: return float(s)
    except: return 0.0

def build_ingredient_conc_map(annexure_data: List[Dict]) -> Dict[str, Dict[str, float]]:
    """
    Build a map: material_name -> {element_symbol -> concentration_µg/g}
    from all processed annexures.
    """
    conc_map: Dict[str, Dict[str, float]] = {}
    for ann in annexure_data:
        material = ann.get("material_name", "").strip()
        if not material: continue
        elem_dict: Dict[str, float] = {}
        for el in ann.get("elements", []):
            sym = el.get("symbol", "").strip()
            if not sym: continue
            val = _parse_conc(el.get("concentration_value", 0))
            elem_dict[sym] = val
        conc_map[material] = elem_dict
    return conc_map

def _match_ingredient(ingredient_name: str, conc_map: Dict[str, Dict[str, float]]) -> Dict[str, float]:
    """Fuzzy-match ingredient name to closest key in conc_map."""
    ingredient_lower = ingredient_name.lower()
    best_key = None
    best_score = 0
    for key in conc_map:
        key_lower = key.lower()
        # Token overlap score
        ing_tokens = set(re.split(r'[\s\(\)\-,]+', ingredient_lower))
        key_tokens  = set(re.split(r'[\s\(\)\-,]+', key_lower))
        overlap = len(ing_tokens & key_tokens)
        if overlap > best_score:
            best_score = overlap
            best_key = key
    return conc_map.get(best_key, {}) if best_score > 0 else {}

def calculate_ei_tables(comp_data: Dict, annexure_data: List[Dict]) -> Dict:
    """
    Calculate Tables 5, 6, 7.
    Returns dict with keys 'class1_2a', 'class2b', 'class3'.
    Each value: {
      "elements": [symbol, ...],
      "rows": [{ingredient, daily_intake_g, measured_conc: {sym: val}, total_mass: {sym: val}}],
      "total_daily_intake": float,
      "element_totals": {sym: total_µg_day},
      "pde": {sym: float},
      "threshold_30pct": {sym: float}
    }
    """
    mdd_sachets = comp_data.get("mdd_sachets", 6)
    mdd_strength = comp_data.get("mdd_strength", "40mg")
    strength_cols = comp_data.get("strength_cols", {"40mg": 3})
    ing_col = comp_data.get("ingredient_col", 1)
    all_rows = comp_data.get("all_rows", [])

    # Build per-ingredient daily intake
    ingredients: List[Dict] = []
    if comp_data.get("sections"):
        for section in comp_data["sections"]:
            for row in section.get("rows", []):
                amt = _parse_amount(row.get(mdd_strength, row.get("40mg", 0)))
                daily_g = amt * mdd_sachets / 1000.0
                ingredients.append({
                    "name": row.get("ingredient", ""),
                    "daily_intake_g": round(daily_g, 3)
                })
    else:
        # Fallback: use raw rows
        str_col_idx = strength_cols.get(mdd_strength, strength_cols.get("40mg", 3))
        for row in all_rows:
            if len(row) <= ing_col: continue
            name = row[ing_col].strip()
            if not name or name.lower() in ("name of ingredient", "ingredient"): continue
            amt = _parse_amount(row[str_col_idx] if str_col_idx < len(row) else "")
            daily_g = amt * mdd_sachets / 1000.0
            ingredients.append({"name": name, "daily_intake_g": round(daily_g, 3)})

    # Build concentration map
    conc_map = build_ingredient_conc_map(annexure_data)

    def build_table(elements: List[str]) -> Dict:
        rows = []
        element_totals = {sym: 0.0 for sym in elements}
        total_intake = 0.0

        for ing in ingredients:
            if ing["daily_intake_g"] == 0: continue
            ing_concs = _match_ingredient(ing["name"], conc_map)
            measured = {}
            total_mass = {}
            for sym in elements:
                conc = ing_concs.get(sym, 0.0)
                measured[sym] = round(conc, 4)
                mass = ing["daily_intake_g"] * conc
                total_mass[sym] = round(mass, 4)
                element_totals[sym] = round(element_totals[sym] + mass, 4)
            total_intake += ing["daily_intake_g"]
            rows.append({
                "ingredient":      ing["name"],
                "daily_intake_g":  round(ing["daily_intake_g"], 3),
                "measured_conc":   measured,
                "total_mass":      total_mass,
            })

        pde      = {sym: ICH_PDE[sym]["pde"] for sym in elements}
        thresh   = {sym: round(pde[sym] * 0.30, 3) if pde[sym] else None for sym in elements}

        return {
            "elements":           elements,
            "rows":               rows,
            "total_daily_intake": round(total_intake, 3),
            "element_totals":     {sym: round(v, 4) for sym, v in element_totals.items()},
            "pde":                pde,
            "threshold_30pct":    thresh,
        }

    return {
        "class1_2a": build_table(TABLE5_ELEMENTS),
        "class2b":   build_table(TABLE6_ELEMENTS),
        "class3":    build_table(TABLE7_ELEMENTS),
    }

