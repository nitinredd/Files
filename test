// ── SECTION 1 — DRUG INFORMATION (per API) ───────────────────────────────────
// One block per API. Each block shows: name, IUPAC, structure image, formula,
// MW, CAS, therapeutic category, indications, manufacturer.
function buildDrugInformation(apis) {
  apis = Array.isArray(apis) ? apis : [];
  if (!apis.length) return [];
  var ch = [];
  ch.push(secHd("1. Drug Information"));

  for (var i = 0; i < apis.length; i++) {
    var api = apis[i] || {};
    var subNo = "1." + (i + 1);
    var subTitle = subNo + " " + (api.name || "API " + (i + 1));
    ch.push(lftPara(subTitle, true, SZ.TEXT));

    // Key-value table
    var kvRows = [];
    function addKV(label, value) {
      if (value == null || value === "") return;
      kvRows.push([label, String(value)]);
    }
    addKV("IUPAC Name",             api.iupac_name);
    addKV("Molecular Formula",      api.molecular_formula);
    addKV("Molecular Weight",       api.molecular_weight);
    addKV("CAS Number",             api.cas_number);
    addKV("Therapeutic Category",   api.therapeutic_category);

    if (kvRows.length) {
      var kvW = [Math.round(CW*0.30), CW - Math.round(CW*0.30)];
      var kvTbl = new Table({
        width: {size:CW, type:WidthType.DXA}, columnWidths: kvW,
        rows: kvRows.map(function(kv) {
          return new TableRow({children:[
            cellL(kv[0], {bold:true, w:kvW[0], size:SZ.SM, fill:CLR.HDR_GREY}),
            cellL(kv[1], {w:kvW[1], size:SZ.SM}),
          ]});
        }),
      });
      ch.push(kvTbl);
      ch.push(blk());
    }

    // Molecular structure image (auto-generated via OPSIN + RDKit upstream,
    // or user-uploaded; passed as base64)
    if (api.structure_b64 && api.structure_b64.length > 100) {
      try {
        var sbuf = Buffer.from(api.structure_b64, "base64");
        var stype = (api.structure_media_type || "").indexOf("jpeg") >= 0 ? "jpg" : "png";
        ch.push(lftPara("Molecular Structure:", true, SZ.SM));
        ch.push(new Paragraph({
          alignment: AlignmentType.CENTER,
          spacing: {before:40, after:40},
          children: [new ImageRun({
            type: stype, data: sbuf,
            transformation: {width:280, height:200},
          })],
        }));
        ch.push(blk());
      } catch (e) { /* skip on decode error */ }
    }

    // Indications (bulleted-style list)
    if (Array.isArray(api.indications) && api.indications.length) {
      ch.push(lftPara("Indications:", true, SZ.SM));
      for (var j = 0; j < api.indications.length; j++) {
        ch.push(bodyPara("• " + api.indications[j]));
      }
      ch.push(blk());
    } else if (api.indications) {
      ch.push(lftPara("Indications:", true, SZ.SM));
      bodyParas(api.indications).forEach(function(p){ch.push(p);});
      ch.push(blk());
    }

    // Manufacturer of API
    if (api.manufacturer || api.manufacturer_address) {
      ch.push(lftPara("Manufacturer of Active Pharmaceutical Ingredient:", true, SZ.SM));
      if (api.manufacturer)         ch.push(bodyPara(api.manufacturer));
      if (api.manufacturer_address) ch.push(bodyPara(api.manufacturer_address));
      ch.push(blk());
    }
  }
  return ch;
}

