# perm." + "concentration / conc." anchor so a plain "%" result never matches.
_PERM_CONC_RE = re.compile(
    r"(?:<|≤|<=|less\s+than|not\s+more\s+than|nmt)?\s*"
    r"([0-9]*\.?[0-9]+)\s*%?\s*(?:of\s+)?(?:the\s+)?(?:ich\s*q3d\s*)?"
    r"perm(?:itted|\.?)\s*conc(?:entration|\.?)?",
    re.IGNORECASE,
)
# "meets Option 1" / "complies with Option 1" with no explicit percentage →
# conservative 30% of Option-1 (matches the DRL worst-case convention).
_MEETS_OPTION1_RE = re.compile(
    r"meets?\s+(?:the\s+)?option\s*1|complies?\s+with\s+(?:ich\s*q3d\s*)?option\s*1|"
    r"within\s+option\s*1|option\s*1\s+(?:limit|compliant|concentration)",
    re.IGNORECASE,
)


def perm_conc_to_ppm(text: str, symbol: str) -> Optional[Tuple[float, float]]:
    """If `text` expresses a result as a PERCENTAGE of the ICH Q3D permitted
    (Option 1) concentration — or as generic 'meets Option 1' — return
    (value_µg_per_g, pct_used) for `symbol`, else None. The percentage defaults
    to 30% for a bare Option-1 compliance statement (conservative worst case).
    Never returns the raw percentage as a concentration."""
    s = (text or "").strip()
    if not s:
        return None
    conc = ICH_Q3D_OPTION1_ORAL_CONC.get(symbol)
    if conc is None:
        return None
    pct: Optional[float] = None
    m = _PERM_CONC_RE.search(s)
    if m:
        try:
            pct = float(m.group(1))
        except (TypeError, ValueError):
            pct = None
    if pct is None and _MEETS_OPTION1_RE.search(s):
        pct = 30.0
    if pct is None or pct <= 0:
        return None
    return (round(conc * pct / 100.0, 8), pct)


# ── Claude helpers ────────────────────────────────────────────────────────────
def call_claude(messages: List[Dict], max_tokens: int = 8192) -> str:
    for attempt in range(3):
        try:
            r = client.messages.create(
                model=MODEL, max_tokens=max_tokens, messages=messages
            )
            return "".join(b.text for b in r.content if hasattr(b, "text"))
        except Exception as e:
            logger.warning(f"Claude attempt {attempt + 1} failed: {e}")
            if attempt < 2:
                time.sleep(2 ** attempt)
    return ""


def claude_vision(image_bytes: bytes, prompt: str) -> str:
    if not image_bytes:
        return ""
    b64 = base64.standard_b64encode(image_bytes).decode()
    return call_claude([{
        "role": "user",
        "content": [
            {"type": "image",
             "source": {"type": "base64", "media_type": "image/png", "data": b64}},
            {"type": "text", "text": prompt},
        ],
    }])


# ── Safe utilities ────────────────────────────────────────────────────────────
def safe_str(v: Any, default: str = "") -> str:
    return str(v).strip() if v is not None else default


def safe_float(v: Any, default: float = 0.0) -> float:
    if isinstance(v, (int, float)):
        return float(v)
    try:
        return float(str(v).strip().replace(",", ""))
    except Exception:
        return default


def safe_json_parse(text: str, default: Any = None) -> Any:
    """
    Parse JSON robustly and RETURN A VALUE MATCHING THE SHAPE OF `default`.

    If the caller expects a dict (default is a dict) but the model returned a
    bare JSON array (e.g. just a list of elements), we coerce it into a dict so
    downstream `.get()` calls never crash with
    'list' object has no attribute 'get'.
    """
    if default is None:
        default = {}
    want_dict = isinstance(default, dict)
    if not text:
        return default
    parsed = None
    for fn in [
        lambda t: json.loads(t),
        lambda t: json.loads(t[t.find("{"):t.rfind("}") + 1]),
        lambda t: json.loads(t[t.find("["):t.rfind("]") + 1]),
    ]:
        try:
            parsed = fn(text)
            break
        except Exception:
            parsed = None
    if parsed is None:
        return default
    # Shape reconciliation
    if want_dict and isinstance(parsed, list):
        # A bare array was returned. If it looks like a list of element dicts,
        # wrap it as {"elements": [...]}; otherwise fall back to default.
        if all(isinstance(x, dict) for x in parsed):
            return {"elements": parsed}
        return default
    if want_dict and not isinstance(parsed, dict):
        return default
    if (not want_dict) and isinstance(default, list) and not isinstance(parsed, list):
        # Caller wanted a list but got something else
        return parsed if isinstance(parsed, list) else default
    return parsed


def normalise_symbol(raw: str) -> Optional[str]:
    """Match any symbol string case-insensitively to an ICH_PDE key."""
    raw = raw.strip()
    return next((k for k in ICH_PDE if k.upper() == raw.upper()), None)


# ── Document-descriptor stripping (Issue 3) ───────────────────────────────────
# Generic study/report descriptors that are NOT material identities. When a
# material name looks like "<descriptor> for/of/on <material>", we keep only the
# <material> part. Product-agnostic: matches descriptor patterns, not specific
# products or vendors.
_DOC_DESCRIPTORS = [
    "material characterization", "material characterisation", "characterization",
    "characterisation", "extractables study", "extractables and leachables",
    "extractables", "leachables study", "leachables", "validation guide",
    "validation report", "technical report", "technical data sheet",
    "certificate of analysis", "certificate of suitability", "specification sheet",
    "specification", "assessment", "evaluation", "study report", "study",
    "report", "insights from the experts", "data sheet", "safety data sheet",
    "test report", "analytical report", "compatibility study",
]
_DESCRIPTOR_CONNECTORS = (" for ", " of ", " on ", " : ", ": ", " - ", " – ")


def strip_document_descriptor(name: str) -> str:
    """
    If `name` is a generic document descriptor optionally followed by the real
    material (e.g. "Material Characterization for Elastomeric Formulation 4432/50"),
    return the material subject. If the name is ONLY a descriptor, return "".
    Otherwise return the name unchanged.
    """
    if not name:
        return ""
    s = " ".join(str(name).split())
    low = s.lower()
    # "<descriptor> <connector> <material>" → keep material
    for desc in _DOC_DESCRIPTORS:
        if low.startswith(desc):
            rest = s[len(desc):]
            rl = rest.lower()
            for conn in _DESCRIPTOR_CONNECTORS:
                if rl.startswith(conn):
                    subject = rest[len(conn):].strip(" :-–").strip()
                    sl = subject.lower()
                    if sl in _DOC_DESCRIPTORS or \
                       any(sl.startswith(d) for d in _DOC_DESCRIPTORS) or \
                       "insights" in sl or "experts" in sl:
                        return ""
                    return subject
            # descriptor with no connector and nothing meaningful after → not a material
            if not rest.strip(" :-–"):
                return ""
    # If the WHOLE string is just a descriptor, it's not a material identity
    if low in _DOC_DESCRIPTORS:
        return ""
    return s


# ── Unit normalization ────────────────────────────────────────────────────────
# ALL concentrations are normalized to µg/g (= ppm) at extraction time so the
# downstream calculation never has to guess the unit.
#   ppm  = µg/g            → factor 1.0
#   ppb  = ng/g            → factor 0.001   (1 ppb = 0.001 ppm)
#   ppt  (parts/trillion)  → factor 0.000001
#   %    = g/100g          → factor 10000   (1% = 10000 ppm)
#   mg/g                   → factor 1000    (1 mg/g = 1000 µg/g)
#   ng/g = ppb             → factor 0.001
#   µg/kg = ppb            → factor 0.001
#   mg/kg = ppm            → factor 1.0
def unit_to_ppm_factor(unit: str) -> float:
    """Return the multiplier that converts a value in `unit` to µg/g (ppm)."""
    u = (unit or "").strip().lower().replace(" ", "")
    u = u.replace("μ", "µ")  # normalise micro sign
    table = {
        "ppm": 1.0, "µg/g": 1.0, "ug/g": 1.0, "mg/kg": 1.0, "mcg/g": 1.0,
        "ppb": 0.001, "ng/g": 0.001, "µg/kg": 0.001, "ug/kg": 0.001,
        "ppt": 0.000001, "pg/g": 0.000001,
        "%": 10000.0, "percent": 10000.0, "g/100g": 10000.0, "w/w%": 10000.0,
        "mg/g": 1000.0,
    }
    return table.get(u, 1.0)  # default: assume already ppm


def normalize_to_ppm(value: float, unit: str) -> float:
    """Convert a numeric concentration in `unit` to µg/g (ppm)."""
    return round(max(0.0, value) * unit_to_ppm_factor(unit), 8)


# ── observed_level parser ─────────────────────────────────────────────────────
# Returns (numeric_value, data_status, unit_hint).
# data_status ∈ {actual, less_than, bdl, blq, nd, not_tested, derived_loq}
def parse_observed_level(observed: str, page_loq: float = 0.0) -> Tuple[float, str, str]:
    """
    Parse a raw observed-level string into (value, status, unit_hint).
    Conservative & traceable: bracketed limits like "BDL (0.034 ppm)" use 0.034.
    """
    s = (observed or "").strip()
    if not s:
        return (0.0, "not_tested", "")
    sl = s.lower()

    # Detect unit hint from the string itself
    unit_hint = ""
    for u in ("ppb", "ng/g", "µg/kg", "ug/kg", "ppt", "mg/g", "ppm", "µg/g", "ug/g", "%"):
        if u in sl:
            unit_hint = u
            break

    # Bracketed numeric limit, e.g. "BDL (0.034 ppm)" / "< LOQ (0.05)"
    bracket = re.search(r"[\(\[]\s*<?\s*([0-9]*\.?[0-9]+)", s)

    # ND / Not Detected / Below LOD → true zero
    if any(k in sl for k in ("not detected", "below lod", "<lod", "nd ", " nd", "absent")) \
       or sl in ("nd", "n.d.", "not detected"):
        # if a bracketed LOD exists, keep status nd but value 0 (true non-detect)
        return (0.0, "nd", unit_hint)

    # Not tested / NA / blank
    if sl in ("na", "n/a", "not tested", "nt", "-", "—", "not analysed", "not analyzed"):
        return (0.0, "not_tested", unit_hint)

    # BDL / BLQ / Below LOQ → use bracketed limit if present (conservative)
    if any(k in sl for k in ("bdl", "blq", "below loq", "below limit", "<loq", "< loq", "nq")):
        if bracket:
            return (float(bracket.group(1)), "bdl", unit_hint)
        if page_loq > 0:
            return (page_loq, "derived_loq", unit_hint)
        return (0.0, "blq", unit_hint)  # no limit available → conservative 0

    # "<X.XX" less-than → use the limit value
    lt = re.match(r"^\s*[<≤]\s*([0-9]*\.?[0-9]+)", s)
    if lt:
        return (float(lt.group(1)), "less_than", unit_hint)

    # Plain number (possibly with trailing unit)
    num = re.search(r"([0-9]*\.?[0-9]+)", s)
    if num:
        return (float(num.group(1)), "actual", unit_hint)

    return (0.0, "not_tested", unit_hint)


# ── PDF rasterisation ─────────────────────────────────────────────────────────
def rasterize_pdf(pdf_bytes: bytes, dpi: int = 250) -> List[bytes]:
    """Convert every PDF page to a PNG image at the given DPI."""
    doc = fitz.open(stream=pdf_bytes, filetype="pdf")
    mat = fitz.Matrix(dpi / 72, dpi / 72)
    pages: List[bytes] = []
    for page in doc:
        pix = page.get_pixmap(matrix=mat, alpha=False, colorspace=fitz.csRGB)
        pages.append(pix.tobytes("png"))
    doc.close()
    return pages


