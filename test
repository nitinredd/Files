const t5 = buildCalcTable(5, safeTable(“class1_2a”), pdeValues);
for (let i = 0; i < t5.length; i++) children.push(t5[i]);
const t6 = buildCalcTable(6, safeTable(“class2b”), pdeValues);
for (let i = 0; i < t6.length; i++) children.push(t6[i]);
const t7 = buildCalcTable(7, safeTable(“class3”), pdeValues);
for (let i = 0; i < t7.length; i++) children.push(t7[i]);
children.push(pageBreakPara());
} catch (err) {
console.error(“Calc table error:”, err.message);
children.push(paraLeft(“Calculation table error: “ + err.message));
children.push(pageBreakPara());
}

// Section 6: Summary & Conclusion
const summary = buildSummarySection(txt);
for (let i = 0; i < summary.length; i++) children.push(summary[i]);

// Section 7: Reference
children.push(sectionHeading(“7. Reference”));
children.push(paraLeft(txt.reference || “NA”));
children.push(blankPara());

// Section 8: Annexure List
const annList = buildAnnexureList(annexureList);
for (let i = 0; i < annList.length; i++) children.push(annList[i]);

// Section 9: Revision History
const revHist = buildRevisionHistory(revisionHistory);
for (let i = 0; i < revHist.length; i++) children.push(revHist[i]);

// Electronic Signatures
const sigs = buildSignatures(meta, signatures);
for (let i = 0; i < sigs.length; i++) children.push(sigs[i]);

const doc = new Document({
styles: {
default: {
document: { run: { font: FONT_NAME, size: SIZE.BODY, color: COLOR.BLACK } },
},
},
sections: [{
properties: {
page: {
size: { width: PAGE_W, height: PAGE_H },
margin: {
top: MARGIN_TOP,
right: MARGIN_RIGHT,
bottom: MARGIN_BOT,
left: MARGIN_LEFT,
header: 400,
footer: 400,
},
},
},
headers: { default: buildPageHeader(meta) },
footers: { default: buildPageFooter() },
children: children,
}],
});

const buf = await Packer.toBuffer(doc);
fs.writeFileSync(outPath, buf);
console.log(“Report written: “ + outPath
+ “  (” + Math.round(buf.length / 1024) + “ KB)”);
}

// ============================================================================
// ENTRY POINT
// ============================================================================
const args = process.argv;
const dataPath = args[2];
const outPath  = args[3];

if (!dataPath || !outPath) {
console.error(“Usage: node generate_report.js <data.json> <out.docx>”);
process.exit(1);
}

generateReport(dataPath, outPath).catch(function (err) {
console.error(“FATAL:”, err.message || err);
if (err.stack) {
const lines = err.stack.split(”\n”).slice(0, 8);
console.error(lines.join(”\n”));
}
process.exit(1);
});
