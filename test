// ── SECTION 4 — PRODUCT NAME, DOSAGE FORM, INDICATION, LABEL CLAIM, COMPOSITION
function buildProductAndComposition(prodInfo, rawMaterials, composition) {
  prodInfo     = prodInfo || {};
  rawMaterials = Array.isArray(rawMaterials) ? rawMaterials : [];
  composition  = Array.isArray(composition)  ? composition  : [];
  var ch = [];
  ch.push(secHd("4. Product Name, Dosage Form, Indication, Label Claim and Composition"));

  // Product-level fields
  if (prodInfo.product_name) {
    ch.push(lftPara("Product Name:", true, SZ.SM));
    ch.push(bodyPara(prodInfo.product_name));
  }
  if (prodInfo.dosage_form) {
    ch.push(lftPara("Dosage Form:", true, SZ.SM));
    ch.push(bodyPara(prodInfo.dosage_form));
  }
  if (Array.isArray(prodInfo.indications) && prodInfo.indications.length) {
    ch.push(lftPara("Indication:", true, SZ.SM));
    prodInfo.indications.forEach(function(ind){ ch.push(bodyPara("• " + ind)); });
  } else if (prodInfo.indication) {
    ch.push(lftPara("Indication:", true, SZ.SM));
    bodyParas(prodInfo.indication).forEach(function(p){ch.push(p);});
  }
  if (prodInfo.label_claim) {
    ch.push(lftPara("Label Claim:", true, SZ.SM));
    bodyParas(prodInfo.label_claim).forEach(function(p){ch.push(p);});
  }
  ch.push(blk());

  // List of raw materials table
  if (rawMaterials.length) {
    ch.push(lftPara("List of Raw Materials", true, SZ.SM));
    var W = [Math.round(CW*0.07), Math.round(CW*0.42),
             Math.round(CW*0.20), 0];
    W[3] = CW - W[0] - W[1] - W[2];
    var rmRows = [new TableRow({children:[
      cell("Sr. No.",             {bold:true, fill:CLR.HDR_GREY, w:W[0], size:SZ.SM}),
      cell("Name of Ingredient",  {bold:true, fill:CLR.HDR_GREY, w:W[1], size:SZ.SM}),
      cell("Specification",       {bold:true, fill:CLR.HDR_GREY, w:W[2], size:SZ.SM}),
      cell("Function",            {bold:true, fill:CLR.HDR_GREY, w:W[3], size:SZ.SM}),
    ]})];
    for (var i = 0; i < rawMaterials.length; i++) {
      var rm = rawMaterials[i] || {};
      rmRows.push(new TableRow({children:[
        cell(String(rm.sno || (i+1)),           {w:W[0], size:SZ.SM}),
        cellL(String(rm.name || ""),            {w:W[1], size:SZ.SM}),
        cellL(String(rm.specification || ""),   {w:W[2], size:SZ.SM}),
        cellL(String(rm.function || ""),        {w:W[3], size:SZ.SM}),
      ]}));
    }
    ch.push(new Table({
      width:{size:CW, type:WidthType.DXA}, columnWidths:W, rows:rmRows,
    }));
    ch.push(blk());
  }

  // Qualitative and Quantitative Composition (multi-stage)
  if (composition.length) {
    ch.push(lftPara("Qualitative and Quantitative Composition", true, SZ.SM));
    var cW = [Math.round(CW*0.45), Math.round(CW*0.28), 0];
    cW[2] = CW - cW[0] - cW[1];
    var cRows = [new TableRow({children:[
      cell("Ingredients", {bold:true, fill:CLR.HDR_GREY, w:cW[0], size:SZ.SM}),
      cell("Role",        {bold:true, fill:CLR.HDR_GREY, w:cW[1], size:SZ.SM}),
      cell("mg/tab",      {bold:true, fill:CLR.HDR_GREY, w:cW[2], size:SZ.SM}),
    ]})];
    for (var si = 0; si < composition.length; si++) {
      var stage = composition[si] || {};
      if (stage.stage_name) {
        cRows.push(new TableRow({children:[new TableCell({
          columnSpan: 3, borders: allBdr(4),
          shading: shade(CLR.SEC_BLUE), margins: mg(),
          children: [lftPara(stage.stage_name, true, SZ.SM)],
        })]}));
      }
      var stageRows = Array.isArray(stage.rows) ? stage.rows : [];
      for (var ri = 0; ri < stageRows.length; ri++) {
        var r = stageRows[ri] || {};
        cRows.push(new TableRow({children:[
          cellL(String(r.ingredient || r.name || ""), {w:cW[0], size:SZ.SM}),
          cellL(String(r.role || r.function || ""),   {w:cW[1], size:SZ.SM}),
          cell(String(r.mg_per_tab != null ? r.mg_per_tab : (r.amount || "")),
               {w:cW[2], size:SZ.SM}),
        ]}));
      }
      if (stage.subtotal_label && stage.subtotal_value != null) {
        cRows.push(new TableRow({children:[new TableCell({
          columnSpan: 2, borders: allBdr(4),
          shading: shade(CLR.HDR_GREY), margins: mg(),
          children: [lftPara(stage.subtotal_label, true, SZ.SM)],
        }),
        cell(String(stage.subtotal_value),
             {bold:true, fill:CLR.HDR_GREY, w:cW[2], size:SZ.SM}),
        ]}));
      }
    }
    ch.push(new Table({
      width:{size:CW, type:WidthType.DXA}, columnWidths:cW, rows:cRows,
    }));
    ch.push(blk());
  }
  return ch;
}

