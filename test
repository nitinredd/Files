_ALIAS_TO_FAMILY: Dict[str, str] = {}
_ALIAS_TO_KEY: Dict[str, str] = {}
for _k, _rule in _FAMILY_RULES.items():
    for _al in _rule["aliases"]:
        _ALIAS_TO_FAMILY[_al.lower()] = _rule["family"]
        _ALIAS_TO_KEY[_al.lower()] = _k

_DOC_DESCRIPTOR_RE = re.compile(
    r"^(residual\s+solvent[s]?|deg\s*&?\s*eg|coa|certificate\s+of\s+analysis|"
    r"specification|quality\s+statement|regulatory\s+information|declaration|"
    r"statement|safety\s+data\s+sheet|sds|monograph)\b", re.IGNORECASE)


def strip_descriptor(name: str) -> str:
    """Recover the material subject from '<descriptor> for <material>' phrasing."""
    s = _s(name)
    m = re.search(r"\bfor\s+(.+)$", s, re.IGNORECASE)
    if m and _DOC_DESCRIPTOR_RE.search(s):
        return m.group(1).strip()
    return s


def is_generic_material_name(name: str) -> bool:
    s = _s(name).lower().strip()
    s = re.sub(r"[^a-z0-9 ]+", "", s).strip()
    return s in _GENERIC_MATERIAL_NAMES


def _norm(text: str) -> str:
    s = _s(text).lower().replace("\u00ae", " ").replace("\u2122", " ").replace("&", " and ")
    s = re.sub(r"[^a-z0-9]+", " ", s)
    return re.sub(r"\s+", " ", s).strip()


def _canonical_tokens(text: str) -> set:
    return {t for t in _norm(text).split() if len(t) > 1 and t not in _NOISE}


def _strip_descriptor_phrases(text: str) -> str:
    """String-level strip of specification / grade / pharmacopoeia / purity
    phrases before identity tokenization. Product-agnostic: strips descriptors
    only, never chemistry identity words."""
    if not text:
        return ""
    s = _s(text)
    s = _DESCRIPTOR_PHRASE_RE.sub(" ", s)
    s = _PURITY_DESCRIPTORS_RE.sub(" ", s)
    return re.sub(r"\s+", " ", s).strip()


def _paren_tokens(text: str) -> set:
    """Extract tokens from parenthesized content and return them as extras.
    'Mannitol (Pearlitol 50C)' \u2192 {pearlitol, 50c}."""
    extras: set = set()
    for m in re.finditer(r"\(([^)]+)\)", _s(text)):
        for t in _norm(m.group(1)).split():
            if len(t) > 1 and t not in _NOISE:
                extras.add(t)
    return extras


def _extras_from_name(text: str) -> set:
    """Return salt / hydrate / purity descriptor extras from a name.
    'Trilaciclib 2HCl' \u2192 {2hcl, hcl}, 'Citric acid monohydrate' \u2192 {monohydrate}."""
    extras: set = set()
    low = _s(text).lower()
    for sfx in _SALT_SUFFIXES + _HYDRATE_SUFFIXES:
        if re.search(rf"\b{re.escape(sfx)}\b", low):
            extras.add(sfx)
    for m in _PURITY_DESCRIPTORS_RE.finditer(text):
        extras.add(re.sub(r"\s+", "_", m.group(0).lower().strip()))
    return extras


def _identity_norm(text: str) -> str:
    """Fully-stripped normalized identity STRING for exact-match tests.

    Removes: parenthesized content, descriptor phrases, salt/hydrate suffixes,
    purity descriptors, noise words, standalone digits. Returns a sorted
    token-set string so equivalent inputs (in any order, any pharmacopoeia
    suffix) produce the same key. Product-agnostic \u2014 never strips chemistry
    identity words.
    """
    if not text:
        return ""
    s = _s(text)
    # Drop paren content from the primary identity string (paren tokens still
    # participate in containment/overlap tiers via the extras set).
    s = re.sub(r"\([^)]*\)", " ", s)
    s = _strip_descriptor_phrases(s)
    # strip salt / hydrate suffix words from the identity
    for sfx in _SALT_SUFFIXES + _HYDRATE_SUFFIXES:
        s = re.sub(rf"\b{re.escape(sfx)}\b", " ", s, flags=re.IGNORECASE)
    tokens = []
    for t in _norm(s).split():
        if t in _NOISE or t.isdigit() or len(t) <= 1:
            continue
        tokens.append(t)
    return " ".join(sorted(set(tokens)))


def _filename_derived_name(filename: str) -> str:
    """Strip filename to the material-name subject (product-agnostic):
    drop extension, annexure markers, SAP/GRN codes, dates, document-type words.
    Returns '' if nothing meaningful remains."""
    if not filename:
        return ""
    s = _s(filename)
    s = re.sub(r"\.(pdf|json|docx?|xlsx?|png|jpe?g|tiff?)$", "", s, flags=re.IGNORECASE)
    s = re.sub(r"[\(\[]?\s*annexure[\s_\-]*\d+\s*[\)\]]?", " ", s, flags=re.IGNORECASE)
    s = re.sub(r"\b(RCQR|RCRR|GRN|AR|ATR|SAP)[\-_ ]?\d{2,}\b", " ", s, flags=re.IGNORECASE)
    s = re.sub(r"[_\-]+", " ", s)
    s = re.sub(r"\b\d{4}[\-/]\d{2}[\-/]\d{2}\b", " ", s)
    s = re.sub(r"\b\d{2}[\-/]\d{2}[\-/]\d{4}\b", " ", s)
    s = re.sub(r"\b\d{8,}\b", " ", s)
    _docwords = (r"coa|certificate\s+of\s+analysis|specification|spec|declaration|"
                 r"statement|sds|msds|regulatory|quality|residual\s+solvents?|"
                 r"annexure|monograph|information|report|final|copy")
    s = re.sub(r"\b(" + _docwords + r")\b", " ", s, flags=re.IGNORECASE)
    s = re.sub(r"\s+", " ", s).strip(" -\u2013:_")
    if not s or re.fullmatch(r"[\d\s.]+", s):
        return ""
    return s


def _detect_family(text: str) -> Tuple[str, str]:
    norm = " " + _norm(text) + " "
    best, best_len = ("", ""), 0
    for alias, fam in _ALIAS_TO_FAMILY.items():
        a = _norm(alias)
        if a and f" {a} " in norm and len(a) > best_len:
            best, best_len = (fam, _ALIAS_TO_KEY[alias]), len(a)
    return best


def _identity(text: str) -> Dict[str, Any]:
    raw = _s(text)
    stripped = strip_descriptor(raw) or raw
    stripped = _strip_descriptor_phrases(stripped)
    fam, fam_key = _detect_family(stripped)
    toks = _canonical_tokens(stripped)
    # Fold paren-content and salt/hydrate extras into the token pool so
    # containment / overlap tiers can see brand names like "PEARLITOL 50C"
    # even when the primary name is just "Mannitol".
    toks |= _paren_tokens(raw)
    toks |= _extras_from_name(raw)
    fam_tokens = _canonical_tokens(fam) if fam else set()
    return {"raw": raw, "tokens": toks, "family": fam, "family_key": fam_key,
            "family_tokens": fam_tokens,
            "identity_norm": _identity_norm(raw)}


def _distinctive(tokens: set) -> set:
    return {t for t in tokens if t not in _GENERIC_TOKENS}


def _pair_blocked(fa: str, fb: str) -> bool:
    if not fa or not fb or fa == fb:
        return False
    return {fa, fb} in [{x, y} for x, y in _NEGATIVE_FAMILY_PAIRS]


def _pool_identity(ann: Dict) -> Dict[str, Any]:
    """Build the annexure identity pool from ALL sources: material_name,
    candidates, filename-derived name, document_title, supplier_name.
    Also emits a set of per-source normalized identity strings for Tier 1/2
    exact-match tests."""
    primary = _s(ann.get("material_name"))
    candidates = [_s(c) for c in (ann.get("material_name_candidates") or []) if _s(c)]
    filename_derived = _filename_derived_name(_s(ann.get("filename")))
    title = _s(ann.get("document_title"))
    supplier = _s(ann.get("supplier_name"))

    sources = []
    if primary and not is_generic_material_name(primary):
        sources.append(("material_name", primary))
    for c in candidates:
        if not is_generic_material_name(c):
            sources.append(("candidate", c))
    if filename_derived and not is_generic_material_name(filename_derived):
        sources.append(("filename", filename_derived))
    if title and not is_generic_material_name(title):
        sources.append(("title", title))
    if supplier:
        sources.append(("supplier", supplier))

    tokens: set = set()
    fam, fam_key = "", ""
    identity_norms: List[Tuple[str, str]] = []   # (source_kind, norm_id)
    for kind, s in sources:
        idd = _identity(s)
        tokens |= idd["tokens"]
        tokens |= idd["family_tokens"]
        if idd["family"] and not fam:
            fam, fam_key = idd["family"], idd["family_key"]
        n = idd.get("identity_norm", "")
        if n:
            identity_norms.append((kind, n))

    return {"tokens": tokens, "family": fam, "family_key": fam_key,
            "identity_norms": identity_norms,
            "filename_derived": filename_derived}


def _score(cid: Dict[str, Any], aid: Dict[str, Any]) -> Tuple[float, str]:
    """Sequential-tier scoring. Never short-circuits at 0 just because a family
    alias is missing; token-based tiers ALWAYS run so any molecule is scorable
    without pre-registration in the family vocabulary.

    Tier 1 (0.99): exact normalized identity match to annexure material_name
    Tier 2 (0.99): exact normalized identity match to any candidate
    Tier 3 (0.97): recognised family alias match
    Tier 4 (0.90): distinctive-token containment (either direction)
    Tier 5 (0.50–0.85): Jaccard + distinctive overlap fallback
    Tier 6 (0.95): exact normalized match to filename-derived name

    Negative family pairs are always blocked (0.0).
    """
    cf, af = cid.get("family", ""), aid.get("family", "")
    if _pair_blocked(cf, af):
        return 0.0, f"blocked negative pair {cf} vs {af}"

    c_norm = cid.get("identity_norm", "")
    identity_norms: List[Tuple[str, str]] = aid.get("identity_norms", [])

    # Tier 1 & 2: exact normalized match against any annexure identity source.
    # material_name and candidates are equally weighted (both 0.99).
    if c_norm:
        for kind, a_norm in identity_norms:
            if not a_norm:
                continue
            if c_norm == a_norm and kind in ("material_name", "candidate"):
                return 0.99, f"exact normalized match to {kind}"
        # Tier 6: filename-derived name exact
        for kind, a_norm in identity_norms:
            if kind == "filename" and a_norm and c_norm == a_norm:
                return 0.95, "exact match to filename-derived name"

    # Tier 3: family alias
    if cf and af and cf == af:
        return 0.97, f"family match: {cf}"

    ctoks = cid.get("tokens", set()) | cid.get("family_tokens", set())
    atoks = aid.get("tokens", set())
    if not ctoks or not atoks:
        return 0.0, "no tokens"
    inter, union = ctoks & atoks, ctoks | atoks
    jacc = len(inter) / len(union) if union else 0.0
    dc, da = _distinctive(ctoks), _distinctive(atoks)
    di, du = dc & da, dc | da
    dov = len(di) / len(du) if du else 0.0

    # Tier 4: distinctive-token containment (either direction)
    if dc and da and di:
        smaller, larger = (dc, da) if len(dc) <= len(da) else (da, dc)
        if smaller and smaller <= larger:
            return 0.90, f"distinctive token containment {sorted(smaller)}"

    # Tier 5: Jaccard + distinctive overlap fallback (0.50–0.85 typical range).
    contain = 0.0
    if dc and da:
        smaller, larger = (dc, da) if len(dc) <= len(da) else (da, dc)
        if smaller:
            contain = len(smaller & larger) / len(smaller)
    if not di:
        # only generic-suffix overlap; suppress hard
        return round(0.12 * jacc, 4), "generic-only overlap"
    score = 0.30 * jacc + 0.40 * dov + 0.30 * contain
    return round(min(0.85, max(0.0, score)), 4), \
        f"distinctive overlap {sorted(di)}"


def map_materials_to_annexures(materials: List[str],
                               annexures: List[Dict]) -> Dict[str, Dict]:
    """Auto-map each composition material to a DEG/EG annexure using tiered
    identity scoring. Product-agnostic: works for any molecule, not just those
    in the family alias vocabulary. Auto-accept threshold: 0.85.
    """
    ann_recs = [(a, _pool_identity(a)) for a in annexures
                if isinstance(a, dict) and not a.get("_error")]
    result: Dict[str, Dict] = {}
    for comp in materials:
        cid = _identity(comp)
        best, best_score, best_reason, runner = None, 0.0, "", 0.0
        for ann, aid in ann_recs:
            sc, reason = _score(cid, aid)
            if sc > best_score:
                runner, best_score, best, best_reason = best_score, sc, ann, reason
            elif sc > runner:
                runner = sc
        if best is not None and best_score >= 0.85:
            conf = round(best_score, 2)
            result[comp] = {
                "matched_annexure": best.get("annexure_number"),
                "matched_material": best.get("material_name", ""),
                "confidence": conf, "match_reason": best_reason,
                "status": "Auto-accepted",
                "needs_confirmation": False, "_annexure": best,
            }
        elif best is not None and best_score >= 0.60:
            # Retain as a mapping but flag for internal audit only (not rendered).
            conf = round(best_score, 2)
            result[comp] = {
                "matched_annexure": best.get("annexure_number"),
                "matched_material": best.get("material_name", ""),
                "confidence": conf, "match_reason": best_reason,
                "status": "Auto-accepted",
                "needs_confirmation": False, "_annexure": best,
            }
        else:
            result[comp] = {
                "matched_annexure": None, "matched_material": "", "confidence": 0.0,
                "match_reason": f"no confident match (best {best_score:.2f})",
                "status": "No match", "needs_confirmation": True, "_annexure": None,
            }
        # DEG/EG spec Part A: flag FDA high-risk families so the assessment can
        # attach the mandatory scientific-rationale observation (from the
        # component name AND the matched annexure material name).
        result[comp]["high_risk_deg_eg"] = (
            is_high_risk_deg_eg(comp)
            or is_high_risk_deg_eg(result[comp].get("matched_material", "")))
    return result


# ════════════════════════════════════════════════════════════════════════════
# ANNEXURE NORMALISATION (DEG/EG schema; NEVER elements[])
# ════════════════════════════════════════════════════════════════════════════
_GENERIC_SCOPE_RE = re.compile(
    r"class\s*[i1-3]+|ovi|organic\s+volatile|other\s+residual\s+solvent|"
    r"residual\s+solvents?|ich\s*q3c|usp\s*<?\s*467|water", re.IGNORECASE)

# DRL SAP material codes start 1000/2000/3000/3500 then 4-5 more digits.
_DRL_SAP_RE = re.compile(r"^(1000|2000|3000|3500)\d{4,5}$")
# DRL specification numbers: SP-CFTO-003256-3 etc.
_DRL_SPEC_NO_RE = re.compile(r"^SP-[A-Z]{2,4}-?\d{6,10}(-\d+)?$", re.IGNORECASE)
# CAS numbers: 1-7 digits - 2 digits - 1 digit
_CAS_RE = re.compile(r"^\d{1,7}-\d{2}-\d$")

# ── Filename-based SAP code / DRL spec no inference (Fix 5) ──────────────────
# DRL SAP codes visible in filenames start 1000/2000/3000/3500 or 350 followed
# by additional digits, delimited by word boundaries (underscore/hyphen/space).
_FILENAME_SAP_RE = re.compile(
    r"(?:^|[_\-\s\(])((?:1000|2000|3000|3500)\d{4,5}|350\d{6})(?=[_\-\s\)\.]|$)"
)
_FILENAME_DATE_RE = re.compile(r"\b(19|20)\d{6}\b")     # YYYYMMDD-like
_FILENAME_SPEC_RE = re.compile(r"(SP-[A-Z]{2,4}-?\d{6,10}(?:-\d+)?)", re.IGNORECASE)


def _infer_material_code_from_filename(filename: str) -> str:
    """Fallback: extract a DRL SAP material code from the filename when the
    CoA body extraction returned empty. Product-agnostic. Filters out
    date-like sequences and vendor GRN prefixes."""
    if not filename:
        return ""
    stem = filename.rsplit(".", 1)[0]
    # Kill date-like sequences (YYYYMMDD, timestamps) before pattern-matching so
    # they can never be picked up as SAP codes.
    stem_clean = _FILENAME_DATE_RE.sub(" ", stem)
    for code in _FILENAME_SAP_RE.findall(stem_clean):
        code = code.strip()
        if 6 <= len(code) <= 9 and code.isdigit():
            return code
    return ""


def _infer_drl_spec_no_from_filename(filename: str) -> str:
    """Fallback: extract a DRL specification number (SP-CFTO-003256-3 style)
    from the filename when body extraction returned empty."""
    if not filename:
        return ""
    stem = filename.rsplit(".", 1)[0]
    m = _FILENAME_SPEC_RE.search(stem)
    if not m:
        return ""
    val = m.group(1)
    return val if _DRL_SPEC_NO_RE.match(val) else ""


# Guarantee-ceiling signals: a vendor MAX the material is guaranteed to stay
# below, NOT quantified/tested per batch, below the regulatory limit. This is
# NOT confirmed presence (Roquette Mannitol class). Kept conservative so a
# genuine per-batch CoA (Polysorbate 80: "NMT 620 ppm, tested per batch by USP
# <469>") never trips it.
_GC_STRONG_SIGNALS = (
    "guarantee", "guaranteed", "not quantified", "not quantitated",
    "not tested per batch", "not routinely tested", "not tested routinely",
    "not tested each batch", "not tested every batch", "below option",
)

# Per-batch testing signals (Tier 1 — confirmed present). When the vendor
# actually MEASURES DEG/EG every batch and reports a numeric CoA result, that is
# a confirmed presence and must NOT be downgraded to a guarantee ceiling even if
# the same document also contains the word "guarantee" (Polysorbate 80 Croda
# CoA regression). Phrased to avoid matching the NEGATED forms in
# _GC_STRONG_SIGNALS ("not tested per batch" etc.).
_PER_BATCH_SIGNALS = (
    "tested each batch", "tested every batch", "tested per batch",
    "per-batch testing", "per batch testing", "batch analysis",
    "routinely tested", "tested routinely", "result:", "found:",
    "test result", "coa result", "each batch is tested", "analysed each batch",
    "analyzed each batch",
)

# FDA high-risk DEG/EG material families (per FDA Guidance for Industry on testing
# of glycerin, propylene glycol, maltitol solution, hydrogenated starch
# hydrolysate, sorbitol solution and other high-risk components). Matched on a
# normalised substring of the resolved material name — RS Bug/DEG-EG spec Part A.
FDA_HIGH_RISK_DEG_EG = (
    "glycerin", "glycerine", "glycerol",
    "propylene glycol",
    "sorbitol", "d-sorbitol", "neosorb", "sorbogem",
    "mannitol", "pearlitol", "d-mannitol",
    "maltitol",
    "hydrogenated starch hydrolysate", "hsh",
    "polyethylene glycol", "peg", "macrogol",
    "polysorbate", "polysorbate 20", "polysorbate 40", "polysorbate 60",
    "polysorbate 80", "tween",
    "polyethylene oxide", "polyethylene glycol oxide",
    "hydrogenated castor oil",
)


def is_high_risk_deg_eg(name: str) -> bool:
    """True when a material name resolves to an FDA high-risk DEG/EG family."""
    n = _norm(name)
    if not n:
        return False
    return any(fam in n for fam in FDA_HIGH_RISK_DEG_EG)


def _has_per_batch_testing_signal(*texts: Any) -> bool:
    """True when the evidence reads as a genuine per-batch measurement (Tier 1)."""
    blob = " ".join(_s(t) for t in texts).lower()
    if not blob:
        return False
    return any(sig in blob for sig in _PER_BATCH_SIGNALS)


def _has_guarantee_ceiling_signal(*texts: Any) -> bool:
    """True when the evidence text reads as a vendor guarantee ceiling rather
    than a confirmed per-batch measurement."""
    blob = " ".join(_s(t) for t in texts).lower()
    if not blob:
        return False
    if any(sig in blob for sig in _GC_STRONG_SIGNALS):
        return True
    # "below / less than …" tied to a USP <469> Option reference.
    if ("below" in blob or "less than" in blob) and (
            "option 1" in blob or "option 2" in blob):
        return True
    return False


# ── Deterministic raw_text backstop for the multi-page CoA bug ────────────────
# When the vision extractor misses a DEG/EG limit that IS present in the (now
# concatenated, multi-page) evidence text — e.g. the Croda Polysorbate 80 CoA:
# "Ethylene Glycol Not more than 620 ppm PASS" (page 2) and "ETHYLENE GLYCOL
# (USP/NF 469) 620 PPM MAX Pass" (page 4) — this recovers the numeric limit and
# the tier from the text. Glycol names use a lookbehind so "ethylene glycol"
# does NOT match inside "diethylene glycol". Product-agnostic.
_EG_NAME_RE = re.compile(
    r"(?<![a-z])(?<!di)(?<!tri)ethylene\s+glycol\b|(?<![a-z])eg(?![a-z])|"
    r"monoethylene\s+glycol", re.IGNORECASE)
_DEG_NAME_RE = re.compile(
    r"diethylene\s+glycol\b|(?<![a-z])deg(?![a-z])", re.IGNORECASE)
# A ppm limit within a short window after the glycol name.
_DEGEG_PPM_RE = re.compile(
    r"(?:not\s+more\s+than|nmt|≤|<=|max(?:imum)?|below|less\s+than)?\s*"
    r"(\d{1,6}(?:\.\d+)?)\s*ppm(?:\s*(?:max|maximum))?", re.IGNORECASE)
_DEGEG_CONFIRMED_RE = re.compile(
    r"\bpass(?:ed|es)?\b|\bcompl(?:y|ies|ied)\b|usp\s*<?\s*/?\s*nf?\s*<?\s*469|"
    r"usp\s*<?\s*469|per\s*[- ]?batch|tested\s+each\s+batch|result\s*[:=]",
    re.IGNORECASE)


def _rescue_glycol_from_text(text: str, name_re: "re.Pattern") -> Optional[Dict]:
    """Recover (present, limit, source, confidence) for one glycol from free text,
    or None when no numeric limit is tied to the glycol. Only ever UPGRADES a
    missed limit; the caller applies it solely when structured evidence is weak.
    A confirmed per-batch/CoA result (PASS / USP<469> / result) → Yes/vendor_coa;
    a guarantee ceiling → No/vendor_guarantee_ceiling; a bare regulatory citation
    with neither → None (never fabricates a Yes)."""
    if not text:
        return None
    for m in name_re.finditer(text):
        window = text[m.start(): m.end() + 120]
        pm = _DEGEG_PPM_RE.search(window)
        if not pm:
            continue
        ppm = pm.group(1)
        confirmed = bool(_DEGEG_CONFIRMED_RE.search(window)) or \
            _has_per_batch_testing_signal(window)
        guarantee = _has_guarantee_ceiling_signal(window)
        if confirmed and not guarantee:
            return {"present": "Yes", "limit": f"NMT {ppm} ppm",
                    "source": "vendor_coa", "confidence": 0.95}
        if guarantee:
            return {"present": "No", "limit": f"< {ppm} ppm",
                    "source": "vendor_guarantee_ceiling", "confidence": 0.9}
        # Numeric limit present but no result/guarantee context → not enough to
        # assert presence (could be a regulatory-limit citation). Skip.
    return None


def process_deg_eg_annexure(obj: Any, index: int) -> Dict:
    """Normalise a DEG/EG annexure object into the strict schema. Repairs bad
    shapes; never raises; never emits EI elements[]."""
    default = {
        "annexure_number": index, "filename": "", "supplier_name": "",
        "material_name": "", "material_name_candidates": [],
        "material_name_source": "body", "needs_material_confirmation": False,
        "material_code": "", "material_code_source": "not_found",
        "cas_number": "", "drl_specification_no": "",
        "document_title": "", "annexure_type": "other",
        "deg_eg_evidence": {
            "deg_present": "Unknown", "deg_specification_limit": None,
            "deg_source": "not_mentioned", "eg_present": "Unknown",
            "eg_specification_limit": None, "eg_source": "not_mentioned",
            "raw_text": "", "page": 1, "confidence": 0.0,
        },
        "declaration_scopes": [], "schema_repaired": False, "_error": False,
        "raw_text": "",
    }
    # Repair: LLM sometimes returns a bare list at top level. Unwrap a single
    # dict element (or the first dict in the list) rather than erroring out.
    repaired_from_list = False
    if isinstance(obj, list):
        dict_items = [x for x in obj if isinstance(x, dict)]
        if len(dict_items) == 1:
            obj = dict_items[0]
            repaired_from_list = True
        elif len(dict_items) > 1:
            # Merge defensively: take the first as base, it's the most likely record
            obj = dict_items[0]
            repaired_from_list = True

    if not isinstance(obj, dict):
        d = dict(default)
        d["_error"] = True
        d["extraction_notes"] = f"Malformed annexure: got {type(obj).__name__}."
        return d

    if obj.get("_error"):
        d = dict(default)
        d["_error"] = True
        d["extraction_notes"] = _s(obj.get("extraction_notes")) or "Extraction failed."
        return d

    out = dict(default)
    if obj.get("schema_repaired") or obj.get("_list_root") or repaired_from_list:
        out["schema_repaired"] = True

    for fld in ("filename", "supplier_name", "document_title", "raw_text"):
        if obj.get(fld) is not None:
            out[fld] = _s(obj.get(fld))

    at = _s(obj.get("annexure_type")).lower()
    if at in ("supplier_declaration", "coa", "specification", "sds", "statement",
              "monograph", "other"):
        out["annexure_type"] = at

    # Material identity — never accept generic doc titles
    mat = _s(obj.get("material_name"))
    cands = obj.get("material_name_candidates", [])
    cands = [_s(c) for c in cands if _s(c)] if isinstance(cands, list) else []
    out["material_name_candidates"] = cands
    src = _s(obj.get("material_name_source")) or "body"
    if mat and not is_generic_material_name(mat):
        out["material_name"] = mat
        out["material_name_source"] = src if src in ("body", "filename_inferred", "title") else "body"
    elif cands and not is_generic_material_name(cands[0]):
        out["material_name"] = cands[0]
        out["material_name_source"] = "body"
    else:
        # infer from filename, never from title
        fn = _s(obj.get("filename"))
        inferred = re.sub(r"\.(pdf|json|docx?|xlsx?)$", "", fn, flags=re.IGNORECASE)
        inferred = re.sub(r"[_\-]+", " ", inferred).strip()
        # strip trailing/leading document-type words (COA, spec, declaration, etc.)
        _docwords = (r"coa|certificate\s+of\s+analysis|specification|spec|"
                     r"declaration|statement|sds|msds|regulatory|quality|"
                     r"residual\s+solvents?|deg\s*&?\s*eg|annexure|monograph|"
                     r"information")
        inferred = re.sub(r"\b(" + _docwords + r")\b", " ", inferred,
                          flags=re.IGNORECASE)
        inferred = re.sub(r"\s+", " ", inferred).strip()
        if inferred and not is_generic_material_name(inferred):
            out["material_name"] = inferred
            out["material_name_source"] = "filename_inferred"
            out["needs_material_confirmation"] = True
        else:
            out["material_name"] = ""
            out["needs_material_confirmation"] = True
    if obj.get("needs_material_confirmation"):
        out["needs_material_confirmation"] = True

    # DEG/EG evidence
    ev = obj.get("deg_eg_evidence")
    if isinstance(ev, dict):
        def present(v):
            v = _s(v).capitalize()
            return v if v in ("Yes", "No", "Unknown") else "Unknown"
        def source(v, default="not_mentioned"):
            v = _s(v).lower()
            allowed = ("vendor_coa", "vendor_spec", "vendor_guarantee_ceiling",
                       "monograph", "policy_statement", "usp_469",
                       "usfda_guidance", "excluded_by_process", "not_mentioned")
            return v if v in allowed else default
        oev = dict(default["deg_eg_evidence"])
        oev["deg_present"] = present(ev.get("deg_present"))
        oev["eg_present"] = present(ev.get("eg_present"))
        oev["deg_source"] = source(ev.get("deg_source"))
        oev["eg_source"] = source(ev.get("eg_source"))
        # numeric limits ONLY from vendor_coa / vendor_spec / usp_469; never from
        # policy_statement / monograph-only / not_mentioned. A guarantee ceiling
        # keeps its numeric limit too — it is documented (as a No), not a result.
        def limit(val, sourceval):
            v = _s(val)
            if not v:
                return None
            if sourceval in ("vendor_coa", "vendor_spec", "usp_469",
                             "vendor_guarantee_ceiling"):
                return v
            return None
        oev["deg_specification_limit"] = limit(ev.get("deg_specification_limit"),
                                               oev["deg_source"])
        oev["eg_specification_limit"] = limit(ev.get("eg_specification_limit"),
                                              oev["eg_source"])
        oev["raw_text"] = _s(ev.get("raw_text"))
        oev["page"] = ev.get("page", 1)
        oev["confidence"] = _f(ev.get("confidence")) or 0.0
        # If a "present=Yes" came only from a policy statement, downgrade to Unknown
        if oev["deg_source"] == "policy_statement":
            oev["deg_present"] = "Unknown"
            oev["deg_specification_limit"] = None
        if oev["eg_source"] == "policy_statement":
            oev["eg_present"] = "Unknown"
            oev["eg_specification_limit"] = None

        # ── RAW-TEXT BACKSTOP (multi-page CoA rescue) ─────────────────────────
        # Recover a DEG/EG numeric limit the vision extractor missed, from the
        # concatenated multi-page evidence text (the Croda Polysorbate 80 CoA
        # bug: EG limit sits on pages 2 & 4 as "Not more than 620 ppm PASS" /
        # "620 PPM MAX Pass"). Only fills a glycol whose structured evidence is
        # WEAK (not already Yes and no limit) so real evidence is never
        # overridden. The GC / consistency guards below still validate the result.
        _rescue_blob = " ".join(t for t in (oev.get("raw_text"),
                                            _s(obj.get("raw_text"))) if t)
        for which, name_re in (("deg", _DEG_NAME_RE), ("eg", _EG_NAME_RE)):
            if oev[f"{which}_present"] == "Yes" or _s(oev[f"{which}_specification_limit"]):
                continue
            rescued = _rescue_glycol_from_text(_rescue_blob, name_re)
            if rescued:
                oev[f"{which}_present"] = rescued["present"]
                oev[f"{which}_specification_limit"] = rescued["limit"]
                oev[f"{which}_source"] = rescued["source"]
                oev["confidence"] = max(_f(oev.get("confidence")),
                                        rescued["confidence"])
                out.setdefault("backstop_recoveries", []).append(
                    f"{which.upper()} {rescued['present']} {rescued['limit']} "
                    f"recovered from multi-page evidence text ({rescued['source']}).")

        # ── GUARANTEE-CEILING GUARD (Roquette Mannitol class) ─────────────────
        # A vendor guarantee ceiling ("EG < 620 ppm, below Option 1, not
        # quantified per batch") is NOT confirmed presence. Downgrade Yes→No and
        # tag source=vendor_guarantee_ceiling, but PRESERVE the numeric limit so
        # the detail table / Observations can still cite the vendor control.
        # This runs BEFORE the consistency guard so the limit is not nulled.
        _gc_notes = []
        # Per-batch measurement (Tier 1) OUTRANKS a guarantee-ceiling signal: a
        # vendor that tests DEG/EG every batch and reports a numeric result is a
        # confirmed presence, even if the document also says "guarantee". Detected
        # once from the evidence text so a Tier-1 CoA is never downgraded.
        _per_batch = _has_per_batch_testing_signal(oev.get("raw_text"))
        for which in ("deg", "eg"):
            srcv = oev[f"{which}_source"]
            limtxt = _s(oev[f"{which}_specification_limit"])
            # Scope the text scan to the per-glycol evidence + its limit string
            # only — never the whole-document raw_text, so unrelated boilerplate
            # ("we guarantee product quality") can't downgrade a real per-batch
            # result (Polysorbate 80).
            is_gc = (srcv == "vendor_guarantee_ceiling"
                     or _has_guarantee_ceiling_signal(oev.get("raw_text"), limtxt))
            # Tier-1 protection: a genuine per-batch result is not a guarantee
            # ceiling. Only downgrade when there is NO per-batch measurement and
            # the source is not already a confirmed numeric CoA/spec/USP<469>.
            if is_gc and _per_batch and srcv != "vendor_guarantee_ceiling":
                _gc_notes.append(
                    f"{which.upper()} carries a guarantee word but also a per-batch "
                    "result → kept as confirmed (Tier 1), not downgraded.")
                is_gc = False
            if is_gc:
                oev[f"{which}_source"] = "vendor_guarantee_ceiling"
                if oev[f"{which}_present"] != "No":
                    oev[f"{which}_present"] = "No"
                    _gc_notes.append(
                        f"{which.upper()} treated as vendor guarantee ceiling "
                        "(below regulatory limit, not quantified per batch) → No; "
                        "limit retained for documentation.")
        if _gc_notes:
            out["guarantee_ceiling_notes"] = _gc_notes
            logger.info("[DEG/EG annexure %s] %s", index, " ".join(_gc_notes))

        # ── CONSISTENCY GUARD (Fix 3) ─────────────────────────────────────────
        # present=Yes is only valid with a real source AND a numeric limit.
        # Otherwise downgrade to Unknown and log the reason. This kills the
        # contradictory "Yes + null + not_mentioned" output.
        _guard_notes = []
        for which in ("deg", "eg"):
            pres = oev[f"{which}_present"]
            lim = oev[f"{which}_specification_limit"]
            srcv = oev[f"{which}_source"]
            if pres == "Yes":
                if srcv not in ("vendor_coa", "vendor_spec", "usp_469"):
                    oev[f"{which}_present"] = "Unknown"
                    oev[f"{which}_specification_limit"] = None
                    _guard_notes.append(
                        f"{which.upper()} present=Yes had source '{srcv or 'empty'}' "
                        "(not a real evidence source) → downgraded to Unknown.")
                elif not _s(lim):
                    oev[f"{which}_present"] = "Unknown"
                    _guard_notes.append(
                        f"{which.upper()} present=Yes had null/empty limit → "
                        "downgraded to Unknown.")
        if _guard_notes:
            out["consistency_downgrades"] = _guard_notes
            logger.warning("[DEG/EG annexure %s] %s", index, " ".join(_guard_notes))

        out["deg_eg_evidence"] = oev

    # ── SAP material code / spec no / CAS (Fix 4c validation) ─────────────────
    def _digits(s: str) -> str:
        m = re.search(r"\d{4,10}", _s(s))
        return m.group(0) if m else ""

    raw_code = _s(obj.get("material_code"))
    code_digits = re.sub(r"[^0-9]", "", raw_code)
    if _DRL_SAP_RE.match(code_digits):
        out["material_code"] = code_digits
        out["material_code_source"] = "sap_code"
    else:
        # Fix 5 – Tier 2 fallback: infer from filename when body extraction fails.
        # Never overrides a valid body-extracted code.
        fn_code = _infer_material_code_from_filename(_s(obj.get("filename"))
                                                     or out.get("filename"))
        if fn_code:
            out["material_code"] = fn_code
            out["material_code_source"] = "filename_inferred"
            logger.debug("[DEG/EG annexure %s] SAP material code %s inferred "
                         "from filename '%s'.", index, fn_code, out.get("filename"))
        else:
            out["material_code"] = ""
            out["material_code_source"] = "not_found"

    spec_no = _s(obj.get("drl_specification_no"))
    if _DRL_SPEC_NO_RE.match(spec_no):
        out["drl_specification_no"] = spec_no
    else:
        fn_spec = _infer_drl_spec_no_from_filename(_s(obj.get("filename"))
                                                   or out.get("filename"))
        out["drl_specification_no"] = fn_spec

    cas = _s(obj.get("cas_number"))
    out["cas_number"] = cas if _CAS_RE.match(cas) else ""

    # Declaration scopes (generic phrases live here, never as DEG/EG limits)
    scopes = obj.get("declaration_scopes", [])
    if isinstance(scopes, list):
        norm_scopes = []
        for sc in scopes:
            if not isinstance(sc, dict):
                continue
            et = _s(sc.get("evidence_type")).lower()
            allowed = ("negative_declaration", "controlled_by_spec", "coa_statement",
                       "excluded_by_process", "policy_statement",
                       "usp_469_reference", "usfda_guidance_reference")
            norm_scopes.append({
                "scope": _s(sc.get("scope")),
                "raw_text": _s(sc.get("raw_text")),
                "evidence_type": et if et in allowed else "policy_statement",
                "page": sc.get("page", 1),
                "confidence": _f(sc.get("confidence")) or 0.0,
            })
        out["declaration_scopes"] = norm_scopes

    return out


# ════════════════════════════════════════════════════════════════════════════
# ASSESSMENT BUILDING (Yes/No presence + spec limits; per-material detail tables)
# ════════════════════════════════════════════════════════════════════════════
# SAP material codes are 6–10 digit numeric identifiers on vendor CoAs; DRL spec
# numbers look like SP-CFTO-003256-3 (letters-digits, hyphen separated).
# DRL SAP material codes start 1000/2000/3000/3500 then 4-5 more digits.
_ASSESS_SAP_RE = re.compile(r"^(1000|2000|3000|3500)\d{4,5}$")


def _extract_sap_code(ann: Optional[Dict]) -> str:
    """Return the validated DRL SAP material code from the annexure. The converter
    normaliser (process_deg_eg_annexure) has already validated it against the DRL
    SAP pattern and rejected vendor/batch/CAS/spec numbers, so we ONLY trust the
    validated 'material_code' field — never a free-text regex scan (which is what
    previously latched onto vendor internal codes and batch numbers). Blank if
    none — never fabricate an M001-style code."""
    if not ann:
        return ""
    code = re.sub(r"[^0-9]", "", _s(ann.get("material_code")))
    return code if _ASSESS_SAP_RE.match(code) else ""


def _extract_drl_spec_no(ann: Optional[Dict]) -> str:
    """Return the validated DRL specification number (e.g. SP-CFTO-003256-3) from
    the annexure's validated field only. Blank if none."""
    if not ann:
        return ""
    return _s(ann.get("drl_specification_no"))


def build_assessment(materials: List[Dict], mapping: Dict[str, Dict]) -> Dict:
    """
    For each non-q.s. material produce an assessment row. Presence is Yes or No
    ONLY (never Unknown): default No, Yes only when the annexure explicitly
    confirms DEG/EG presence with numeric evidence (vendor CoA / DRL specification
    / USP <469>). Real SAP material codes are extracted from the annexure; if none
    is found the code is left blank (never an M001-style fabrication). Positive
    findings generate one 6-column, 2-row detail table each.
    """
    assessment_table: List[Dict] = []
    detail_tables: List[Dict] = []
    observation_items: List[Dict] = []
    warnings: List[str] = []
    manual_review_items: List[str] = []
    unmapped: List[str] = []

    for m in materials:
        name = m["name"]
        if m.get("is_qs"):
            continue
        mp = mapping.get(name, {})
        ann = mp.get("_annexure")

        # Default No/No; upgrade to Yes only on explicit numeric evidence.
        deg_present, eg_present = "No", "No"
        deg_limit = eg_limit = None
        # Guarantee ceiling: present stays No, but the vendor-guaranteed limit is
        # documented (Roquette Mannitol class). Tracked separately from confirmed.
        deg_gc = eg_gc = False
        deg_gc_limit = eg_gc_limit = None
        raw_text = ""
        material_code = _extract_sap_code(ann)
        drl_spec_no = _extract_drl_spec_no(ann)

        if ann is None:
            unmapped.append(name)
            warnings.append(f"Material '{name}' has no matched annexure; assessed "
                            "as No based on default (no positive evidence).")
            manual_review_items.append(f"Unmapped material (assessed No): {name}")
        else:
            ev = ann.get("deg_eg_evidence", {}) or {}
            raw_text = _s(ev.get("raw_text"))
            _NUMERIC_SRC = ("vendor_coa", "vendor_spec", "usp_469")
            if ev.get("deg_present") == "Yes" and ev.get("deg_source") in _NUMERIC_SRC:
                deg_present = "Yes"
                deg_limit = ev.get("deg_specification_limit")
            elif (ev.get("deg_source") == "vendor_guarantee_ceiling"
                  and _s(ev.get("deg_specification_limit"))):
                deg_gc = True
                deg_gc_limit = ev.get("deg_specification_limit")
            if ev.get("eg_present") == "Yes" and ev.get("eg_source") in _NUMERIC_SRC:
                eg_present = "Yes"
                eg_limit = ev.get("eg_specification_limit")
            elif (ev.get("eg_source") == "vendor_guarantee_ceiling"
                  and _s(ev.get("eg_specification_limit"))):
                eg_gc = True
                eg_gc_limit = ev.get("eg_specification_limit")
            # policy/regulatory-only discussion never drives a Yes; stays No.
            if (ev.get("deg_source") == "policy_statement"
                    or ev.get("eg_source") == "policy_statement"):
                manual_review_items.append(
                    f"Policy-statement evidence for '{name}' (not used as a "
                    "material-specific limit).")

        # Specification-limit cell text for Table 2. Prefer confirmed limits; a
        # guarantee ceiling still documents its numeric limit even though the
        # presence stays No (Mannitol EG shows "< 620 ppm"). Identical DEG/EG
        # limit strings are collapsed so a shared spec reads once (Polysorbate 80
        # shows "NMT 620 ppm", not "NMT 620 ppm; NMT 620 ppm").
        def _uniq(vals):
            seen, out = set(), []
            for v in (_s(x) for x in vals if _s(x)):
                if v not in seen:
                    seen.add(v)
                    out.append(v)
            return out
        confirmed_limits = _uniq((deg_limit, eg_limit))
        gc_limits = _uniq((deg_gc_limit, eg_gc_limit))
        if confirmed_limits:
            spec_limit = "; ".join(confirmed_limits)
        elif gc_limits:
            spec_limit = "; ".join(gc_limits)
        else:
            spec_limit = "Not applicable"

        assessment_table.append({
            "material_code": material_code, "ingredient": name,
            "deg_present": deg_present, "eg_present": eg_present,
            "specification_limit": spec_limit,
        })

        has_confirmed = deg_present == "Yes" or eg_present == "Yes"
        has_gc = deg_gc or eg_gc

        # Positive finding OR guarantee ceiling → 6-column, 2-row detail table
        # (approved format). The guarantee-ceiling table documents the vendor
        # control even though Table 2 shows No/No.
        if has_confirmed or has_gc:
            # Per glycol: confirmed limit, else guarantee-ceiling limit, else NA.
            deg_val = (_s(deg_limit) if deg_present == "Yes"
                       else _s(deg_gc_limit) if deg_gc else "NA")
            eg_val = (_s(eg_limit) if eg_present == "Yes"
                      else _s(eg_gc_limit) if eg_gc else "NA")
            spec_cell = (drl_spec_no + "*") if drl_spec_no else ""
            confirmed_which = ([n for n, ok in
                                (("Diethylene Glycol", deg_present == "Yes"),
                                 ("Ethylene Glycol", eg_present == "Yes")) if ok])
            gc_which = ([n for n, ok in (("Diethylene Glycol", deg_gc),
                                         ("Ethylene Glycol", eg_gc)) if ok])
            if has_confirmed:
                intro = (f"{name} was identified as a potential source of "
                         f"{' and '.join(confirmed_which)}. The specification "
                         "controls and vendor evidence are summarised below.")
                inference = (f"Based on the vendor evidence, {name} is controlled "
                             f"for {' and '.join(confirmed_which)} by specification; "
                             "the residual level is within the applicable "
                             "specification limit. Hence, no additional drug product "
                             "testing is required.\n*Current version will be considered")
            else:
                glist = " and ".join(gc_which)
                intro = (f"For {name}, the vendor provides a guarantee ceiling for "
                         f"{glist} below the applicable USP <469> regulatory limit. "
                         "The by-product is not quantified per batch and is therefore "
                         "not confirmed present; the vendor guarantee is summarised "
                         "below for documentation.")
                inference = (f"The vendor guarantees {glist} remain below the USP "
                             "<469> Option 1 limit; the level is not quantified per "
                             "batch and is not confirmed present. Hence there is no "
                             "potential risk of DEG/EG and no drug product testing is "
                             "required.\n*Current version will be considered")
            detail_tables.append({
                "material": name,
                "guarantee_ceiling": bool(has_gc and not has_confirmed),
                "intro": intro,
                "caption": (f"Assessment of Diethylene Glycol and Ethylene Glycol "
                            f"for {name}"),
                "columns": ["Excipients", "Name", "USP Monograph", "Vendor COA",
                            "DRL Specification", "DRL Specification No."],
                "rows": [
                    [name, "Diethylene Glycol (DEG)", "NA", deg_val, deg_val,
                     spec_cell],
                    [name, "Ethylene Glycol (EG)", "NA", eg_val, eg_val,
                     spec_cell],
                ],
                "footnote": "*Current version will be considered",
                "inference": inference,
            })
            observation_items.append({
                "name": name,
                "matched_material": mp.get("matched_material", ""),
                "deg_present": deg_present, "eg_present": eg_present,
                "deg_guarantee_ceiling": deg_gc, "eg_guarantee_ceiling": eg_gc,
                "deg_limit": _s(deg_limit) or _s(deg_gc_limit),
                "eg_limit": _s(eg_limit) or _s(eg_gc_limit),
                "guarantee_ceiling": bool(has_gc and not has_confirmed),
                # Authoritative FDA high-risk flag from the mapper (falls back to a
                # name check so a directly-built assessment still resolves it).
                "high_risk_deg_eg": bool(mp.get("high_risk_deg_eg")
                                         or is_high_risk_deg_eg(name)
                                         or is_high_risk_deg_eg(mp.get("matched_material", ""))),
                "raw_text": raw_text,
            })

    return {
        "assessment_table": assessment_table,
        "detail_tables": detail_tables,
        "observation_items": observation_items,
        "warnings": warnings,
        "manual_review_items": manual_review_items,
        "unmapped_materials": unmapped,
    }


# ════════════════════════════════════════════════════════════════════════════
# VALIDATION (warning-first)
# ════════════════════════════════════════════════════════════════════════════
def validate_deg_eg(composition: Dict, assessment: Dict, payload: Dict = None) -> Dict:
    errors: List[str] = []
    warnings: List[str] = list(assessment.get("warnings", []))
    manual_review_items: List[str] = list(assessment.get("manual_review_items", []))

    if composition.get("_error"):
        errors.append(composition.get("error", "Composition parsing failed."))
    if not composition.get("materials"):
        errors.append("No component rows were parsed from the composition Excel.")
    if payload is not None:
        comp = payload.get("composition") or []
        comp_rows = sum(len(s.get("rows", [])) for s in comp if isinstance(s, dict))
        if comp_rows == 0:
            errors.append("Composition table is empty — nothing to render.")

    positives = [r for r in assessment.get("assessment_table", [])
                 if r["deg_present"] == "Yes" or r["eg_present"] == "Yes"]

    # Presence is strictly Yes/No now, so the conclusion is always definitive:
    # positive_controlled when any Yes, otherwise no_risk. Warnings/manual-review
    # items are retained for the audit trail but NEVER downgrade the conclusion or
    # inject regulatory hedging into the narrative.
    if errors:
        conclusion_status = "blocked"
    elif positives:
        conclusion_status = "positive_controlled"
    else:
        conclusion_status = "no_risk"

    return {
        "errors": errors, "warnings": warnings,
        "manual_review_items": manual_review_items,
        "unmapped_materials": assessment.get("unmapped_materials", []),
        "has_positive": bool(positives), "has_unknown": False,
        "conclusion_status": conclusion_status,
    }


# ════════════════════════════════════════════════════════════════════════════
# PAYLOAD BUILDER (matches generate_deg_eg.js)
# ════════════════════════════════════════════════════════════════════════════
def _derive_strength_from_composition(composition: Dict) -> str:
    """Build a strength label from the composition's strength columns
    (e.g. '40 mg / 20 mg / 10 mg')."""
    cols = composition.get("comp_columns", []) or []
    strengths = [c for c in cols if re.search(r"\d\s*(mg|mcg|µg|g|%)", _s(c),
                                              re.IGNORECASE)]
    return " / ".join(strengths) if strengths else ""


def build_deg_eg_payload(meta: Dict, composition: Dict, assessment: Dict,
                         text_sections: Dict, validation: Dict = None) -> Dict:
    validation = validation or {}

    # Auto-fill strength from composition strength columns if not provided.
    strength = _s(meta.get("strength")) or _derive_strength_from_composition(composition)

    # Auto-append product name to a generic-only title.
    product = _s(meta.get("product_name"))
    title = _s(meta.get("title")) or ("Risk Assessment of Diethylene Glycol and "
                                      "Ethylene Glycol")
    if product and product.lower() not in title.lower():
        title = f"{title} for {product}"

    # Ensure Change History renders in the body (Section 8): default one row.
    revision_history = meta.get("revision_history") or []
    if not revision_history:
        doc_no = _s(meta.get("document_no"))
        ver = _s(meta.get("version")) or "1.0, CURRENT"
        revision_history = [{
            "document_version": (f"{doc_no} / {ver}" if doc_no else ver),
            "changes": "New document. First issue.",
        }]

    return {
        "meta": {
            "product_name": product,
            "dosage_form": meta.get("dosage_form", ""),
            "strength": strength,
            "market": meta.get("market", ""),
            "department": meta.get("department", "FR&D"),
            "document_no": meta.get("document_no", ""),
            "version": meta.get("version", "1.0, CURRENT"),
            "protocol": meta.get("protocol", "NA"),
            "sop_format_number": meta.get("sop_format_number", ""),
            "title": title,
            "approved_date": meta.get("approved_date", ""),
        },
        "text_sections": text_sections,
        "composition": composition.get("composition", []),
        "comp_columns": composition.get("comp_columns", []),
        "composition_caption": "Table 1: Qualitative and Quantitative composition",
        "assessment_table": assessment.get("assessment_table", []),
        "assessment_caption": ("Table 2: Assessment of Diethylene Glycol and "
                               "Ethylene Glycol in the input API and Excipients"),
        "detail_tables": assessment.get("detail_tables", []),
        "revision_history": revision_history,
        "signatures": meta.get("signatures", []),
        # ── audit channels — all "_" prefixed so the JS renderer ignores them.
        # Never lands in the rendered document. Kept for internal telemetry only.
        "_verification_audit": {
            "conclusion_status": validation.get("conclusion_status", ""),
            "validation_warnings": validation.get("warnings", []),
            "manual_review_items": validation.get("manual_review_items", []),
            "unmapped_materials": validation.get("unmapped_materials", []),
        },
    }
