# ── Safe utilities ────────────────────────────────────────────────────────────
def safe_int(v: Any, default: int = 0) -> int:
    if isinstance(v, int): return v
    try: return int(float(str(v).strip()))
    except: return default

def safe_float(v: Any, default: float = 0.0) -> float:
    if isinstance(v, float): return v
    try: return float(str(v).strip().replace(",",""))
    except: return default

def safe_str(v: Any, default: str = "") -> str:
    return str(v).strip() if v is not None else default

def safe_json_parse(text: str, default: Any = None) -> Any:
    if default is None: default = {}
    if not text: return default
    for fn in [
        lambda t: json.loads(t),
        lambda t: json.loads(t[t.find("{"):t.rfind("}")+1]),
        lambda t: json.loads(t[t.find("["):t.rfind("]")+1]),
    ]:
        try: return fn(text)
        except: pass
    return default

def safe_list_get(lst: Any, idx: int, default: Any = None) -> Any:
    try:
        if lst and 0 <= idx < len(lst): return lst[idx]
    except: pass
    return default

def safe_calc_table(calc_tables: Optional[Dict], key: str) -> Dict:
    empty = {"elements":[],"rows":[],"total_daily_intake":0.0,
             "element_totals":{},"pde":{},"threshold_30pct":{}}
    if not calc_tables or not isinstance(calc_tables, dict): return dict(empty)
    t = calc_tables.get(key)
    if not t or not isinstance(t, dict): return dict(empty)
    out = dict(empty); out.update(t); return out


