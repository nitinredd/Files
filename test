"use strict";
/**
 * generate_benoc.js — Reference renderer for BE NOC Application document.
 *
 * Document type: Bio-Equivalence Study No Objection Certificate (BE NOC).
 * This is a REGULATORY IMPORT APPLICATION, not a risk assessment document.
 * Content is 100% assembled from annexures + metadata form. No calculations.
 *
 * Follows the approved document structure exactly:
 *   1. Table of Contents
 *   2. Drug Information (per API: IUPAC, structure, formula, MW, CAS,
 *      therapeutic category, indications, manufacturer)
 *   3. Manufacturing Address (test batch + BE batch)
 *   4. Regulatory Status in Different Countries
 *   5. Product Name, Dosage Form, Indication, Label Claim & Composition
 *      (list of raw materials + multi-stage quantitative composition)
 *   6. Equipment Details
 *   7. Manufacturing Process (narrative)
 *   8. Manufacturing Process Flow (visual/text flow)
 *   9. Proposed Drug Substance Specifications (per API — SUMMARY only)
 *  10. Patent Status
 *  11. Innovator Product Details
 *  12. Finished Product Specification (SUMMARY only)
 *  13. Comparative Dissolution Profile (data + charts + F2)
 *  14. Stability Data (per condition, per timepoint)
 *  15. RLD Utilization Breakup
 *  16. Narcotic Declaration (only if API is NDPS-controlled)
 *  17. List of Annexures
 *  18. Revision History
 *  Electronic Signatures
 */

var fs    = require("fs");
var JSZip = require("jszip");
var docx  = require("docx");

var Document            = docx.Document;
var Packer              = docx.Packer;
var Paragraph           = docx.Paragraph;
var TextRun             = docx.TextRun;
var Table               = docx.Table;
var TableRow            = docx.TableRow;
var TableCell           = docx.TableCell;
var ImageRun            = docx.ImageRun;
var Header              = docx.Header;
var Footer              = docx.Footer;
var AlignmentType       = docx.AlignmentType;
var BorderStyle         = docx.BorderStyle;
var WidthType           = docx.WidthType;
var ShadingType         = docx.ShadingType;
var VerticalAlign       = docx.VerticalAlign;
var PageNumber          = docx.PageNumber;
var PageBreak           = docx.PageBreak;
var convertInchesToTwip = docx.convertInchesToTwip;

// ── Page geometry: A4 Portrait (BE NOC is regulatory submission — A4) ────────
var PAGE_W = convertInchesToTwip(8.27);
var PAGE_H = convertInchesToTwip(11.69);
var MAR_L  = convertInchesToTwip(0.6);
var MAR_R  = convertInchesToTwip(0.6);
var MAR_T  = convertInchesToTwip(0.98);
var MAR_B  = convertInchesToTwip(0.6);
var CW     = PAGE_W - MAR_L - MAR_R;

// ── Colors ───────────────────────────────────────────────────────────────────
var CLR = {
  BLACK:    "000000",
  WHITE:    "FFFFFF",
  HDR_GREY: "D9D9D9",
  SEC_BLUE: "BDD7EE",
};

// ── Font & sizes ─────────────────────────────────────────────────────────────
var F  = "Times New Roman";
var SZ = { XXS:10, XS:12, SM:14, TEXT:24, MD:20, LG:22, XL:26 };

// ── Border / shading / margin helpers ────────────────────────────────────────
function bdr(sz, clr) {
  return { style: BorderStyle.SINGLE, size: sz||4, color: clr||CLR.BLACK };
}
function allBdr(sz) {
  var b = bdr(sz);
  return { top:b, bottom:b, left:b, right:b, insideHorizontal:b, insideVertical:b };
}
function shade(fill) { return { fill:fill, type:ShadingType.CLEAR, color:"auto" }; }
function mg() { return { top:30, right:60, bottom:30, left:60 }; }

// ── Run and paragraph helpers ────────────────────────────────────────────────
function run(text, opts) {
  opts = opts || {};
  return new TextRun({
    text:    String(text==null?"":text),
    bold:    !!opts.bold,
    italics: !!opts.italics,
    size:    opts.size||SZ.TEXT,
    font:    F,
    color:   opts.color||CLR.BLACK,
    noProof: true,
  });
}

function para(content, opts) {
  opts = opts || {};
  var children;
  if (typeof content === "string") children = [run(content, opts)];
  else if (Array.isArray(content)) children = content;
  else if (content) children = [content];
  else children = [run("", opts)];
  return new Paragraph({
    alignment: opts.align || AlignmentType.LEFT,
    spacing: {
      before: opts.before == null ? 40 : opts.before,
      after:  opts.after  == null ? 40 : opts.after,
      line:   opts.line || 264,
    },
    children: children,
  });
}

function bodyPara(text, opts) {
  opts = opts || {};
  return new Paragraph({
    alignment: AlignmentType.BOTH,
    spacing: { before:opts.before||20, after:opts.after||20, line:288 },
    children: [run(text, {bold:!!opts.bold, size:opts.size||SZ.TEXT})],
  });
}

function bodyParas(text) {
  if (text == null) return [];
  if (Array.isArray(text)) {
    return text.filter(function(t){return String(t||"").trim();})
               .map(function(t){return bodyPara(String(t).trim());});
  }
  return String(text).trim().split(/\n+/)
    .filter(function(l){return l.trim();})
    .map(function(l){return bodyPara(l.trim());});
}

function ctrPara(text, bold, size) {
  return para(text, {align:AlignmentType.CENTER, bold:!!bold, size:size||SZ.TEXT});
}
function lftPara(text, bold, size) {
  return para(text, {align:AlignmentType.LEFT, bold:!!bold, size:size||SZ.TEXT});
}
function blk()   { return para("", {before:20, after:20}); }
function pgBrk() { return new Paragraph({children:[new PageBreak()]}); }
function secHd(text) {
  return para(text, {align:AlignmentType.LEFT, bold:true, size:SZ.MD, before:80, after:40});
}
// Neutral placeholder for a section whose data was not supplied. Deliberately a
// simple factual note — never review/warning language (that lives in the UI only).
function phNote() {
  return para("Not provided.", {italics:true, size:SZ.TEXT, after:40});
}

// ── Cell helpers ─────────────────────────────────────────────────────────────
function cell(text, opts) {
  opts = opts || {};
  return new TableCell({
    columnSpan: opts.cs || 1,
    rowSpan:    opts.rs || 1,
    width:      opts.w ? {size:opts.w, type:WidthType.DXA} : undefined,
    borders:    allBdr(4),
    shading:    opts.fill ? shade(opts.fill) : undefined,
    margins:    mg(),
    verticalAlign: VerticalAlign.CENTER,
    children: [new Paragraph({
      alignment: opts.align || AlignmentType.CENTER,
      spacing: {before:0, after:0},
      children: [run(text, {bold:!!opts.bold, size:opts.size||SZ.SM, color:opts.color})],
    })],
  });
}
function cellL(text, opts) {
  opts = opts || {};
  opts.align = AlignmentType.LEFT;
  return cell(text, opts);
}
function cellML(paras, opts) {
  opts = opts || {};
  var arr = Array.isArray(paras) ? paras : [paras];
  var children = arr.filter(function(p){return p != null;}).map(function(p) {
    if (p instanceof Paragraph) return p;
    return new Paragraph({
      alignment: opts.align || AlignmentType.LEFT,
      spacing: {before:0, after:0},
      children: [run(String(p), {bold:!!opts.bold, size:opts.size||SZ.SM})],
    });
  });
  if (!children.length) {
    children = [new Paragraph({children:[run("")]})];
  }
  return new TableCell({
    columnSpan: opts.cs || 1,
    width: opts.w ? {size:opts.w, type:WidthType.DXA} : undefined,
    borders: allBdr(4),
    shading: opts.fill ? shade(opts.fill) : undefined,
    margins: mg(),
    verticalAlign: VerticalAlign.CENTER,
    children: children,
  });
}

// ── PAGE HEADER ──────────────────────────────────────────────────────────────
function buildHeader(meta, logoB64, logoType) {
  meta = meta || {};
  var C1=900, C4=1700, C2=Math.round(CW*0.45), C3=CW-C1-C2-C4;

  var logoCell;
  if (logoB64 && logoB64.length > 100) {
    try {
      var buf = Buffer.from(logoB64, "base64");
      var lt  = (logoType||"").indexOf("jpeg") >= 0 ? "jpg" : "png";
      logoCell = new TableCell({
        width: {size:C4, type:WidthType.DXA},
        borders: allBdr(4), margins: mg(),
        verticalAlign: VerticalAlign.CENTER,
        children: [new Paragraph({
          alignment: AlignmentType.RIGHT,
          spacing: {before:0, after:0},
          children: [new ImageRun({
            type: lt, data: buf,
            transformation: {width:110, height:44},
          })],
        })],
      });
    } catch(e) {
      logoCell = cell("", {w:C4, align:AlignmentType.RIGHT});
    }
  } else {
    logoCell = cell("", {w:C4, align:AlignmentType.RIGHT});
  }

  var r1 = new TableRow({children:[
    cell("IPDO", {bold:true, size:SZ.MD, align:AlignmentType.LEFT, w:C1}),
    new TableCell({
      columnSpan: 2, width: {size:C2+C3, type:WidthType.DXA},
      borders: allBdr(4), margins: mg(),
      verticalAlign: VerticalAlign.CENTER,
      children: [ctrPara("BE NOC Application", true, SZ.MD)],
    }),
    logoCell,
  ]});

  function hdrLine(label, value) {
    return new Paragraph({
      alignment: AlignmentType.LEFT, spacing: {before:0, after:0},
      children: [
        run(label, {bold:true, size:SZ.XS}),
        run(" " + value, {size:SZ.XS}),
      ],
    });
  }

  var r2 = new TableRow({children:[
    new TableCell({
      columnSpan: 3, width: {size:C1+C2+C3, type:WidthType.DXA},
      borders: allBdr(4), margins: mg(),
      verticalAlign: VerticalAlign.CENTER,
      children: [new Paragraph({
        alignment: AlignmentType.LEFT, spacing: {before:0, after:0},
        children: [run("Title: " + (meta.title||""), {size:SZ.XS})],
      })],
    }),
    new TableCell({
      width: {size:C4, type:WidthType.DXA},
      borders: allBdr(4), margins: mg(),
      verticalAlign: VerticalAlign.CENTER,
      children: [
        hdrLine("Department:", meta.department||""),
        hdrLine("Strength:",   meta.strength||""),
        hdrLine("Market:",     meta.market||""),
        hdrLine("Protocol:",   meta.protocol||""),
      ],
    }),
  ]});

  var w1=Math.round(CW*0.18), w2=Math.round(CW*0.35),
      w3=Math.round(CW*0.22), w4=CW-w1-w2-w3;
  var r3 = new TableRow({children:[
    cellL("Document No: "+(meta.document_no||""),   {size:SZ.XS, w:w1}),
    cellL("Product Name: "+(meta.product_name||""), {size:SZ.XS, w:w2}),
    cellL("Dosage Form: "+(meta.dosage_form||""),   {size:SZ.XS, w:w3}),
    cellL("Version: "+(meta.version||""),           {size:SZ.XS, w:w4}),
  ]});

  var tbl = new Table({
    width: {size:CW, type:WidthType.DXA},
    columnWidths: [C1, C2, C3, C4],
    rows: [r1, r2, r3],
  });
  return new Header({children:[tbl, blk()]});
}

// ── PAGE FOOTER ──────────────────────────────────────────────────────────────
function buildFooter() {
  return new Footer({children:[new Paragraph({
    alignment: AlignmentType.CENTER,
    spacing: {before:0, after:0},
    children: [
      run("Page ", {size:SZ.XS}),
      new TextRun({children:[PageNumber.CURRENT], size:SZ.XS, font:F}),
      run(" of ", {size:SZ.XS}),
      new TextRun({children:[PageNumber.TOTAL_PAGES], size:SZ.XS, font:F}),
    ],
  })]});
}

// ── TITLE PAGE ───────────────────────────────────────────────────────────────
function buildTitlePage(meta) {
  meta = meta || {};
  var sop = meta.sop_format_number || "";
  var sopRow = new Table({
    width: {size:CW, type:WidthType.DXA}, columnWidths: [CW],
    rows: [new TableRow({children:[new TableCell({
      borders: allBdr(4), margins: mg(),
      children: [lftPara("SOP Format Number: "+sop, false, SZ.SM)],
    })]})],
  });
  var titleText = meta.title
    || "Application for Grant of NOC for Import of Innovator Product for Bio-Equivalence Study";
  var titleBox = new Table({
    width: {size:CW, type:WidthType.DXA}, columnWidths: [CW],
    rows: [new TableRow({children:[new TableCell({
      borders: allBdr(12),
      margins: {top:600, right:600, bottom:600, left:600},
      children: [ctrPara(titleText, true, SZ.XL)],
    })]})],
  });
  return [sopRow, blk(), titleBox, pgBrk()];
}

// ── TABLE OF CONTENTS ────────────────────────────────────────────────────────
function buildTOC() {
  var entries = [
    {no:"1",  title:"Drug Information",                                          page:""},
