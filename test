# ── Excel composition parser ──────────────────────────────────────────────────
def _find_excel_row_number(ingredient_name: str, all_rows: List[List[str]]) -> int:
    """Find the 1-based row number in the original Excel rows that matches ingredient_name."""
    ing_lower = ingredient_name.lower().strip()
    if not ing_lower:
        return 0
    for i, row in enumerate(all_rows):
        for cell_val in row:
            if cell_val and ing_lower in cell_val.lower():
                return i + 1  # 1-based (matches "Row N:" in rows_text)
    return 0


def parse_composition_excel(excel_bytes: bytes, excel_filename: str = "") -> Dict:
    """
    Generic parser: works for oral sachets, injections, any formulation.
    Returns sections with ingredients and their amounts.
    Each ingredient row is tagged with _row_number and _excel_filename for citations.
    """
    wb = openpyxl.load_workbook(BytesIO(excel_bytes), data_only=True)
    ws = wb.worksheets[0]
    sheet_name = ws.title if ws.title else "Sheet1"
    rows_text: List[str] = []
    all_rows: List[List[str]] = []
    for i, row in enumerate(ws.iter_rows(values_only=True)):
        if any(c is not None for c in row):
            row_str = [str(c) if c is not None else "" for c in row]
            rows_text.append(f"Row {i+1}: {' | '.join(row_str)}")
            all_rows.append(row_str)
    wb.close()
    sheet_dump = "\n".join(rows_text[:100])

    prompt = (
        "Pharmaceutical composition spreadsheet. Extract EVERYTHING.\n\n"
        "1. ALL column headers exactly as they appear\n"
        "2. ALL rows including section headers and ingredient rows\n"
        "3. Route of administration (oral/parenteral/injection/topical)\n"
        "4. MDD in grams (total drug product per day)\n\n"
        "Return ONLY this JSON (no markdown):\n"
        "{\n"
        '  "route": "oral or parenteral or injection",\n'
        '  "mdd_g": 1.0,\n'
        '  "doses_per_day": 1,\n'
        '  "unit": "exact unit string e.g. mg/unit or mg/0.65mL",\n'
        '  "ingredient_col": "exact column header for ingredient name",\n'
        '  "amount_col": "exact column header for ingredient amount",\n'
        '  "amount_unit": "mg",\n'
        '  "amount_per_dose": true,\n'
        '  "columns": ["exact col1 header","exact col2 header","..."],\n'
        '  "sections": [\n'
        '    {\n'
        '      "name": "section header or empty string",\n'
        '      "rows": [\n'
        '        {"ingredient":"...","columns":{"Col1":"val","Col2":"val",...}}\n'
        '      ]\n'
        '    }\n'
        '  ]\n'
        "}\n\n"
        "IMPORTANT:\n"
        "- columns[]: exact headers as in the spreadsheet\n"
        "- For each row, map each value to its exact column header\n"
        "- mdd_g in GRAMS (e.g. injection 0.65mL → 0.65g)\n"
        "- ingredient_col: exact column header containing the ingredient/material name\n"
        "- amount_col: exact column header containing the ingredient amount (mg or g per dose)\n"
        "- amount_unit: unit of the amount column: 'mg', 'g', 'mL', or 'mg/mL'\n"
        "- amount_per_dose: true if amounts are per single dose, false if already per day\n"
        f"Spreadsheet:\n{sheet_dump}"
    )
    raw = claude_text(prompt)
    parsed = safe_json_parse(raw, {})

    if isinstance(parsed, dict) and isinstance(parsed.get("sections"), list) and parsed["sections"]:
        result = parsed
    else:
        logger.warning("Excel parse: fallback to raw rows")
        fallback_rows = []
        for row in all_rows[1:]:
            if len(row) > 2 and row[0].strip():
                fallback_rows.append({"ingredient": row[0], "amount": row[2] if len(row)>2 else "0",
                                       "unit": "", "function": ""})
        result = {"sections": [{"name": "Composition", "rows": fallback_rows}],
                  "route": "oral", "mdd_g": 1.0, "doses_per_day": 1, "unit": ""}

    result["mdd_g"]          = safe_float(result.get("mdd_g", 1.0), default=1.0)
    result["doses_per_day"]   = safe_int(result.get("doses_per_day", 1), default=1)
    result["route"]           = safe_str(result.get("route", "oral")) or "oral"
    result["ingredient_col"]  = safe_str(result.get("ingredient_col", ""))
    result["amount_col"]      = safe_str(result.get("amount_col", ""))
    result["amount_unit"]     = safe_str(result.get("amount_unit", "mg"))
    result["amount_per_dose"] = bool(result.get("amount_per_dose", True))
    if not isinstance(result.get("sections"), list): result["sections"] = []
    if not isinstance(result.get("columns"), list):  result["columns"] = []
    result["all_rows"]     = all_rows
    result["_sheet_name"]  = sheet_name
    result["_excel_filename"] = excel_filename

    # Tag every ingredient row with its Excel row number for citations
    for section in result["sections"]:
        if not isinstance(section, dict): continue
        for row in (section.get("rows") or []):
            if not isinstance(row, dict): continue
            ingredient = row.get("ingredient", "")
            row["_row_number"]     = _find_excel_row_number(ingredient, all_rows)
            row["_excel_filename"] = excel_filename
            row["_sheet_name"]     = sheet_name

    return result


# ── Annexure processor ────────────────────────────────────────────────────────
def _flatten_docai_json(obj: Any, depth: int = 0) -> str:
    if depth > 8: return ""
    parts: List[str] = []
    if isinstance(obj, dict):
        if "text" in obj and isinstance(obj["text"], str): parts.append(obj["text"])
        for v in obj.values(): parts.append(_flatten_docai_json(v, depth+1))
    elif isinstance(obj, list):
        for item in obj: parts.append(_flatten_docai_json(item, depth+1))
    elif isinstance(obj, (str, int, float)): parts.append(str(obj))
    return " ".join(p for p in parts if p.strip())


def process_annexure(annexure_json: Any, index: int,
                     filename: str = "") -> Dict:
    """
    Process a Document AI JSON annexure.
    Each extracted element is tagged with _field_path (where in the JSON the
    concentration value was found) and _filename for citation purposes.
    """
    text_content = _flatten_docai_json(annexure_json)
    prompt = (
        f"Extract elemental impurity data from Annexure {index}.\n"
        "Return ONLY this JSON (no markdown):\n"
        "{\n"
        f'  "annexure_number":{index},"supplier_name":"","material_name":"",\n'
        '  "source_type":"","date_filled":"",\n'
        '  "elements":[\n'
        '    {"symbol":"","name":"","class":"","concentration_value":0.05,\n'
        '     "concentration_unit":"ppm","analytical_method":"","intentionally_added":"No",\n'
        '     "observed_level":"","listed_in_coa":"Yes","comments":""}\n'
        '  ]\n'
        "}\n\n"
        "Rules: concentration_value is numeric (µg/g=ppm). BLQ→0.05. NA/blank→0.\n"
        f"Text:\n{text_content[:8000]}"
    )
    raw = call_claude([{"role":"user","content":prompt}])
    default = {"annexure_number":index,"supplier_name":"N/A","material_name":"N/A",
               "source_type":"","date_filled":"","elements":[]}
    parsed = safe_json_parse(raw, default)
    if not isinstance(parsed, dict): return default
    for k, v in default.items(): parsed.setdefault(k, v)
    if not isinstance(parsed.get("elements"), list): parsed["elements"] = []

    # Tag each element with its field path in the raw Document AI JSON
    for el in parsed["elements"]:
        if not isinstance(el, dict): continue
        conc_val = el.get("concentration_value", "")
        # Search for the concentration value in the raw JSON tree
        el["_field_path"] = find_field_path_in_docai(annexure_json, str(conc_val))
        el["_filename"] = filename

    parsed["_filename"] = filename
    return parsed


# ── Calculation engine ────────────────────────────────────────────────────────
def _parse_conc(val: Any) -> float:
    """Parse concentration to µg/g (ppm). BLQ→0.05."""
    if val is None: return 0.0
    if isinstance(val, (int, float)): return max(0.0, float(val))
    s = str(val).strip().lower()
    if s in ("","na","nd","blq","bdl","none","null","nq","not detected","not quantified"): return 0.05
    s = re.sub(r"(ppm|µg/g|ug/g|<|>|\s)", "", s)
    try: return max(0.0, float(s))
    except: return 0.05


def _parse_amount_g(val: Any) -> float:
    """Parse ingredient amount to grams."""
    if val is None: return 0.0
    s = str(val).strip().lower()
    if s in ("","q.s.","qs","na","qs to ph","qs to 1ml","qs to volume"): return 0.0
    s = re.sub(r"[^\d.\-eE]","",s)
    try: return float(s)
    except: return 0.0


def _build_conc_map(annexure_data: List[Dict]) -> Dict[str, Dict[str, float]]:
    conc_map: Dict[str, Dict[str, float]] = {}
    for ann in annexure_data:
        if not isinstance(ann, dict): continue
        material = safe_str(ann.get("material_name",""))
        if not material: continue
        elem_dict: Dict[str, float] = {}
        for el in (ann.get("elements") or []):
            if not isinstance(el, dict): continue
            sym = safe_str(el.get("symbol",""))
            if sym: elem_dict[sym] = _parse_conc(el.get("concentration_value",0))
        conc_map[material] = elem_dict
    return conc_map


def _match_ingredient_with_meta(
    name: str,
    conc_map: Dict[str, Dict[str, float]],
) -> Tuple[Dict[str, float], float, str, str]:
    """
    Fuzzy match an ingredient name to an annexure material name.
    Returns (conc_dict, score, matched_key, method).
    method is one of: "exact" | "substring" | "token_overlap" | "none"
    """
    if not conc_map or not name:
        return {}, 0.0, "", "none"
    name_lower = name.lower().strip()

    # Strategy 1: exact (case-insensitive)
    for key in conc_map:
        if key and key.lower().strip() == name_lower:
            return conc_map[key], 1.0, key, "exact"

    # Strategy 2 + 3: token overlap + substring
    best_key: Optional[str] = None
    best_score: float = 0.0
    best_method: str = "none"
    for key in conc_map:
        if not key: continue
        key_lower = key.lower().strip()
        tokens_n = set(t for t in re.split(r'[\s\(\)\-,/\.\*]+', name_lower) if len(t) > 1)
        tokens_k = set(t for t in re.split(r'[\s\(\)\-,/\.\*]+', key_lower)  if len(t) > 1)
        if not tokens_n or not tokens_k: continue
        overlap = len(tokens_n & tokens_k)
        score   = overlap / max(len(tokens_n), len(tokens_k))
        method  = "token_overlap"
        if name_lower in key_lower or key_lower in name_lower:
            sub = max(score, 0.5)
            if sub > score:
                score  = sub
                method = "substring"
        if score > best_score:
            best_score = score
            best_key   = key
            best_method = method

    if best_score >= 0.15 and best_key:
        logger.debug(f"Matched '{name}' → '{best_key}' (score={best_score:.2f})")
        return conc_map[best_key], best_score, best_key, best_method
    logger.debug(f"No annexure match for '{name}' (best={best_score:.2f})")
    return {}, 0.0, "", "none"


def _match_ingredient(name: str, conc_map: Dict[str, Dict[str, float]]) -> Dict[str, float]:
    concs, _, _, _ = _match_ingredient_with_meta(name, conc_map)
    return concs


def calculate_ei_tables(comp_data: Dict, annexure_data: List[Dict],
                        citation_builder: Optional[CitationBuilder] = None,
                        annexure_filenames: Optional[List[str]] = None,
                        excel_filename: str = "") -> Dict:
    """
    Product-agnostic EI calculation.

    Formula: Daily_exposure (µg/day) = Amount_in_MDD (g/day) × Conc (µg/g)

    When citation_builder is provided, every cell in Tables 5/6/7 is traced back
    to its source (annexure element, Excel row, ICH Q3D table).
    """
    route         = safe_str(comp_data.get("route","oral"))
    mdd_g         = safe_float(comp_data.get("mdd_g", 1.0), default=1.0)
    doses_per_day = safe_int(comp_data.get("doses_per_day", 1), default=1)
    ingredient_col  = safe_str(comp_data.get("ingredient_col", ""))
    amount_col      = safe_str(comp_data.get("amount_col", ""))
    amount_unit_raw = safe_str(comp_data.get("amount_unit", "mg")).lower()
    amount_per_dose = comp_data.get("amount_per_dose", True)
    sheet_name      = safe_str(comp_data.get("_sheet_name", "Sheet1"))

    # Build annexure lookup by material name (for citation metadata)
    ann_by_material: Dict[str, Dict] = {
        safe_str(ann.get("material_name","")): ann
        for ann in annexure_data if isinstance(ann, dict)
    }

    def _get_field(row: Dict, col_key: str, fallbacks: List[str]) -> str:
        cols_dict = row.get("columns", {})
        if isinstance(cols_dict, dict):
            if col_key and col_key in cols_dict:
                return safe_str(cols_dict[col_key])
            for k, v in cols_dict.items():
                for fb in fallbacks:
                    if fb.lower() in k.lower():
                        return safe_str(v)
        for fb in fallbacks:
            if fb in row:
                return safe_str(row[fb])
        return ""

    # Build ingredient list with daily intake in grams
    ingredients: List[Dict] = []
    sections = comp_data.get("sections") or []
    for section in sections:
        if not isinstance(section, dict): continue
        for row in (section.get("rows") or []):
            if not isinstance(row, dict): continue

            name = _get_field(row, ingredient_col,
                              ["ingredient","name","Name of Ingredient",
                               "material","Material","component","Component"])
            if not name: continue

            raw_amount_str = _get_field(row, amount_col,
                                        ["amount","qty","Qty","40mg","quantity",
                                         "Quantity","mg/unit","mg/0.65mL","mg/mL"])
            amount_raw = _parse_amount_g(raw_amount_str)
            if amount_raw == 0:
                continue

            if "µg" in amount_unit_raw or "ug" in amount_unit_raw:
                amount_g = amount_raw / 1_000_000.0
            elif "mg" in amount_unit_raw:
                amount_g = amount_raw / 1000.0
            elif "ml" in amount_unit_raw:
                amount_g = amount_raw
            elif "g" in amount_unit_raw:
                amount_g = amount_raw
            else:
                amount_g = amount_raw / 1000.0 if amount_raw > 1 else amount_raw

            if amount_per_dose:
                daily_g = round(amount_g * doses_per_day, 8)
            else:
                daily_g = round(amount_g, 8)

            ingredients.append({
                "name":            name,
                "daily_g":         daily_g,
                "_row_number":     row.get("_row_number", 0),
                "_raw_amount_str": raw_amount_str,
                "_excel_filename": row.get("_excel_filename", excel_filename),
                "_sheet_name":     row.get("_sheet_name", sheet_name),
            })

    logger.info(f"EI calc: {len(ingredients)} ingredients with non-zero amounts, "
                f"route={route}, mdd_g={mdd_g}g, {len(annexure_data)} annexures")

    conc_map = _build_conc_map(annexure_data)

    # Track which ingredient→annexure matches have been cited (once per ingredient)
    cited_matches: set = set()

    def build_one_table(elements: List[str], table_name: str) -> Dict:
        rows: List[Dict] = []
        elem_totals: Dict[str, float] = {sym: 0.0 for sym in elements}
        total_intake = 0.0

        for ing in ingredients:
            if ing["daily_g"] == 0:
                continue

            ing_concs, match_score, matched_key, match_method = \
                _match_ingredient_with_meta(ing["name"], conc_map)

            # Cite the ingredient→annexure match (once per unique ingredient)
            if citation_builder and matched_key and ing["name"] not in cited_matches:
                matched_ann = ann_by_material.get(matched_key, {})
                ann_idx = matched_ann.get("annexure_number", 0)
                citation_builder.cite_ingredient_match(
                    ing["name"], matched_key, ann_idx, match_score, match_method
                )
                cited_matches.add(ing["name"])

            # Cite the daily intake from Excel (per table, since each table
            # is a distinct calculation block with its own element set)
            intake_cid = ""
            if citation_builder:
                intake_cid = citation_builder.cite_daily_intake(
                    table_name,
                    ing["name"],
                    ing["daily_g"],
                    ing.get("_excel_filename", excel_filename),
                    ing.get("_sheet_name", sheet_name),
                    ing.get("_row_number", 0),
                    ing.get("_raw_amount_str", ""),
                    comp_data.get("amount_unit", "mg"),
                    mdd_g,
                    doses_per_day,
                    amount_col,
                )

            measured: Dict[str, float] = {}
            total_mass: Dict[str, float] = {}
            ann_index_for_row = 0

            for sym in elements:
                conc            = ing_concs.get(sym, 0.0)
                measured[sym]   = round(conc, 4)
                mass            = ing["daily_g"] * conc
                total_mass[sym] = round(mass, 6)
                elem_totals[sym]= round(elem_totals[sym] + mass, 6)

                if citation_builder:
                    # Cite measured concentration from annexure
                    conc_cid = ""
                    if matched_key:
                        matched_ann = ann_by_material.get(matched_key, {})
                        ann_idx     = matched_ann.get("annexure_number", 0)
                        ann_index_for_row = ann_idx
                        ann_fname   = (
                            annexure_filenames[ann_idx - 1]
                            if annexure_filenames and 0 < ann_idx <= len(annexure_filenames)
                            else matched_ann.get("_filename", "")
                        )
                        el_data = next(
                            (e for e in (matched_ann.get("elements") or [])
                             if isinstance(e, dict) and e.get("symbol") == sym),
                            {}
                        )
                        conc_cid = citation_builder.cite_measured_conc(
                            table_name, ing["name"], sym,
                            conc, ann_idx, ann_fname,
                            matched_key,
                            matched_ann.get("supplier_name", ""),
                            el_data.get("_field_path", "text_extraction"),
                            str(el_data.get("concentration_value", "")),
                            el_data.get("concentration_unit", "ppm"),
                            el_data.get("analytical_method", ""),
                        )

                    # Cite daily exposure as a derived calculation
                    citation_builder.cite_daily_exposure(
                        table_name, ing["name"], sym,
                        round(mass, 6),
                        intake_cid, conc_cid,
                        ing["daily_g"], conc,
                    )

            total_intake += ing["daily_g"]
            rows.append({
                "ingredient":         ing["name"],
                "daily_intake_g":     round(ing["daily_g"], 6),
                "measured_conc":      measured,
                "total_mass":         total_mass,
                "_annexure_source":   matched_key,
                "_annexure_index":    ann_index_for_row,
            })

        # PDE and 30% threshold by route
        pde_vals  = {sym: get_pde(sym, route) for sym in elements}
        threshold = {
            sym: round(pde_vals[sym] * 0.30, 4) if pde_vals[sym] else None
            for sym in elements
        }

        # PDE and threshold guideline citations
        pde_sources: Dict[str, str] = {}
        if citation_builder:
            for sym in elements:
                pde = pde_vals.get(sym)
                if pde is not None:
                    ich_class     = ICH_PDE.get(sym, {}).get("class", "?")
                    guideline_tbl = get_ich_guideline_table(ich_class)
                    pde_sources[sym] = guideline_tbl
                    pde_cid = citation_builder.cite_pde(
                        table_name, sym, pde, ich_class, route, guideline_tbl
                    )
                    thresh = threshold.get(sym)
                    if thresh is not None:
                        citation_builder.cite_threshold(
                            table_name, sym, thresh, pde_cid, pde
                        )

        return {
            "elements":           elements,
            "rows":               rows,
            "total_daily_intake": round(total_intake, 6),
            "element_totals":     {sym: round(v, 6) for sym, v in elem_totals.items()},
            "pde":                pde_vals,
            "threshold_30pct":    threshold,
            "route":              route,
            "pde_sources":        pde_sources,
        }

    return {
        "class1_2a": build_one_table(TABLE5_ELEMENTS, "Table 5 / Class 1+2A"),
        "class2b":   build_one_table(TABLE6_ELEMENTS, "Table 6 / Class 2B"),
        "class3":    build_one_table(TABLE7_ELEMENTS, "Table 7 / Class 3"),
    }


# ── Text section generation ───────────────────────────────────────────────────
def generate_text_sections(ref_structure: Dict, annexure_data: List[Dict],
                           calc_tables: Dict, comp_data: Dict,
                           citation_builder: Optional[CitationBuilder] = None) -> Dict:
    """
    Generate all narrative text sections dynamically.
    The prompt is product-agnostic — Claude uses reference structure + calculations.
    When citation_builder is provided, records which prompt inputs were used.
    """
    empty: Dict = {
        "abstract":"","objective":"","study_location":"NA","background":"",
        "sources_intro":"","drug_substance_section":"","excipient_intro":"",
        "manufacturing_section":"","container_closure_section":"","utilities_section":"",
        "control_strategy":"","testing_recommendation":"","conclusion":"",
        "observation":"","reference":"NA",
    }
    meta    = ref_structure.get("meta", {}) or {}
    route   = safe_str(comp_data.get("route","oral"))
    mdd_g   = safe_float(comp_data.get("mdd_g",1.0))
    doses   = safe_int(comp_data.get("doses_per_day",1))
    toc     = ref_structure.get("toc_entries",[]) or []

    ann_summary = [{"material":a.get("material_name","N/A"),
                    "supplier":a.get("supplier_name","N/A"),
                    "n_elements":len(a.get("elements",[])or[])}
                   for a in annexure_data if isinstance(a, dict)]

    t5 = safe_calc_table(calc_tables,"class1_2a")
    t6 = safe_calc_table(calc_tables,"class2b")
    t7 = safe_calc_table(calc_tables,"class3")

    crossing = {sym: {"total":t5["element_totals"].get(sym,0),
                      "pde30":round(t5["pde"].get(sym,0)*0.3,4)}
                for sym in TABLE5_ELEMENTS
                if t5["pde"].get(sym) and t5["element_totals"].get(sym,0) > t5["pde"].get(sym,0)*0.3}

    toc_info = ""
    if toc:
        toc_info = "TOC sections from reference: " + "; ".join(
            f"{e.get('no','?')}. {e.get('title','')}" for e in toc[:15])

    prompt = (
        "You are a pharmaceutical regulatory writer creating an ICH Q3D (R2) TSR.\n\n"
        f"Product: {meta.get('product_name','')}\n"
        f"Dosage form: {meta.get('dosage_form','')}\n"
        f"Route: {route}\n"
        f"MDD: {mdd_g}g/day ({doses} dose(s)/day)\n"
        f"Document No: {meta.get('document_no','')}\n\n"
        f"{toc_info}\n\n"
        f"Annexures ({len(annexure_data)} materials):\n{json.dumps(ann_summary)}\n\n"
        "Calculation formula: Daily exposure (µg/day) = Amount_in_MDD(g) × Conc(µg/g)\n"
        f"- Class 1+2A totals: {json.dumps(t5['element_totals'])}\n"
        f"- Class 2B totals:   {json.dumps(t6['element_totals'])}\n"
        f"- Class 3 totals:    {json.dumps(t7['element_totals'])}\n"
        f"- Route-specific PDEs used: {route}\n"
        f"- Elements crossing 30% PDE: {json.dumps(crossing)}\n\n"
        "Generate concise factual ICH Q3D regulatory text matching the product.\n"
        "Return ONLY this JSON (no markdown):\n"
        '{"abstract":"","objective":"","study_location":"NA","background":"",\n'
        '"sources_intro":"","drug_substance_section":"","excipient_intro":"",\n'
        '"manufacturing_section":"","container_closure_section":"","utilities_section":"",\n'
        '"control_strategy":"","testing_recommendation":"","conclusion":"",\n'
        '"observation":"","reference":"NA"}'
    )

    generation_ts = datetime.now(timezone.utc).isoformat()
    raw    = claude_text(prompt, max_tokens=6000)
    parsed = safe_json_parse(raw, {})
    if not isinstance(parsed, dict):
        logger.error("Text generation returned no valid JSON; using empty sections")
        return empty
    for k, v in empty.items(): parsed.setdefault(k, v)

    # Record text generation citations (Layer 2)
    if citation_builder:
        prompt_hash    = hashlib.sha256(prompt.encode()).hexdigest()[:16]
        ann_numbers    = [a.get("annexure_number", i+1) for i, a in enumerate(annexure_data)]
        meta_fields    = [k for k, v in meta.items() if v]
        calc_refs      = ["element_totals", "pde", "threshold_30pct", "crossing"]

        for section_key, section_val in parsed.items():
            if section_val and section_val != "NA":
                citation_builder.cite_text_section(
                    section_key,
                    "generate_text_sections_v1",
                    prompt_hash,
                    meta_fields,
                    ann_numbers,
                    calc_refs,
                    generation_ts,
                )

    return parsed


# ── Assemble and invoke Node.js ───────────────────────────────────────────────
def assemble_and_generate(
    ref_structure: Dict, page_images: List[bytes],
    figure_pages: List[Dict], annexure_data: List[Dict],
    comp_data: Dict, calc_tables: Dict, text_sections: Dict,
    ref_bytes: bytes = b"", logo_b64: str = "",
    logo_type: str = "",
    citation_builder: Optional[CitationBuilder] = None,
    enable_inline_citations: bool = False,
    report_id: str = "",
    pdf_filename: str = "",
) -> Tuple[bytes, Optional[Dict], Optional[str]]:
    """
    Assemble all data, invoke Node.js to build the DOCX, and write
    citation_ledger.json + traceability_report.html alongside the output.

    Returns (docx_bytes, ledger_dict, html_string).
    ledger_dict and html_string are None when citation_builder is not provided.
    """
    figures_b64: List[Dict] = []
    for fig in figure_pages:
        if not isinstance(fig, dict): continue
        pi = fig.get("page_index")
        if pi is None: continue
        try:
            img_bytes = extract_figure_from_page(ref_bytes, pi, dpi=200)
        except Exception as e:
            logger.warning(f"Figure raster p{pi}: {e}")
            img_bytes = safe_list_get(page_images, pi, b"")
        if not img_bytes: continue
        figures_b64.append({"page_index":pi,
                             "description":fig.get("description",""),
                             "figure_label":fig.get("figure_label","Figure 1"),
                             "data_b64":base64.standard_b64encode(img_bytes).decode(),
                             "media_type":"image/png"})

    annexure_list = [{"material":a.get("material_name","N/A"),
                      "supplier":a.get("supplier_name","N/A"),
                      "annexure":f"Annexure {a.get('annexure_number','?')}"}
                     for a in annexure_data if isinstance(a, dict)]

    additional_tables = extract_additional_tables([])

    report_data = {
        "meta":              ref_structure.get("meta",{}) or {},
        "toc_entries":       ref_structure.get("toc_entries",[]) or [],
        "logo_b64":          logo_b64,
        "logo_type":         logo_type,
        "text_sections":     text_sections or {},
        "composition":       comp_data.get("sections",[]) or [],
        "comp_columns":      comp_data.get("columns",[]) or [],
        "comp_meta":         {"route": comp_data.get("route","oral"),
                              "mdd_g": comp_data.get("mdd_g",1.0),
                              "doses_per_day": comp_data.get("doses_per_day",1),
                              "unit": comp_data.get("unit",""),
                              "ingredient_col": comp_data.get("ingredient_col",""),
                              "amount_col": comp_data.get("amount_col",""),
                              "amount_unit": comp_data.get("amount_unit","mg")},
        "annexure_list":     annexure_list,
        "calc_tables":       calc_tables or {},
        "revision_history":  ref_structure.get("revision_history",[]) or [],
        "signatures":        ref_structure.get("signatures",[]) or [],
        "figures":           figures_b64,
        "pde_values":        dict(ICH_PDE),
        "additional_tables": additional_tables,
        # Citation layer controls
        "enable_inline_citations": enable_inline_citations,
    }

    generated_at  = datetime.now(timezone.utc).isoformat()
    ledger_dict: Optional[Dict] = None
    html_str:    Optional[str]  = None

    with tempfile.TemporaryDirectory() as tmpdir:
        json_path    = Path(tmpdir) / "report_data.json"
        docx_path    = Path(tmpdir) / "report.docx"
        ledger_path  = Path(tmpdir) / "citation_ledger.json"
        html_path    = Path(tmpdir) / "traceability_report.html"
        js_script    = Path(__file__).parent / "generate_report.js"

        with open(json_path,"w",encoding="utf-8") as f:
            json.dump(report_data, f, ensure_ascii=False)

        result = subprocess.run(
            ["node", str(js_script), str(json_path), str(docx_path)],
            capture_output=True, text=True, timeout=180)
        if result.returncode != 0:
            raise RuntimeError(
                f"Node.js failed (exit {result.returncode}).\n"
                f"STDERR: {result.stderr[-2000:]}\nSTDOUT: {result.stdout[-500:]}")
        if not docx_path.exists():
            raise RuntimeError(f"Node.js OK but no DOCX written.\nSTDOUT: {result.stdout}")
        docx_bytes = docx_path.read_bytes()
        if len(docx_bytes) < 5000:
            raise RuntimeError(f"DOCX too small ({len(docx_bytes)} bytes).")

        # Build and write citation ledger + HTML
        if citation_builder:
            try:
                ledger_dict = citation_builder.write_ledger(
                    str(ledger_path), report_id, generated_at
                )
                write_traceability_report(ledger_dict, str(html_path))
                html_str = html_path.read_text(encoding="utf-8")
            except Exception as e:
                logger.warning(f"Citation ledger write failed: {e}")

        return docx_bytes, ledger_dict, html_str


