def rasterize_pdf_pages(pdf_bytes: bytes, dpi: int = 150) -> List[bytes]:
    """Render every PDF page to a PNG image."""
    doc = fitz.open(stream=pdf_bytes, filetype="pdf")
    pages = []
    mat = fitz.Matrix(dpi/72, dpi/72)
    for page in doc:
        pix = page.get_pixmap(matrix=mat, alpha=False)
        pages.append(pix.tobytes("png"))
    doc.close()
    return pages

def extract_embedded_images(pdf_bytes: bytes) -> Dict[int, List[bytes]]:
    """
    Extract actual embedded bitmap images from each PDF page.
    Returns {page_index: [image_bytes, ...]}.
    Falls back to full-page raster if no bitmaps found on figure pages.
    """
    doc = fitz.open(stream=pdf_bytes, filetype="pdf")
    result: Dict[int, List[bytes]] = {}
    for page_num, page in enumerate(doc):
        img_list = page.get_images(full=True)
        if img_list:
            imgs = []
            for img_info in img_list:
                try:
                    xref = img_info[0]
                    base = doc.extract_image(xref)
                    imgs.append(base["image"])
                except Exception:
                    pass
            if imgs:
                result[page_num] = imgs
    doc.close()
    return result

def identify_figure_pages(page_images: List[bytes]) -> List[Dict]:
    """
    Ask Claude to identify which pages contain figures/diagrams.
    Returns list of {page_index, description, position_in_report}.
    """
    # Sample every page with a quick Claude call
    prompt_template = """Look at this page image from a pharmaceutical technical report.
Does this page contain any figure, diagram, flowchart, or schematic image (not tables, not text)?

If YES, respond with JSON: {{"has_figure": true, "description": "brief description", "figure_label": "Figure X: ..."}}
If NO, respond with JSON: {{"has_figure": false}}

Return ONLY the JSON, nothing else."""

    figures = []
    for i, img in enumerate(page_images):
        try:
            raw = claude_vision(img, prompt_template)
            start = raw.find("{"); end = raw.rfind("}") + 1
            if start >= 0:
                data = json.loads(raw[start:end])
                if data.get("has_figure"):
                    figures.append({
