# ── Pre-flight ────────────────────────────────────────────────────────────────
def validate_inputs(ref_pdf_bytes: bytes, excel_bytes: bytes,
                    annexure_uploads: List[Tuple[str, bytes]]) -> List[str]:
    errors: List[str] = []
    try:
        doc = fitz.open(stream=ref_pdf_bytes, filetype="pdf")
        n = len(doc); doc.close()
        if n == 0: errors.append("Reference PDF has 0 pages.")
        elif n < 5: errors.append(f"Reference PDF has only {n} pages — expected 10+.")
    except Exception as e:
        errors.append(f"Reference PDF cannot be opened: {e}")
    try:
        wb = openpyxl.load_workbook(BytesIO(excel_bytes), data_only=True)
        if not wb.worksheets: errors.append("Excel has no sheets.")
        else:
            ws = wb.worksheets[0]
            nrows = sum(1 for row in ws.iter_rows(values_only=True) if any(c is not None for c in row))
            if nrows < 3: errors.append(f"Excel sheet has only {nrows} non-empty rows.")
        wb.close()
    except Exception as e:
        errors.append(f"Excel cannot be opened: {e}")
    if not annexure_uploads:
        errors.append("No annexure JSON/PDF files uploaded.")
    for i, (name, raw_bytes) in enumerate(annexure_uploads):
        lower_name = name.lower()
        if lower_name.endswith(".json"):
            raw = raw_bytes.decode("utf-8","replace")
        elif lower_name.endswith(".pdf"):
            try:
                doc = fitz.open(stream=raw_bytes, filetype="pdf")
                n = len(doc); doc.close()
                if n == 0:
                    errors.append(f"Annexure {i+1} ({name}): PDF has 0 pages.")
            except Exception as e:
                errors.append(f"Annexure {i+1} ({name}): PDF cannot be opened: {e}")
            continue
        else:
            errors.append(f"Annexure {i+1} ({name}): upload must be JSON or PDF.")
            continue
        try:
            obj = json.loads(raw.lstrip("\ufeff"))
            if not isinstance(obj, (dict, list)):
                errors.append(f"Annexure {i+1} ({name}): JSON must be object or array.")
        except json.JSONDecodeError as e:
            errors.append(f"Annexure {i+1} ({name}): invalid JSON — {e}")
    import shutil
    if not shutil.which("node"):
        errors.append("Node.js not found. Install Node.js >= 18.")
    else:
        for pkg in ["docx", "jszip"]:
            r = subprocess.run(["node","-e",f"require('{pkg}');process.exit(0)"],
                               capture_output=True, timeout=10, env=node_runtime_env())
            if r.returncode != 0:
                errors.append(f"npm package '{pkg}' not found. Run: npm install {pkg}")
    creds = os.environ.get("GOOGLE_APPLICATION_CREDENTIALS","")
    if creds and not Path(creds).exists():
        errors.append(f"GCP credentials not found: {creds}")
    return errors


# ── PDF utilities ─────────────────────────────────────────────────────────────
def rasterize_pdf_pages(pdf_bytes: bytes, dpi: int = 200) -> List[bytes]:
    doc = fitz.open(stream=pdf_bytes, filetype="pdf")
    pages: List[bytes] = []
    mat = fitz.Matrix(dpi/72, dpi/72)
    for page in doc:
        pix = page.get_pixmap(matrix=mat, alpha=False, colorspace=fitz.csRGB)
        pages.append(pix.tobytes("png"))
    doc.close()
    return pages


ELEMENT_NAME_TO_SYMBOL = {
    safe_str(info.get("name", "")).lower(): sym
    for sym, info in ICH_PDE.items()
    if isinstance(info, dict)
}


def _sha256_bytes(data: bytes) -> str:
    return hashlib.sha256(data).hexdigest()


def _annexure_cache_path(file_sha256: str) -> Path:
    cache_dir = Path(__file__).parent / ".annexure_cache"
    cache_dir.mkdir(parents=True, exist_ok=True)
    return cache_dir / f"{file_sha256}.json"


def _first_text(*values: Any) -> str:
    for value in values:
        text = safe_str(value)
        if text:
            return text
    return ""


def _normalise_element_symbol(row: Dict) -> str:
    raw = _first_text(row.get("symbol"), row.get("element_symbol"), row.get("Symbol"))
    raw = re.sub(r"[^A-Za-z]", "", raw)
    if raw:
        for sym in ALL_ELEMENTS:
            if sym.lower() == raw.lower():
                return sym
    name = _first_text(row.get("element"), row.get("element_name"),
                       row.get("name"), row.get("Element"))
    key = re.sub(r"\s+", " ", name.lower()).strip()
    return ELEMENT_NAME_TO_SYMBOL.get(key, "")


def _iter_pdf_extracted_rows(page_data: Any) -> List[Dict]:
    if not isinstance(page_data, dict):
        return []
    rows: List[Dict] = []
    for key in ("rows", "elements"):
        value = page_data.get(key)
        if isinstance(value, list):
            rows.extend(r for r in value if isinstance(r, dict))
    for table in page_data.get("tables") or []:
        if not isinstance(table, dict):
            continue
        table_rows = table.get("rows") or table.get("body_rows") or []
        if isinstance(table_rows, list):
            rows.extend(r for r in table_rows if isinstance(r, dict))
    return rows


def _cell_value(value: Any) -> str:
    if value is None:
        return "NOT_REPORTED"
    text = safe_str(value)
    return text if text else "NOT_REPORTED"


def _rows_to_docai_like_json(rows: List[Dict], metadata: Dict,
                             file_name: str, file_sha256: str,
                             page_count: int, page_extractions: List[Dict]) -> Dict:
    headers = [
        "Symbol", "Element", "Observed Level", "Concentration Value",
        "Concentration Unit", "Analytical Method", "Intentionally Added",
        "Listed In COA", "Data Status", "Comments",
    ]
    body_rows = []
    text_lines = [
        f"Annexure PDF file: {file_name}",
        f"Supplier Name: {metadata.get('supplier_name','')}",
        f"Material Name: {metadata.get('material_name','')}",
        f"Source Type: {metadata.get('source_type','')}",
        f"Date Filled: {metadata.get('date_filled','')}",
        "Extracted elemental impurity table:",
        " | ".join(headers),
    ]
    for row in rows:
        symbol = _normalise_element_symbol(row)
        if not symbol:
            continue
        element_name = _first_text(
            row.get("element"), row.get("element_name"), row.get("name"),
            ICH_PDE.get(symbol, {}).get("name", ""),
        )
        concentration_value = row.get("concentration_value")
        observed_level = _first_text(
            row.get("observed_level"), row.get("reported_value"),
            row.get("result"), concentration_value,
        )
        values = [
            symbol,
            element_name,
            _cell_value(observed_level),
            _cell_value(concentration_value),
            _first_text(row.get("concentration_unit"), row.get("unit")),
            _first_text(row.get("analytical_method"), row.get("method")),
            _first_text(row.get("intentionally_added"), row.get("intended")),
            _first_text(row.get("listed_in_coa"), row.get("listed_in_coa_or_spec")),
            _first_text(row.get("data_status"), row.get("status")),
            _first_text(row.get("comments"), row.get("note")),
        ]
        body_rows.append({"cells": [{"text": str(v)} for v in values]})
        text_lines.append(" | ".join(str(v) for v in values))

    table = {
        "headerRows": [{"cells": [{"text": h} for h in headers]}],
        "bodyRows": body_rows,
    }
    return {
        "text": "\n".join(text_lines),
        "tables": [table],
        "_source": {
            "type": "pdf",
            "filename": file_name,
            "sha256": file_sha256,
            "pages": page_count,
            "cache_hit": False,
            "page_extractions": page_extractions,
        },
    }


def extract_annexure_pdf_to_json(pdf_bytes: bytes, file_name: str,
                                 dpi: int = 200) -> Dict:
    """
    Convert an uploaded annexure PDF into a Document-AI-like JSON object.
    The result is cached by SHA-256 so repeated runs do not re-call Claude.
    """
    file_sha256 = _sha256_bytes(pdf_bytes)
    cache_path = _annexure_cache_path(file_sha256)
    if cache_path.exists():
        try:
            cached = json.loads(cache_path.read_text(encoding="utf-8"))
            if isinstance(cached, dict):
                cached.setdefault("_source", {})
                cached["_source"]["cache_hit"] = True
                return cached
        except Exception as e:
            logger.warning(f"Annexure cache read failed for {file_name}: {e}")

    doc = fitz.open(stream=pdf_bytes, filetype="pdf")
    metadata: Dict[str, str] = {}
    extracted_rows: List[Dict] = []
    page_extractions: List[Dict] = []
    mat = fitz.Matrix(dpi/72, dpi/72)
    elements_hint = ", ".join(ALL_ELEMENTS)
    try:
        page_count = len(doc)
        for page_index in range(page_count):
            pix = doc.load_page(page_index).get_pixmap(
                matrix=mat, alpha=False, colorspace=fitz.csRGB)
            image_bytes = pix.tobytes("png")
            prompt = (
                "This is one page of a pharmaceutical elemental impurity annexure PDF.\n"
                "Extract only supplier-provided elemental impurity table data visible on this page.\n"
                "Do not infer, estimate, or fill missing concentrations. Do not create default values.\n"
                "If a concentration cell is blank, NA, not tested, or not reported, use null.\n"
                "If the page does not contain elemental impurity table rows, return page_has_ei_table false.\n"
                "Use numeric concentration_value only when the number is printed. For '<0.5', use 0.5 and keep observed_level '<0.5'.\n"
                "Do not output the 25 ICH elements unless they are actually present on this page.\n"
                f"ICH element symbols to recognize: {elements_hint}.\n\n"
                "Return ONLY this JSON object:\n"
                "{\n"
                '  "page_has_ei_table": false,\n'
                '  "supplier_name": "", "material_name": "", "source_type": "", "date_filled": "",\n'
                '  "tables": [{"title": "", "rows": [\n'
                '    {"symbol": "Pb", "element": "Lead", "observed_level": "<0.5",\n'
                '     "concentration_value": 0.5, "concentration_unit": "ug/g",\n'
                '     "analytical_method": "", "intentionally_added": "",\n'
                '     "listed_in_coa": "", "data_status": "reported", "comments": ""}\n'
                "  ]}]\n"
                "}"
            )
            raw = claude_vision(image_bytes, prompt, max_tokens=6000)
            parsed = safe_json_parse(raw, {})
            if not isinstance(parsed, dict):
                parsed = {"page_has_ei_table": False, "parse_error": "Claude returned non-object JSON"}
            parsed["_page_number"] = page_index + 1
            page_extractions.append(parsed)

            for key in ("supplier_name", "material_name", "source_type", "date_filled"):
                if not metadata.get(key) and safe_str(parsed.get(key)):
                    metadata[key] = safe_str(parsed.get(key))

            rows = _iter_pdf_extracted_rows(parsed)
            if rows:
                extracted_rows.extend(rows)
    finally:
        doc.close()

    docai_like = _rows_to_docai_like_json(
        extracted_rows, metadata, file_name, file_sha256, page_count, page_extractions)
    body_rows = docai_like.get("tables", [{}])[0].get("bodyRows", [])
    if not body_rows:
        raise ValueError(f"No elemental impurity table rows were extracted from {file_name}.")
    try:
        cache_path.write_text(json.dumps(docai_like, ensure_ascii=False, indent=2),
                              encoding="utf-8")
    except Exception as e:
        logger.warning(f"Annexure cache write failed for {file_name}: {e}")
    return docai_like


def extract_figure_from_page(pdf_bytes: bytes, page_index: int, dpi: int = 200) -> bytes:
    """Crop top 38% (header+caption) and bottom 10% (page number) of figure page."""
    doc = fitz.open(stream=pdf_bytes, filetype="pdf")
    try:
        page = doc.load_page(page_index)
        r = page.rect
        crop = fitz.Rect(r.x0 + r.width*0.02, r.y0 + r.height*0.38,
                         r.x1 - r.width*0.02, r.y1 - r.height*0.10)
        mat = fitz.Matrix(dpi/72, dpi/72)
        pix = page.get_pixmap(matrix=mat, alpha=False, colorspace=fitz.csRGB, clip=crop)
        return pix.tobytes("png")
    finally:
        doc.close()


def identify_figure_pages(page_images: List[bytes]) -> List[Dict]:
    prompt = (
        "Look at this page from a pharmaceutical technical report.\n"
        "Does it contain a figure, diagram, flowchart, or schematic "
        "(NOT a table, NOT only text)?\n\n"
        'YES: {"has_figure":true,"description":"...","figure_label":"Figure X: ..."}\n'
        'NO:  {"has_figure":false}\nReturn ONLY the JSON.'
    )
    figures: List[Dict] = []
    for i, img in enumerate(page_images):
        try:
            raw = claude_vision(img, prompt)
            data = safe_json_parse(raw, {"has_figure": False})
            if isinstance(data, dict) and data.get("has_figure"):
                figures.append({"page_index": i,
                                 "description": safe_str(data.get("description","")),
                                 "figure_label": safe_str(data.get("figure_label",""))})
        except Exception as e:
            logger.warning(f"Figure detect p{i}: {e}")
    return figures


def extract_reference_structure(page_images: List[bytes]) -> Dict:
    """
    Extract ALL content from the reference PDF:
    - Page 1 metadata (header fields)
    - TOC (whatever sections the product has)
    - Every page: section text AND any tables (with exact columns)
    - Revision history and signatures
    This is the key to product-agnosticism: we extract as-is, render as-is.
    """
    # ── Metadata from page 1 ─────────────────────────────────────────────────
    meta_prompt = (
        "This is page 1 of a pharmaceutical TSR document.\n"
        "Extract ALL metadata exactly as shown. Return ONLY this JSON:\n"
        '{"title":"","document_no":"","product_name":"","dosage_form":"","version":"",'
        '"strength":"","department":"","market":"","protocol":"",'
        '"sop_format_number":"","route_of_administration":""}'
    )
    meta_raw = claude_vision(safe_list_get(page_images, 0, b""), meta_prompt)
    meta = safe_json_parse(meta_raw, {})
    if not isinstance(meta, dict): meta = {}

    # ── TOC from page 2 ───────────────────────────────────────────────────────
    toc_prompt = (
        "This page is from a pharmaceutical Technical Summary Report.\n\n"
        "Does this page contain a TABLE OF CONTENTS section?\n"
        "A real TABLE OF CONTENTS has:\n"
        "  - A heading 'TABLE OF CONTENTS' or 'CONTENTS'\n"
        "  - Numbered section entries (1, 2, 3...) with titles and page numbers\n"
        "  - Page numbers are integers (e.g. 3, 4, 15)\n\n"
        "The IPDO page header table (IPDO | Technical Summary Report | Dr.Reddy's)\n"
        "is NOT a table of contents — ignore it.\n"
        "A metadata table (Title, Document No, Product Name, Department...) is\n"
        "NOT a table of contents — return is_toc:false for those pages.\n\n"
        "If this IS a TABLE OF CONTENTS, return ONLY:\n"
        '{"is_toc":true,"entries":[{"no":"1","title":"Abstract","page":"3"}]}\n'
        "If NOT a TOC page:\n"
        '{"is_toc":false,"entries":[]}'
    )
    toc_entries: List[Dict] = []
    for i in range(min(4, len(page_images))):
        try:
            raw = claude_vision(safe_list_get(page_images, i, b""), toc_prompt)
            d = safe_json_parse(raw, {})
            if not (isinstance(d, dict) and d.get("is_toc")): continue
            candidates = d.get("entries", [])
            if not isinstance(candidates, list) or not candidates: continue

            # Validate: real TOC entries have:
            #   "no"   = numeric string or small integer ("1","2",...,"12")
            #   "page" = numeric string ("3","4","15","16")
            # If the header metadata table was mistaken for a TOC, entries look like:
            #   {"no":"Title","title":"Risk assessment...","page":"FR&D"}
            # We reject those by checking that both "no" and "page" are numeric.
            def is_valid_toc_entry(e: Dict) -> bool:
                if not isinstance(e, dict): return False
                no_val   = safe_str(e.get("no",   "")).strip()
                page_val = safe_str(e.get("page",  "")).strip()
                # "no" must be a small integer string ("1"–"20")
                try:
                    n = int(no_val)
                    if n < 1 or n > 50: return False
                except (ValueError, TypeError):
                    return False
                # "page" must be a numeric string
                try:
                    int(page_val)
                except (ValueError, TypeError):
                    return False
                return True

            valid = [e for e in candidates if is_valid_toc_entry(e)]
            # Require at least 3 valid entries to accept as a real TOC
            if len(valid) >= 3:
                toc_entries = valid
                break
        except Exception:
            pass

    # ── Revision history and signatures (last 3 pages) ────────────────────────
    # NOTE: We no longer do per-page full extraction — it was only used for
    # additional_tables which caused the header table to repeat 12+ times.
    # Removing saves ~18 Claude API calls per report.
    pages_data: List[Dict] = []   # kept for compatibility, not populated
    revision_data: List[Dict] = []
    sig_data: List[Dict] = []
    rev_prompt = (
        "This page may contain revision history table and/or electronic signatures.\n"
        "Return ONLY: "
        '{"revision_history":[{"document_version":"","changes":""}],'
        '"signatures":[{"intention":"","employee_id":"","user_name":"","date":""}]}'
    )
    for i in range(max(0, len(page_images)-3), len(page_images)):
        try:
            raw = claude_vision(safe_list_get(page_images, i, b""), rev_prompt)
            d = safe_json_parse(raw, {})
            if isinstance(d, dict):
                rh = d.get("revision_history")
                sg = d.get("signatures")
                if isinstance(rh, list) and rh: revision_data = rh
                if isinstance(sg, list) and sg: sig_data = sg
        except Exception:
            pass

    return {
        "meta":             meta,
        "toc_entries":      toc_entries,
        "revision_history": revision_data,
        "signatures":       sig_data,
    }


def extract_composition_tables(pages_data: List[Dict]) -> Dict:
    """
    From the page-by-page extraction, find and return all composition/ingredient
    tables exactly as extracted — columns, rows, captions preserved verbatim.
    """
    comp_tables: List[Dict] = []
    for page in pages_data:
        if not isinstance(page, dict): continue
        for sec in (page.get("sections") or []):
            if not isinstance(sec, dict): continue
            for tbl in (sec.get("tables") or []):
                if not isinstance(tbl, dict): continue
                # Identify composition/ingredient/packing tables
                cap = safe_str(tbl.get("caption","")).lower()
                cols = tbl.get("columns", [])
                is_comp = any(kw in cap for kw in
                              ["ingredient","composition","packing","material","substance",
                               "excipient","table 1","table 2","detail"])
                if is_comp or (cols and any("ingredient" in str(c).lower() or
                                             "material" in str(c).lower() or
                                             "component" in str(c).lower()
                                             for c in cols)):
                    comp_tables.append(tbl)
    return {"tables": comp_tables}


def extract_additional_tables(pages_data: List[Dict]) -> List[Dict]:
    """
    Intentionally returns empty list.

    We previously tried to extract "extra" tables from the PDF pages verbatim,
    but the repeating IPDO header table (Field | Value) appears on every page
    and was passing all filters, causing it to be rendered 12+ times.

    The structured pipeline already renders every needed table:
      - Table 1: Composition (from Excel)
      - Table 2: Annexure list (from annexure_data)
      - Tables 5/6/7: EI calculations (from calculate_ei_tables)
      - Revision history, signatures, TOC (from reference structure)

    Any additional product-specific tables (e.g. "Potential risk" summary)
    are captured as text in the Claude-generated text_sections instead.
    """
    return []


# ── Excel composition parser ──────────────────────────────────────────────────
def parse_composition_excel(excel_bytes: bytes) -> Dict:
    """
    Generic parser: works for oral sachets, injections, any formulation.
    Returns sections with ingredients and their amounts.
    """
    wb = openpyxl.load_workbook(BytesIO(excel_bytes), data_only=True)
    ws = wb.worksheets[0]
    rows_text: List[str] = []
    all_rows: List[List[str]] = []
    for i, row in enumerate(ws.iter_rows(values_only=True)):
        if any(c is not None for c in row):
            row_str = [str(c) if c is not None else "" for c in row]
            rows_text.append(f"Row {i+1}: {' | '.join(row_str)}")
            all_rows.append(row_str)
    wb.close()
    sheet_dump = "\n".join(rows_text[:100])

    prompt = (
        "Pharmaceutical composition spreadsheet. Extract EVERYTHING accurately.\n\n"
        "This spreadsheet lists ingredients for a drug product.\n"
        "Your most critical task is correctly identifying doses_per_day.\n\n"
        "IMPORTANT DEFINITIONS:\n"
        "- doses_per_day: number of unit doses taken per day at MAXIMUM DAILY DOSE\n"
        "  For oral sachets: if MDD=240mg and each sachet=40mg → doses_per_day=6\n"
        "  For oral tablets: if MDD=2 tablets/day → doses_per_day=2\n"
        "  For injections: usually 1 (one injection per day)\n"
        "  For topical: number of applications per day\n"
        "- amount_per_dose: each row's amount is per SINGLE DOSE UNIT (sachet/tablet/injection)\n"
        "  Daily intake for each ingredient = amount_per_dose × doses_per_day\n"
        "- mdd_g: total mass of drug PRODUCT administered per day in grams\n"
        "  NOT just the active ingredient strength.\n"
        "  For sachets: (sum of ALL ingredient amounts in one sachet, in mg) "
        "× doses_per_day ÷ 1000\n\n"
        "Return ONLY this JSON (no markdown):\n"
        "{\n"
        '  "route": "oral or parenteral or injection or topical",\n'
        '  "doses_per_day": 6,\n'
        "  // CRITICAL: number of unit doses at MDD. "
        "For 240mg/day in 40mg sachets this is 6.\n"
        '  "mdd_strength_mg": 40,\n'
        "  // strength of one unit dose in mg (e.g. 40mg sachet)\n"
        '  "mdd_total_mg_per_day": 240,\n'
        "  // total active ingredient per day = mdd_strength_mg × doses_per_day\n"
        '  "mdd_g": 19.0,\n'
        "  // total PRODUCT mass per day in grams (all ingredients × doses_per_day / 1000)\n"
        '  "unit": "mg/sachet",\n'
        '  "ingredient_col": "Name of Ingredient",\n'
        '  "amount_col": "exact column header for per-dose ingredient amount",\n'
        '  "amount_unit": "mg",\n'
        '  "columns": ["exact col1 header","exact col2 header","..."],\n'
        '  "sections": [\n'
        '    {\n'
        '      "name": "section header or empty string",\n'
        '      "rows": [\n'
        '        {"ingredient":"...","columns":{"Col1":"val","Col2":"val",...}}\n'
        '      ]\n'
        '    }\n'
        '  ]\n'
        "}\n\n"
        "RULES:\n"
        "- columns[]: exact headers as in the spreadsheet\n"
        "- amount_col: the column with per-unit-dose ingredient amounts\n"
        "- amount_unit: 'mg', 'g', 'mL', or 'mg/mL'\n"
        "- For each row, map values to exact column headers\n"
        "- If the spreadsheet has columns for multiple strengths (40mg, 20mg, 10mg),\n"
        "  amount_col should be the HIGHEST STRENGTH column (worst case for EI)\n"
        "- mdd_g = total product mass per day. For sachets with multiple ingredients\n"
        "  summing to ~3g per sachet × 6 sachets = ~18-20g/day\n"
        f"Spreadsheet:\n{sheet_dump}"
    )
    raw = claude_text(prompt)
    parsed = safe_json_parse(raw, {})

    if isinstance(parsed, dict) and isinstance(parsed.get("sections"), list) and parsed["sections"]:
        result = parsed
    else:
        raise ValueError(
            "Composition Excel could not be parsed into structured rows. "
            "No default MDD, route, or ingredient amounts were applied."
        )

    doses_per_day    = safe_int(result.get("doses_per_day", 0), default=0)
    mdd_strength_mg  = safe_float(result.get("mdd_strength_mg", 0.0), default=0.0)
    mdd_total_mg     = safe_float(result.get("mdd_total_mg_per_day", 0.0), default=0.0)

    # Cross-check: if Claude returned mdd_strength_mg and doses_per_day,
    # verify they are consistent with mdd_total_mg_per_day
    if mdd_strength_mg > 0 and doses_per_day > 0:
        expected_total = mdd_strength_mg * doses_per_day
        if mdd_total_mg > 0 and abs(expected_total - mdd_total_mg) > 1.0:
            logger.warning(
                f"MDD inconsistency: strength={mdd_strength_mg}mg × "
                f"doses={doses_per_day} = {expected_total}mg/day but "
                f"mdd_total_mg_per_day={mdd_total_mg}mg. "
                f"Using strength×doses = {expected_total}mg/day."
            )
            mdd_total_mg = expected_total

    amount_col_text = safe_str(result.get("amount_col", ""))
    unit_text = safe_str(result.get("amount_unit", ""))
    if not unit_text:
        unit_hint = (amount_col_text + " " + safe_str(result.get("unit", ""))).lower()
        if "ug" in unit_hint or "Âµg" in unit_hint:
            unit_text = "ug"
        elif "mg" in unit_hint:
            unit_text = "mg"
        elif "ml" in unit_hint:
            unit_text = "mL"
        elif re.search(r"(^|\W)g($|\W)", unit_hint):
            unit_text = "g"

    if doses_per_day <= 0:
        raise ValueError("Composition Excel did not provide a valid doses_per_day; MDD scaling cannot continue.")
    if not safe_str(result.get("route", "")):
        raise ValueError("Composition Excel did not provide route of administration; route-specific PDEs cannot be selected.")
    if not safe_str(result.get("ingredient_col", "")):
        raise ValueError("Composition Excel did not identify the ingredient column.")
    if not amount_col_text:
        raise ValueError("Composition Excel did not identify the per-dose amount column.")
    if not unit_text:
        raise ValueError("Composition Excel did not identify the amount unit.")

    parsed_mdd_g = safe_float(result.get("mdd_g", 0.0), default=0.0)
    if parsed_mdd_g <= 0:
        per_dose_total_g = 0.0
        for section in result.get("sections", []) or []:
            if not isinstance(section, dict):
                continue
            for row in section.get("rows", []) or []:
                if not isinstance(row, dict):
                    continue
                cols = row.get("columns", {})
                raw_amount = cols.get(amount_col_text) if isinstance(cols, dict) else row.get("amount")
                amount_raw = _parse_amount_g(raw_amount)
                unit_lower = unit_text.lower()
                if "ug" in unit_lower or "Âµg" in unit_lower:
                    per_dose_total_g += amount_raw / 1_000_000.0
                elif "mg" in unit_lower:
                    per_dose_total_g += amount_raw / 1000.0
                elif "ml" in unit_lower or "g" in unit_lower:
                    per_dose_total_g += amount_raw
        parsed_mdd_g = round(per_dose_total_g * doses_per_day, 8)
    if parsed_mdd_g <= 0:
        raise ValueError("Composition Excel did not provide enough numeric amount data to calculate product MDD in g/day.")

    result["mdd_g"]             = parsed_mdd_g
    result["doses_per_day"]     = doses_per_day
    result["mdd_strength_mg"]   = mdd_strength_mg
    result["mdd_total_mg_per_day"] = mdd_total_mg
    result["route"]             = safe_str(result.get("route", ""))
    result["ingredient_col"]    = safe_str(result.get("ingredient_col", ""))
    result["amount_col"]        = safe_str(result.get("amount_col", ""))
    result["amount_unit"]       = unit_text
    result["amount_per_dose"]   = True  # amounts are always per-dose; we scale by doses_per_day
    if not isinstance(result.get("sections"), list): result["sections"] = []
    if not isinstance(result.get("columns"), list):  result["columns"] = []
    result["all_rows"] = all_rows
    return result


# ── Annexure processor ────────────────────────────────────────────────────────
def _flatten_docai_json(obj: Any, depth: int = 0) -> str:
    if depth > 8: return ""
    parts: List[str] = []
    if isinstance(obj, dict):
        if "text" in obj and isinstance(obj["text"], str): parts.append(obj["text"])
        for v in obj.values(): parts.append(_flatten_docai_json(v, depth+1))
    elif isinstance(obj, list):
        for item in obj: parts.append(_flatten_docai_json(item, depth+1))
    elif isinstance(obj, (str, int, float)): parts.append(str(obj))
    return " ".join(p for p in parts if p.strip())


def _extract_docai_tables(obj):
    """
    Extract structured table grids from a Document AI JSON.
    Returns list of tables; each table is list of rows; each row is list of cell strings.
    Handles Document AI v1/v1beta3 table structure and common variants.
    """
    tables = []
    doc_text = obj.get("text", "") if isinstance(obj, dict) else ""

    def cell_text(cell):
        if isinstance(cell, str): return cell.strip()
        if not isinstance(cell, dict): return ""
        if "text" in cell: return str(cell["text"]).strip()
        if "mentionText" in cell: return str(cell["mentionText"]).strip()
        anchor = cell.get("layout", {}).get("textAnchor", {})
        if anchor and doc_text:
            segments = anchor.get("textSegments", [])
            parts = []
            for seg in segments:
                start = int(seg.get("startIndex", 0))
                end   = int(seg.get("endIndex", 0))
                if end > start:
                    parts.append(doc_text[start:end])
            if parts: return "".join(parts).strip()
        for key in ("content", "value"):
            if key in cell:
                v = cell[key]
                if isinstance(v, dict) and "text" in v: return str(v["text"]).strip()
                if isinstance(v, str): return v.strip()
        return ""

    def extract_node(node, depth=0):
        if depth > 10 or not node: return
        if isinstance(node, dict):
            if "tables" in node:
                for tbl in (node["tables"] or []):
                    grid = []
                    for section in ("headerRows", "bodyRows"):
                        for row in (tbl.get(section) or []):
                            row_cells = [cell_text(c) for c in (row.get("cells") or [])]
                            if any(row_cells): grid.append(row_cells)
                    if len(grid) >= 2: tables.append(grid)
            for rows_key in ("tableRows", "rows"):
                if rows_key in node:
                    grid = []
                    for row in (node.get(rows_key) or []):
                        if isinstance(row, dict):
                            rc = [cell_text(c)
                                  for c in (row.get("cells") or row.get("tableCells") or [])]
                        elif isinstance(row, list):
                            rc = [str(c).strip() for c in row]
                        else: continue
                        if any(rc): grid.append(rc)
                    if len(grid) >= 2: tables.append(grid)
            for v in node.values(): extract_node(v, depth+1)
        elif isinstance(node, list):
            for item in node: extract_node(item, depth+1)

    extract_node(obj)
    return tables


def _tables_to_text(tables):
    """Format extracted tables as readable text for Claude."""
    parts = []
    for ti, table in enumerate(tables):
        parts.append(f"=== Table {ti+1} ===")
        for row in table:
            parts.append(" | ".join(row))
        parts.append("")
    return "\n".join(parts)


