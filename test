def _parse_conc(val) -> float:
“”“Parse a concentration value to float µg/g.”””
if val is None: return 0.0
if isinstance(val, (int, float)): return max(0.0, float(val))
s = str(val).strip().lower()
if s in (””, “na”, “nd”, “blq”, “bdl”, “none”, “null”): return 0.05  # use LOQ conservatively
# strip common units and text
s = re.sub(r”(ppm|ug/g|<|>)”, “”, s).replace(” “, “”)
try:
return max(0.0, float(s))
except (ValueError, TypeError):
return 0.05  # unknown value → use LOQ as conservative default

