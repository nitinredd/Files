META_FIELDS = [
    "title", "document_no", "product_name", "dosage_form", "version",
    "strength", "department", "market", "protocol", "sop_format_number",
]


def _slug_key(label: Any, fallback: str = "amount") -> str:
    raw = safe_str(label).lower()
    raw = raw.replace("µ", "u")
    raw = re.sub(r"[^a-z0-9]+", "_", raw).strip("_")
    return raw or fallback


def _is_blank(v: Any) -> bool:
    return safe_str(v).lower() in ("", "na", "n/a", "none", "null")


def _first_nonblank(*vals: Any) -> str:
    for v in vals:
        s = safe_str(v)
        if not _is_blank(s):
            return s
    return ""


def _build_title_from_meta(meta: Dict) -> str:
    product = safe_str(meta.get("product_name", ""))
    strength = safe_str(meta.get("strength", ""))
    if not product:
        return safe_str(meta.get("title", ""))
    title = f"Risk assessment for elemental impurities in {product}"
    if strength and strength.lower() not in title.lower():
        title += f" {strength}"
    return title


def merge_product_metadata(ref_meta: Dict, comp_data: Dict,
                           overrides: Optional[Dict] = None,
                           pde_route_override: str = "auto") -> Dict:
    """Merge reference metadata with product-specific Excel/manual values."""
    ref_meta = ref_meta or {}
    comp_meta = (comp_data or {}).get("product_metadata", {})
    if not isinstance(comp_meta, dict):
        comp_meta = {}
    overrides = overrides or {}

    meta = {k: safe_str(ref_meta.get(k, "")) for k in META_FIELDS}
    product_signal = False
    for source in (comp_meta, overrides):
        for key in META_FIELDS:
            val = safe_str(source.get(key, ""))
            if not _is_blank(val):
                meta[key] = val
                if key in ("title", "product_name", "dosage_form", "strength"):
                    product_signal = True

    if (product_signal and _is_blank(overrides.get("title", ""))
            and _is_blank(comp_meta.get("title", ""))):
        meta["title"] = _build_title_from_meta(meta)

    route = infer_pde_route(meta, pde_route_override)
    meta["pde_route"] = route
    return meta


def _iter_composition_rows(sections: Any) -> List[Dict]:
    rows: List[Dict] = []
    if not isinstance(sections, list):
        return rows
    for section in sections:
        if not isinstance(section, dict):
            continue
        for row in section.get("rows", []) or []:
            if isinstance(row, dict):
                rows.append(row)
    return rows


def _infer_amount_columns(parsed: Dict, sections: List[Dict]) -> List[Dict]:
    columns: List[Dict] = []
    seen = set()

    def add_col(key: Any, label: Any = "", unit: str = "mg") -> None:
        k = safe_str(key)
        if not k:
            k = _slug_key(label)
        if k in seen:
            return
        seen.add(k)
        columns.append({
            "key": k,
            "label": safe_str(label) or k,
            "unit": unit or "mg",
        })

    raw_cols = parsed.get("amount_columns", [])
    if isinstance(raw_cols, list):
        for col in raw_cols:
            if isinstance(col, dict):
                add_col(col.get("key"), col.get("label"), safe_str(col.get("unit", "mg")))
            else:
                add_col(col, col)

    strength_cols = parsed.get("strength_cols", {})
    if isinstance(strength_cols, dict):
        for label in strength_cols:
            add_col(label, label)

    rows = _iter_composition_rows(sections)
    protected = {
        "ingredient", "name", "material", "material_name", "material_code",
        "function", "status", "compendial_status", "comments", "source",
    }
    for row in rows:
        for key, value in row.items():
            k = safe_str(key)
            if not k or k.lower() in protected:
                continue
            if _parse_amount(value) > 0:
                add_col(k, k)

    return columns


def _normalize_composition_result(parsed: Dict,
                                  all_rows: List[List[str]]) -> Dict:
    if not isinstance(parsed, dict):
        parsed = {}
    sections = parsed.get("sections", [])
    if not isinstance(sections, list) or not sections:
        fallback_rows = []
        for row in all_rows[1:]:
            if len(row) > 1 and safe_str(row[1]):
                fallback_rows.append({
                    "material_code": row[0] if len(row) > 0 else "",
                    "ingredient":    row[1],
                    "function":      row[2] if len(row) > 2 else "",
                    "qty_per_unit_mg": row[3] if len(row) > 3 else "0",
                })
        sections = [{"name": "Composition", "rows": fallback_rows}]

    for section in sections:
        if not isinstance(section, dict):
            continue
        section.setdefault("name", "Composition")
        rows = section.get("rows", [])
        if not isinstance(rows, list):
            section["rows"] = []
            continue
        for row in rows:
            if not isinstance(row, dict):
                continue
            row["ingredient"] = _first_nonblank(
                row.get("ingredient"), row.get("name"),
                row.get("material"), row.get("material_name"),
            )
            row["material_code"] = _first_nonblank(
                row.get("material_code"), row.get("code"),
            )
            row["function"] = _first_nonblank(row.get("function"), row.get("role"))
            row["status"] = _first_nonblank(
                row.get("status"), row.get("compendial_status"),
            )

    parsed["sections"] = [s for s in sections if isinstance(s, dict)]
    amount_columns = _infer_amount_columns(parsed, parsed["sections"])
    if not amount_columns:
        amount_columns = [{
            "key": "qty_per_unit_mg",
            "label": "Qty/unit (mg)",
            "unit": "mg",
        }]
    parsed["amount_columns"] = amount_columns

    amount_keys = {c["key"] for c in amount_columns}
    primary = _first_nonblank(
        parsed.get("mdd_amount_key"),
        parsed.get("primary_amount_key"),
        parsed.get("mdd_strength"),
    )
    if primary not in amount_keys:
        primary = amount_columns[0]["key"]
    parsed["mdd_amount_key"] = primary
    parsed["mdd_strength"] = primary

    daily_units = parsed.get("daily_units", parsed.get("mdd_units", parsed.get("mdd_sachets", 1)))
    try:
        daily_units_f = float(str(daily_units).strip())
    except Exception:
        daily_units_f = 1.0
    if daily_units_f <= 0:
        daily_units_f = 1.0
    parsed["daily_units"] = daily_units_f
    parsed["mdd_sachets"] = daily_units_f
    parsed["daily_unit_label"] = _first_nonblank(
        parsed.get("daily_unit_label"), parsed.get("unit_label"), "unit/day",
    )

    columns = []
    sample_rows = _iter_composition_rows(parsed["sections"])
    has_code = any(safe_str(r.get("material_code", "")) for r in sample_rows)
    has_function = any(safe_str(r.get("function", "")) for r in sample_rows)
    has_status = any(safe_str(r.get("status", "")) for r in sample_rows)
    if has_code:
        columns.append({"key": "material_code", "label": "Material code"})
    columns.append({"key": "ingredient", "label": "Name of Ingredient"})
    if has_function:
        columns.append({"key": "function", "label": "Function"})
    if has_status:
        columns.append({"key": "status", "label": "Compendial Status"})
    for col in amount_columns:
        columns.append({"key": col["key"], "label": col["label"]})
    parsed["composition_columns"] = columns

    product_meta = parsed.get("product_metadata", {})
    product_meta = product_meta if isinstance(product_meta, dict) else {}
    if _is_blank(product_meta.get("product_name", "")):
        for row in _iter_composition_rows(parsed["sections"]):
            function_text = safe_str(row.get("function", "")).lower()
            if "active" in function_text or "drug substance" in function_text:
                product_meta["product_name"] = safe_str(row.get("ingredient", ""))
                break
    parsed["product_metadata"] = product_meta
    return parsed


