# ============================================================================
# SAFE UTILITIES — never raise, always return a sane default
# ============================================================================
def safe_int(v: Any, default: int = 0) -> int:
    if v is None:
        return default
    if isinstance(v, int):
        return v
    try:
        return int(float(str(v).strip()))
    except Exception:
        return default


def safe_str(v: Any, default: str = "") -> str:
    if v is None:
        return default
    return str(v).strip()


def safe_json_parse(text: str, default: Any = None) -> Any:
    if default is None:
        default = {}
    if not text:
        return default
    for strategy in ["direct", "object", "array"]:
        try:
            if strategy == "direct":
                return json.loads(text)
            elif strategy == "object":
                s = text.find("{")
                e = text.rfind("}") + 1
                if s >= 0 and e > s:
                    return json.loads(text[s:e])
            else:
                s = text.find("[")
                e = text.rfind("]") + 1
                if s >= 0 and e > s:
                    return json.loads(text[s:e])
        except Exception:
            pass
    return default


def safe_list_get(lst: Any, idx: int, default: Any = None) -> Any:
    try:
        if lst and 0 <= idx < len(lst):
            return lst[idx]
    except Exception:
        pass
    return default


def safe_calc_table(calc_tables: Optional[Dict], key: str) -> Dict:
    empty: Dict = {
        "elements": [], "rows": [], "total_daily_intake": 0.0,
        "element_totals": {}, "pde": {}, "threshold_30pct": {},
    }
    if not calc_tables or not isinstance(calc_tables, dict):
        return empty
    t = calc_tables.get(key)
    if not t or not isinstance(t, dict):
        return empty
    out = dict(empty)
    out.update(t)
    return out


