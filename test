// ── SECTION 12 — COMPARATIVE DISSOLUTION PROFILE ─────────────────────────────
function buildDissolutionSection(dissolution) {
  dissolution = dissolution || {};
  var ch = [];
  ch.push(secHd("12. Comparative Dissolution Profile of Reference and Test Product"));

  if (dissolution.media_description) {
    ch.push(bodyPara(dissolution.media_description, {italics:true}));
    ch.push(blk());
  }

  // Product & Batch identification table
  if (dissolution.reference_batch || dissolution.test_batch) {
    var idW = [Math.round(CW*0.30), Math.round(CW*0.35), 0];
    idW[2] = CW - idW[0] - idW[1];
    ch.push(new Table({
      width:{size:CW, type:WidthType.DXA}, columnWidths:idW,
      rows:[
        new TableRow({children:[
          cell("Product",     {bold:true, fill:CLR.HDR_GREY, w:idW[0], size:SZ.SM}),
          cell("Reference",   {bold:true, fill:CLR.HDR_GREY, w:idW[1], size:SZ.SM}),
          cell("Test Product",{bold:true, fill:CLR.HDR_GREY, w:idW[2], size:SZ.SM}),
        ]}),
        new TableRow({children:[
          cell("Batch Number", {bold:true, w:idW[0], size:SZ.SM}),
          cellL(String(dissolution.reference_batch || ""), {w:idW[1], size:SZ.SM}),
          cellL(String(dissolution.test_batch || ""),      {w:idW[2], size:SZ.SM}),
        ]}),
      ],
    }));
    ch.push(blk());
  }

  // Dissolution data tables per API / stage
  var tables = Array.isArray(dissolution.tables) ? dissolution.tables : [];
  for (var i = 0; i < tables.length; i++) {
    var t = tables[i] || {};
    if (t.caption) ch.push(lftPara(t.caption, true, SZ.SM));
    var W = [Math.round(CW*0.18),
             Math.round(CW*0.20), Math.round(CW*0.20),
             Math.round(CW*0.20), 0];
    W[4] = CW - W[0] - W[1] - W[2] - W[3];
    var rows = [new TableRow({children:[
      cell(t.x_axis_label || "Time (minutes)", {bold:true, fill:CLR.HDR_GREY, w:W[0], size:SZ.SM}),
      cell("Reference %DR",                     {bold:true, fill:CLR.HDR_GREY, w:W[1], size:SZ.SM}),
      cell("Reference %RSD",                    {bold:true, fill:CLR.HDR_GREY, w:W[2], size:SZ.SM}),
      cell("Test %DR",                          {bold:true, fill:CLR.HDR_GREY, w:W[3], size:SZ.SM}),
      cell("Test %RSD",                         {bold:true, fill:CLR.HDR_GREY, w:W[4], size:SZ.SM}),
    ]})];
    var dataPoints = Array.isArray(t.data_points) ? t.data_points : [];
    for (var j = 0; j < dataPoints.length; j++) {
      var d = dataPoints[j] || {};
      rows.push(new TableRow({children:[
        cell(String(d.time || ""),           {w:W[0], size:SZ.SM}),
        cell(String(d.ref_pct_dr || ""),     {w:W[1], size:SZ.SM}),
        cell(String(d.ref_pct_rsd || ""),    {w:W[2], size:SZ.SM}),
        cell(String(d.test_pct_dr || ""),    {w:W[3], size:SZ.SM}),
        cell(String(d.test_pct_rsd || ""),   {w:W[4], size:SZ.SM}),
      ]}));
    }
    if (t.f2_value != null && t.f2_value !== "") {
      rows.push(new TableRow({children:[
        cellL("F2 Similarity Factor", {bold:true, w:W[0]+W[1], cs:2, size:SZ.SM, fill:CLR.HDR_GREY}),
        cell(String(t.f2_value), {bold:true, cs:3, w:W[2]+W[3]+W[4], size:SZ.SM, fill:CLR.HDR_GREY}),
      ]}));
    }
    ch.push(new Table({
      width:{size:CW, type:WidthType.DXA}, columnWidths:W, rows:rows,
    }));
    ch.push(blk());

    // Chart image (auto-generated via matplotlib upstream)
    if (t.chart_b64 && t.chart_b64.length > 100) {
      try {
        var cbuf = Buffer.from(t.chart_b64, "base64");
        var ct = (t.chart_media_type || "").indexOf("jpeg") >= 0 ? "jpg" : "png";
        var ccap = t.chart_caption || t.caption || "";
        if (ccap) ch.push(lftPara(ccap, true, SZ.SM));
        ch.push(new Paragraph({
          alignment: AlignmentType.CENTER,
          spacing: {before:40, after:40},
          children: [new ImageRun({
            type: ct, data: cbuf,
            transformation: {width:480, height:280},
          })],
        }));
        ch.push(blk());
      } catch(e) { /* skip */ }
    }
  }
  return ch;
}

// ── SECTION 13 — STABILITY DATA ──────────────────────────────────────────────
// Renders one block per storage condition, listing all timepoints with test
// parameters and results. Data extracted from stability annexure files.
function buildStabilitySection(stabilityBlocks) {
  stabilityBlocks = Array.isArray(stabilityBlocks) ? stabilityBlocks : [];
  if (!stabilityBlocks.length) return [];
  var ch = [];
  ch.push(secHd("13. Stability Data"));

  for (var i = 0; i < stabilityBlocks.length; i++) {
    var block = stabilityBlocks[i] || {};
    var title = "Storage Condition: " + (block.storage_condition || "");
    ch.push(lftPara(title, true, SZ.TEXT));

    // Metadata table
    var metaRows = [];
    function addMeta(label, value) {
      if (value == null || value === "") return;
      metaRows.push([label, String(value)]);
    }
    addMeta("Batch Number",           block.batch_number);
    addMeta("Stability Batch Number", block.stability_batch_number);
    addMeta("Batch Size",             block.batch_size);
    addMeta("Manufacturing Date",     block.mfg_date);
    addMeta("Study Initiation Date",  block.study_initiation_date);
    addMeta("Protocol Number",        block.protocol_no);
    addMeta("Pack",                   block.pack);
    addMeta("Testing Frequency",      block.testing_frequency);
    if (metaRows.length) {
      var mW = [Math.round(CW*0.35), CW - Math.round(CW*0.35)];
      var mTbl = new Table({
        width:{size:CW, type:WidthType.DXA}, columnWidths:mW,
        rows: metaRows.map(function(mv) {
          return new TableRow({children:[
            cellL(mv[0], {bold:true, w:mW[0], size:SZ.SM, fill:CLR.HDR_GREY}),
            cellL(mv[1], {w:mW[1], size:SZ.SM}),
          ]});
        }),
      });
      ch.push(mTbl);
      ch.push(blk());
    }

    // Test results table (per timepoint)
    var results = Array.isArray(block.results) ? block.results : [];
    var timepoints = Array.isArray(block.timepoints) ? block.timepoints : ["Initial"];
    if (results.length && timepoints.length) {
      var testColW = Math.round(CW * 0.30);
      var specColW = Math.round(CW * 0.20);
      var remainingW = CW - testColW - specColW;
      var tpColW = timepoints.length > 0
        ? Math.floor(remainingW / timepoints.length)
        : remainingW;
      var widths = [testColW, specColW];
      for (var tpi = 0; tpi < timepoints.length; tpi++) widths.push(tpColW);
      widths[widths.length - 1] = CW - testColW - specColW - tpColW * (timepoints.length - 1);

      var hdrChildren = [
        cell("Characteristic", {bold:true, fill:CLR.HDR_GREY, w:widths[0], size:SZ.SM}),
        cell("Specification",  {bold:true, fill:CLR.HDR_GREY, w:widths[1], size:SZ.SM}),
      ];
      for (var tpj = 0; tpj < timepoints.length; tpj++) {
        hdrChildren.push(cell(String(timepoints[tpj]),
          {bold:true, fill:CLR.HDR_GREY, w:widths[2+tpj], size:SZ.SM}));
      }
      var rRows = [new TableRow({children:hdrChildren})];
      for (var ri = 0; ri < results.length; ri++) {
        var r = results[ri] || {};
        var rowCells = [
          cellL(String(r.characteristic || r.test || ""), {w:widths[0], size:SZ.SM}),
          cellL(String(r.specification || ""),            {w:widths[1], size:SZ.SM}),
        ];
        var vals = Array.isArray(r.values) ? r.values : [];
        for (var vi = 0; vi < timepoints.length; vi++) {
          rowCells.push(cell(String(vals[vi] != null ? vals[vi] : ""),
            {w:widths[2+vi], size:SZ.SM}));
        }
        rRows.push(new TableRow({children:rowCells}));
      }
      ch.push(new Table({
        width:{size:CW, type:WidthType.DXA}, columnWidths:widths, rows:rRows,
      }));
      ch.push(blk());
    }

    // AR numbers
    if (block.ar_numbers) {
      ch.push(bodyPara("AR Numbers: " + block.ar_numbers, {italics:true, size:SZ.XS}));
      ch.push(blk());
    }
  }
  return ch;
}

// ── SECTION 14 — RLD UTILIZATION BREAKUP ─────────────────────────────────────
function buildRLDUtilization(rld) {
  rld = rld || {};
  var ch = [];
  ch.push(secHd("14. RLD Utilization Breakup"));

  // Import declaration
  var declLines = [];
  if (rld.brand_name)     declLines.push("Brand Name: " + rld.brand_name);
  if (rld.manufacturer)   declLines.push("Manufacturer / Distributor: " + rld.manufacturer);
  if (rld.class_of_drug)  declLines.push("Class of Drug: " + rld.class_of_drug);
  if (rld.total_quantity) declLines.push("Quantity to be Imported: " + rld.total_quantity);
  if (rld.country)        declLines.push("Country: " + rld.country);
  if (rld.pack_and_count) declLines.push("Pack and Count: " + rld.pack_and_count);
  for (var i = 0; i < declLines.length; i++) ch.push(bodyPara(declLines[i]));
  ch.push(blk());

  // Utilization breakup table
  var breakup = Array.isArray(rld.breakup) ? rld.breakup : [];
  if (breakup.length) {
    ch.push(lftPara("Detailed Utilization Breakup of the Innovator Sample", true, SZ.SM));
    if (rld.product_name) ch.push(bodyPara("Product Name: " + rld.product_name));
    if (rld.total_quantity) ch.push(bodyPara("Total Quantity Required: " + rld.total_quantity));
    ch.push(blk());
    var W = [Math.round(CW*0.10), Math.round(CW*0.55), 0];
    W[2] = CW - W[0] - W[1];
    var rows = [new TableRow({children:[
      cell("S. No.",           {bold:true, fill:CLR.HDR_GREY, w:W[0], size:SZ.SM}),
      cell("Test Description", {bold:true, fill:CLR.HDR_GREY, w:W[1], size:SZ.SM}),
      cell("Quantity Required (Nos)", {bold:true, fill:CLR.HDR_GREY, w:W[2], size:SZ.SM}),
    ]})];
    for (var j = 0; j < breakup.length; j++) {
      var b = breakup[j] || {};
      rows.push(new TableRow({children:[
        cell(String(b.sno || (j+1)),         {w:W[0], size:SZ.SM}),
        cellL(String(b.description || ""),   {w:W[1], size:SZ.SM}),
        cell(String(b.quantity || ""),       {w:W[2], size:SZ.SM}),
      ]}));
    }
    // Total row
    var totalQty = 0;
    for (var k = 0; k < breakup.length; k++) {
      var q = parseInt(breakup[k].quantity, 10);
      if (!isNaN(q)) totalQty += q;
    }
    if (totalQty > 0) {
      rows.push(new TableRow({children:[
        cellL("Total Quantity", {cs:2, bold:true, fill:CLR.HDR_GREY, w:W[0]+W[1], size:SZ.SM}),
        cell(String(totalQty),  {bold:true, fill:CLR.HDR_GREY, w:W[2], size:SZ.SM}),
      ]}));
    }
    ch.push(new Table({
      width:{size:CW, type:WidthType.DXA}, columnWidths:W, rows:rows,
    }));
    ch.push(blk());
  }
  return ch;
}

