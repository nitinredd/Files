#!/usr/bin/env python3
"""
BE NOC Backend — Bio-Equivalence Study No-Objection-Certificate (import NOC)
Dr. Reddy's IPDO

Consumes the converted BE NOC annexure JSONs (from benoc_annexure_convertor.py)
plus the metadata form, routes each annexure by annexure_type to the correct
section, and assembles the renderer payload consumed by generate_benoc.js.

This module is 100% ASSEMBLY — there are NO calculations and NO exposure
formulae in a BE NOC. Every rendered value comes verbatim from an annexure or
the metadata form. The only synthesised artifacts are:
  * molecular structure images  (OPSIN → RDKit, with PubChem fallback), and
  * comparative-dissolution charts (matplotlib),
both of which are OPTIONAL — a failure omits the image and logs a warning; it
never fails the report.

Isolation: fully separate from EI / RS / DEG-EG. It REUSES (does not rebuild)
the proven identity resolver from residual_solvent.py for API↔specification and
STP↔API matching, and the NDPS registry for controlled-substance detection.
"""
from __future__ import annotations

import io
import re
import json
import base64
import logging
import unicodedata
from typing import Any, Dict, List, Optional, Tuple

# Reuse the PROVEN identity resolver (descriptor stripping, identity pooling,
# distinctive-token scoring, negative-pair protection). Imported, never rebuilt.
import residual_solvent as RS
import benoc_ndps_controlled_substances as NDPS
import benoc_chemistry_lookup as CHEM

logger = logging.getLogger(__name__)


# ══════════════════════════════════════════════════════════════════════════════
# SMALL HELPERS
# ══════════════════════════════════════════════════════════════════════════════
def _s(v: Any, default: str = "") -> str:
    if v is None:
        return default
    return unicodedata.normalize("NFKC", str(v)).strip()


_PLACEHOLDER = {"", "n/a", "na", "none", "not mentioned", "not applicable",
                "not specified", "null", "-", "--"}


def _empty(v: Any) -> bool:
    if v is None:
        return True
    if isinstance(v, str):
        return _s(v).lower() in _PLACEHOLDER
    if isinstance(v, (list, dict)):
        return len(v) == 0
    return False


def _as_list(v: Any) -> List[Any]:
    if isinstance(v, list):
        return v
    if _empty(v):
        return []
    return [v]


def _first(*vals: Any) -> str:
    for v in vals:
        if not _empty(v):
            return _s(v)
    return ""


# ══════════════════════════════════════════════════════════════════════════════
# ANNEXURE NORMALISER (pre-converted JSON upload path)
# ══════════════════════════════════════════════════════════════════════════════
def process_benoc_annexure(obj: Any, index: int) -> Dict:
    """Normalise a pre-converted (JSON-uploaded) annexure into the consistent
    shape the backend expects. Mirrors the converter output. Never raises."""
    if not isinstance(obj, dict):
        return {"annexure_number": index, "annexure_type": "generic",
                "_error": True, "material_name": "",
                "extraction_notes": "annexure was not a JSON object"}
    out = dict(obj)
    at = _s(out.get("annexure_type")).lower().replace(" ", "_")
    from benoc_annexure_convertor import ANNEXURE_TYPES  # single source of truth
    if at not in ANNEXURE_TYPES:
        at = "generic"
    out["annexure_type"] = at
    out["annexure_number"] = index
    out.setdefault("material_name", "")
    out.setdefault("_error", False)
    return out


# ══════════════════════════════════════════════════════════════════════════════
# IDENTITY MATCHING (reuses the RS resolver — no rebuild)
# ══════════════════════════════════════════════════════════════════════════════
def _best_identity_match(query: str, candidates: List[str]) -> Tuple[int, float]:
    """Return (index_of_best_candidate, score) using the RS identity scorer.
    (-1, 0.0) when nothing scores. Product-agnostic; negative-pair protected."""
    if not query or not candidates:
        return -1, 0.0
    q_id = RS._rs_identity(query)
    best_i, best_score = -1, 0.0
    for i, c in enumerate(candidates):
        if _empty(c):
            continue
        c_id = RS._rs_identity(c)
        score, _reason = RS._rs_score(q_id, c_id)
        if score > best_score:
            best_i, best_score = i, score
    return best_i, best_score


# ══════════════════════════════════════════════════════════════════════════════
# CONTROLLED SUBSTANCE DETECTION (NDPS)
# ══════════════════════════════════════════════════════════════════════════════
def detect_controlled_substances(apis: List[Dict], meta: Dict,
                                 narcotic_annexure: Optional[Dict] = None) -> Dict:
    """Screen every API against the NDPS registry. Returns the narcotic_declaration
    payload block. If any API triggers, applicable=True and declaration_text is
    populated (verbatim from a narcotic annexure when present, else synthesised)."""
    api_names = [_s(a.get("name")) for a in (apis or []) if _s(a.get("name"))]
    screen = NDPS.screen_apis(api_names)

    # Verbatim declaration from an uploaded narcotic annexure takes precedence.
    verbatim = _s(narcotic_annexure.get("declaration_text")) if narcotic_annexure else ""
    ndps_ref = (_s(narcotic_annexure.get("ndps_reference")) if narcotic_annexure
                else "") or "NDPS Act, 1985"

    product = _first(meta.get("product_name"))
    block: Dict[str, Any] = {
        "applicable": bool(screen["applicable"]) or bool(verbatim),
        "product_name": product,
        "ndps_reference": ndps_ref,
        "controlled_substances": screen["controlled"],
        "triggering_names": screen["triggering_names"],
        "company_name": _first(meta.get("company_name"), "Dr. Reddy's Laboratories Ltd."),
        "declared_by": _first(narcotic_annexure.get("declared_by") if narcotic_annexure else "",
                              meta.get("declared_by")),
        "title": _first(narcotic_annexure.get("title") if narcotic_annexure else "",
                        meta.get("declarant_title")),
        "company_address": _first(
            narcotic_annexure.get("company_address") if narcotic_annexure else "",
            meta.get("company_address")),
    }
    if not block["applicable"]:
        block["declaration_text"] = ""
        return block

    if verbatim:
        block["declaration_text"] = verbatim
    else:
        names = ", ".join(screen["triggering_names"]) or product or "the product"
        block["declaration_text"] = (
            f"We hereby declare that {names} used in the composition of "
            f"{product or 'the product'} falls under the Narcotic Drugs and "
            f"Psychotropic Substances list as notified under the {ndps_ref}. The "
            "necessary regulatory requirements applicable to controlled substances "
            "/ precursor chemicals shall be complied with for the import of the "
            "innovator sample for the bio-equivalence study.")
    return block


# ══════════════════════════════════════════════════════════════════════════════
# MOLECULAR STRUCTURE GENERATION  (OPSIN → RDKit, PubChem fallback; never fatal)
# ══════════════════════════════════════════════════════════════════════════════
def _preprocess_iupac(name: str) -> str:
    """Greek→latin, collapse whitespace, normalise brackets, strip trailing
    punctuation. Product-agnostic."""
    if not name:
        return ""
    s = unicodedata.normalize("NFKC", str(name))
    greek = {"α": "alpha", "β": "beta", "γ": "gamma", "δ": "delta", "ε": "epsilon",
             "ω": "omega", "λ": "lambda", "μ": "mu", "π": "pi", "σ": "sigma",
             "τ": "tau", "ξ": "xi", "Δ": "delta"}
    for g, l in greek.items():
        s = s.replace(g, l)
    s = s.replace("[", "(").replace("]", ")") if s.count("[") != s.count("]") else s
    s = re.sub(r"\s+", " ", s).strip()
    s = s.strip(" .,;:")
    return s


def _iupac_to_smiles(iupac: str) -> str:
    """OPSIN name→SMILES via py2opsin if available. Returns '' on any failure."""
    name = _preprocess_iupac(iupac)
    if not name:
        return ""
    try:
        from py2opsin import py2opsin           # optional dependency (bundles OPSIN)
        smiles = py2opsin(name, output_format="SMILES")
        if isinstance(smiles, str) and smiles.strip():
            return smiles.strip().split()[0]
    except Exception as e:
        logger.info(f"OPSIN unavailable/failed for '{name[:40]}': {e}")
    return ""


def _smiles_to_png_b64(smiles: str) -> str:
    """RDKit SMILES→PNG base64. Returns '' on any failure."""
    if not smiles:
        return ""
    try:
        from rdkit import Chem                  # optional dependency
        from rdkit.Chem.Draw import rdMolDraw2D
        mol = Chem.MolFromSmiles(smiles)
        if mol is None:
            return ""
        d = rdMolDraw2D.MolDraw2DCairo(560, 400)
        d.DrawMolecule(mol)
        d.FinishDrawing()
        return base64.standard_b64encode(d.GetDrawingText()).decode()
    except Exception as e:
        logger.info(f"RDKit render failed: {e}")
        return ""


def _pubchem_png_b64(name: str, cas: str = "") -> str:
    """Fallback: fetch a structure PNG from PubChem PUG-REST by name or CAS.
    Uses stdlib urllib with a short timeout; returns '' if offline/unavailable."""
    import urllib.request
    import urllib.parse
    for ident in [c for c in (cas, name) if _s(c)]:
        try:
            q = urllib.parse.quote(_s(ident))
            url = (f"https://pubchem.ncbi.nlm.nih.gov/rest/pug/compound/name/"
                   f"{q}/PNG?image_size=560x400")
            with urllib.request.urlopen(url, timeout=8) as resp:
                if resp.status == 200:
                    data = resp.read()
                    if data and len(data) > 200:
                        return base64.standard_b64encode(data).decode()
        except Exception as e:
            logger.info(f"PubChem fallback failed for '{ident[:40]}': {e}")
    return ""


def generate_structure(api: Dict) -> Tuple[str, str]:
    """Structure image for one API. Fallback chain: OPSIN→RDKit, then PubChem.
    Returns (base64_png, media_type) or ('','') — NEVER raises."""
    # If the annexure already supplied a structure, keep it.
    if not _empty(api.get("structure_b64")):
        return _s(api.get("structure_b64")), _first(api.get("structure_media_type"),
                                                    "image/png")
    iupac = _s(api.get("iupac_name"))
    name = _s(api.get("name"))
    cas = _s(api.get("cas_number"))
    try:
        smiles = _iupac_to_smiles(iupac) or _iupac_to_smiles(name)
        b64 = _smiles_to_png_b64(smiles) if smiles else ""
        if not b64:
            b64 = _pubchem_png_b64(name, cas)
        if b64:
            return b64, "image/png"
    except Exception as e:
        logger.warning(f"Structure generation error for '{name}': {e}")
    logger.warning(f"No molecular structure generated for API '{name}' "
                   "— structure block omitted.")
    return "", ""


# ══════════════════════════════════════════════════════════════════════════════
# DISSOLUTION CHART GENERATION  (matplotlib; never fatal)
# ══════════════════════════════════════════════════════════════════════════════
def _num(v: Any) -> Optional[float]:
    try:
        s = re.sub(r"[^0-9.\-]", "", _s(v))
        return float(s) if s not in ("", "-", ".") else None
    except Exception:
        return None


def generate_dissolution_chart(table: Dict) -> Tuple[str, str]:
    """Render a Reference-vs-Test %DR line chart (error bars from %RSD) for one
    dissolution table. Returns (base64_png, media_type) or ('','') — never raises."""
    points = _as_list(table.get("data_points"))
    xs, ref, refe, tst, tste = [], [], [], [], []
    for p in points:
        if not isinstance(p, dict):
            continue
        t = _num(p.get("time"))
        rd = _num(p.get("ref_pct_dr"))
        td = _num(p.get("test_pct_dr"))
        if t is None or (rd is None and td is None):
            continue
        xs.append(t)
        ref.append(rd if rd is not None else float("nan"))
        tst.append(td if td is not None else float("nan"))
        rr = _num(p.get("ref_pct_rsd"));  refe.append(rr if rr is not None else 0.0)
        tr = _num(p.get("test_pct_rsd")); tste.append(tr if tr is not None else 0.0)
    if len(xs) < 2:
        return "", ""
    try:
        import matplotlib
        matplotlib.use("Agg")
        import matplotlib.pyplot as plt
        order = sorted(range(len(xs)), key=lambda i: xs[i])
        xs = [xs[i] for i in order]
        ref = [ref[i] for i in order]; refe = [refe[i] for i in order]
        tst = [tst[i] for i in order]; tste = [tste[i] for i in order]
        fig, ax = plt.subplots(figsize=(6.6, 3.9), dpi=130)
        ax.errorbar(xs, ref, yerr=refe, marker="o", capsize=3, linewidth=1.8,
                    label="Reference", color="#1f4e79")
        ax.errorbar(xs, tst, yerr=tste, marker="s", capsize=3, linewidth=1.8,
                    label="Test", color="#c00000")
        ax.set_xlabel(_first(table.get("x_axis_label"), "Time (minutes)"))
        ax.set_ylabel("% Drug Released")
        cap = _s(table.get("caption")) or _s(table.get("chart_caption"))
        if cap:
            ax.set_title(cap, fontsize=9)
        ax.set_ylim(0, 110)
        ax.grid(True, linestyle=":", alpha=0.5)
        ax.legend(loc="lower right", fontsize=9)
        fig.tight_layout()
        buf = io.BytesIO()
        fig.savefig(buf, format="png")
        plt.close(fig)
        return base64.standard_b64encode(buf.getvalue()).decode(), "image/png"
    except Exception as e:
        logger.warning(f"Dissolution chart generation failed: {e}")
        return "", ""


# ══════════════════════════════════════════════════════════════════════════════
# ANNEXURE COLLECTION + SECTION ROUTING
# ══════════════════════════════════════════════════════════════════════════════
def collect_by_type(annexures: List[Dict]) -> Dict[str, Any]:
    """Group converted annexures by annexure_type (errors excluded from bodies)."""
    grouped: Dict[str, Any] = {
        "main": None, "stability": [], "manufacturing_license": [],
        "test_license": None, "location_declaration": None,
        "rld_utilization": None, "narcotic_declaration": None,
        "stp_document": [], "generic": [], "errors": [],
    }
    for ann in annexures or []:
        if not isinstance(ann, dict):
            continue
        if ann.get("_error"):
            grouped["errors"].append(ann)
            continue
        at = _s(ann.get("annexure_type")).lower() or "generic"
        if at == "main_application_document":
            # If multiple, keep the richest (most APIs + composition rows).
            if grouped["main"] is None or _richness(ann) > _richness(grouped["main"]):
                if grouped["main"] is not None:
                    grouped["generic"].append(grouped["main"])
                grouped["main"] = ann
            else:
                grouped["generic"].append(ann)
        elif at == "stability_file":
            grouped["stability"].append(ann)
        elif at == "manufacturing_license":
            grouped["manufacturing_license"].append(ann)
        elif at == "test_license":
            grouped["test_license"] = grouped["test_license"] or ann
        elif at == "manufacturing_location_declaration":
            grouped["location_declaration"] = grouped["location_declaration"] or ann
        elif at == "rld_utilization":
            grouped["rld_utilization"] = grouped["rld_utilization"] or ann
        elif at == "narcotic_declaration":
            grouped["narcotic_declaration"] = grouped["narcotic_declaration"] or ann
        elif at == "stp_document":
            grouped["stp_document"].append(ann)
        else:
            grouped["generic"].append(ann)
    return grouped


def _richness(ann: Dict) -> int:
    return (len(_as_list(ann.get("apis"))) * 5
            + sum(len(_as_list(s.get("rows"))) for s in _as_list(ann.get("composition"))
                  if isinstance(s, dict))
            + len(_as_list(ann.get("equipment"))))


# ══════════════════════════════════════════════════════════════════════════════
# API IDENTITY DERIVATION  (the main application document is the OUTPUT, not an
# upload — so when it is absent the API identities are derived from the product
# name and the drug-substance STPs, and their chemistry is backfilled from the
# curated reference. Never overrides an extracted or form-supplied value.)
# ══════════════════════════════════════════════════════════════════════════════
_DOSAGE_QUALIFIERS = re.compile(
    r"\b(extended[\s\-]*release|modified[\s\-]*release|delayed[\s\-]*release|"
    r"sustained[\s\-]*release|prolonged[\s\-]*release|immediate[\s\-]*release|"
    r"er|xr|sr|ir|mr|dr|xl|cr|"
    r"film[\s\-]*coated|sugar[\s\-]*coated|enteric[\s\-]*coated|coated|"
    r"dispersible|orally[\s\-]*disintegrating|chewable|effervescent|"
    r"tablets?|capsules?|caplets?|softgels?|pills?|"
    r"oral|solution|suspension|syrup|elixir|injection|for\s+injection|"
    r"powder|granules?|sachets?|drops?|cream|ointment|gel|patch(?:es)?)\b",
    re.IGNORECASE)


def _parse_api_names_from_product(product_name: str) -> List[str]:
    """Split a product name like 'Loratadine and Pseudoephedrine Sulfate ER
    Tablets' into candidate API names ['Loratadine', 'Pseudoephedrine Sulfate'].
    Product-agnostic; strips trailing dosage-form / release qualifiers."""
    s = _s(product_name)
    if not s:
        return []
    s = _DOSAGE_QUALIFIERS.sub(" ", s)
    parts = re.split(r"\s+and\s+|\s*[/+&,]\s*", s, flags=re.IGNORECASE)
    seen, out = set(), []
    for p in parts:
        p = re.sub(r"\s+", " ", p).strip(" -–—:;.")
        if not p or re.fullmatch(r"[\d.\s]+", p):
            continue
        k = p.lower()
        if k not in seen:
            seen.add(k)
            out.append(p)
    return out


def _derive_api_names(main: Dict, meta: Dict, grouped: Dict) -> List[str]:
    """Derive API display names when no main document supplied them: product name
    first, then any drug-substance STP's applicable product. De-duplicated by
    canonical chemistry identity so 'Pseudoephedrine' and 'Pseudoephedrine
    Sulfate' collapse to one API."""
    names: List[str] = _parse_api_names_from_product(
        _first(meta.get("product_name"), main.get("product_name")))
    for stp in _as_list(grouped.get("stp_document")):
        if not isinstance(stp, dict):
            continue
        cls = _s(stp.get("document_class")).lower()
        prod = _s(stp.get("applicable_product"))
        if not prod:
            continue
        is_fp = "finish" in cls or "product" in cls or "tablet" in prod.lower()
        if not is_fp:
            names.append(prod)
    # De-dup by canonical chemistry identity; when a reference hit exists, use its
    # canonical BASE name for display so the name stays consistent with the base
    # chemistry that is backfilled (e.g. 'Pseudoephedrine Sulfate' → 'Pseudoephedrine').
    seen, uniq = set(), []
    for n in names:
        hit = CHEM.lookup(n)
        canon = hit.get("canonical_name") if hit else ""
        key = (canon or n).lower()
        if key and key not in seen:
            seen.add(key)
            uniq.append(canon or n)
    return uniq


def _apply_api_overrides(apis: List[Dict], meta: Dict) -> None:
    """Merge the scientist's optional per-API metadata overrides. A non-empty
    override field WINS (fills a gap or corrects a value); empty fields are
    ignored. An override whose name matches no existing API introduces a new API."""
    overrides = _as_list(meta.get("api_overrides"))
    if not overrides:
        return
    names = [_s(a.get("name")) for a in apis]
    for ov in overrides:
        if not isinstance(ov, dict):
            continue
        oname = _s(ov.get("name"))
        if not oname:
            continue
        idx, score = _best_identity_match(oname, names) if names else (-1, 0.0)
        if idx < 0 or score < 0.60:
            apis.append({"name": oname})
            names.append(oname)
            idx = len(apis) - 1
        tgt = apis[idx]
        for fld in ("iupac_name", "molecular_formula", "molecular_weight",
                    "cas_number", "therapeutic_category", "manufacturer",
                    "manufacturer_address"):
            v = _s(ov.get(fld))
            if v:
                tgt[fld] = v
        inds = ov.get("indications")
        if isinstance(inds, str) and _s(inds):
            inds = [x.strip() for x in re.split(r"[\n;]+", inds) if x.strip()]
        if isinstance(inds, list) and inds:
            tgt["indications"] = inds


def _backfill_chemistry(api: Dict) -> None:
    """Fill EMPTY identity-chemistry fields (IUPAC/formula/MW/CAS/category) from
    the curated reference. Never overrides an extracted or form-supplied value.
    Indications and manufacturer are deliberately NOT filled here."""
    chem = CHEM.lookup(_s(api.get("name")))
    if not chem:
        return
    for fld in CHEM.CHEMISTRY_FIELDS:
        if _empty(api.get(fld)) and _s(chem.get(fld)):
            api[fld] = chem[fld]
            api["_chemistry_source"] = "reference_lookup"


def build_specs_from_stp(stp: Dict) -> List[Dict]:
    """Section 8/11 spec rows from an STP SUMMARY (test names only; the STP holds
    no per-test acceptance criteria — the method PDF is referenced as an annexure).
    Each row cross-references the STP number (factual, not a review placeholder)."""
    tests = [_s(t) for t in _as_list(stp.get("tests_covered")) if _s(t)]
    if not tests:
        return []
    num = _s(stp.get("stp_number"))
    ref = f"As per STP No. {num}" if num else "As per approved STP"
    return [{"sno": i + 1, "test": t, "specification": ref}
            for i, t in enumerate(tests)]


def _canon_drug_key(name: str) -> str:
    """Salt/hydrate-stripped canonical key for same-drug comparison. Prefers the
    curated chemistry canonical name, else the NDPS salt-stripping normalizer.
    Makes 'Pseudoephedrine Sulphate' and 'Pseudoephedrine Sulfate' compare equal."""
    n = _s(name)
    if not n:
        return ""
    hit = CHEM.lookup(n)
    if hit and hit.get("canonical_name"):
        return hit["canonical_name"].lower()
    try:
        k = NDPS._normalize(n)
        if k:
            return k
    except Exception:
        pass
    return n.lower()


def _match_api_index(query: str, api_names: List[str]) -> Tuple[int, float]:
    """Match an STP's applicable product to an API. Canonical drug-identity match
    first (salt-insensitive), then the RS distinctive-token scorer as a fallback."""
    if not query or not api_names:
        return -1, 0.0
    qk = _canon_drug_key(query)
    if qk:
        for i, nm in enumerate(api_names):
            if _canon_drug_key(nm) == qk:
                return i, 1.0
    return _best_identity_match(query, api_names)


def _attach_stp_ds_specs(apis: List[Dict], grouped: Dict) -> None:
    """Populate Section 8 drug-substance specs from drug-substance STP summaries,
    matched to an API by applicable product. Only fills an API that has NO
    specifications yet (never overrides a main-document extraction)."""
    stps = [s for s in _as_list(grouped.get("stp_document")) if isinstance(s, dict)]
    if not stps or not apis:
        return
    api_names = [_s(a.get("name")) for a in apis]
    for stp in stps:
        cls = _s(stp.get("document_class")).lower()
        prod = _s(stp.get("applicable_product"))
        is_fp = "finish" in cls or "product" in cls or "tablet" in prod.lower()
        if is_fp:
            continue
        specs = build_specs_from_stp(stp)
        if not specs:
            continue
        idx, score = _match_api_index(prod, api_names) if prod else (-1, 0.0)
        if idx < 0 and len(apis) == 1:
            idx, score = 0, 1.0
        if idx < 0 or score < 0.60:
            continue
        if not _as_list(apis[idx].get("specifications")):
            apis[idx]["specifications"] = specs
            apis[idx]["_spec_source"] = "stp_summary"


# ══════════════════════════════════════════════════════════════════════════════
# APIS  (derive identities → merge specs → backfill chemistry → structures)
# ══════════════════════════════════════════════════════════════════════════════
def build_apis(main: Dict, meta: Dict, grouped: Dict,
               generate_images: bool = True) -> List[Dict]:
    meta = meta or {}
    grouped = grouped or {}
    apis = [dict(a) for a in _as_list(main.get("apis")) if isinstance(a, dict)]

    # No APIs from a main document (the usual BE NOC case — the main application
    # document IS the target output, not an upload). Derive the identities so
    # Section 1 can be partially populated from the chemistry reference.
    if not apis:
        apis = [{"name": n} for n in _derive_api_names(main, meta, grouped)]

    specs_blocks = _as_list(main.get("drug_substance_specs"))

    # Attach each drug-substance spec block to the matching API (RS resolver).
    api_names = [_s(a.get("name")) for a in apis]
    for blk in specs_blocks:
        if not isinstance(blk, dict):
            continue
        specs = _as_list(blk.get("specifications"))
        if not specs:
            continue
        bname = _s(blk.get("api_name"))
        idx, score = _best_identity_match(bname, api_names) if bname else (-1, 0.0)
        if idx < 0 and len(apis) == 1:
            idx, score = 0, 1.0            # single API — unambiguous
        if idx >= 0 and score >= 0.60:
            apis[idx].setdefault("specifications", [])
            apis[idx]["specifications"].extend(specs)
        elif apis:
            apis[0].setdefault("specifications", [])
            apis[0]["specifications"].extend(specs)

    # Scientist gap-fill overrides, then chemistry backfill (empty fields only).
    _apply_api_overrides(apis, meta)
    for a in apis:
        _backfill_chemistry(a)

    # Section 8 fallback: drug-substance specs from STP summaries.
    _attach_stp_ds_specs(apis, grouped)

    for a in apis:
        a.setdefault("specifications", [])
        a.setdefault("indications", _as_list(a.get("indications")))
        if generate_images:
            b64, mt = generate_structure(a)
            if b64:
                a["structure_b64"] = b64
                a["structure_media_type"] = mt
    return apis


# ══════════════════════════════════════════════════════════════════════════════
# STABILITY  (one block per uploaded stability annexure)
# ══════════════════════════════════════════════════════════════════════════════
def build_stability(stability_annexures: List[Dict]) -> List[Dict]:
    blocks: List[Dict] = []
    for ann in stability_annexures or []:
        if not isinstance(ann, dict):
            continue
        tps = _as_list(ann.get("timepoints")) or ["Initial"]
        blocks.append({
            "storage_condition": _s(ann.get("storage_condition")),
            "batch_number": _s(ann.get("batch_number")),
            "stability_batch_number": _s(ann.get("stability_batch_number")),
            "batch_size": _s(ann.get("batch_size")),
            "mfg_date": _s(ann.get("mfg_date")),
            "study_initiation_date": _s(ann.get("study_initiation_date")),
            "protocol_no": _s(ann.get("protocol_no")),
            "pack": _s(ann.get("pack")),
            "testing_frequency": _s(ann.get("testing_frequency")),
            "ar_numbers": _s(ann.get("ar_numbers")),
            "timepoints": [_s(t) for t in tps],
            "results": [r for r in _as_list(ann.get("results")) if isinstance(r, dict)],
        })
    # Stable ordering: by storage condition then by first timepoint.
    blocks.sort(key=lambda b: (b["storage_condition"], ",".join(b["timepoints"])))
    return blocks


# ══════════════════════════════════════════════════════════════════════════════
# DISSOLUTION  (attach generated charts)
# ══════════════════════════════════════════════════════════════════════════════
def build_dissolution(main: Dict, generate_charts: bool = True) -> Dict:
    diss = main.get("dissolution")
    if not isinstance(diss, dict):
        return {}
    out = {
        "media_description": _s(diss.get("media_description")),
        "reference_batch": _s(diss.get("reference_batch")),
        "test_batch": _s(diss.get("test_batch")),
        "tables": [],
    }
    for t in _as_list(diss.get("tables")):
        if not isinstance(t, dict):
            continue
        tbl = dict(t)
        if generate_charts:
            b64, mt = generate_dissolution_chart(tbl)
            if b64:
                tbl["chart_b64"] = b64
                tbl["chart_media_type"] = mt
        out["tables"].append(tbl)
    return out


# ══════════════════════════════════════════════════════════════════════════════
# MANUFACTURING ADDRESS  (main doc → location declaration fallback)
# ══════════════════════════════════════════════════════════════════════════════
def build_manufacturing_address(main: Dict, location_decl: Optional[Dict]) -> Dict:
    addr = main.get("manufacturing_address") if isinstance(main.get("manufacturing_address"), dict) else {}
    test_addr = _s(addr.get("test_batch_address"))
    be_addr = _s(addr.get("be_batch_address"))
    if location_decl:
        test_addr = test_addr or _s(location_decl.get("test_batch_address"))
        be_addr = be_addr or _s(location_decl.get("be_batch_address"))
    # If only one is present, the BE batch is manufactured at the same site.
    if test_addr and not be_addr:
        be_addr = test_addr
    if be_addr and not test_addr:
        test_addr = be_addr
    return {"test_batch_address": test_addr, "be_batch_address": be_addr}


# ══════════════════════════════════════════════════════════════════════════════
# FINISHED PRODUCT SPEC (Section 11) — main doc → finished-product STP summary
# ══════════════════════════════════════════════════════════════════════════════
def build_finished_product_spec(main: Dict, grouped: Dict) -> List[Dict]:
    fp = [s for s in _as_list(main.get("finished_product_spec")) if isinstance(s, dict)]
    if fp:
        return fp
    for stp in _as_list(grouped.get("stp_document")):
        if not isinstance(stp, dict):
            continue
        cls = _s(stp.get("document_class")).lower()
        prod = _s(stp.get("applicable_product"))
        if "finish" in cls or "product" in cls or "tablet" in prod.lower():
            specs = build_specs_from_stp(stp)
            if specs:
                return specs
    return []


# ══════════════════════════════════════════════════════════════════════════════
# INNOVATOR (Section 10) — main doc innovator block, with RLD-utilization fallback
# ══════════════════════════════════════════════════════════════════════════════
def build_innovator(main: Dict, grouped: Dict, meta: Dict) -> Dict:
    inv = dict(main.get("innovator")) if isinstance(main.get("innovator"), dict) else {}
    rld = grouped.get("rld_utilization") or {}
    if _empty(inv.get("generic_name")):
        inv["generic_name"] = _first(rld.get("product_name"),
                                      main.get("product_name"), meta.get("product_name"))
    if _empty(inv.get("brand_name")):
        inv["brand_name"] = _s(rld.get("brand_name"))
    if _empty(inv.get("manufacturer")):
        inv["manufacturer"] = _s(rld.get("manufacturer"))
    if _empty(inv.get("strength")):
        inv["strength"] = _first(meta.get("strength"))
    return inv


# ══════════════════════════════════════════════════════════════════════════════
# ANNEXURE LIST  (sequential numbering in final section order — RF)
# ══════════════════════════════════════════════════════════════════════════════
def build_annexure_list(grouped: Dict, apis: List[Dict],
                        narcotic_applicable: bool) -> List[Dict]:
    """Sequential Annexure 1..N in the mandated order, preserving source filenames
    for traceability:
      1. Test License (Form 29)
      2. Drug Substance STP(s) + Finished Product STP
      3. Manufacturing Licenses (Form 25 + Form 28)
      4. RLD Utilization Breakup + Narcotic Declaration (if applicable)
      5. Stability Data (per condition/timepoint)
    """
    items: List[Tuple[str, str]] = []      # (title, source_filename)

    # 1. Test License
    tl = grouped.get("test_license")
    if tl:
        items.append(("Test License (Form 29)", _s(tl.get("filename"))))

    # 2. STPs — drug substance first (ordered by API), then finished product.
    stps = list(grouped.get("stp_document") or [])
    api_names = [_s(a.get("name")) for a in apis]
    ds_stps, fp_stps, other_stps = [], [], []
    for stp in stps:
        cls = _s(stp.get("document_class")).lower()
        prod = _s(stp.get("applicable_product"))
        if "finish" in cls or "product" in cls or "tablet" in prod.lower():
            fp_stps.append(stp)
        elif "substance" in cls or "drug substance" in cls:
            ds_stps.append(stp)
        else:
            # Classify by whether the applicable product matches an API name.
            idx, score = _best_identity_match(prod, api_names) if prod else (-1, 0.0)
            (ds_stps if score >= 0.6 else other_stps).append(stp)

    def _stp_title(stp: Dict, kind: str) -> str:
        num = _s(stp.get("stp_number"))
        prod = _s(stp.get("applicable_product")) or _s(stp.get("material_name"))
        bits = [f"{kind} Standard Test Procedure"]
        if prod:
            bits.append(f"for {prod}")
        if num:
            bits.append(f"(STP No. {num})")
        return " ".join(bits)

    for stp in ds_stps:
        items.append((_stp_title(stp, "Drug Substance"), _s(stp.get("filename"))))
    for stp in other_stps:
        items.append((_stp_title(stp, "Drug Substance"), _s(stp.get("filename"))))
    for stp in fp_stps:
        items.append((_stp_title(stp, "Finished Product"), _s(stp.get("filename"))))

    # 3. Manufacturing licenses (Form 25 before Form 28 before GMP).
    def _lic_rank(lic: Dict) -> int:
        f = _s(lic.get("license_form"))
        return {"25": 0, "28": 1, "GMP": 2}.get(f, 3)
    for lic in sorted(grouped.get("manufacturing_license") or [], key=_lic_rank):
        form = _s(lic.get("license_form"))
        num = _s(lic.get("license_number"))
        label = (f"Manufacturing License (Form {form})" if form and form != "GMP"
                 else ("GMP Certificate" if form == "GMP" else "Manufacturing License"))
        if num:
            label += f" No. {num}"
        items.append((label, _s(lic.get("filename"))))

    # 4. RLD utilization + narcotic declaration.
    rld = grouped.get("rld_utilization")
    if rld:
        items.append(("RLD Utilization Breakup", _s(rld.get("filename"))))
    if narcotic_applicable:
        nd = grouped.get("narcotic_declaration")
        items.append(("Narcotic Declaration (NDPS Act, 1985)",
                      _s(nd.get("filename")) if nd else ""))

    # 5. Stability data (per condition/timepoint).
    for st in build_stability_sources(grouped.get("stability") or []):
        items.append((st[0], st[1]))

    # Emit with sequential numbering.
    out: List[Dict] = []
    for i, (title, src) in enumerate(items, start=1):
        entry = {"annexure_no": f"Annexure {i}", "title": title}
        if src:
            entry["source_filename"] = src
        out.append(entry)
    return out


def build_stability_sources(stability_annexures: List[Dict]) -> List[Tuple[str, str]]:
    rows: List[Tuple[str, str]] = []
    for ann in stability_annexures or []:
        cond = _s(ann.get("storage_condition")) or "stability condition"
        tps = ", ".join(_s(t) for t in _as_list(ann.get("timepoints"))) or "all timepoints"
        rows.append((f"Stability Data — {cond} ({tps})", _s(ann.get("filename"))))
    rows.sort(key=lambda r: r[0])
    return rows


# ══════════════════════════════════════════════════════════════════════════════
# VALIDATION  (warning-first — the BE NOC main application document is the TARGET
# OUTPUT, not an input; the report is assembled from WHATEVER supporting files the
# scientist uploads, and unpopulated sections are left empty. Generation is
# hard-blocked ONLY on a true structural failure:
#   1. no files were uploaded at all, or
#   2. every uploaded annexure failed extraction completely.
# Every missing-content condition is a UI-only WARNING, never a blocker and never
# rendered into the DOCX body.)
# ══════════════════════════════════════════════════════════════════════════════
def validate_benoc(grouped: Dict, payload: Dict,
                   annexures: Optional[List[Dict]] = None) -> Dict:
    errors: List[str] = []
    warnings: List[str] = []

    payload = payload or {}
    apis = _as_list(payload.get("apis"))
    composition = _as_list(payload.get("composition"))
    anns = [a for a in (annexures or []) if isinstance(a, dict)]

    # ── STRUCTURAL HARD BLOCKS (only these two) ───────────────────────────────
    if not anns:
        errors.append("No supporting files were uploaded. Upload at least one "
                      "supporting document (STP, stability, licence, RLD "
                      "utilization, location declaration, or narcotic declaration).")
    elif all(a.get("_error") for a in anns):
        errors.append("Every uploaded file failed extraction. Re-upload readable "
                      "PDFs/DOCX for at least one supporting document.")

    # ── CONTENT-AVAILABILITY WARNINGS (never block; never rendered) ───────────
    # Warnings reflect the FINAL assembled payload, so a gap the scientist filled
    # via the optional metadata form clears its warning.
    main = grouped.get("main") or {}

    # Section 1 — Drug Information.
    if apis:
        gap = [a for a in apis if _empty(a.get("indications"))
               or (_empty(a.get("manufacturer")) and _empty(a.get("manufacturer_address")))]
        if gap:
            warnings.append("Section 1 Drug Information partially populated: chemistry "
                            "lookup used; indications and manufacturer address not "
                            "extracted.")
    else:
        warnings.append("Section 1 Drug Information not populated: no API identity "
                        "could be derived from the product name or STPs.")

    # Section 3 — Regulatory status (payload defaults to 'Not applicable', so check
    # whether a main document actually supplied it).
    if _empty(main.get("regulatory_status")):
        warnings.append("Section 3 Regulatory Status not populated: main application "
                        "document not uploaded.")

    # Section 4 — Composition / raw materials.
    comp_rows = sum(len(_as_list(s.get("rows"))) for s in composition
                    if isinstance(s, dict))
    if comp_rows == 0:
        warnings.append("Section 4 Composition table not populated: BMR/MFR not "
                        "uploaded.")
    if _empty(payload.get("raw_materials")):
        warnings.append("Section 4 Raw materials list not populated: BMR/MFR not "
                        "uploaded.")

    # Sections 5/6/7 — equipment, process narrative, process flow.
    if _empty(payload.get("equipment")):
        warnings.append("Section 5 Equipment list not populated: BMR/MFR not uploaded.")
    if _empty(payload.get("manufacturing_process")):
        warnings.append("Section 6 Manufacturing Process narrative not populated: "
                        "BMR/MFR not uploaded.")
    if _empty(payload.get("process_flow")):
        warnings.append("Section 7 Manufacturing Process Flow not populated: BMR/MFR "
                        "not uploaded.")

    # Section 8 — per-API drug substance specification (from its STP).
    for a in apis:
        if _empty(a.get("specifications")):
            nm = _s(a.get("name")) or "API"
            warnings.append(f"Section 8 {nm} drug substance specification not "
                            f"populated: {nm} STP not uploaded.")

    # Section 12 — comparative dissolution.
    diss = payload.get("dissolution") if isinstance(payload.get("dissolution"), dict) else {}
    if not _as_list(diss.get("tables")):
        warnings.append("Section 12 Comparative Dissolution not populated: comparative "
                        "dissolution report not uploaded.")

    # Supporting-annexure availability (informational).
    if not grouped.get("stability"):
        warnings.append("Section 13 Stability Data not populated: no stability file "
                        "uploaded.")
    if not grouped.get("rld_utilization"):
        warnings.append("Section 14 RLD Utilization not populated: no RLD utilization "
                        "breakup uploaded.")
    if not grouped.get("manufacturing_license"):
        warnings.append("No manufacturing license (Form 25/28) uploaded.")
    if not grouped.get("test_license"):
        warnings.append("No test license (Form 29) uploaded.")
    if not grouped.get("stp_document"):
        warnings.append("No STP documents uploaded — Sections 8/11 and the annexure "
                        "list will omit STP entries.")

    # Structure-image diagnostics (optional artifact — never blocks).
    for a in apis:
        if _empty(a.get("iupac_name")):
            warnings.append(f"API '{_s(a.get('name'))}' has no IUPAC name — molecular "
                            "structure may be omitted.")
        elif _empty(a.get("structure_b64")):
            warnings.append(f"Molecular structure could not be generated for "
                            f"'{_s(a.get('name'))}' — structure block omitted.")

    for e in grouped.get("errors", []):
        warnings.append(f"Annexure '{_s(e.get('filename'))}' failed extraction: "
                        f"{_s(e.get('extraction_notes'))}")

    return {"errors": errors, "warnings": warnings,
            "can_generate": not errors}


