def _parse_conc(val) -> float:
“”“Parse concentration to µg/g. BLQ → LOQ (0.05).”””
if val is None:
return 0.0
if isinstance(val, (int, float)):
return max(0.0, float(val))
s = str(val).strip().lower()
if s in (””, “na”, “nd”, “blq”, “bdl”, “none”, “null”):
return 0.05
s = re.sub(r”(ppm|ug/g|<|>)”, “”, s).replace(” “, “”)
try:
return max(0.0, float(s))
except (ValueError, TypeError):
return 0.05

def _parse_amount(val) -> float:
“”“Parse mg amount to float. q.s. → 0.”””
if val is None:
return 0.0
s = str(val).strip().lower()
if s in (””, “q.s.”, “qs”, “na”):
return 0.0
try:
return float(s)
except Exception:
return 0.0

def build_ingredient_conc_map(annexure_data: List[Dict]) -> Dict[str, Dict[str, float]]:
“”“Build {material_name: {sym: conc_µg/g}} from all annexures.”””
conc_map: Dict[str, Dict[str, float]] = {}
for ann in annexure_data:
material = safe_str(ann.get(“material_name”, “”))
if not material:
continue
elem_dict: Dict[str, float] = {}
for el in ann.get(“elements”, []):
if not isinstance(el, dict):
continue
sym = safe_str(el.get(“symbol”, “”))
if not sym:
continue
elem_dict[sym] = _parse_conc(el.get(“concentration_value”, 0))
conc_map[material] = elem_dict
return conc_map

def _match_ingredient(ingredient_name: str,
conc_map: Dict[str, Dict[str, float]]) -> Dict[str, float]:
“”“Fuzzy-match ingredient → annexure material via token overlap.”””
if not conc_map or not ingredient_name:
return {}
ing_lower = ingredient_name.lower().strip()
best_key = None
best_score = 0
for key in conc_map:
if not key:
continue
key_lower = key.lower().strip()
ing_tokens = set(t for t in re.split(r”[\s()-,]+”, ing_lower) if t)
key_tokens = set(t for t in re.split(r”[\s()-,]+”, key_lower) if t)
if not ing_tokens or not key_tokens:
continue
overlap = len(ing_tokens & key_tokens)
if overlap > best_score:
best_score = overlap
best_key = key
return conc_map.get(best_key, {}) if best_score > 0 else {}

