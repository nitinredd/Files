# ── Calculation-model selection (unit-aware) ──────────────────────────────────
def detect_calculation_model(annexure_data: List[Dict]) -> Dict:
    """
    Decide mass-based (µg/g) vs volume-based (µg/mL) from the annexure units.
    Returns {model, concentration_unit, evidence, ambiguous}.
    """
    saw_mass = 0
    saw_vol = 0
    evidence: List[str] = []
    for ann in annexure_data or []:
        if not isinstance(ann, dict):
            continue
        mat = _sstr(ann.get("material_name", ""))
        for el in (ann.get("elements") or []):
            if not isinstance(el, dict):
                continue
            ru = (_sstr(el.get("raw_unit", "")) or
                  _sstr(el.get("concentration_unit", ""))).lower()
            if not ru:
                continue
            if ru in ("µg/ml", "ug/ml", "mcg/ml"):
                saw_vol += 1
                evidence.append(f"{mat}: µg/mL")
            elif ru in ("ppm", "µg/g", "ug/g", "mg/kg", "ppb", "ng/g", "%", "mg/g"):
                saw_mass += 1
                evidence.append(f"{mat}: {ru}")
    ambiguous = (saw_mass == 0 and saw_vol == 0)
    if saw_vol > 0 and saw_vol >= saw_mass:
        model = "volume_based"
        conc_unit = "ug/mL"
    else:
        model = "mass_based"
        conc_unit = "ug/g"
    return {
        "model": model,
        "concentration_unit": conc_unit,
        "evidence": evidence[:12],
        "ambiguous": ambiguous,
        "n_mass": saw_mass,
        "n_volume": saw_vol,
    }


