#!/usr/bin/env python3
"""
deg_eg.py — Diethylene Glycol (DEG) & Ethylene Glycol (EG) Risk Assessment.

FULLY ISOLATED workflow. No imports of residual_solvent or any EI module.
NO calculations, NO exposure formula, NO MDD×ppm, NO PDE, NO USP <467> matrix,
NO Total Daily Exposure. Only:
  - composition parsing (Section 4 Table 1, stage-wise, q.s. preserved)
  - annexure-driven Yes/No DEG/EG presence + specification limits
  - per-material detail tables for positive findings
  - narrative + warning-first validation

The ONLY thing reused from the EI injection workflow is the identity-resolver
*architecture* (descriptor stripping, identity pooling, brand/family aliases,
canonical tokens, negative-pair protection, confidence scoring). It is ported
here with DEG/EG-appropriate material vocabulary; no EI scientific logic.
"""
import re
import json
import logging
from typing import Any, Dict, List, Optional, Tuple

logger = logging.getLogger(__name__)

# ════════════════════════════════════════════════════════════════════════════
# Basic helpers (self-contained; no shared imports)
# ════════════════════════════════════════════════════════════════════════════
def _s(v: Any, default: str = "") -> str:
    return str(v).strip() if v is not None else default


def _f(v: Any) -> Optional[float]:
    try:
        return float(v)
    except (TypeError, ValueError):
        return None


def deg_eg_safe_json(text: str, want: str = "dict") -> Any:
    """Parse model output defensively. Repairs bare-list roots; never raises.
    Mirrors the safe-JSON scaffolding used elsewhere but is self-contained."""
    if isinstance(text, (dict, list)):
        obj = text
    else:
        s = _s(text)
        if not s:
            return {} if want == "dict" else []
        s = s.replace("```json", "").replace("```", "").strip()
        # find the outermost JSON object/array
        start = min([i for i in (s.find("{"), s.find("[")) if i >= 0] or [-1])
        if start > 0:
            s = s[start:]
        try:
            obj = json.loads(s)
        except Exception:
            # try to locate a trailing-brace-balanced object
            try:
                obj = json.loads(s[: s.rfind("}") + 1])
            except Exception:
                return {"_error": True, "extraction_notes": "unparseable JSON"} \
                    if want == "dict" else []
    if want == "dict":
        if isinstance(obj, dict):
            return obj
        if isinstance(obj, list):
            # schema repair: wrap a bare list
            return {"_list_root": True, "extracted_items": obj, "schema_repaired": True}
        return {"_error": True, "extraction_notes": "unexpected JSON shape"}
    return obj if isinstance(obj, list) else [obj]


# ════════════════════════════════════════════════════════════════════════════
# COMPOSITION PARSING (same Excel shape as RS unit composition; stage-wise)
# Self-contained openpyxl reader — does not import residual_solvent.
# ════════════════════════════════════════════════════════════════════════════
_STRENGTH_RE = re.compile(r"^\s*\d+(?:\.\d+)?\s*mg\s*$", re.IGNORECASE)
_COMP_HINTS = ("ingredient", "component", "material", "name of ingredient", "name")
_FUNCTION_HINTS = ("function", "role", "category")
_COMPENDIA_HINTS = ("compendia", "compendial", "status", "grade")
_STAGE_HINTS = ("stage", "step", "process step", "manufacturing stage")
_QS_HINTS = ("q.s", "qs to", "q.s.", "water", "purified water")

# Stage / process section labels that sometimes appear as full-width header rows
# in composition Excels. These must NEVER be treated as material (ingredient) rows
# in the Table 2 assessment.
_STAGE_LABEL_RE = re.compile(
    r"^\s*(seal\s*coat(ing)?|drug\s*load(ing)?|drug\s*layer(ing)?|sub\s*coat(ing)?|"
    r"enteric\s*coat(ing)?|film\s*coat(ing)?|lubricat(ion|ing)?|inactive\s*granul\w*|"
    r"intra\s*granular|extra\s*granular|blend(ing)?|core|coating|granulation|"
    r"mixing|dispensing|compression|encapsulation|barrier\s*coat(ing)?)\s*:?\s*$",
    re.IGNORECASE)


def _is_stage_header_row(name: str, strength_cells: List[str]) -> bool:
    """A row is a stage/section header (not a material) when its ingredient text
    matches a known stage label AND it carries no quantitative strength value."""
    if not _STAGE_LABEL_RE.match(_s(name)):
        return False
    for v in strength_cells:
        sv = _s(v)
        if sv and re.search(r"\d", sv):
            return False
    return True


def _add_or_merge_material(materials: List[Dict], seen_keys: set, name: str,
                           is_qs: bool, function: str) -> None:
    """Append a material unless an identity-equivalent one already exists, in which
    case merge (keep first display name, record the alias). Uses family / distinctive
    tokens with negative-pair protection (defined later in this module)."""
    exact = name.strip().lower()
    if exact in seen_keys:
        return
    cid = _identity(name)
    fam = cid.get("family", "")
    dist = _distinctive(cid.get("tokens", set()))
    for m in materials:
        if m.get("is_qs") != is_qs:
            continue
        mid = _identity(m["name"])
        mfam = mid.get("family", "")
        if _pair_blocked(fam, mfam):
            continue
        merged = False
        if fam and mfam and fam == mfam:
            merged = True
        elif not fam and not mfam:
            mdist = _distinctive(mid.get("tokens", set()))
            if dist and mdist and dist == mdist:
                merged = True
        if merged:
            m.setdefault("aliases", []).append(name)
            seen_keys.add(exact)
            return
    seen_keys.add(exact)
    materials.append({"name": name, "is_qs": is_qs, "function": function,
                      "aliases": []})


def _is_qs_value(cell_value: str) -> bool:
    s = _s(cell_value).lower().strip()
    if not s:
        return False
    s_norm = re.sub(r"[^a-z0-9 ]+", "", s)
    if s_norm in ("qs", "q s", "qsto", "q s to"):
        return True
    return bool(re.search(r"\bq\.?\s*s\.?\b", s))


def _col_index(header: List[str], hints: Tuple[str, ...]) -> Optional[int]:
    for i, h in enumerate(header):
        hl = h.lower().strip()
        if any(hint in hl for hint in hints):
            return i
    return None


def _strength_columns(header: List[str]) -> List[Tuple[int, str, float]]:
    out = []
    for i, h in enumerate(header):
        if _STRENGTH_RE.match(h or ""):
            m = re.search(r"\d+(?:\.\d+)?", h)
            if m:
                out.append((i, h.strip(), float(m.group(0))))
    return out


def read_excel_grid(excel_bytes: bytes, max_rows: int = 400) -> List[Dict]:
    import openpyxl
    from io import BytesIO
    wb = openpyxl.load_workbook(BytesIO(excel_bytes), data_only=True)
    sheets = []
    for ws in wb.worksheets:
        grid = []
        for i, row in enumerate(ws.iter_rows(values_only=True)):
            grid.append(["" if c is None else str(c).strip() for c in row])
            if i > max_rows:
                break
        if not grid:
            continue
        header_idx, best = 0, -1
        for idx in range(min(len(grid), 15)):
            cells = grid[idx]
            nonempty = [c for c in cells if c]
            if not nonempty:
                continue
            low = " | ".join(c.lower() for c in nonempty)
            score = len(nonempty)
            if any(h in low for h in _COMP_HINTS):
                score += 5
            if any(_STRENGTH_RE.match(c) for c in nonempty):
                score += 5
            if score > best:
                best, header_idx = score, idx
        sheets.append({"sheet": ws.title, "header": grid[header_idx],
                       "rows": grid[header_idx + 1:], "header_idx": header_idx})
    wb.close()
    return sheets


def parse_deg_eg_composition(excel_bytes: bytes) -> Dict:
    """
    Parse the composition Excel into stage-wise display rows for Section 4 Table 1.
    NO calculations. q.s. rows preserved. Returns composition sections + columns +
    the distinct material list for assessment.
    Hard-fails (via _error) only when the workbook can't be read or has no rows.
    """
    try:
        sheets = read_excel_grid(excel_bytes)
    except Exception as e:
        return {"_error": True, "error": f"Excel read failed: {e}",
                "composition": [], "comp_columns": [], "materials": []}
    if not sheets:
        return {"_error": True, "error": "Empty workbook",
                "composition": [], "comp_columns": [], "materials": []}

    # Pick the sheet that looks most like a composition (has a component column)
    sheet = None
    for sh in sheets:
        if _col_index(sh["header"], _COMP_HINTS) is not None:
            sheet = sh
            break
    sheet = sheet or sheets[0]
    header = sheet["header"]
    rows = sheet["rows"]
    comp_idx = _col_index(header, _COMP_HINTS)
    if comp_idx is None:
        return {"_error": True, "error": "No ingredient/component column found",
                "composition": [], "comp_columns": [], "materials": []}

    func_idx = _col_index(header, _FUNCTION_HINTS)
    compendia_idx = _col_index(header, _COMPENDIA_HINTS)
    stage_idx = _col_index(header, _STAGE_HINTS)
    strengths = _strength_columns(header)

    # Display columns (verbatim, in approved order)
    display_columns = [header[comp_idx]]
    if func_idx is not None:
        display_columns.append(header[func_idx])
    if compendia_idx is not None:
        display_columns.append(header[compendia_idx])
    display_columns += [lbl for (_i, lbl, _mg) in strengths]
    if stage_idx is not None:
        display_columns.append(header[stage_idx])

    # Build stage-grouped sections (preserve stage order)
    sections: List[Dict] = []
    section_index: Dict[str, Dict] = {}
    materials: List[Dict] = []
    seen_materials = set()

    for r in rows:
        if comp_idx >= len(r):
            continue
        name = _s(r[comp_idx])
        if not name:
            continue
        # Skip full-width stage/section header rows (e.g. "Seal coating",
        # "Drug Loading") so they never become material rows in Table 2.
        _strength_cells = [_s(r[si]) if si < len(r) else "" for (si, _l, _m) in strengths]
        if _is_stage_header_row(name, _strength_cells):
            continue
        stage = _s(r[stage_idx]) if (stage_idx is not None and stage_idx < len(r)) else ""
        is_qs = any(h in name.lower() for h in _QS_HINTS)
        # also q.s. from any strength cell value
        for (si, _lbl, _mg) in strengths:
            if si < len(r) and _is_qs_value(_s(r[si])):
                is_qs = True
                break

        disp = {header[comp_idx]: name}
        if func_idx is not None and func_idx < len(r):
            disp[header[func_idx]] = _s(r[func_idx])
        if compendia_idx is not None and compendia_idx < len(r):
            disp[header[compendia_idx]] = _s(r[compendia_idx])
        for (si, lbl, _mg) in strengths:
            disp[lbl] = _s(r[si]) if si < len(r) else ""
        if stage_idx is not None and stage_idx < len(r):
            disp[header[stage_idx]] = stage

        sec_key = stage or "Composition"
        if sec_key not in section_index:
            sec = {"name": sec_key if stage else "", "rows": []}
            section_index[sec_key] = sec
            sections.append(sec)
        section_index[sec_key]["rows"].append({"ingredient": name, "columns": disp})

        # Distinct material list with IDENTITY-BASED aggregation so synonymous /
        # grade-variant names collapse to one assessment identity (e.g.
        # "Hypromellose 5 cps" ↔ "Hypromellose 5cps"; "Hydroxypropyl Cellulose" ↔
        # "Hydroxy Propyl Cellulose"). Negative-pair protection prevents unrelated
        # materials that share weak generic tokens from merging.
        func_val = disp.get(header[func_idx]) if func_idx is not None else ""
        _add_or_merge_material(materials, seen_materials, name, is_qs, func_val)

    if not materials:
        return {"_error": True, "error": "No component rows parsed",
                "composition": sections, "comp_columns": display_columns, "materials": []}

    return {
        "_error": False,
        "composition": sections,
        "comp_columns": display_columns,
        "materials": materials,
        "sheet": sheet["sheet"],
    }


