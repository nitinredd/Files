def parse_composition_excel(excel_bytes: bytes) -> Dict:
    """Parse composition Excel using Claude to understand structure."""
    wb = openpyxl.load_workbook(BytesIO(excel_bytes), data_only=True)
    ws = wb.worksheets[0]

    rows_text: List[str] = []
    all_rows:  List[List[str]] = []
    for i, row in enumerate(ws.iter_rows(values_only=True)):
        if any(c is not None for c in row):
            row_str = [str(c) if c is not None else "" for c in row]
            rows_text.append(f"Row {i + 1}: {' | '.join(row_str)}")
            all_rows.append(row_str)
    wb.close()

    sheet_dump = "\n".join(rows_text[:80])

    prompt = (
        "Below is spreadsheet data from a pharmaceutical product composition file.\n"
        "Identify:\n"
        "1. Which column holds the ingredient name\n"
        "2. Which columns hold amounts per strength (e.g. 40mg, 20mg, 10mg)\n"
        "3. Which rows are section headers vs ingredient rows\n"
        "4. The MDD strength (highest dose)\n"
        "5. Number of sachets per day for worst-case MDD\n\n"
        "Return ONLY this JSON (no markdown):\n"
        '{\n'
        '  "ingredient_col": 1,\n'
        '  "strength_cols": {"40mg": 3, "20mg": 4, "10mg": 5},\n'
        '  "mdd_strength": "40mg",\n'
        '  "mdd_sachets": 6,\n'
        '  "sections": [\n'
        '    {"name": "Seal coating", "rows": [\n'
        '      {"ingredient": "...", "status": "USP", '
        '"40mg": "...", "20mg": "...", "10mg": "..."}\n'
        '    ]}\n'
        '  ]\n'
        '}\n\n'
        f"Spreadsheet:\n{sheet_dump}"
    )

    raw = claude_text(prompt)
    parsed = safe_json_parse(raw, {})

    if (isinstance(parsed, dict)
            and isinstance(parsed.get("sections"), list)
            and parsed["sections"]):
        result = parsed
    else:
        logger.warning("Excel parse: using raw-row fallback")
        fallback_rows = []
        for row in all_rows[1:]:
            if len(row) > 3 and row[1].strip():
                fallback_rows.append({
                    "ingredient": row[1],
                    "status":     row[2] if len(row) > 2 else "",
                    "40mg":       row[3] if len(row) > 3 else "0",
                    "20mg":       row[4] if len(row) > 4 else "0",
                    "10mg":       row[5] if len(row) > 5 else "0",
                })
        result = {
            "sections": [{"name": "Composition", "rows": fallback_rows}],
            "ingredient_col": 1,
            "strength_cols": {"40mg": 3, "20mg": 4, "10mg": 5},
        }

    result["mdd_sachets"]    = safe_int(result.get("mdd_sachets", 6), default=6)
    result["ingredient_col"] = safe_int(result.get("ingredient_col", 1), default=1)
    result["mdd_strength"]   = safe_str(result.get("mdd_strength", "40mg")) or "40mg"
    if not isinstance(result.get("sections"), list):
        result["sections"] = []
    if not isinstance(result.get("strength_cols"), dict):
        result["strength_cols"] = {"40mg": 3, "20mg": 4, "10mg": 5}
    result["all_rows"] = all_rows
    return result


