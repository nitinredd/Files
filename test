// ── GENERIC TABLE RENDERER ───────────────────────────────────────────────────
function renderGenericTable(caption, columns, rows) {
  if (!Array.isArray(columns)||!columns.length) return [];
  if (!Array.isArray(rows)||!rows.length) return [];

  var N = columns.length;
  var firstW = Math.round(CW * 0.30);
  var restW  = N > 1 ? Math.floor((CW - firstW) / (N - 1)) : CW;
  var colWidths = [firstW];
  for (var ci = 1; ci < N - 1; ci++) colWidths.push(restW);
  if (N > 1) colWidths.push(CW - firstW - restW * (N - 2));

  var sz = N <= 4 ? SZ.SM : (N <= 8 ? SZ.XS : SZ.XXS);

  var hdrCells = columns.map(function(col, i) {
    return cell(String(col||""), {bold:true, fill:CLR.HDR_GREY, w:colWidths[i], size:sz});
  });
  var hdrRow = new TableRow({children: hdrCells});

  var dataRows = rows.filter(Boolean).map(function(row) {
    var rowArr = Array.isArray(row) ? row : [];
    var cells = colWidths.map(function(w, i) {
      var val = rowArr[i] != null ? String(rowArr[i]) : "";
      return i === 0 ? cellL(val, {w:w, size:sz}) : cell(val, {w:w, size:sz});
    });
    return new TableRow({children: cells});
  });

  var tbl = new Table({
    width: {size:CW, type:WidthType.DXA},
    columnWidths: colWidths,
    rows: [hdrRow].concat(dataRows),
  });

  var result = [];
  if (caption) result.push(lftPara(caption, true, SZ.SM));
  result.push(tbl);
  result.push(blk());
  return result;
}


// ── COMPOSITION TABLE ─────────────────────────────────────────────────────────
function buildCompositionTable(sections, compColumns, compMeta) {
  compMeta    = compMeta    || {};
  compColumns = Array.isArray(compColumns) && compColumns.length ? compColumns : null;

  var cols;
  if (compColumns) {
    cols = compColumns;
  } else {
    cols = ["Name of Ingredient","Function",
            "40 mg\nmg/unit","20 mg\nmg/unit","10 mg\nmg/unit"];
  }

  var N = cols.length;
  var firstW = Math.round(CW * 0.35);
  var restW  = N > 1 ? Math.floor((CW - firstW) / (N - 1)) : CW;
  var colWidths = [firstW];
  for (var ci = 1; ci < N - 1; ci++) colWidths.push(restW);
  if (N > 1) colWidths.push(CW - firstW - restW * (N - 2));

  var sz = N <= 4 ? SZ.SM : (N <= 6 ? SZ.XS : SZ.XXS);

  var hdrRow = new TableRow({children: cols.map(function(col, i) {
    return cell(String(col||""), {bold:true, fill:CLR.HDR_GREY, w:colWidths[i], size:sz});
  })});

  var dataRows = [];
  var sArr = Array.isArray(sections) ? sections : [];
  for (var si = 0; si < sArr.length; si++) {
    var sec = sArr[si];
    if (!sec || typeof sec !== "object") continue;
    if (sec.name) {
      dataRows.push(new TableRow({children:[new TableCell({
        columnSpan:N, borders:allBdr(4), shading:shade(CLR.SEC_BLUE), margins:mg(),
        children:[lftPara(sec.name, true, sz)],
      })]}));
    }
    var rArr = Array.isArray(sec.rows) ? sec.rows : [];
    for (var ri = 0; ri < rArr.length; ri++) {
      var row = rArr[ri];
      if (!row || typeof row !== "object") continue;
      var cells = colWidths.map(function(w, i) {
        var colName = cols[i] || "";
        var val = "";
        if (row.columns && typeof row.columns === "object") {
          val = row.columns[colName] != null ? String(row.columns[colName]) : "";
          if (!val && i === 0) val = String(row.ingredient || row.name || "");
        } else {
          if (i === 0) val = String(row.ingredient || row.name || "");
          else if (i === 1) val = String(row.function || row.role || row.status || "");
          else {
            var keys = ["40mg","20mg","10mg","amount","qty","qty_unit","compendial_status"];
            val = String(row[keys[i-1]] || row.amount || "");
          }
        }
        return i === 0 ? cellL(val, {w:w, size:sz}) : cell(val, {w:w, size:sz});
      });
      dataRows.push(new TableRow({children: cells}));
    }
  }

  var tbl = new Table({
    width:{size:CW,type:WidthType.DXA},
    columnWidths:colWidths,
    rows:[hdrRow].concat(dataRows),
  });

  return [
    secHd("5. Drug product elemental impurity risk assessment"),
    lftPara("Table 1: Quantitative and Qualitative Composition", true, SZ.SM),
    tbl, pgBrk(),
  ];
}

