import { useState, useEffect, useRef } from 'react'

/**
 * ResponseStream — right panel in REVEAL state.
 * Streams tokens with per-batch fade-in animation and auto-scrolls.
 *
 * Props:
 *   response    — accumulated response string
 *   isStreaming — boolean, true while SSE is active
 */
export default function ResponseStream({ response, isStreaming }) {
  const scrollRef = useRef(null)
  const prevLengthRef = useRef(0)
  const [batches, setBatches] = useState([])

  // As new tokens arrive, accumulate them into batches for fade-in animation
  useEffect(() => {
    if (response.length > prevLengthRef.current) {
      const newPart = response.slice(prevLengthRef.current)
      prevLengthRef.current = response.length
      setBatches((prev) => [...prev, { text: newPart, id: Date.now() + Math.random() }])
    }
  }, [response])

  // Reset batches when response is cleared
  useEffect(() => {
    if (response === '') {
      setBatches([])
      prevLengthRef.current = 0
    }
  }, [response])

  // Auto-scroll to bottom as tokens arrive
  useEffect(() => {
    if (scrollRef.current) {
      scrollRef.current.scrollTop = scrollRef.current.scrollHeight
    }
  }, [batches])

  const isEmpty = batches.length === 0

  return (
    <div className="panel-right">
      {/* Header */}
      <div className="panel-header">
        <span className="panel-label">Model Response</span>
        <div className="streaming-status">
          <span className={`streaming-dot ${isStreaming ? 'active' : 'done'}`} />
          <span className={`streaming-label ${isStreaming ? 'active' : 'done'}`}>
            {isStreaming ? 'STREAMING' : 'COMPLETE'}
          </span>
        </div>
      </div>

      {/* Response area */}
      <div ref={scrollRef} className="response-scroll">
        <div className="response-text">
          {batches.map((batch) => (
            <span key={batch.id} className="token-batch">
              {batch.text}
            </span>
          ))}
          {isStreaming && !isEmpty && (
            <span className="cursor-blink" aria-hidden="true" />
          )}
          {isEmpty && isStreaming && (
            <span className="response-waiting">
              <span className="spinner" style={{ borderColor: 'rgba(14,165,233,0.3)', borderTopColor: 'var(--secondary)', display: 'inline-block' }} />
            </span>
          )}
        </div>
      </div>
    </div>
  )
}
