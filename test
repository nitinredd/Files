                                     + f"  ({parsed.get('api_row_method','')})",
            "Dose volume (mL)":      parsed.get("dose_volume_ml",0),
            "Strength (mg/mL)":      parsed.get("strength_mg_per_ml",0),
            "API per dose (mg)":     parsed.get("api_per_dose_mg",0),
            "Doses/day":             parsed.get("doses_per_day",1),
            "MDD (mg/day)":          parsed.get("mdd_mg",0),
            "MDD source":            parsed.get("mdd_source",""),
            "Density (g/mL)":        parsed.get("density_g_per_ml",0),
            "Density source":        parsed.get("density_source",""),
            "Annexure units":        f"mass={model_info.get('n_mass',0)}, "
                                     f"volume={model_info.get('n_volume',0)}",
            "Calculation model":     model_info.get("model",""),
            "Concentration unit":    model_info.get("concentration_unit",""),
        }
        st.table({"Field": list(vrow.keys()),
                  "Value / source": [str(v) for v in vrow.values()]})

        # Component daily quantities
        st.markdown("**Component daily quantities:**")
        comp_rows = []
        for r in parsed_get_comp_rows(st.session_state["inj_comp"]):
            comp_rows.append({
                "Component": r["ingredient"][:40],
                "QS / process aid": "Yes" if r.get("_is_qs") else "No",
                "Daily intake": r.get("_daily_intake",0),
                "Basis": r.get("_intake_basis",""),
            })
        if comp_rows:
            st.dataframe(comp_rows, use_container_width=True, height=240)

        if warnings:
            with st.expander(f"⚠️ {len(warnings)} warning(s)", expanded=True):
                for w in warnings: st.warning(w)

        if errors:
            st.error("❌ Validation gate FAILED — cannot generate the report:")
            for e in errors: st.markdown(f"- {e}")
            st.info("Fix the inputs above or use the manual overrides, then "
                    "click **Analyze inputs** again.")
        else:
            st.success("✅ Validation passed. You may generate the report.")
            if st.button("📝 Generate Injection EI Report", type="primary"):
                _generate_injection_report()

    # Persistent download (survives reruns)
    if st.session_state.get("inj_report_ready") and st.session_state.get("inj_docx_bytes"):
        st.markdown("---")
        st.success("✅ Report ready. Download below — the page stays so you can review.")
        st.download_button("📥 Download Report (DOCX)",
            data=st.session_state["inj_docx_bytes"],
            file_name=st.session_state.get("inj_docx_fname","TSR_injection.docx"),
            mime="application/vnd.openxmlformats-officedocument.wordprocessingml.document",
            key="dl_inj_docx")
        if st.session_state.get("inj_traceability_csv"):
            st.download_button(
                "📥 Download Source-Traceability table (CSV) — internal QC only",
                data=st.session_state["inj_traceability_csv"],
                file_name="injection_source_traceability.csv", mime="text/csv",
                key="dl_inj_trace")


def parsed_get_comp_rows(comp: Dict) -> List[Dict]:
    return comp.get("_injection_rows", []) if isinstance(comp, dict) else []


def _generate_injection_report() -> None:
    """Build the injection EI report from validated session state."""
    try:
        parsed     = st.session_state["inj_parsed"]
        model_info = st.session_state["inj_model"]
        comp       = st.session_state["inj_comp"]
        annexure_data = st.session_state["inj_annexure_data"]
        header     = st.session_state["inj_header"]

        with st.spinner("Calculating EI tables…"):
            calc_tables = calculate_ei_tables(comp, annexure_data)

        with st.spinner("Generating narrative…"):
            text_sections = generate_text_sections(header, annexure_data,
                                                   calc_tables, comp)

        # Fishbone (auto)
        figure_pages = [_build_fishbone_figure(header)]

        # ref_structure built from header (parenteral)
        ref_structure = {
            "meta": {
                "title": (f"Risk assessment for elemental impurities in "
                          f"{header['product_name']}"),
                "document_no":  header["document_no"],
                "product_name": header["product_name"],
                "dosage_form":  header["dosage_form"],
                "strength":     header["strength"],
                "department":   header["department"],
                "market":       header["market"],
                "version":      header["version"],
                "protocol":     header["protocol"],
                "sop_format_number": header["sop_format_number"],
                "route_of_administration": "parenteral",
            },
            "toc_entries": [], "revision_history": [], "signatures": [],
        }

        logo_bytes, logo_mt = load_logo_from_assets()
        logo_b64 = base64.standard_b64encode(logo_bytes).decode() if logo_bytes else ""

        with st.spinner("Rendering DOCX…"):
            docx_bytes = assemble_and_generate(
                ref_structure, [], figure_pages, annexure_data, comp,
                calc_tables, text_sections, ref_bytes=b"",
                logo_b64=logo_b64, logo_type=logo_mt)

        fname = (f"{header['document_no'].replace('/','_').replace(' ','_')}_"
                 f"{datetime.now().strftime('%Y%m%d_%H%M%S')}.docx")
        st.session_state["inj_docx_bytes"] = docx_bytes
        st.session_state["inj_docx_fname"] = fname
        st.session_state["inj_report_ready"] = True

        # traceability CSV
        import csv as _csv, io as _io
        ann_no_map = {safe_str(a.get("material_name","")): a.get("annexure_number","?")
                      for a in annexure_data if isinstance(a, dict)}
        buf = _io.StringIO(); w = _csv.writer(buf)
        w.writerow(["Ingredient","Daily intake","Matched annexure","Matched material",
                    "Match type","Confidence","Status"])
        for a in calc_tables.get("_match_audit", []):
            mkey = a.get("matched_key","")
            w.writerow([a.get("ingredient",""), f"{a.get('daily_g',0):.6f}",
                        (f"Annexure {ann_no_map.get(mkey,'?')}" if mkey else "No match"),
                        mkey or "—", a.get("match_type",""), a.get("match_confidence",""),
                        ("Matched" if a.get("matched") else "No match")])
        st.session_state["inj_traceability_csv"] = buf.getvalue().encode("utf-8")

    except Exception as e:
        st.error(f"Report generation failed: {e}")
        logger.exception("Injection report error")


def _rs_debug_dump(name: str, obj) -> None:
    """Persist a debug JSON artifact for the RS pipeline (best-effort)."""
    try:
        import tempfile, os
        d = os.path.join(tempfile.gettempdir(), "rs_debug")
        os.makedirs(d, exist_ok=True)
        with open(os.path.join(d, name), "w") as f:
            json.dump(obj, f, indent=2, default=str)
    except Exception:
        pass


def _rs_str_df(rows: list):
    """Build a display-safe dataframe (all strings) to avoid Arrow type errors."""
    try:
        import pandas as pd
        if not rows:
            return pd.DataFrame()
        return pd.DataFrame(rows).astype(str)
    except Exception:
        return rows


def _run_residual_solvent_workflow() -> None:
    """Fully isolated, mode-aware Residual Solvent (USP <467> / ICH Q3C) workflow."""
    import residual_solvent as _rs

    st.subheader("🧴 Residual Solvent Risk Assessment — USP <467> / ICH Q3C")
    st.caption("Separate from Elemental Impurities. Enter basic metadata, upload "
               "the composition Excel and any solvent-declaration annexures. The "
               "system classifies the Excel, derives the dose basis, maps "
               "annexures, computes exposure (mg/day), and asks you only for "
               "anything genuinely missing.")

    # ── Step 1: metadata + uploads only ───────────────────────────────────────
    c1, c2 = st.columns(2)
    with c1:
        rs_product = st.text_input("Product Name *",
            placeholder="e.g. Esomeprazole Magnesium for DR Oral Suspension")
        rs_doc_no  = st.text_input("Document No *", placeholder="e.g. TSR-RS-01-0001")
    with c2:
        rs_dosage_form = st.selectbox("Dosage Form / Route",
            ["Oral Suspension", "Delayed-Release Capsule", "Tablet",
             "Delayed-Release Tablet", "Capsule", "Oral Solution", "Injection",
             "Other"], index=0)
        rs_market = st.text_input("Market", value="US")
        # RS Bug 1: the assessment framework sets the compendial priority used when
        # one solvent is listed under several pharmacopoeias (USP/NF vs Ph.Eur vs
        # JP). USP <467> is the US-market default and reproduces prior behaviour.
        rs_framework = st.selectbox("Assessment Framework",
            ["USP <467>", "Ph.Eur", "JP", "ICH Q3C"], index=0,
            help="Chosen at project start. Determines which compendial limit wins "
                 "when the same solvent is tagged under multiple pharmacopoeias.")
        st.session_state["rs_framework"] = rs_framework

    st.caption("Strength, No. of doses and Maximum Daily Dose are derived from the "
               "Excel. You will only be asked for a value if it cannot be found.")

    fc1, fc2 = st.columns(2)
    with fc1:
        rs_excel = st.file_uploader("Residual Solvent Composition Excel *",
                                    type=["xlsx", "xls"], key="rs_excel")
    with fc2:
        rs_annx = st.file_uploader("Solvent Declaration Annexures (PDF or JSON)",
                                   type=["pdf", "json"], accept_multiple_files=True,
                                   key="rs_annx",
                                   help="Optional. Upload raw vendor PDFs — they are "
                                        "converted automatically. Pre-converted JSON "
                                        "is also accepted.")

    can_go = bool(rs_excel and rs_product and rs_doc_no)
    if st.button("🔎 Analyze Excel", type="primary", disabled=not can_go,
                 key="rs_classify_btn"):
        for k in ("rs_cls", "rs_parsed", "rs_calc", "rs_mapping", "rs_annexures",
                  "rs_errors", "rs_warnings", "rs_header", "rs_docx_bytes",
                  "rs_report_ready", "rs_excel_bytes", "rs_ready_to_calc",
                  # RS Bug 2: clear the single-strength dose/salt/overage inputs so a
                  # new product re-detects its own asterisk footnote (setdefault
                  # would otherwise keep the previous product's seeded values).
                  "rs_single_salt", "rs_single_overage", "rs_single_mdd",
                  "rs_single_vol", "rs_single_density"):
            st.session_state.pop(k, None)
        try:
            excel_bytes = rs_excel.getvalue()
            st.session_state["rs_excel_bytes"] = excel_bytes
            cls = _rs.classify_rs_excel(excel_bytes)
            _rs_debug_dump("debug_rs_classification.json",
                           {k: v for k, v in cls.items() if k != "sheets"})
            st.session_state["rs_cls"] = cls
            # annexures: auto-dispatch (PDF → RS converter, JSON → RS normaliser)
            if rs_annx:
                with st.spinner("Converting / reading annexures…"):
                    annexures = dispatch_annexures(
                        "Residual Solvent Risk Assessment", rs_annx)
            else:
                annexures = []
            st.session_state["rs_annexures"] = annexures
            _rs_debug_dump("debug_rs_annexures.json", annexures)
            st.session_state["rs_header"] = {
                "title": f"Residual Solvent Risk Assessment for {rs_product.strip()}",
                "document_no": rs_doc_no.strip(),
                "product_name": rs_product.strip(),
                "dosage_form": rs_dosage_form.strip(),
                "strength": "", "market": rs_market.strip(),
                "maximum_daily_dose": "",
                "department": "FR&D", "version": "1.0, CURRENT", "protocol": "NA",
                "sop_format_number": "",
            }
        except Exception as e:
            st.error(f"Excel analysis failed: {e}")
            logger.exception("RS classify error")

    cls = st.session_state.get("rs_cls")
    if not cls:
        return

    mode = cls.get("mode")
    st.markdown("---")
    st.info(f"**Detected Excel mode:** `{mode}`  •  sheet: `{cls.get('sheet','?')}`")

    # ── Step 2: mode-specific dose basis (missing-details only) ───────────────
    parsed = None
    excel_bytes = st.session_state.get("rs_excel_bytes")

    if mode == "insufficient_material_names_only":
        st.error("❌ This Excel has material names but no quantity, strength, MDD, "
                 "or amount-in-maximum-dose columns. A residual-solvent assessment "
                 "cannot be calculated. Please upload a richer Excel (with strength "
                 "columns, component MDD, or an amount-in-maximum-dose column).")
        return

    if mode == "unit_composition_strength_columns":
        strengths = cls.get("strengths", [])
        max_strength = max(strengths, key=lambda x: x[2]) if strengths else None
        st.markdown("**Missing calculation basis detected — unit-composition Excel.**")
        st.write("Detected strength columns: " +
                 ", ".join(lbl for _i, lbl, _mg in strengths))
        if max_strength:
            st.write(f"Auto-selected maximum strength: **{max_strength[1]}**")
        mdd_in = st.number_input(
            "Enter Maximum Daily Dose (mg/day) — required for this Excel",
            min_value=0.0, value=0.0, step=10.0, key="rs_mdd_input",
            help="No. of doses will be derived as MDD ÷ selected strength.")
        if max_strength and mdd_in > 0:
            derived = mdd_in / max_strength[2]
            st.caption(f"Derived No. of doses = {mdd_in:g} ÷ {max_strength[2]:g} "
                       f"= **{derived:g}**")
        proceed = st.button("✅ Use this MDD and continue", key="rs_modeb_go",
                            disabled=(mdd_in <= 0 or not max_strength))
        if proceed:
            parsed = _rs.parse_unit_composition_excel(cls, mdd_mg_day=float(mdd_in))
            st.session_state["rs_header"]["strength"] = max_strength[1]
            st.session_state["rs_header"]["maximum_daily_dose"] = f"{mdd_in:g} mg"
            st.session_state["rs_parsed"] = parsed
            st.session_state["rs_ready_to_calc"] = True

    elif mode == "component_mdd_only":
        parsed = _rs.parse_component_mdd_only_excel(cls)
        st.session_state["rs_parsed"] = parsed
        st.session_state["rs_ready_to_calc"] = True
        if parsed.get("product_mdd_mg"):
            st.session_state["rs_header"]["maximum_daily_dose"] = \
                f"{parsed['product_mdd_mg']:g} mg"

    elif mode == "single_strength_unit_composition":
        # Single-strength unit composition: ONE quantity column with a unit basis
        # (mg/vial, mg/mL, mg/tablet, mg/sachet, mg/dose). RF1: ask ONE question —
        # the API's Maximum Daily Dose (mg/day). The dose multiplier is derived
        # from the auto-detected API row's per-unit quantity.
        unit_basis = cls.get("unit_basis") or "unit"
        qty_col_label = cls.get("qty_col_label") or "Quantity"
        is_liquid = unit_basis == "ml"
        st.markdown("**Single-strength unit composition detected.**")
        st.write(f"Quantity column: `{qty_col_label}` · unit basis: `{unit_basis}`")

        # RS Bug 2: auto-detect a salt/base (or overage) asterisk footnote and
        # pre-fill the Advanced inputs. A salt-form API's dose multiplier must use
        # the free-base label strength (Trilaciclib 432/300 = 1.44), NOT the salt
        # formulation weight (432/349). The user can still override below.
        _salt_detect = _rs.detect_salt_base_from_classified(cls)
        if _salt_detect and _salt_detect.get("kind") == "salt_base":
            st.session_state.setdefault(
                "rs_single_salt", round(float(_salt_detect["salt_factor"]), 4))
            st.info(
                f"Salt-form API footnote detected: "
                f"**{_salt_detect['salt_weight']:g} mg salt is equivalent to "
                f"{_salt_detect['base_weight']:g} mg base** "
                f"(salt factor {_salt_detect['salt_factor']:.4f}). Pre-filled under "
                f"*Advanced* — enter the API MDD as the **free-base** value.")
        elif _salt_detect and _salt_detect.get("kind") == "overage":
            st.session_state.setdefault(
                "rs_single_overage",
                round(float(_salt_detect["overage_pct"]) * 100.0, 2))
            st.info(
                f"Overage footnote detected: "
                f"**{_salt_detect['overage_pct'] * 100:g}% overage**. "
                f"Pre-filled under *Advanced*.")
        # Guarantee the widget keys exist (detected value, else the neutral
        # default) so the number_inputs below can read Session State without a
        # value=/key= conflict warning.
        st.session_state.setdefault("rs_single_salt", 1.0)
        st.session_state.setdefault("rs_single_overage", 0.0)

        # Volume-dosed liquids (mg/mL) ask for the daily dose VOLUME (mL/day); the
        # multiplier is that volume directly (RS Bug 1), so an API overage in the
        # mg/mL strength never skews the dose. Solids ask for the API MDD (mg/day).
        mdd_in = 0.0
        dose_vol_in = 0.0
        overage_in = 0.0
        if is_liquid:
            dose_vol_in = st.number_input(
                "Daily dose volume (mL/day)",
                min_value=0.0, value=0.0, step=0.001, format="%.3f",
                key="rs_single_vol",
                help=("Volume of the solution administered per day. Every "
                      "component's amount in the maximum dose = its mg/mL strength "
                      "× this volume. The dose multiplier equals this volume."))
        else:
            mdd_in = st.number_input(
                "Maximum Daily Dose (MDD) of API (mg/day)",
                min_value=0.0, value=0.0, step=0.001, format="%.3f",
                key="rs_single_mdd",
                help=("Enter the maximum amount of the ACTIVE (API) taken per day, "
                      "in mg. Every component's amount in the maximum dose is "
                      "scaled from the auto-detected API row — no dose count "
                      "needed."))
        with st.expander("Advanced (salt/base conversion, overage, liquid density)"):
            salt_in = st.number_input(
                "API salt factor (salt MW / free-base MW)", min_value=0.0,
                step=0.001, format="%.4f", key="rs_single_salt",
                help=("Use when the composition lists the SALT but the MDD is a "
                      "free-base value. Auto-filled from an asterisk footnote when "
                      "detected; default 1.0 (no conversion)."))
            # Overage applies to BOTH forms: for a solid it rescales the multiplier
            # (MDD × (1+overage) / api_qty, RF2); for a liquid the dose volume
            # already fixes the multiplier so overage only relabels the strength.
            _ov_help = ("Set when the API strength is inclusive of a manufacturing "
                        "overage (e.g. 10 for a 1.1 mg/mL fill labelled 1 mg/mL). "
                        + ("Only affects the DISPLAYED label strength; the dose "
                           "volume fixes the multiplier."
                           if is_liquid else
                           "Rescales the dose multiplier to MDD × (1+overage) ÷ "
                           "api_qty and relabels the strength.")
                        + " Default 0.")
            overage_in = st.number_input(
                "API overage in strength (%)", min_value=0.0,
                step=1.0, format="%.2f", key="rs_single_overage",
                help=_ov_help) / 100.0
            if is_liquid:
                density_in = st.number_input(
                    "Solution density (g/mL)", min_value=0.0, value=1.0,
                    step=0.01, format="%.3f", key="rs_single_density",
                    help=("Used for liquid drug-product mass "
                          "(volume × density × 1000). Default 1.0 g/mL."))
            else:
                density_in = 1.0
        proceed_single = st.button(
            "✅ Use this dose and continue", key="rs_single_go",
            disabled=((dose_vol_in <= 0) if is_liquid else (mdd_in <= 0)))
        if proceed_single:
            parsed = _rs.parse_single_strength_unit_composition(
                cls, mdd_mg_day=float(mdd_in), unit_basis=unit_basis,
                salt_factor=float(salt_in), density_g_per_ml=float(density_in),
                dose_volume_ml=(float(dose_vol_in) if is_liquid else None),
                overage_pct=float(overage_in))
            hdr = st.session_state["rs_header"]
            # RF6a/6b: strength shows the API (label) strength, never the column
            # header; overage products carry a footnote.
            if parsed.get("strength_label"):
                hdr["strength"] = parsed["strength_label"]
            if parsed.get("strength_note"):
                hdr["strength_note"] = parsed["strength_note"]
            # RF6b: infer dosage form when the user did not supply one.
            if parsed.get("dosage_form_inferred") and not str(hdr.get("dosage_form") or "").strip():
                hdr["dosage_form"] = parsed["dosage_form_inferred"]
            # RF6c: MDD label in Table 1 — mg/day for solids, label dose for liquids.
            if parsed.get("mdd_mg_day"):
                hdr["maximum_daily_dose"] = f"{parsed['mdd_mg_day']:g} mg/day"
            elif is_liquid and parsed.get("product_mdd_mg"):
                hdr["maximum_daily_dose"] = (
                    f"{parsed['product_mdd_mg']:g} mg/day "
                    f"({dose_vol_in:g} mL/day)")
            st.session_state["rs_parsed"] = parsed
            st.session_state["rs_ready_to_calc"] = True
            if parsed.get("api_component"):
                st.caption(f"API detected: **{parsed['api_component']}** "
                           f"({parsed.get('api_qty_per_unit')} mg/{unit_basis}); "
                           f"dose multiplier = {parsed.get('multiplier')}.")

    elif mode == "detailed_rs_calculation":
        # Detailed mode: Excel is authoritative. Try the DETERMINISTIC flat parser
        # first (no LLM, no MDD/strength prompt). Only fall back to Claude vision
        # extraction if the flat parser cannot read usable rows.
        with st.spinner("Reading detailed RS calculation Excel…"):
            flat = _rs.parse_flat_detailed_rs_excel(excel_bytes)
            if flat and flat.get("rows"):
                _rs_debug_dump("debug_rs_raw_excel.json", flat)
                parsed = _rs.parse_rs_excel(flat)
            else:
                raw = _rs_parse_excel_raw(excel_bytes)
                _rs_debug_dump("debug_rs_raw_excel.json", raw)
                parsed = _rs.parse_rs_excel(raw)
        st.session_state["rs_parsed"] = parsed
        st.session_state["rs_ready_to_calc"] = True
        if parsed.get("product_mdd_mg"):
            st.session_state["rs_header"]["maximum_daily_dose"] = \
                f"{parsed['product_mdd_mg']:g} mg"

    elif mode == "combined_workbook":
        # Sheet 1 (unit composition) drives Section 4 Table 2; Sheet 2 (detailed
        # RS calculation) drives Section 5. Detailed sheet is the calculation
        # source; annexures are traceability evidence only.
        st.markdown("**Combined workbook detected** — unit-composition sheet "
                    f"`{cls['unit_sheet']['sheet']}` drives the composition table; "
                    f"detailed sheet `{cls['detailed_sheet']['sheet']}` drives the "
                    "residual-solvent calculation.")
        with st.spinner("Reading detailed RS calculation sheet…"):
            raw = _rs_parse_excel_raw(excel_bytes)
            _rs_debug_dump("debug_rs_raw_excel.json", raw)
            parsed = _rs.parse_rs_excel(raw)
        # Override the composition display with the unit-composition sheet so
        # Section 4 preserves stages/strengths verbatim.
        try:
            unit_cls = {**cls["unit_sheet"], "sheets": cls.get("sheets", [])}
            unit_parsed = _rs.parse_unit_composition_excel(unit_cls, mdd_mg_day=0.0)
            parsed["_display_sections"] = unit_parsed.get("_display_sections", [])
            parsed["_display_columns"] = unit_parsed.get("_display_columns", [])
        except Exception as _e:
            logger.warning(f"combined unit-sheet parse failed: {_e}")
        st.session_state["rs_parsed"] = parsed
        st.session_state["rs_ready_to_calc"] = True
        if parsed.get("product_mdd_mg"):
            st.session_state["rs_header"]["maximum_daily_dose"] = \
                f"{parsed['product_mdd_mg']:g} mg"

    # ── Step 3: calculate + validate once we have a parsed model ──────────────
    if st.session_state.get("rs_ready_to_calc") and st.session_state.get("rs_parsed"):
        parsed = st.session_state["rs_parsed"]
        annexures = st.session_state.get("rs_annexures", [])
        # display copy for Table 2 (deterministic parsers already set _display_*)
        if "_display_sections" not in parsed:
            parsed["_display_columns"] = parsed.get("columns", [])
            parsed["_display_sections"] = [{
                "name": "Composition",
                "rows": [{"ingredient": r["component"], "columns": r.get("columns", {})}
                         for r in parsed["rows"]]}]
        _rs_debug_dump("debug_rs_parsed.json",
                       {k: v for k, v in parsed.items() if k != "sheets"})

        comps = [r["component"] for r in parsed["rows"] if not r["_is_qs"]]

        # Section 5 calculation uses AGGREGATED identities for unit-composition /
        # MDD modes. For detailed / combined modes the Excel already carries the
        # final per-row solvent matrix, so it is authoritative — do NOT aggregate.
        if parsed.get("mode") in ("detailed_rs_calculation", "combined_workbook") \
           or parsed.get("solvents_display"):
