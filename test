    enable_inline_citations = st.checkbox(
        "🔗 Enable inline citations in DOCX "
        "(appends [Ann.N] and [ICH-Q3D-A2.N] markers to table values)",
        value=False,
        help="When ON, superscript-style footnote markers appear in Tables 5/6/7 cells."
    )

    btn_disabled = not (ref_pdf and excel_file and annexure_files)
    if st.button("🚀 Generate Report", type="primary", disabled=btn_disabled):
        progress = st.progress(0)
        log = st.empty()
        try:
            # ── Step 0: Pre-flight ──────────────────────────────────────────
            log.info("🔍 Validating uploads…")
            annexure_raw = [(af.name, af.getvalue().decode("utf-8","replace"))
                            for af in annexure_files]
            errors = validate_inputs(ref_pdf.getvalue(), excel_file.getvalue(), annexure_raw)
            if errors:
                for err in errors: st.error(f"❌ {err}")
                st.stop()
            st.success("✅ Pre-flight OK.")
            progress.progress(4)

            # ── Initialise citation builder ─────────────────────────────────
            cb = CitationBuilder()

            # ── Step 1: Rasterize PDF ───────────────────────────────────────
            log.info("📄 Rasterizing reference PDF…")
            ref_bytes   = ref_pdf.getvalue()
            page_images = rasterize_pdf_pages(ref_bytes, dpi=150)
            st.success(f"Reference PDF: {len(page_images)} pages.")

            # Register PDF for integrity hash
            cb.register_pdf(ref_pdf.name, ref_bytes, len(page_images))
            progress.progress(7)

            # ── Step 2: Logo ────────────────────────────────────────────────
            log.info("🖼 Loading logo from assets/…")
            logo_bytes, logo_mt = load_logo_from_assets()
            logo_b64  = base64.standard_b64encode(logo_bytes).decode() if logo_bytes else ""
            logo_type = logo_mt
            if logo_b64: st.success("✅ Logo loaded from assets/logo.png")
            else: st.info("ℹ️ No logo in assets/. Save as assets/logo.png for logo in report.")
            progress.progress(10)

            # ── Step 3: Figure pages ────────────────────────────────────────
            log.info("🔍 Identifying figure pages…")
            figure_pages = identify_figure_pages(page_images)
            if figure_pages:
                st.success(f"Found {len(figure_pages)} figure page(s): "
                           + ", ".join(f"p{f['page_index']+1}" for f in figure_pages))
            else:
                st.warning("No figure pages detected.")
            progress.progress(18)

            # ── Step 4: Reference structure ─────────────────────────────────
            log.info("📑 Extracting report structure, TOC, and all page tables…")
            ref_structure = extract_reference_structure(
                page_images,
                pdf_filename=ref_pdf.name,
                citation_builder=cb,
            )
            meta = ref_structure.get("meta",{}) or {}
            toc  = ref_structure.get("toc_entries",[]) or []
            st.success(f"Product: {meta.get('product_name','(extracted)')} | "
                       f"Doc: {meta.get('document_no','')} | "
                       f"TOC: {len(toc)} sections")
            progress.progress(32)

            # ── Step 5: Parse Excel ─────────────────────────────────────────
            log.info("📊 Parsing composition Excel…")
            comp_data = parse_composition_excel(
                excel_file.getvalue(),
                excel_filename=excel_file.name,
            )
            # Register Excel for integrity hash
            cb.register_excel(
                excel_file.name,
                excel_file.getvalue(),
                comp_data.get("_sheet_name", "Sheet1"),
            )
            n_ing = sum(len(s.get("rows",[])) for s in comp_data.get("sections",[])
                        if isinstance(s, dict))
            st.success(
                f"Excel: {n_ing} ingredients | "
                f"Route: {comp_data.get('route','?')} | "
                f"MDD: {comp_data.get('mdd_g','?')}g/day × "
                f"{comp_data.get('doses_per_day','?')} dose(s)")
            progress.progress(42)

            # ── Step 6: Process annexures ───────────────────────────────────
            log.info(f"🔬 Processing {len(annexure_files)} annexure(s)…")
            annexure_data: List[Dict] = []
            sorted_files  = sorted(annexure_files, key=lambda f: f.name)
            annexure_filenames: List[str] = []
            for i, af in enumerate(sorted_files):
                try:
                    raw_json = json.loads(af.getvalue().decode("utf-8","replace").lstrip("﻿"))
                except Exception as e:
                    st.warning(f"  ⚠️ Annexure {i+1} ({af.name}): bad JSON — {e}")
                    annexure_data.append({"annexure_number":i+1,"supplier_name":"N/A",
                                          "material_name":"N/A","elements":[]})
                    annexure_filenames.append(af.name)
                    continue
                ann = process_annexure(raw_json, i+1, filename=af.name)
                annexure_data.append(ann)
                annexure_filenames.append(af.name)
                # Register annexure for integrity hash
                cb.register_annexure(
                    i+1, af.name, af.getvalue(),
                    ann.get("material_name","N/A"),
                    ann.get("supplier_name","N/A"),
                )
                st.write(f"  ✅ Annexure {i+1}: **{ann.get('material_name','?')}** "
                         f"({ann.get('supplier_name','?')}) — "
                         f"{len(ann.get('elements',[]))} elements")
                progress.progress(42 + int(20*(i+1)/len(annexure_files)))

            # ── Step 7: Calculate EI tables ─────────────────────────────────
            log.info("🧮 Calculating EI tables (formula: daily_g × conc_µg/g)…")
            calc_tables = calculate_ei_tables(
                comp_data, annexure_data,
                citation_builder=cb,
                annexure_filenames=annexure_filenames,
                excel_filename=excel_file.name,
            )
            t5 = safe_calc_table(calc_tables,"class1_2a")

            n_rows_5 = len(t5.get("rows",[]))
            ann_materials = [a.get("material_name","?") for a in annexure_data
                             if isinstance(a,dict)]
            st.write(f"  📊 Calc diagnostics: route={comp_data.get('route','?')} | "
                     f"mdd_g={comp_data.get('mdd_g','?')}g | "
                     f"ingredient_col='{comp_data.get('ingredient_col','?')}' | "
                     f"amount_col='{comp_data.get('amount_col','?')}' | "
                     f"Class1+2A rows={n_rows_5}")
            if n_rows_5 == 0:
                st.warning("⚠️ No ingredient rows in Class1+2A table — check "
                           "ingredient_col / amount_col / annexure matching above.")
            st.write(f"  📦 Annexure materials: {', '.join(ann_materials[:8])}")

            crossing = [sym for sym in TABLE5_ELEMENTS
                        if t5["pde"].get(sym) and
                        t5["element_totals"].get(sym,0) > t5["pde"].get(sym,0)*0.30]
            if crossing:
                st.warning(f"Elements > 30% PDE: {', '.join(crossing)}")
            else:
                st.success("All Class 1+2A elements ≤ 30% PDE." if n_rows_5>0
                           else "⚠️ Tables empty — check diagnostics above.")
            progress.progress(72)

            # ── Step 8: Generate text ───────────────────────────────────────
            log.info("✍️ Generating report text with Claude…")
            text_sections = generate_text_sections(
                ref_structure, annexure_data, calc_tables, comp_data,
                citation_builder=cb,
            )
            progress.progress(82)

            # ── Step 9: Build DOCX + ledger + HTML ─────────────────────────
            log.info("📝 Building DOCX + citation ledger…")
            doc_no  = safe_str(meta.get("document_no","TSR")).replace("/","_").replace(" ","_")
            ver     = safe_str(meta.get("version","v")).split(",")[0].replace(" ","").replace(".","_")
            ts_str  = datetime.now().strftime('%Y%m%d_%H%M%S')
            base_name  = f"{doc_no}_{ver}_{ts_str}"
            report_id  = base_name

            docx_bytes, ledger_dict, html_str = assemble_and_generate(
                ref_structure, page_images, figure_pages,
                annexure_data, comp_data, calc_tables, text_sections,
                ref_bytes=ref_bytes, logo_b64=logo_b64, logo_type=logo_type,
                citation_builder=cb,
                enable_inline_citations=enable_inline_citations,
                report_id=report_id,
                pdf_filename=ref_pdf.name,
            )
            progress.progress(100)
            log.success("✅ Report generated!")

            # Persist outputs so download buttons survive re-runs caused by clicking them
            st.session_state["_tsr_docx"]      = docx_bytes
            st.session_state["_tsr_ledger"]    = ledger_dict
            st.session_state["_tsr_html"]      = html_str
            st.session_state["_tsr_base_name"] = base_name

        except Exception as e:
            st.error(f"Pipeline error: {e}")
            logger.exception("Pipeline error")

    # ── Persistent download panel ─────────────────────────────────────────────
    # Rendered on every run so clicking any one button doesn't lose the others.
    if "_tsr_docx" in st.session_state:
        st.markdown("### 📥 Downloads")
        dl1, dl2, dl3 = st.columns(3)
        _base = st.session_state["_tsr_base_name"]
        _docx = st.session_state["_tsr_docx"]
        _ledger = st.session_state["_tsr_ledger"]
        _html = st.session_state["_tsr_html"]

        with dl1:
            st.download_button(
                "📄 Report (DOCX)",
                data=_docx,
                file_name=f"{_base}.docx",
                mime="application/vnd.openxmlformats-officedocument.wordprocessingml.document",
                key="dl_docx",
            )
        with dl2:
            if _ledger:
                st.download_button(
                    "📋 Citation Ledger (JSON)",
                    data=json.dumps(_ledger, ensure_ascii=False, indent=2).encode("utf-8"),
                    file_name=f"{_base}_citation_ledger.json",
                    mime="application/json",
                    key="dl_ledger",
                )
                n_cit = _ledger.get("summary", {}).get("total_citations", 0)
                low   = _ledger.get("summary", {}).get("low_confidence_matches", 0)
                st.caption(f"{n_cit} citations | {low} low-confidence matches")
            else:
                st.info("Citation ledger not generated.")
        with dl3:
            if _html:
                st.download_button(
                    "🔍 Traceability Report (HTML)",
                    data=_html.encode("utf-8"),
                    file_name=f"{_base}_traceability.html",
                    mime="text/html",
                    key="dl_html",
                )
            else:
                st.info("Traceability report not generated.")

    with st.expander("ℹ️ Setup & Formula"):
        st.markdown("""
**Formula:** `Daily exposure (µg/day) = Amount_in_MDD (g/day) × Conc (µg/g)`

This works for **any product**:
- Oral sachets: amount per sachet × sachets/day → g/day
- Injections: amount per injection → g/day
- Topical: amount per application × applications/day → g/day

**PDE values used:** Automatically selected based on route of administration
(oral vs parenteral vs other).

**Citation Ledger:** A `citation_ledger.json` is generated alongside every DOCX,
recording the exact source (annexure field path, Excel row, ICH Q3D table) for
every number in Tables 5, 6, and 7.

**Traceability Report:** A self-contained `traceability_report.html` shows the
full audit trail: input hashes, ingredient matching scores, calculation chains,
and text generation provenance.

**npm deps (once):** `npm install docx jszip`

**Logo:** Save as `assets/logo.png` next to `app.py`

**TOC:** Extracted automatically from the reference PDF — matches the product's actual sections.
""")


if __name__ == "__main__":
    main()
