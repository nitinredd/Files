def generate_text_sections(ref_structure: Dict, annexure_data: List[Dict],
                           calc_tables: Dict, comp_data: Dict) -> Dict:
    """Generate all narrative sections using Claude."""
    empty: Dict = {
        "abstract": "", "objective": "", "study_location": "NA",
        "background": "", "sources_intro": "", "drug_substance_section": "",
        "excipient_intro": "", "manufacturing_section": "",
        "container_closure_section": "", "utilities_section": "",
        "control_strategy": "", "observation": "", "conclusion": "",
        "reference": "NA",
    }

    ann_summary = []
    for ann in annexure_data:
        if isinstance(ann, dict):
            ann_summary.append({
                "material":       ann.get("material_name", "N/A"),
                "supplier":       ann.get("supplier_name", "N/A"),
                "elements_count": len(ann.get("elements", []) or []),
            })

    t5 = safe_calc_table(calc_tables, "class1_2a")
    t6 = safe_calc_table(calc_tables, "class2b")
    t7 = safe_calc_table(calc_tables, "class3")

    crossing: Dict = {}
    for sym in TABLE5_ELEMENTS:
        pde   = ICH_PDE[sym]["pde"]
        total = t5["element_totals"].get(sym, 0)
        if pde and total > pde * 0.3:
            crossing[sym] = {"total": total, "pde30": round(pde * 0.3, 3)}

    prompt = (
        "You are a pharmaceutical regulatory writer creating an ICH Q3D (R2) TSR.\n\n"
        f"Product metadata:\n{json.dumps(ref_structure.get('meta', {}), indent=2)}\n\n"
        f"Annexures ({len(annexure_data)} materials):\n"
        f"{json.dumps(ann_summary, indent=2)}\n\n"
        "Calculation results:\n"
        f"- Class 1+2A totals: {json.dumps(t5['element_totals'])}\n"
        f"- Class 2B totals: {json.dumps(t6['element_totals'])}\n"
        f"- Class 3 totals: {json.dumps(t7['element_totals'])}\n"
        f"- PDEs: {json.dumps({s: ICH_PDE[s]['pde'] for s in TABLE5_ELEMENTS})}\n"
        f"- MDD sachets: {comp_data.get('mdd_sachets', 6)}, "
        f"strength: {comp_data.get('mdd_strength', '40mg')}\n\n"
        f"Elements crossing 30% PDE: {json.dumps(crossing)}\n\n"
        "Generate concise, factual ICH Q3D regulatory text.\n"
        "Return ONLY this JSON (no markdown, no extra text):\n"
        '{\n'
        '  "abstract": "...",\n'
        '  "objective": "...",\n'
        '  "study_location": "NA",\n'
        '  "background": "...",\n'
        '  "sources_intro": "...",\n'
        '  "drug_substance_section": "...",\n'
        '  "excipient_intro": "...",\n'
        '  "manufacturing_section": "...",\n'
        '  "container_closure_section": "...",\n'
        '  "utilities_section": "...",\n'
        '  "control_strategy": "...",\n'
        '  "observation": "...",\n'
        '  "conclusion": "...",\n'
        '  "reference": "NA"\n'
        '}'
    )

    raw    = claude_text(prompt, max_tokens=6000)
    parsed = safe_json_parse(raw, {})
    if not isinstance(parsed, dict):
        logger.error("Text generation returned no valid JSON; using empty sections")
        return empty
    for k, v in empty.items():
        parsed.setdefault(k, v)
    return parsed


