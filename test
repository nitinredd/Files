def _expand_abbreviation(tok: str) -> List[str]:
    """Expand a known abbreviation to its canonical token(s); else return [tok]."""
    exp = _ABBREVIATION_MAP.get(tok)
    if exp:
        return exp.split()
    return [tok]


# British ↔ American spelling and common chemical-name variants → canonical form.
_SPELLING_MAP = {
    "sulphite": "sulfite", "sulphate": "sulfate", "sulphur": "sulfur",
    "sulphuric": "sulfuric", "aluminium": "aluminum", "caesium": "cesium",
    "colour": "color", "centre": "center", "fibre": "fiber",
    "oestradiol": "estradiol", "phosphate": "phosphate",
    "glycerine": "glycerin", "glycerin": "glycerin", "glycerol": "glycerin",
    "saccharose": "sucrose", "hydroxypropylcellulose": "hydroxypropyl cellulose",
}


def _apply_spelling(tok: str) -> str:
    return _SPELLING_MAP.get(tok, tok)


def _norm_identity_text(text: Any) -> str:
    s = safe_str(text).lower()
    s = s.replace("\u03bc", "u").replace("\u00b5", "u").replace("&", " and ")
    # Drop registered/trademark glyphs and bracketed qualifiers like "(sifted)"
    s = s.replace("\u00ae", " ").replace("\u2122", " ")
    s = re.sub(r"[^a-z0-9]+", " ", s)
    return re.sub(r"\s+", " ", s).strip()


# Generic document descriptors that are not material identities (Issue 3).
_DOC_DESCRIPTORS_APP = [
    "material characterization", "material characterisation", "characterization",
    "characterisation", "extractables study", "extractables and leachables",
    "extractables", "leachables study", "leachables", "validation guide",
    "validation report", "technical report", "technical data sheet",
    "certificate of analysis", "certificate of suitability", "specification sheet",
    "specification", "assessment", "evaluation", "study report", "study",
    "report", "insights from the experts", "data sheet", "safety data sheet",
    "test report", "analytical report", "compatibility study",
]
_DESCRIPTOR_CONNECTORS_APP = (" for ", " of ", " on ", " : ", ": ", " - ", " – ")


def _strip_doc_descriptor(name: str) -> str:
    """Return the material subject from a '<descriptor> for <material>' phrase;
    '' if the name is only a descriptor; unchanged otherwise. Product-agnostic."""
    if not name:
        return ""
    s = " ".join(safe_str(name).split())
    low = s.lower()
    for desc in _DOC_DESCRIPTORS_APP:
        if low.startswith(desc):
            rest = s[len(desc):]
            rl = rest.lower()
            for conn in _DESCRIPTOR_CONNECTORS_APP:
                if rl.startswith(conn):
                    subject = rest[len(conn):].strip(" :-–").strip()
                    sl = subject.lower()
                    # If what's after the connector is itself a descriptor/tagline,
                    # it's not a material identity.
                    if sl in _DOC_DESCRIPTORS_APP or \
                       any(sl.startswith(d) for d in _DOC_DESCRIPTORS_APP) or \
                       "insights" in sl or "experts" in sl:
                        return ""
                    return subject
            if not rest.strip(" :-–"):
                return ""
    if low in _DOC_DESCRIPTORS_APP:
        return ""
    return s


def _canonical_tokens(text: Any) -> set:
    """
    Identity tokens with pharmacopeial/descriptive/brand-marker noise removed,
    spelling reconciled, and standard chemical abbreviations expanded (CMC →
    carboxymethylcellulose, Na → sodium). This is the comparison vocabulary that
    survives real-world naming variation.
    """
    out: set = set()
    for t in _norm_identity_text(text).split():
        # Expand 1-char element abbreviations (k, ca) before the length filter
        if t in _ABBREVIATION_MAP:
            for piece in _expand_abbreviation(t):
                piece = _apply_spelling_full(piece)
                if piece and piece not in _NOISE_TOKENS and len(piece) > 1:
                    out.add(piece)
            continue
        if len(t) <= 1:
            continue
        if t in _NOISE_TOKENS:
            continue
        t = _apply_spelling_full(t)
        for piece in _expand_abbreviation(t):
            piece = _apply_spelling_full(piece)
            if piece and piece not in _NOISE_TOKENS and len(piece) > 1:
                out.add(piece)
    return out


def _contains_alias_norm(text_norm: str, alias_norm: str) -> bool:
    if not text_norm or not alias_norm:
        return False
    pattern = r"(?<![a-z0-9])" + re.escape(alias_norm) + r"(?![a-z0-9])"
    return re.search(pattern, text_norm) is not None


def _identity_tokens(text: Any) -> set:
    return set(t for t in _norm_identity_text(text).split() if len(t) > 1)


def _detect_brand(texts: List[str]) -> Tuple[str, str]:
    matches: List[Tuple[int, int, str, str]] = []
    for text_pos, text in enumerate(texts):
        tn = _norm_identity_text(text)
        if not tn:
            continue
        for brand, rule in BRAND_IDENTITY_RULES.items():
            for alias in rule.get("aliases", []):
                an = _norm_identity_text(alias)
                if _contains_alias_norm(tn, an):
                    matches.append((text_pos, -len(an), brand, alias))
    if not matches:
        return "", ""
    matches.sort()
    return matches[0][2], matches[0][3]


def _detect_family(texts: List[str]) -> Tuple[str, str]:
    matches: List[Tuple[int, int, str, str]] = []
    for text_pos, text in enumerate(texts):
        tn = _norm_identity_text(text)
        if not tn:
            continue
        for family, aliases in MATERIAL_FAMILY_ALIASES.items():
            for alias in aliases:
                an = _norm_identity_text(alias)
                if _contains_alias_norm(tn, an):
                    matches.append((text_pos, -len(an), family, alias))
    if not matches:
        return "", ""
    matches.sort()
    return matches[0][2], matches[0][3]


def _extract_material_identity(text: str) -> Dict[str, Any]:
    raw = safe_str(text)
    parenthetical = [p.strip() for p in re.findall(r"[\(\[]([^\)\]]+)[\)\]]", raw)
                     if p.strip()]
    bare = re.sub(r"[\(\[][^\)\]]*[\)\]]", "", raw).strip()
    brand, brand_alias = _detect_brand(parenthetical + [raw, bare])
    family, family_alias = _detect_family([raw, bare] + parenthetical)

    if brand:
        family = safe_str(BRAND_IDENTITY_RULES.get(brand, {}).get("family", family))
        family_alias = brand_alias or family_alias

    fragments = _ordered_unique(
        [_norm_identity_text(raw)]
        + [_norm_identity_text(p) for p in parenthetical]
        + [_norm_identity_text(bare)]
    )
    # Canonical core = distinctive tokens with noise/spelling normalized, as a
    # frozenset, so two names that differ only in pharmacopeial/brand/descriptor
    # noise share the SAME core ("sodium chloride usp" ≈ "sodium chloride emprove").
    core = frozenset(_canonical_tokens(bare or raw))
    return {
        "raw": raw,
        "norm": _norm_identity_text(raw),
        "bare_norm": _norm_identity_text(bare),
        "parenthetical": parenthetical,
        "fragments": fragments,
        "core": core,
        "brand": brand,
        "brand_alias": brand_alias,
        "family": family,
        "family_alias": family_alias,
        "identity_sources": [raw] if raw else [],
    }


def _merge_annexure_identity(sources: List[str]) -> Dict[str, Any]:
    """
    Build an annexure identity by POOLING identity evidence from multiple text
    sources (material name, supplier trade name, document title/filename).
    Product-agnostic: any source that carries the true material identity (a
    brand, a chemistry name, an abbreviation) contributes to the match pool, so
    a valid annexure is not missed just because the composition uses a different
    name than the annexure's material_name field.
    """
    sources = [safe_str(s) for s in sources if safe_str(s)]
    if not sources:
        return _extract_material_identity("")
    # Primary identity from the material_name (first source)
    primary = _extract_material_identity(sources[0])
    all_fragments = list(primary.get("fragments", []))
    brand = safe_str(primary.get("brand"))
    brand_alias = safe_str(primary.get("brand_alias"))
    family = safe_str(primary.get("family"))
    family_alias = safe_str(primary.get("family_alias"))
    # Pool the remaining sources (supplier, title, filename)
    for src in sources[1:]:
        idn = _extract_material_identity(src)
        for f in idn.get("fragments", []):
            if f and f not in all_fragments:
                all_fragments.append(f)
        # Adopt a brand/family only if the primary had none (don't override a
        # confidently-identified material with a supplier-derived guess)
        if not brand and idn.get("brand"):
            brand = safe_str(idn.get("brand"))
            brand_alias = safe_str(idn.get("brand_alias"))
        if not family and idn.get("family"):
            family = safe_str(idn.get("family"))
            family_alias = safe_str(idn.get("family_alias"))
    if brand:
        family = safe_str(BRAND_IDENTITY_RULES.get(brand, {}).get("family", family))
    merged = dict(primary)
    merged["fragments"] = all_fragments
    merged["brand"] = brand
    merged["brand_alias"] = brand_alias
    merged["family"] = family
    merged["family_alias"] = family_alias
    merged["identity_sources"] = sources
    # Pool the canonical core across every identity source (material name +
    # supplier + title + filename + candidates), so distinctive identity tokens
    # present in a supplier/trade name or document title contribute to matching.
    pooled_core: set = set(primary.get("core") or set())
    for src in sources:
        pooled_core |= _canonical_tokens(src)
    merged["core"] = frozenset(pooled_core)
    return merged


def _identity_key(identity: Dict[str, Any]) -> str:
    return (safe_str(identity.get("brand"))
            or safe_str(identity.get("family"))
            or safe_str(identity.get("bare_norm"))
            or safe_str(identity.get("norm")))


def _pair_in(pair_list: List[Tuple[str, str]], a: str, b: str) -> bool:
    return (a, b) in pair_list or (b, a) in pair_list


def _identity_conflict_reason(ingredient: Dict[str, Any],
                              annexure: Dict[str, Any]) -> str:
    ing_brand = safe_str(ingredient.get("brand"))
    ann_brand = safe_str(annexure.get("brand"))
    ing_family = safe_str(ingredient.get("family"))
    ann_family = safe_str(annexure.get("family"))

    if ing_brand and ann_brand and _pair_in(NEGATIVE_BRAND_PAIRS, ing_brand, ann_brand):
        return f"blocked brand pair {ing_brand} vs {ann_brand}"
    if ing_brand and ann_brand and ing_brand != ann_brand:
        return f"ingredient brand {ing_brand} cannot use {ann_brand} annexure"
    if ing_brand and not ann_brand:
        # A branded ingredient can use an UNBRANDED annexure only when the
        # annexure names the SAME material family chemically (e.g. brand
        # "Polyox" ↔ "Polyethylene oxide"). If the annexure has a different or
        # unknown family, keep the strict block (prevents a brand borrowing a
        # generic-chemistry annexure that may belong to another brand/grade).
        brand_fam = safe_str(BRAND_IDENTITY_RULES.get(ing_brand, {}).get("family")) \
                    or ing_family
        if brand_fam and ann_family and brand_fam == ann_family \
           and not _pair_in(NEGATIVE_FAMILY_PAIRS, brand_fam, ann_family):
            pass  # same material, expressed chemically → allowed
        else:
            return f"ingredient brand {ing_brand} requires same-brand or same-family annexure"

    if ing_family and ann_family and _pair_in(NEGATIVE_FAMILY_PAIRS, ing_family, ann_family):
        return f"blocked family pair {ing_family} vs {ann_family}"
    if ing_family and ann_family and ing_family != ann_family:
        return f"material family mismatch {ing_family} vs {ann_family}"
    return ""


def _annexure_candidates(conc_map: Dict[str, Dict[str, float]],
                         identity_pool: Dict[str, List[str]] = None
                         ) -> List[Dict[str, Any]]:
    identity_pool = identity_pool or {}
    candidates: List[Dict[str, Any]] = []
    for order, key in enumerate(conc_map.keys()):
        # Pool identity from material_name + supplier + title/filename when available
        sources = identity_pool.get(key)
        if sources:
            identity = _merge_annexure_identity(sources)
        else:
            identity = _extract_material_identity(key)
        candidates.append({
            "key": key,
            "order": order,
            "identity": identity,
            "concs": conc_map.get(key, {}),
        })
    return candidates


_GENERIC_TOKENS = {
    # Only truly ubiquitous, non-identifying words. Anions/cations like
    # "chloride"/"sulfate"/"sodium" are KEPT, because in combination they
    # identify a material (e.g. "sodium chloride" vs "sodium hydroxide").
    "injection","injectable","solution","water","wfi","b","a",
}


def _apply_spelling_full(tok: str) -> str:
    """Token-level spelling reconciliation, including substring rules so that
    'metabisulphite'→'metabisulfite', 'disulphide'→'disulfide', etc."""
    if tok in _SPELLING_MAP:
        return _SPELLING_MAP[tok]
    # British 'sulph' → American 'sulf' anywhere in the token
    if "sulph" in tok:
        tok = tok.replace("sulph", "sulf")
    if tok.startswith("aluminium"):
        tok = tok.replace("aluminium", "aluminum")
    return _SPELLING_MAP.get(tok, tok)


def _evidence_tokens(identity: Dict[str, Any]) -> set:
    """
    All identity tokens pooled from every fragment AND every pooled source
    (material name, supplier, trade name, title, filename, candidates), with
    pharmacopeial/descriptive/brand-marker noise removed and spelling reconciled.
    """
    toks: set = set()
    for frag in identity.get("fragments", []) or []:
        toks |= _canonical_tokens(frag)
    for src in identity.get("identity_sources", []) or []:
        toks |= _canonical_tokens(src)
    return toks


def _distinctive(tokens: set) -> set:
    """Drop generic chemistry tokens that don't establish identity on their own."""
    return {t for t in tokens if t not in _GENERIC_TOKENS}


def _candidate_score(ingredient: Dict[str, Any], candidate: Dict[str, Any]) -> float:
    """
    Evidence-based similarity in [0,1]. Scores the ingredient's pooled, noise-
    stripped identity tokens against the candidate annexure's POOLED tokens
    (material name + supplier + trade name + title + filename + candidates).

    Real-world naming variation is handled by:
      • stripping pharmacopeial refs (USP, Ph.Eur, EMPROVE), descriptive
        qualifiers (sifted, micronized), and brand-marker words before scoring;
      • reconciling spelling (sulphite→sulfite);
      • rewarding distinctive chemical-core agreement over generic tokens;
      • a CONTAINMENT bonus: if the shorter name's distinctive core is fully
        contained in the longer name, treat it as a strong match (e.g.
        "Chlorobutanol Hemihydrate" ⊆ "Chlorobutanol Hemihydrate USP (sifted)").
    """
    annexure = candidate.get("identity", {})
    ing_fragments = ingredient.get("fragments", []) or []
    ann_fragments = annexure.get("fragments", []) or []
    if any(f and f in ann_fragments for f in ing_fragments):
        return 1.0

    ing_tokens = _evidence_tokens(ingredient)
    ann_tokens = _evidence_tokens(annexure)
    if not ann_tokens:
        ann_tokens = _canonical_tokens(candidate.get("key", ""))
    if not ing_tokens or not ann_tokens:
        base = 0.0
    else:
        inter = ing_tokens & ann_tokens
        union = ing_tokens | ann_tokens
        jaccard = len(inter) / len(union) if union else 0.0
        dist_ing = _distinctive(ing_tokens)
        dist_ann = _distinctive(ann_tokens)
        dist_inter = dist_ing & dist_ann
        dist_union = dist_ing | dist_ann
        dist_overlap = len(dist_inter) / len(dist_union) if dist_union else 0.0
        # Containment: is one side's distinctive core fully inside the other's?
        contain = 0.0
        if dist_ing and dist_ann:
            smaller, larger = ((dist_ing, dist_ann)
                               if len(dist_ing) <= len(dist_ann)
                               else (dist_ann, dist_ing))
            if smaller and smaller <= larger:
                contain = 1.0
            elif smaller:
                contain = len(smaller & larger) / len(smaller)
        if dist_inter:
            # Blend: distinctive overlap + containment dominate; jaccard supports
            base = 0.30 * jaccard + 0.35 * dist_overlap + 0.35 * contain
        else:
            base = 0.15 * jaccard  # only generic tokens overlap → weak
    if ingredient.get("brand") and ingredient.get("brand") == annexure.get("brand"):
        base = max(base, 0.98)
    if ingredient.get("family") and ingredient.get("family") == annexure.get("family"):
        base = max(base, 0.82)
    return round(base, 4)


def _profile_signature(concs: Dict[str, float]) -> Tuple[float, ...]:
    return tuple(round(safe_float(concs.get(sym, 0.0)), 6) for sym in ALL_ELEMENTS)


def _resolve_ingredient_match(name: str,
                              conc_map: Dict[str, Dict[str, float]],
                              identity_pool: Dict[str, List[str]] = None) -> Dict[str, Any]:
    identity = _extract_material_identity(name)
    empty = {
        "concs": {},
        "matched_key": "",
        "match_type": "none",
        "confidence": 0.0,
        "identity": identity,
        "identity_key": _identity_key(identity),
        "match_reason": "No annexure data available.",
        "validation_flags": [],
    }
    if not conc_map or not name:
        return empty

    candidates = _annexure_candidates(conc_map, identity_pool)
    blocked: List[str] = []

    def allowed_candidates() -> List[Dict[str, Any]]:
        allowed: List[Dict[str, Any]] = []
        for candidate in candidates:
            reason = _identity_conflict_reason(identity, candidate["identity"])
            if reason:
                blocked.append(f"{candidate['key']} ({reason})")
                continue
            allowed.append(candidate)
        return allowed

    # Stage 1: explicit brand identity is authoritative. If Aerosil is detected,
    # only an Aerosil annexure can satisfy the match.
    brand = safe_str(identity.get("brand"))
    if brand:
        brand_matches = [
            c for c in candidates
            if safe_str(c["identity"].get("brand")) == brand
            and not _identity_conflict_reason(identity, c["identity"])
        ]
        if brand_matches:
            brand_matches.sort(key=lambda c: (-_candidate_score(identity, c), c["order"]))
            best = brand_matches[0]
            return {
                "concs": best["concs"],
                "matched_key": best["key"],
                "match_type": "exact_brand",
                "confidence": 1.0,
                "identity": identity,
                "identity_key": _identity_key(identity),
                "match_reason": f"Detected brand '{brand}' and matched the same brand annexure.",
                "validation_flags": [],
            }
        # No same-brand annexure. Before giving up, a brand maps to a canonical
        # material family — an annexure that names that SAME material chemically
        # (e.g. brand "Polyox" ↔ annexure "Polyethylene oxide") is the same
        # substance and is allowed. Negative-constrained families stay blocked,
        # so this never re-opens Aerosil↔Prosolv (different families).
        brand_family = safe_str(BRAND_IDENTITY_RULES.get(brand, {}).get("family")) \
                       or safe_str(identity.get("family"))
        if brand_family:
            fam_matches = [
                c for c in candidates
                if safe_str(c["identity"].get("family")) == brand_family
                and not safe_str(c["identity"].get("brand"))   # annexure has no conflicting brand
                and not _identity_conflict_reason(identity, c["identity"])
            ]
            if fam_matches:
                fam_matches.sort(key=lambda c: (-_candidate_score(identity, c), c["order"]))
                best = fam_matches[0]
                return {
                    "concs": best["concs"],
                    "matched_key": best["key"],
                    "match_type": "brand_family",
                    "confidence": 0.9,
                    "identity": identity,
                    "identity_key": _identity_key(identity),
                    "match_reason": (
                        f"Brand '{brand}' had no same-brand annexure, but an "
                        f"annexure names the same material chemically "
                        f"({brand_family})."
                    ),
                    "validation_flags": [],
                }
        empty["match_reason"] = (
            f"Detected brand '{brand}', but no annexure with the same brand was found. "
            "Fuzzy and generic chemistry matches were blocked."
        )
        empty["validation_flags"] = ["brand_unresolved"]
        return empty

    allowed = allowed_candidates()

    # Stage 2: exact material name / exact extracted fragment.
    for candidate in allowed:
        ann_identity = candidate["identity"]
        ann_fragments = ann_identity.get("fragments", []) or []
        if any(f and f in ann_fragments for f in identity.get("fragments", [])):
            return {
                "concs": candidate["concs"],
                "matched_key": candidate["key"],
                "match_type": "exact_material",
                "confidence": 1.0,
                "identity": identity,
                "identity_key": _identity_key(identity),
                "match_reason": "Exact material-name identity match.",
                "validation_flags": [],
            }

    # Stage 2b: canonical-core match (noise-tolerant). Two names that differ only
    # in pharmacopeial refs, brand markers, descriptive qualifiers, or spelling
    # reduce to the same distinctive core. Accept when the cores are equal, or
    # one core fully contains the other (e.g. "Chlorobutanol Hemihydrate" core ⊆
    # "Chlorobutanol Hemihydrate USP (sifted)" core), provided the core is
    # non-trivially specific (≥1 distinctive token after generic removal).
    ing_core = identity.get("core") or frozenset()
    ing_core_dist = frozenset(_distinctive(set(ing_core)))
    if ing_core_dist:
        core_hits = []
        for candidate in allowed:
            ann_core = candidate["identity"].get("core") or frozenset()
            ann_core_dist = frozenset(_distinctive(set(ann_core)))
            if not ann_core_dist:
                continue
            if ing_core_dist == ann_core_dist:
                core_hits.append((candidate, 1.0))
            elif ing_core_dist <= ann_core_dist or ann_core_dist <= ing_core_dist:
                # containment — score by how complete the smaller side is
                smaller = min(ing_core_dist, ann_core_dist, key=len)
                larger = max(ing_core_dist, ann_core_dist, key=len)
                core_hits.append((candidate, len(smaller) / len(larger)))
        if core_hits:
            core_hits.sort(key=lambda x: (-x[1], x[0]["order"]))
            best, cscore = core_hits[0]
            # Require the top core match to be unambiguous
            if cscore >= 0.99 or len(core_hits) == 1 or \
               (len(core_hits) > 1 and cscore - core_hits[1][1] >= 0.15):
                return {
                    "concs": best["concs"],
                    "matched_key": best["key"],
                    "match_type": "canonical_core",
                    "confidence": round(min(1.0, 0.90 + 0.10 * cscore), 2),
                    "identity": identity,
                    "identity_key": _identity_key(identity),
                    "match_reason": (
                        "Matched on canonical material core after removing "
                        "pharmacopeial/brand/descriptor noise and reconciling spelling."
                    ),
                    "validation_flags": [],
                }

    # Stage 3: controlled dictionary / material-family match.
    family = safe_str(identity.get("family"))
    if family:
        family_matches = [
            c for c in allowed
            if safe_str(c["identity"].get("family")) == family
        ]
        if len(family_matches) == 1:
            best = family_matches[0]
            return {
                "concs": best["concs"],
                "matched_key": best["key"],
                "match_type": "dictionary",
                "confidence": 0.92,
                "identity": identity,
                "identity_key": _identity_key(identity),
                "match_reason": f"Single compatible annexure found for material family '{family}'.",
                "validation_flags": ["generic_family_match"] if best["identity"].get("brand") else [],
            }
        if len(family_matches) > 1:
            scored = sorted(family_matches,
                            key=lambda c: (-_candidate_score(identity, c), c["order"]))
            top_score = _candidate_score(identity, scored[0])
            next_score = _candidate_score(identity, scored[1])
            if top_score >= 0.95 and top_score >= next_score + 0.05:
                best = scored[0]
                return {
                    "concs": best["concs"],
                    "matched_key": best["key"],
                    "match_type": "dictionary",
                    "confidence": round(top_score, 2),
                    "identity": identity,
                    "identity_key": _identity_key(identity),
                    "match_reason": f"Best compatible dictionary match for material family '{family}'.",
                    "validation_flags": [],
                }
            empty["match_reason"] = (
                f"Multiple compatible annexures exist for material family '{family}'. "
                "A supplier or brand is required to choose one deterministically."
            )
            empty["validation_flags"] = ["ambiguous_family"]
            return empty

    # Stage 4: evidence-driven resolution over POOLED annexure identity.
    # Scores the ingredient against each candidate's full evidence (material name
    # + supplier + trade name + filename). Requires the best candidate to (a)
    # clear an acceptance threshold AND (b) beat the runner-up by a margin, so an
    # ambiguous tie returns UNKNOWN rather than a forced (possibly wrong) match.
    scored = sorted([(c, _candidate_score(identity, c)) for c in allowed],
                    key=lambda item: (-item[1], item[0]["order"]))
    if scored:
        best, score = scored[0]
        runner = scored[1][1] if len(scored) > 1 else 0.0
        margin = score - runner
        # Strong, unambiguous evidence → accept with calibrated confidence
        if score >= FUZZY_ACCEPT_THRESHOLD and (margin >= 0.10 or len(scored) == 1):
            # Confidence reflects evidence quality, not raw similarity alone:
            # blend the score with the separation margin, capped below 1.0 so
            # only exact/brand matches earn top confidence.
            conf = min(0.90, round(0.6 * score + 0.4 * min(1.0, score + margin), 2))
            return {
                "concs": best["concs"],
                "matched_key": best["key"],
                "match_type": "evidence",
                "confidence": conf,
                "identity": identity,
                "identity_key": _identity_key(identity),
                "match_reason": (
                    f"Resolved by pooled-evidence agreement (score {score:.2f}, "
                    f"margin over next candidate {margin:.2f})."
                ),
                "validation_flags": ["evidence_match"] if conf < 0.8 else [],
            }
        # Evidence exists but is ambiguous or weak → UNKNOWN, with explanation
        if score > 0:
            empty["match_reason"] = (
                f"Insufficient/ambiguous evidence to assign an annexure "
                f"(best score {score:.2f}, next {runner:.2f}, margin {margin:.2f}). "
                "Left UNKNOWN to preserve traceability rather than forcing a match."
            )
            empty["validation_flags"] = ["unresolved_ambiguous"]
            empty["candidates"] = [
                {"key": c["key"], "score": round(s, 2)} for c, s in scored[:5] if s > 0
            ]
            return empty
        # No token overlap at all, but compatible annexures exist → still offer
        # them to the semantic fallback (abbreviation/trade-name cases where token
        # scoring is blind). Capped to a few to keep the LLM call cheap.
        if scored:
            empty["validation_flags"] = ["unresolved_ambiguous"]
            empty["candidates"] = [{"key": c["key"], "score": 0.0}
                                   for c, _s in scored[:5]]
            empty["match_reason"] = (
                "No deterministic token overlap; deferring to semantic check."
            )
            return empty

    reason = "No compatible annexure passed deterministic identity checks."
    if blocked:
        reason += " Blocked candidate(s): " + "; ".join(_ordered_unique(blocked)[:5])
    empty["match_reason"] = reason
    return empty


def process_annexure(annexure_json: Any, index: int) -> Dict:
    """
    Ingest a structured annexure JSON produced by annexure_converter.py.
    No Claude calls needed here — the JSON already has exact extracted values.
    Validates structure, normalises element symbols, detects quality issues.
    """
    default: Dict = {
        "annexure_number": index,
        "supplier_name":   "",
        "material_name":   "",
        "source_type":     "",
        "date_filled":     "",
        "analytical_method": "",
        "elements":        [],
    }

    if not isinstance(annexure_json, dict):
        # Schema reconciliation: a converter/file may hand us a bare list. If it
        # looks like a list of element dicts, wrap it so the data is preserved
        # rather than discarded. Anything else → flagged default (never crash).
        if isinstance(annexure_json, list) and annexure_json and \
           all(isinstance(x, dict) for x in annexure_json):
            logger.warning(f"Annexure {index}: root was a list — coercing to "
                           f"{{'elements': [...]}} ({len(annexure_json)} items).")
            annexure_json = {"elements": annexure_json}
        else:
            logger.warning(f"Annexure {index}: JSON root is not a usable dict — "
                           f"got {type(annexure_json).__name__}. Flagged as malformed.")
            d = dict(default)
            d["_error"] = True
            d["extraction_notes"] = (f"Malformed annexure: expected an object, got "
                                     f"{type(annexure_json).__name__}.")
            return d

    # Copy top-level metadata
    result: Dict = dict(default)
    for field in ("supplier_name", "material_name", "source_type", "date_filled",
                  "analytical_method", "lot_number", "specification_reference",
                  "extraction_notes", "document_title", "filename"):
        val = annexure_json.get(field)
        if val is not None:
            result[field] = safe_str(val)
    # List-valued identity fallbacks (candidates)
    cands = annexure_json.get("material_name_candidates", [])
    if isinstance(cands, list):
        result["material_name_candidates"] = [safe_str(c) for c in cands if safe_str(c)]
    # If material_name is empty but candidates/title exist, promote the best one
    if not safe_str(result.get("material_name", "")):
        if result.get("material_name_candidates"):
            result["material_name"] = result["material_name_candidates"][0]
        elif safe_str(result.get("document_title", "")):
            result["material_name"] = safe_str(result["document_title"])
    # Strip generic document descriptors ("Material Characterization for X" → "X")
    result["material_name"] = _strip_doc_descriptor(safe_str(result.get("material_name","")))
    if isinstance(result.get("material_name_candidates"), list):
        result["material_name_candidates"] = [
            c for c in (_strip_doc_descriptor(x)
                        for x in result["material_name_candidates"]) if c
        ]
    # If stripping emptied the name, recover from candidates
    if not result.get("material_name") and result.get("material_name_candidates"):
        result["material_name"] = result["material_name_candidates"][0]
    result["annexure_number"] = index

    # Validate and normalise elements
    raw_elements = annexure_json.get("elements", [])
    if not isinstance(raw_elements, list):
        logger.warning(f"Annexure {index}: 'elements' is not a list")
        return result

    cleaned: List[Dict] = []
    seen_syms: set = set()

    for el in raw_elements:
        if not isinstance(el, dict):
            continue

        # Normalise symbol case-insensitively
        raw_sym = safe_str(el.get("symbol", ""))
        sym = next((k for k in ICH_PDE if k.upper() == raw_sym.upper()), None)
        if not sym:
            logger.debug(f"Annexure {index}: unknown element symbol {raw_sym!r} — skipped")
            continue
        if sym in seen_syms:
            continue  # deduplicate
        seen_syms.add(sym)

        # Concentration: normalize to µg/g using the stored unit (safeguard).
        raw_unit = safe_str(el.get("concentration_unit", "ppm")) or "ppm"
        conc_val = _parse_conc(el.get("concentration_value"), raw_unit)

        # Preserve the full audit trail produced by annexure_converter.py
        raw_value = el.get("raw_value", el.get("concentration_value", 0))
        try:    raw_value = float(raw_value)
        except (TypeError, ValueError): raw_value = 0.0

        cleaned.append({
            "symbol":               sym,
            "name":                 safe_str(el.get("name", ICH_PDE[sym]["name"])),
            "class":                safe_str(el.get("class", ICH_PDE[sym]["class"])),
            # concentration_value is ALWAYS µg/g after this point
            "concentration_value":  round(conc_val, 6),
            "concentration_unit":   "ug/g",
            "raw_value":            round(raw_value, 6),
            "raw_unit":             safe_str(el.get("raw_unit", raw_unit)),
            "data_status":          safe_str(el.get("data_status", "")),
            "analytical_method":    safe_str(el.get("analytical_method",
                                                     result.get("analytical_method", ""))),
            "intentionally_added":  safe_str(el.get("intentionally_added", "No")),
            "observed_level":       safe_str(el.get("observed_level", "")),
            "listed_in_coa":        safe_str(el.get("listed_in_coa", "")),
            "comments":             safe_str(el.get("comments", "")),
        })

    result["elements"] = cleaned

    # Quality flags
    n_vals  = len(cleaned)
    n_zero  = sum(1 for e in cleaned if e["concentration_value"] == 0.0)
    n_nonz  = n_vals - n_zero
    n_005   = sum(1 for e in cleaned
                  if abs(e["concentration_value"] - 0.05) < 0.001 and
                  e["concentration_value"] > 0)

    if n_vals > 0 and n_005 / n_vals > 0.4:
        logger.warning(
            f"Annexure {index} ({result.get('material_name','?')}): "
            f"{n_005}/{n_vals} concentrations = 0.05 — "
            "possible placeholder values from converter."
        )
        result["_warning_placeholder_values"] = True

    logger.info(
        f"Annexure {index}: {result.get('material_name','?')} | "
        f"{n_nonz} non-zero / {n_vals} elements"
    )
    return result


def process_annexure_pdf(pdf_bytes: bytes, index: int) -> Dict:
    """
    Extract EI data from an annexure supplied as a PDF file.
    Rasterizes each page and uses Claude Vision to read the EI table directly.
    This is the accurate path for scanned vendor annexure PDFs.
    """
    default = {
        "annexure_number": index,
        "supplier_name":   "",
        "material_name":   "",
        "source_type":     "",
        "date_filled":     "",
        "elements":        [],
    }

    try:
        doc = fitz.open(stream=pdf_bytes, filetype="pdf")
        page_images: List[bytes] = []
        mat = fitz.Matrix(250/72, 250/72)
        for page in doc:
            pix = page.get_pixmap(matrix=mat, alpha=False, colorspace=fitz.csRGB)
            page_images.append(pix.tobytes("png"))
        doc.close()
    except Exception as e:
        logger.error(f"Annexure {index} PDF rasterize failed: {e}")
        return default

    if not page_images:
        return default

    # Pass 1: extract supplier and material name from page 1
    meta_prompt = (
        "This is a vendor elemental impurity declaration form.\n"
        "Extract the supplier name and material/excipient name.\n"
        'Return ONLY: {"supplier_name":"exact company name","material_name":"exact material name"}'
    )
    meta_raw    = claude_vision(page_images[0], meta_prompt)
    meta_parsed = safe_json_parse(meta_raw, {})
    supplier = safe_str(meta_parsed.get("supplier_name", ""))
    material = safe_str(meta_parsed.get("material_name", ""))

    # Pass 2: extract EI concentrations from each page
    ei_prompt = (
        "This page is from a pharmaceutical vendor elemental impurity (EI) "
        "declaration form for ICH Q3D compliance.\n\n"
        "FIRST, identify the concentration UNIT from the column header/footnote:\n"
        "  ppm / µg/g / mg/kg  (equivalent)\n"
        "  ppb / ng/g / µg/kg  (1000x smaller than ppm)\n"
        "  %  (10000x larger than ppm)\n"
        "Report the EXACT unit you see in concentration_unit. Do NOT assume ppm "
        "if the header says ppb — that causes a 1000x error.\n\n"
        "Then extract concentration values for every element in the table:\n"
        "- Read every numeric value EXACTLY as printed (in its own unit)\n"
        "- '<0.3' or '\u22640.3' → use 0.3 (conservative)\n"
        "- 'BDL (0.034 ppm)' bracketed limit → use 0.034; observed_level the full text\n"
        "- 'BLQ'/'Below LOQ' with no bracket → use the LOQ if shown, else 0.0\n"
        "- 'ND'/'Not Detected'/'Below LOD' → 0.0\n"
        "- 'NA'/blank/not tested → 0.0\n"
        "- Never use 0.05 unless literally printed\n"
        "- observed_level: the EXACT raw cell text (audit trail)\n"
        "- Return empty elements list if no EI table on this page\n\n"
        "Return ONLY this JSON:\n"
        '{"elements":['
        '{"symbol":"Pb","name":"Lead","class":"1",'
        '"concentration_value":285,"concentration_unit":"ppb",'
        '"analytical_method":"ICP-MS","observed_level":"285 ppb"}'
        ']}'
    )

    all_elements: List[Dict] = []
    seen_symbols: set = set()

    for page_img in page_images:
        raw    = claude_vision(page_img, ei_prompt)
        parsed = safe_json_parse(raw, {})
        page_els = parsed.get("elements", [])
        if not isinstance(page_els, list):
            continue
        for el in page_els:
            if not isinstance(el, dict):
                continue
            # Normalise symbol: match case-insensitively against ICH_PDE keys
            raw_sym = safe_str(el.get("symbol", "")).strip()
            sym = next((k for k in ICH_PDE if k.upper() == raw_sym.upper()), None)
            if not sym:
                continue   # not a recognised ICH Q3D element
            if sym in seen_symbols:
                continue
            conc_raw = el.get("concentration_value")
            if conc_raw is None:
                continue
            try:
                conc_val = float(conc_raw)
            except (TypeError, ValueError):
                continue
            seen_symbols.add(sym)
            raw_unit = safe_str(el.get("concentration_unit", "ppm")) or "ppm"
            conc_ugg = _parse_conc(conc_val, raw_unit)   # normalize ppb/%/etc → µg/g
            all_elements.append({
                "symbol":              sym,
                "name":                safe_str(el.get("name", ICH_PDE.get(sym, {}).get("name", sym))),
                "class":               safe_str(el.get("class", ICH_PDE.get(sym, {}).get("class", ""))),
                "concentration_value": round(conc_ugg, 6),
                "concentration_unit":  "ug/g",
                "raw_value":           round(max(0.0, conc_val), 6),
                "raw_unit":            raw_unit,
                "data_status":         "actual",
                "analytical_method":   safe_str(el.get("analytical_method", "")),
                "intentionally_added": safe_str(el.get("intentionally_added", "No")),
                "observed_level":      safe_str(el.get("observed_level", "")),
                "listed_in_coa":       safe_str(el.get("listed_in_coa", "")),
                "comments":            safe_str(el.get("comments", "")),
            })

    logger.info(
        f"Annexure {index} PDF: supplier={supplier!r}, "
        f"material={material!r}, {len(all_elements)} elements"
    )
    return {
        "annexure_number": index,
        "supplier_name":   supplier,
        "material_name":   material,
        "source_type":     "",
        "date_filled":     "",
        "elements":        all_elements,
    }


# ── Calculation engine ────────────────────────────────────────────────────────
# Unit → µg/g (ppm) conversion factors (mirror of annexure_converter)
_UNIT_PPM_FACTOR = {
    "ppm":1.0,"µg/g":1.0,"ug/g":1.0,"mg/kg":1.0,"mcg/g":1.0,
    "ppb":0.001,"ng/g":0.001,"µg/kg":0.001,"ug/kg":0.001,
    "ppt":0.000001,"pg/g":0.000001,
    "%":10000.0,"percent":10000.0,"g/100g":10000.0,"w/w%":10000.0,
    "mg/g":1000.0,
}

def _unit_factor(unit: str) -> float:
    u = (unit or "").strip().lower().replace(" ","").replace("μ","µ")
    return _UNIT_PPM_FACTOR.get(u, 1.0)


def _parse_conc(val: Any, unit: str = "") -> float:
    """
    Parse a concentration to µg/g (ppm), applying unit conversion.
    Annexure JSON from annexure_converter.py already stores µg/g, but this
    guards against raw ppb/% values that bypassed normalization.
    BLQ/ND/blank → 0.0.
    """
    if val is None: return 0.0
    if isinstance(val, (int, float)):
        return round(max(0.0, float(val)) * _unit_factor(unit), 8)
    s = str(val).strip().lower()
    if s in ("","na","n/a","nd","blq","bdl","none","null","nq","not tested",
             "not detected","not quantified","below lod","below loq",
             "below limit","absent"): return 0.0
    # detect inline unit if not given
    inline_unit = unit
    for u in ("ppb","ng/g","µg/kg","ug/kg","ppt","mg/g","ppm","µg/g","ug/g","%"):
        if u in s:
            inline_unit = inline_unit or u
            break
    s2 = re.sub(r"(ppm|ppb|ppt|µg/g|ug/g|ng/g|mg/g|µg/kg|ug/kg|mg/kg|%|\s)", "", s)
    s2 = s2.replace("<","").replace(">","").replace("≤","")
    try: return round(max(0.0, float(s2)) * _unit_factor(inline_unit), 8)
    except: return 0.0


def _parse_amount_g(val: Any) -> float:
    """Parse ingredient amount to grams."""
    if val is None: return 0.0
    s = str(val).strip().lower()
    if s in ("","q.s.","qs","na","qs to ph","qs to 1ml","qs to volume"): return 0.0
    s = re.sub(r"[^\d.\-eE]","",s)
    try: return float(s)
    except: return 0.0


def _build_identity_pool(annexure_data: List[Dict]) -> Dict[str, List[str]]:
    """
    Build {material_name: [identity_source_strings]} for matching. Each annexure
    contributes its material_name PLUS supplier trade name, document title, and
    source filename so the matcher can resolve composition ingredients that use a
    supplier/brand/abbreviated name rather than the exact material_name.
    Product-agnostic: pools whatever identity text the annexure provides.
    """
    pool: Dict[str, List[str]] = {}
    for ann in annexure_data:
        if not isinstance(ann, dict):
            continue
        material = safe_str(ann.get("material_name", ""))
        cand = ann.get("material_name_candidates") or []
        if not material:
            material = (safe_str(cand[0]) if cand else "") \
                       or safe_str(ann.get("document_title","")) \
                       or safe_str(ann.get("supplier_name","")) \
                       or f"Annexure {ann.get('annexure_number','?')}"
        if not material:
            continue
        sources = [material]
        for fld in ("supplier_name", "trade_name", "brand_name", "document_title",
                    "title", "source_file", "filename", "annexure_title",
                    "specification_reference"):
            v = safe_str(ann.get(fld, ""))
            if v and v not in sources:
                sources.append(v)
        # Include all alternative identity candidates extracted by the converter
        for c in (ann.get("material_name_candidates", []) or []):
            cs = safe_str(c)
            if cs and cs not in sources:
                sources.append(cs)
        pool[material] = sources
    return pool


def _ei_element_rank(el: Dict) -> Tuple[int, int, float]:
    """Rank an EI element observation for cluster dedup: a MEASURED value beats an
    LOD/LOQ/BDL statement, a non-zero value beats zero, higher value wins ties."""
    ds = safe_str(el.get("data_status", "")).lower()
    raw = safe_str(el.get("raw_value", "")).lower()
    try:
        v = float(el.get("concentration_value", 0) or 0)
    except (TypeError, ValueError):
        v = 0.0
    is_lodloq = any(k in ds or k in raw
                    for k in ("lod", "loq", "bdl", "not detected", "<"))
    return (0 if is_lodloq else 1, 1 if v > 0 else 0, v)


def merge_ei_evidence(cluster: Dict) -> Dict:
    """Cluster evidence merge (EI side): UNION the ICH Q3D elements across every
    annexure documenting the SAME material, deduped by symbol preferring a
    measured value over LOD/LOQ, plus best material code / vendor and widened name
    candidates. A size-1 cluster returns that annexure unchanged (baselines safe)."""
    import annexure_identity_clustering as _AC
    anns = [a for a in (cluster.get("annexures") or []) if isinstance(a, dict)]
    if len(anns) <= 1:
        return anns[0] if anns else {}
    primary = _AC._pick_primary_annexure(cluster) or anns[0]
    merged = dict(primary)
    by_sym: Dict[str, Dict] = {}
    for a in anns:
        for el in (a.get("elements") or []):
            if not isinstance(el, dict):
                continue
            sym = safe_str(el.get("symbol", ""))
            if not sym:
                continue
            if sym not in by_sym or _ei_element_rank(el) > _ei_element_rank(by_sym[sym]):
                by_sym[sym] = el
    merged["elements"] = list(by_sym.values())
    cands = list(merged.get("material_name_candidates") or [])
    for a in anns:
        nm = safe_str(a.get("material_name", ""))
        if nm and nm not in cands:
            cands.append(nm)
    merged["material_name_candidates"] = cands
    code = _AC._pick_best_material_code(cluster)
    if code:
        merged["material_code"] = code
    vend = _AC._pick_best_vendor(cluster)
    if vend and not safe_str(merged.get("supplier_name", "")):
        merged["supplier_name"] = vend
    return merged


def _cluster_merge_ei_annexures(annexure_data: List[Dict]) -> List[Dict]:
    """Collapse annexures that document the same material into one merged evidence
    row (union of elements) so a CoA + declaration for one excipient no longer
    overwrite each other in the concentration map. Returns the merged list; on any
    failure returns the input unchanged so EI never regresses."""
    try:
        import annexure_identity_clustering as _AC
        clusters = _AC.cluster_annexures_by_identity(annexure_data)
        return [merge_ei_evidence(cl) for cl in clusters]
    except Exception:
        logger.exception("EI cluster merge skipped")
        return annexure_data


def _build_conc_map(annexure_data: List[Dict]) -> Dict[str, Dict[str, float]]:
    """
    Build {material_name: {symbol: conc_µg_per_g}}.
    Applies unit conversion using each element's concentration_unit so that
    ppb/%/mg-g values are correctly normalized to µg/g even if the converter
    did not already normalize them.
    """
    conc_map: Dict[str, Dict[str, float]] = {}
    for ann in annexure_data:
        if not isinstance(ann, dict): continue
        material = safe_str(ann.get("material_name",""))
        if not material:
            # Don't discard an annexure that has identity evidence elsewhere —
            # fall back to candidates / document title / supplier / a synthetic
            # key so its data remains visible to the mapping layer.
            cand = ann.get("material_name_candidates") or []
            material = (safe_str(cand[0]) if cand else "") \
                       or safe_str(ann.get("document_title","")) \
                       or safe_str(ann.get("supplier_name","")) \
                       or f"Annexure {ann.get('annexure_number','?')}"
        elem_dict: Dict[str, float] = {}
        for el in (ann.get("elements") or []):
            if not isinstance(el, dict): continue
            sym = safe_str(el.get("symbol",""))
            if not sym: continue
            unit = safe_str(el.get("concentration_unit",""))
            elem_dict[sym] = _parse_conc(el.get("concentration_value",0), unit)
        conc_map[material] = elem_dict
    return conc_map


def _build_audit_map(annexure_data: List[Dict]) -> Dict[str, Dict[str, Dict]]:
    """Build {material: {symbol: {raw_value, raw_unit, data_status, observed}}}."""
    audit: Dict[str, Dict[str, Dict]] = {}
    for ann in annexure_data:
        if not isinstance(ann, dict): continue
        material = safe_str(ann.get("material_name",""))
        if not material: continue
        sub: Dict[str, Dict] = {}
        for el in (ann.get("elements") or []):
            if not isinstance(el, dict): continue
            sym = safe_str(el.get("symbol",""))
            if not sym: continue
            sub[sym] = {
                "conc_ugg":    _parse_conc(el.get("concentration_value", 0),
                                           el.get("concentration_unit", "ug/g")),
                "raw_value":   el.get("raw_value", el.get("concentration_value", 0)),
                "raw_unit":    safe_str(el.get("raw_unit", el.get("concentration_unit","ug/g"))),
                "data_status": safe_str(el.get("data_status","")),
                "observed":    safe_str(el.get("observed_level","")),
            }
        audit[material] = sub
    return audit


def _match_ingredient_detailed(name: str,
                               conc_map: Dict[str, Dict[str, float]],
                               identity_pool: Dict[str, List[str]] = None
                               ) -> Tuple[Dict[str, float], str, str, float]:
    """
    Match ingredient name to an annexure material with identity-first rules.
    Returns (conc_dict, matched_key, match_type, confidence).
    match_type is one of exact_brand, exact_material, dictionary, fuzzy, none.
    """
    match = _resolve_ingredient_match(name, conc_map, identity_pool)
    return (
        match.get("concs", {}),
        safe_str(match.get("matched_key", "")),
        safe_str(match.get("match_type", "none")),
        safe_float(match.get("confidence", 0.0)),
    )

def _match_ingredient(name: str, conc_map: Dict[str, Dict[str, float]],
                      identity_pool: Dict[str, List[str]] = None) -> Dict[str, float]:
    """Backward-compatible wrapper — returns just the concentration dict."""
    concs, _key, _mtype, _conf = _match_ingredient_detailed(name, conc_map, identity_pool)
    return concs

def _semantic_adjudicate(ingredient_name: str,
                         candidates: List[Dict[str, Any]]) -> Optional[Dict[str, Any]]:
    """
    Scalable semantic fallback for ingredient↔annexure equivalence that the
    deterministic layer could not resolve. Asks Claude to judge whether the
    ingredient is the SAME material as any candidate annexure, understanding
    abbreviations, trade names, salts/hydrates, and chemical synonyms WITHOUT a
    hardcoded dictionary. Returns the chosen candidate dict + confidence, or None.

    This never forces a match: Claude is instructed to answer "none" unless it is
    confident the materials are chemically the same substance.
    """
    if not candidates:
        return None
    try:
        lines = []
        for i, c in enumerate(candidates):
            lines.append(f'{i}: "{c.get("key","")}"')
        cand_block = "\n".join(lines)
        prompt = (
            "You are a pharmaceutical materials expert performing entity "
            "resolution for an elemental-impurity report. Decide whether the "
            "COMPOSITION INGREDIENT below refers to the SAME physical material as "
            "any ANNEXURE CANDIDATE. Treat as the same material when they are the "
            "same chemical substance despite differences in: abbreviations (CMC = "
            "carboxymethylcellulose, Na = sodium), trade/brand names, pharmacopeial "
            "suffixes (USP, Ph.Eur), grade/qualifier descriptors, salt or hydrate "
            "forms, or spelling. Do NOT match merely because they share a common "
            "element or generic word (e.g. both contain 'sodium'). If you are not "
            "confident they are the same material, answer none.\n\n"
            f'COMPOSITION INGREDIENT: "{ingredient_name}"\n\n'
            f"ANNEXURE CANDIDATES:\n{cand_block}\n\n"
            'Return ONLY JSON: {"index": <candidate number or -1>, '
            '"confidence": <0.0-1.0>, "reason": "<short>"}'
        )
        raw = claude_text(prompt, max_tokens=400)
        data = safe_json_parse(raw, {})
        if not isinstance(data, dict):
            return None
        idx = data.get("index", -1)
        try:
            idx = int(idx)
        except Exception:
            idx = -1
        conf = safe_float(data.get("confidence", 0.0))
        if idx is None or idx < 0 or idx >= len(candidates) or conf < 0.70:
            return None
        chosen = candidates[idx]
        return {
            "candidate": chosen,
            "confidence": round(min(0.9, conf), 2),  # cap below deterministic-exact
            "reason": safe_str(data.get("reason", "semantic equivalence")),
        }
    except Exception as e:
        logger.warning(f"Semantic adjudication unavailable: {e}")
        return None


def calculate_ei_tables(comp_data: Dict, annexure_data: List[Dict]) -> Dict:
    """
    Product-agnostic EI calculation.
    
    Formula: Daily_exposure (µg/day) = Amount_in_MDD (g/day) × Conc (µg/g)
    
    For each ingredient:
      amount_in_mdd_g = ingredient_amount × (mdd_g / dose_unit_mass)
      daily_exposure  = amount_in_mdd_g × measured_conc_µg_per_g
    
    mdd_g = total mass of drug product per day in grams
    This works for: oral sachets, injections, tablets, topical, etc.
    """
    route       = safe_str(comp_data.get("route","oral"))
    mdd_g       = safe_float(comp_data.get("mdd_g", 1.0), default=1.0)
    doses_per_day = safe_int(comp_data.get("doses_per_day", 1), default=1)

    # Column keys Claude extracted from the spreadsheet
    ingredient_col  = safe_str(comp_data.get("ingredient_col", ""))
    amount_col      = safe_str(comp_data.get("amount_col", ""))
    amount_unit_raw = safe_str(comp_data.get("amount_unit", "mg")).lower()
    amount_per_dose = comp_data.get("amount_per_dose", True)

    def _get_field(row: Dict, col_key: str, fallbacks: List[str]) -> str:
        """Get a value from a row, checking columns dict first, then direct keys."""
        cols_dict = row.get("columns", {})
        if isinstance(cols_dict, dict):
            # Try exact column key
            if col_key and col_key in cols_dict:
                return safe_str(cols_dict[col_key])
            # Try all column values if key not found
            for k, v in cols_dict.items():
                for fb in fallbacks:
                    if fb.lower() in k.lower():
                        return safe_str(v)
        # Try direct row keys
        for fb in fallbacks:
            if fb in row:
                return safe_str(row[fb])
        return ""

    # Build ingredient list with daily intake in grams
    ingredients: List[Dict] = []
    sections = comp_data.get("sections") or []

    # ── Injection path: use pre-computed per-component daily intake ────────────
    # When comp_data carries "_injection_rows" (built by injection_support), each
    # row already has its daily intake (g/day for mass-based, mL/day for
    # volume-based) and a QS flag. We trust those and skip the OSD amount parsing.
    injection_rows = comp_data.get("_injection_rows")
    if injection_rows:
        for r in injection_rows:
            if not isinstance(r, dict):
                continue
            if r.get("_is_qs"):
                continue  # QS / process aids excluded from quantitative summation
            di = safe_float(r.get("_daily_intake", 0))
            if di <= 0:
                continue
            ingredients.append({
                "name":        safe_str(r.get("ingredient", "")),
                "daily_g":     round(di, 8),  # generic daily intake (g or mL)
                "mg_per_unit": safe_float(r.get("_component_mg", 0)) /
                               max(1, doses_per_day),
                "section":     safe_str(r.get("section", "")),
            })
    else:
        for section in sections:
            if not isinstance(section, dict): continue
            for row in (section.get("rows") or []):
                if not isinstance(row, dict): continue

                # ── Get ingredient name ──────────────────────────────────────
                name = _get_field(row, ingredient_col,
                                  ["ingredient","name","Name of Ingredient",
                                   "material","Material","component","Component"])
                if not name: continue

                # ── Get raw amount ───────────────────────────────────────────
                raw_amount_str = _get_field(row, amount_col,
                                            ["amount","qty","Qty","quantity","Quantity",
                                             "mg/unit","mg/mL"])
                amount_raw = _parse_amount_g(raw_amount_str)
                if amount_raw == 0:
                    continue  # skip fillers/QS with no amount

                # ── Convert to grams based on reported unit ──────────────────
                if "µg" in amount_unit_raw or "ug" in amount_unit_raw:
                    amount_g = amount_raw / 1_000_000.0
                elif "mg" in amount_unit_raw:
                    amount_g = amount_raw / 1000.0
                elif "ml" in amount_unit_raw:
                    amount_g = amount_raw
                elif "g" in amount_unit_raw:
                    amount_g = amount_raw
                else:
                    amount_g = amount_raw / 1000.0 if amount_raw > 1 else amount_raw

                # ── Scale to daily dose ──────────────────────────────────────
                daily_g = round(amount_g * doses_per_day, 8)
                mg_per_unit = round(amount_g * 1000.0, 6)
                section_name = safe_str(section.get("name", ""))
                ingredients.append({
                    "name":        name,
                    "daily_g":     daily_g,
                    "mg_per_unit": mg_per_unit,
                    "section":     section_name,
                })

    mdd_total = comp_data.get("mdd_total_mg_per_day", 0)
    logger.info(
        f"EI calc: {len(ingredients)} ingredient rows | route={route} | "
        f"doses_per_day={doses_per_day} | mdd_total={mdd_total}mg/day | "
        f"annexures={len(annexure_data)}"
    )

    # Cluster-merge annexures documenting the SAME material (union ICH Q3D
    # elements) so a CoA + declaration for one excipient contribute ONE merged
    # evidence row instead of overwriting in the concentration map. Size-1
    # clusters return the original annexure, so single-annexure EI baselines are
    # unchanged.
    annexure_data = _cluster_merge_ei_annexures(annexure_data)

    conc_map      = _build_conc_map(annexure_data)
    audit_map     = _build_audit_map(annexure_data)
    identity_pool = _build_identity_pool(annexure_data)

    # ── Match audit: every ingredient row, with type + confidence + raw data ──
    match_records: List[Dict] = []
    match_audit: List[Dict] = []
    total_daily_g_all = sum(ing["daily_g"] for ing in ingredients)
    for ing in ingredients:
        match = _resolve_ingredient_match(ing["name"], conc_map, identity_pool)
        # ── Semantic fallback (scalable, no hardcoded aliases) ────────────────
        # If deterministic resolution was UNKNOWN but produced plausible
        # candidates, ask the LLM to judge chemical equivalence. This covers
        # the long tail of abbreviation/trade-name/salt variations that no
        # dictionary can fully enumerate. It can only ADD a match, never override
        # a deterministic one, and never forces a low-confidence assignment.
        if (match.get("match_type") == "none"
                and match.get("validation_flags") == ["unresolved_ambiguous"]):
            cand_keys = [c.get("key") for c in (match.get("candidates") or [])]
            cand_objs = [{"key": k} for k in cand_keys if k]
            verdict = _semantic_adjudicate(ing["name"], cand_objs)
            if verdict:
                ckey = verdict["candidate"]["key"]
                if ckey in conc_map:
                    match = {
                        "concs": conc_map[ckey],
                        "matched_key": ckey,
                        "match_type": "semantic",
                        "confidence": verdict["confidence"],
                        "identity": match.get("identity", {}),
                        "identity_key": match.get("identity_key", ""),
                        "match_reason": "LLM semantic equivalence: " + verdict["reason"],
                        "validation_flags": ["semantic_match"],
                    }
        concs = match.get("concs", {})
        matched_key = safe_str(match.get("matched_key", ""))
        mtype = safe_str(match.get("match_type", "none"))
        conf = safe_float(match.get("confidence", 0.0))
        matched   = bool(concs) and mtype != "none"
        n_nonzero = sum(1 for v in concs.values() if v > 0)
        pct_mass  = round(ing["daily_g"] / total_daily_g_all * 100, 1) if total_daily_g_all else 0
        # Per-element raw audit for the matched material
        raw_audit = audit_map.get(matched_key, {}) if matched_key else {}
        identity = match.get("identity", {}) or {}
        profile_sig = _profile_signature(concs) if matched else tuple()
        match_record = {
            "ingredient":     ing["name"],
            "section":        ing.get("section", ""),
            "daily_g":        ing["daily_g"],
            "pct_of_total":   pct_mass,
            "matched":        matched,
            "matched_key":    matched_key,
            "match_type":     mtype,
            "match_confidence": conf,
            "n_nonzero_conc": n_nonzero,
            "detected_brand":  safe_str(identity.get("brand", "")),
            "material_family": safe_str(identity.get("family", "")),
            "identity_key":    safe_str(match.get("identity_key", "")),
            "match_reason":    safe_str(match.get("match_reason", "")),
            "validation_flags": match.get("validation_flags", []) or [],
            "profile_signature": profile_sig,
            "raw_audit":      raw_audit,
            "concs":           concs,
        }
        match_records.append(match_record)
        match_audit.append({k: v for k, v in match_record.items() if k != "concs"})
        if not matched:
            logger.warning(
                f"NO ANNEXURE MATCH: '{ing['name']}' "
                f"({ing['daily_g']:.4f}g/day, {pct_mass}% of total) — contributes 0."
            )
        elif n_nonzero == 0:
            logger.warning(
                f"ALL-ZERO: '{ing['name']}' matched '{matched_key}' ({mtype}) "
                f"but all elements = 0."
            )

    def build_one_table(elements: List[str]) -> Dict:
        rows: List[Dict] = []
        elem_totals: Dict[str, float] = {sym: 0.0 for sym in elements}
        total_intake = 0.0
        for idx, ing in enumerate(ingredients):
            if ing["daily_g"] == 0: continue
            match = match_records[idx]
            concs = match.get("concs", {})
            matched_key = safe_str(match.get("matched_key", ""))
            mtype = safe_str(match.get("match_type", "none"))
            conf = safe_float(match.get("match_confidence", 0.0))
            raw_audit = audit_map.get(matched_key, {}) if matched_key else {}
            measured:    Dict[str, float] = {}
            total_mass:  Dict[str, float] = {}
            audit_cells: Dict[str, Dict]  = {}
            for sym in elements:
                conc            = concs.get(sym, 0.0)
                measured[sym]   = round(conc, 6)
                mass            = ing["daily_g"] * conc
                total_mass[sym] = round(mass, 8)
                elem_totals[sym]= round(elem_totals[sym] + mass, 8)
                ra = raw_audit.get(sym, {})
                audit_cells[sym] = {
                    "conc_ugg":    round(conc, 6),
                    "raw_value":   ra.get("raw_value", conc),
                    "raw_unit":    ra.get("raw_unit", "ug/g"),
                    "data_status": ra.get("data_status", ""),
                    "observed":    ra.get("observed", ""),
                }
            total_intake += ing["daily_g"]
            rows.append({
                "ingredient":     ing["name"],
                "section":        ing.get("section", ""),
                "mg_per_unit":    ing.get("mg_per_unit", 0),
                "daily_intake_g": round(ing["daily_g"], 6),
                "matched_key":    matched_key,
                "match_type":     mtype,
                "match_confidence": conf,
                "match_reason":   safe_str(match.get("match_reason", "")),
                "detected_brand": safe_str(match.get("detected_brand", "")),
                "material_family": safe_str(match.get("material_family", "")),
                "validation_flags": match.get("validation_flags", []) or [],
                "measured_conc":  measured,
                "total_mass":     total_mass,
                "audit":          audit_cells,
            })

        pde_vals = {sym: get_pde(sym, route) for sym in elements}
        threshold = {sym: round(pde_vals[sym]*0.30, 6) if pde_vals[sym] else None
                     for sym in elements}

        # ── Explicit risk classification per element ──────────────────────────
        risk: Dict[str, str] = {}
        for sym in elements:
            total = elem_totals[sym]
            pde   = pde_vals[sym]
            if pde is None:
                risk[sym] = "no_pde"            # element has no established PDE (e.g. Mg)
            elif total > pde:
                risk[sym] = "exceeds_pde"       # >100% PDE — serious
            elif total > pde * 0.30:
                risk[sym] = "exceeds_30pct"     # >30% PDE — requires confirmatory testing
            else:
                risk[sym] = "low"               # <30% PDE — low risk
        return {
            "elements":           elements,
            "rows":               rows,
            "total_daily_intake": round(total_intake, 6),
            "element_totals":     {sym: round(v, 8) for sym, v in elem_totals.items()},
            "pde":                pde_vals,
            "threshold_30pct":    threshold,
            "risk":               risk,
            "route":              route,
            "match_audit":        match_audit,
            "unmatched_ingredients": [a for a in match_audit if not a["matched"]],
            "zero_conc_ingredients": [a for a in match_audit
                                      if a["matched"] and a["n_nonzero_conc"] == 0],
        }

    t5 = build_one_table(TABLE5_ELEMENTS)
    t6 = build_one_table(TABLE6_ELEMENTS)
    t7 = build_one_table(TABLE7_ELEMENTS)

    # ── Validation warnings — surfaced before report build ────────────────────
    warnings: List[str] = []
    # 1. Unmatched ingredients
    for a in match_audit:
        if not a["matched"]:
            warnings.append(
                f"Ingredient '{a['ingredient']}' ({a['daily_g']:.4f} g/day) "
                f"has NO annexure match — contributes 0 to all elements."
            )
    for a in match_audit:
        if not a["matched"] and a.get("match_reason"):
            warnings.append(
                f"Identity validation for '{a['ingredient']}': {a.get('match_reason')}"
            )
        elif a.get("matched") and a.get("n_nonzero_conc", 0) == 0:
            warnings.append(
                f"Ingredient '{a['ingredient']}' matched annexure "
                f"'{a.get('matched_key','?')}', but every elemental concentration is 0. "
                "Verify this is true nondetect data and not a missing-source substitution."
            )

    # 2. Suspicious unit cases: raw unit ppb but converted value looks like ppm-scale
    for a in match_audit:
        for sym, ra in (a.get("raw_audit") or {}).items():
            ru = (ra.get("raw_unit","") or "").lower()
            rv = safe_float(ra.get("raw_value", 0))
            if ru in ("ppb","ng/g","µg/kg","ug/kg") and rv >= 10:
                warnings.append(
                    f"'{a['ingredient']}' {sym}: raw {rv} {ru} — verify ppb→µg/g "
                    f"conversion was applied (expected {rv/1000:.4f} µg/g)."
                )
    for a in match_audit:
        flags = a.get("validation_flags", []) or []
        if a["matched"] and (
            a.get("match_type") == "fuzzy" or "generic_family_match" in flags
        ):
            warnings.append(
                f"Ingredient '{a['ingredient']}' was matched to annexure "
                f"'{a.get('matched_key','?')}' by {a.get('match_type')} "
                f"(confidence {a.get('match_confidence')}). {a.get('match_reason','')}"
            )

    matched_by_annexure: Dict[str, List[Dict]] = {}
    profiles_by_signature: Dict[Tuple[float, ...], List[Dict]] = {}
    for a in match_audit:
        if not a.get("matched"):
            continue
        matched_key = safe_str(a.get("matched_key", ""))
        matched_by_annexure.setdefault(matched_key, []).append(a)
        sig = tuple(a.get("profile_signature", ()) or ())
        if sig and any(v > 0 for v in sig):
            profiles_by_signature.setdefault(sig, []).append(a)

    for matched_key, rows_for_key in matched_by_annexure.items():
        identities = _ordered_unique([
            safe_str(r.get("identity_key")) or _norm_identity_text(r.get("ingredient", ""))
            for r in rows_for_key
        ])
        display_names = _ordered_unique([safe_str(r.get("ingredient", "")) for r in rows_for_key])
        if len(identities) > 1:
            warnings.append(
                f"Annexure '{matched_key}' is reused across distinct ingredient identities "
                f"{display_names[:5]}. Confirm this is intentional and not borrowed data."
            )

    for sig, rows_for_profile in profiles_by_signature.items():
        matched_keys = _ordered_unique([safe_str(r.get("matched_key", "")) for r in rows_for_profile])
        identities = _ordered_unique([
            safe_str(r.get("identity_key")) or _norm_identity_text(r.get("ingredient", ""))
            for r in rows_for_profile
        ])
        if len(matched_keys) > 1 or len(identities) > 1:
            names = _ordered_unique([safe_str(r.get("ingredient", "")) for r in rows_for_profile])
            warnings.append(
                f"Identical non-zero impurity profile detected across distinct mapped rows "
                f"{names[:5]} using annexure(s) {matched_keys[:5]}. Verify independent sources."
            )

    # 3. Totals over thresholds (all classes)
    for tbl, label in ((t5,"Class1/2A"),(t6,"Class2B"),(t7,"Class3")):
        for sym in tbl["elements"]:
            r = tbl["risk"].get(sym)
            tot = tbl["element_totals"].get(sym,0)
            pde = tbl["pde"].get(sym)
            if r == "exceeds_pde":
                warnings.append(f"{label} {sym}: {tot:.4f} µg/day EXCEEDS PDE ({pde}) — verify data/units.")
            elif r == "exceeds_30pct":
                warnings.append(f"{label} {sym}: {tot:.4f} µg/day exceeds 30% PDE ({pde}) — confirmatory testing.")
    # 4. High Pb/As/Tl in stearate-type lubricants (classic ppb-as-ppm error signature)
    for a in match_audit:
        nm = a["ingredient"].lower()
        if "stearate" in nm or "ligamed" in nm:
            for sym in ("Pb","As","Tl"):
                ra = (a.get("raw_audit") or {}).get(sym, {})
                rv_ugg = safe_float(ra.get("conc_ugg", ra.get("raw_value",0)))
                # if the stored value is implausibly high for a lubricant
                cm = conc_map.get(a.get("matched_key",""), {})
                if cm.get(sym, 0) > 5.0:
                    warnings.append(
                        f"'{a['ingredient']}' {sym} = {cm.get(sym):.3f} µg/g is unusually "
                        f"high for a lubricant — check for a ppb→µg/g unit error."
                    )

    # ── Calculation metadata / unit_config (consumed by generate_report.js) ───
    calc_model = safe_str(comp_data.get("calculation_model", "mass_based"))
    is_volume  = calc_model == "volume_based"
    is_inj     = ("parenteral" in route.lower() or "inject" in route.lower())
    unit_config = {
        "dosage_category":    "injection" if is_inj else "osd",
        "route":              route,
        "pde_route":          "parenteral" if is_inj else "oral",
        "calculation_model":  calc_model,
        "daily_intake_unit":  "mL/day" if is_volume else "g/day",
        "concentration_unit": "µg/mL"  if is_volume else "µg/g",
        "exposure_unit":      "µg/day",
        "intake_col_label":   "Daily Intake (mL/day)" if is_volume else "Daily Intake (g/day)",
        "conc_header_label":  "Measured Concentration (µg/mL)" if is_volume
                              else "Measured Concentration (µg/g)",
        # Per-presentation quantity column label: tablets→mg/tab, injections→mg/dose
        "qty_col_label":      "mg/dose" if is_inj else "mg/tab",
    }

    return {
        "class1_2a": t5,
        "class2b":   t6,
        "class3":    t7,
        "_match_audit":   match_audit,
        "_warnings":      warnings,
        "unit_config":    unit_config,
    }


# ── Text section generation ───────────────────────────────────────────────────
def generate_text_sections(header: Dict, annexure_data: List[Dict],
                           calc_tables: Dict, comp_data: Dict) -> Dict:
    """
    Generate all narrative text sections from the user-entered header + calculations.
    Fully product-agnostic — no reference PDF. All product details come from header.
    """
    # Standard regulatory references — always included regardless of product
    STANDARD_REFERENCES = (
        "1. Impurities: Guidelines for elemental impurities Q3D (R2) final "
        "version dated 26 April 2022. "
        "2. USP General Chapter <232> Elemental Impurities — Limits. "
        "3. USP General Chapter <233> Elemental Impurities — Procedures. "
        "4. Ph. Eur. 5.20 Metal Catalysts or Metal Reagents. "
        "5. ICH Q3D (R2) Option 1 — Concentration limits."
    )
    empty: Dict = {
        "abstract":"","objective":"","study_location":"NA","background":"",
        "sources_intro":"","drug_substance_section":"","excipient_intro":"",
        "manufacturing_section":"","container_closure_section":"","utilities_section":"",
        "control_strategy":"","testing_recommendation":"","conclusion":"",
        "observation":"","reference": STANDARD_REFERENCES,
    }
    # Product details come from the user-entered header — never hardcoded
    product     = safe_str(header.get("product_name", ""))
    dosage_form = safe_str(header.get("dosage_form", ""))
    strength    = safe_str(header.get("strength", ""))
    route       = safe_str(header.get("route", "") or comp_data.get("route", "oral"))
    mdd_mg      = safe_float(header.get("mdd_mg_per_day", 0))
    doses       = safe_int(header.get("doses_per_day", comp_data.get("doses_per_day", 1)))
    mdd_g       = safe_float(comp_data.get("mdd_g", mdd_mg/1000.0 if mdd_mg>0 else 1.0))
    meta        = {
        "product_name": product, "dosage_form": dosage_form, "strength": strength,
        "document_no": safe_str(header.get("document_no","")),
        "route_of_administration": route,
    }
    toc = []

    ann_summary = [{"material":a.get("material_name","N/A"),
                    "supplier":a.get("supplier_name","N/A"),
                    "n_elements":len(a.get("elements",[])or[])}
                   for a in annexure_data if isinstance(a, dict)]

    t5 = safe_calc_table(calc_tables,"class1_2a")
    t6 = safe_calc_table(calc_tables,"class2b")
    t7 = safe_calc_table(calc_tables,"class3")

    crossing = {}
    for sym in TABLE5_ELEMENTS:
        pde_val = t5["pde"].get(sym, 0) or 0
        total   = t5["element_totals"].get(sym, 0) or 0
        if pde_val and total > pde_val * 0.3:
            rows_with_sym = [r for r in t5.get("rows",[]) if isinstance(r,dict)]
            dominant = max(rows_with_sym,
                          key=lambda r: r.get("total_mass",{}).get(sym, 0),
                          default={})
            crossing[sym] = {
                "total":               round(total, 4),
                "pde":                 round(pde_val, 4),
                "pde30":               round(pde_val * 0.3, 4),
                "pct_pde":             round(total / pde_val * 100, 1),
                "dominant_contributor":dominant.get("ingredient", "unknown"),
            }

    # Tell Claude how many TOC sections there are so it writes the right structure
    toc_info = ""
    if toc:
        toc_info = "TOC sections from reference: " + "; ".join(
            f"{e.get('no','?')}. {e.get('title','')}" for e in toc[:15])

    # Build match audit context
    match_audit = calc_tables.get("_match_audit", [])
    unmatched   = [a["ingredient"] for a in match_audit if not a["matched"]]
    zero_conc   = [a["ingredient"] for a in match_audit
                   if a.get("matched") and a.get("n_nonzero_conc", 0) == 0]
    has_data_gaps = bool(unmatched or zero_conc)

    # Confirmatory testing is required when ANY element exceeds 30% PDE
    needs_confirmatory = bool(crossing)

    unmatched_warning = ""
    if unmatched:
        unmatched_warning = (
            f"\nDATA GAPS — {len(unmatched)} ingredient(s) had no annexure match "
            f"and contributed 0 to all elements: {unmatched[:8]}. "
            "Acknowledge this limitation in the conclusion."
        )
    if zero_conc:
        unmatched_warning += (
            f"\nZERO-CONCENTRATION INGREDIENTS — {len(zero_conc)} matched but "
            f"all concentrations = 0: {zero_conc[:5]}. May indicate extraction issues."
        )

    # ── Build deterministic fields that must not be left to Claude ──────────
    # Testing recommendation: ALWAYS required when any element > 30% PDE
    if needs_confirmatory:
        crossing_summary = "; ".join(
            f"{sym}: {v['total']:.4f}µg/day ({v['pct_pde']:.1f}% of PDE, "
            f"dominant contributor: {v['dominant_contributor']})"
            for sym, v in crossing.items()
        )
        forced_testing_rec = (
            "Confirmatory elemental impurity testing on Exhibit batches is recommended "
            "as per ICH Q3D (R2) Option 1 requirements. The following Class 1 and/or "
            f"Class 2A elements exceeded 30% of the PDE threshold: {crossing_summary}."
        )
        forced_conclusion = (
            "Based on this theoretical risk assessment, the elemental impurity levels "
            "in the drug product are within the ICH Q3D (R2) Option 1 limits for the "
            f"{route} route of administration for most elements. However, the following "
            f"Class 1/2A element(s) exceed 30% of the PDE threshold: "
            f"{', '.join(crossing.keys())}. The dominant contributor is "
            f"{list(crossing.values())[0]['dominant_contributor'] if crossing else 'unknown'}. "
            "Therefore, confirmatory elemental analysis on Exhibit batches is required "
            "prior to commercial release. No additional routine controls are required "
            "pending satisfactory Exhibit batch test results."
        )
    else:
        forced_testing_rec = (
            "Routine elemental impurity testing is not required as all elements are "
            "within 30% of the ICH Q3D (R2) PDE limits. However, elemental analysis "
            "on Exhibit batches is recommended as a confirmatory measure."
        )
        forced_conclusion = (
            "Based on this theoretical risk assessment conducted in accordance with "
            "ICH Q3D (R2), all elemental impurity levels in the drug product are "
            "within the Option 1 permitted concentration limits for the "
            f"{route} route of administration. No additional controls are required."
        )

    # ── Build observation text from actual calculation data ───────────────────
    t5_summary = []
    for sym in TABLE5_ELEMENTS:
        total = t5["element_totals"].get(sym, 0) or 0
        pde_v = t5["pde"].get(sym, 0) or 0
        thr   = t5["threshold_30pct"].get(sym, 0) or 0
        if pde_v:
            pct = round(total / pde_v * 100, 1)
            flag = " *** EXCEEDS 30% PDE ***" if total > thr else ""
            t5_summary.append(f"{sym}: {total:.4f}µg/day ({pct}% of PDE){flag}")

    forced_observation = (
        f"Class 1 and Class 2A element daily exposures ({route} route): "
        + "; ".join(t5_summary)
        + (f". Total daily product intake: {t5.get('total_daily_intake',0):.4f}g/day."
           if t5.get('total_daily_intake') else "")
        + (f" DATA GAPS: {len(unmatched)} ingredient(s) had no annexure match "
           f"({unmatched[:5]})." if unmatched else "")
    )

    # ── Build a STRICTLY DATA-BOUND material directory ────────────────────────
    # Each entry uses the EXACT annexure_number (same as Table 2) and ONLY the
    # supplier name that actually appears in the annexure. Nothing is invented.
    # This is the single source of truth the narrative must cite.
    material_directory: List[Dict] = []
    for ann in annexure_data:
        if not isinstance(ann, dict):
            continue
        mat = safe_str(ann.get("material_name", ""))
        if not mat or mat == "N/A":
            continue
        ann_no   = ann.get("annexure_number", "?")
        supplier = safe_str(ann.get("supplier_name", ""))
        # Which elements were actually reported with a non-zero level
        detected = [safe_str(e.get("symbol",""))
                    for e in (ann.get("elements") or [])
                    if isinstance(e, dict) and safe_float(e.get("concentration_value",0)) > 0]
        intentionally = [safe_str(e.get("symbol",""))
                    for e in (ann.get("elements") or [])
                    if isinstance(e, dict)
                    and safe_str(e.get("intentionally_added","")).lower() in ("yes","y","true")]
        material_directory.append({
            "material":       mat,
            "annexure_no":    ann_no,
            "supplier":       supplier,          # "" if vendor did not state it
            "detected":       [s for s in detected if s],
            "intentionally":  [s for s in intentionally if s],
        })

    # A compact, explicit listing for the prompt — each material with its OWN
    # annexure number and supplier (or "supplier not stated in annexure").
    directory_lines = []
    for m in material_directory:
        sup = m["supplier"] if m["supplier"] else "supplier not stated in annexure"
        det = ", ".join(m["detected"]) if m["detected"] else "none above reporting limit"
        directory_lines.append(
            f'  - "{m["material"]}" | Annexure {m["annexure_no"]} | supplier: {sup} '
            f'| elements detected: {det}'
        )
    directory_str = "\n".join(directory_lines) if directory_lines else "  (no annexures)"

    excipient_names = [m["material"] for m in material_directory]
    excipient_str = "; ".join(excipient_names[:16]) if excipient_names else "per composition"

    # Total daily product intake (g/day) from the calculated Class 1+2A table
    total_daily_g = safe_float(t5.get("total_daily_intake", mdd_g))

    # ── Route-appropriate manufacturing description (no template bleed-through) ─
    is_parenteral = "parenteral" in route.lower() or "inject" in route.lower()
    is_liquid     = any(k in dosage_form.lower()
                        for k in ("suspension","solution","syrup","liquid","injection","drops"))
    is_tablet     = any(k in dosage_form.lower()
                        for k in ("tablet","capsule","caplet"))
    is_sachet     = any(k in dosage_form.lower()
                        for k in ("sachet","granule","powder","pellet"))
    if is_tablet:
        mfg_process_hint = (
            "a solid oral dosage form. Typical process steps: dispensing, blending, "
            "granulation (wet or dry) where applicable, drying, lubrication, "
            "compression into tablets, and film coating where applicable. Contact "
            "parts are typically SS 316L. Do NOT mention compounding of bulk "
            "suspension, filtration, or liquid filling."
        )
    elif is_sachet:
        mfg_process_hint = (
            "a solid oral unit-dose (sachet/powder/granules). Typical process steps: "
            "dispensing, blending/granulation, drying, lubrication, and filling into "
            "sachets. Contact parts are typically SS 316L. Do NOT mention bulk "
            "suspension or liquid filling unless the dosage form is liquid."
        )
    elif is_parenteral or is_liquid:
        mfg_process_hint = (
            "a liquid/parenteral dosage form. Typical process steps: compounding of "
            "the solution/suspension, filtration, and aseptic or terminal filling. "
            "Contact parts are typically SS 316L, with tubing and filters."
        )
    else:
        mfg_process_hint = (
            f"a {dosage_form} dosage form. Describe only generic, route-appropriate "
            "process steps and contact materials (e.g. SS 316L). Do NOT assume a "
            "liquid or suspension process unless the dosage form indicates it."
        )

    prompt = (
        f"Write an ICH Q3D (R2) Technical Summary Report for Dr. Reddy's IPDO.\n\n"
        f"PRODUCT: {product}\n"
        f"DOSAGE FORM: {dosage_form}\n"
        f"STRENGTH (per unit dose): {strength}\n"
        f"ROUTE: {route}\n"
        f"MAXIMUM DAILY DOSE (MDD): {mdd_mg:.3f} mg of drug substance per day\n"
        f"  (taken as {doses} unit dose(s) per day; total product intake "
        f"= {total_daily_g:.4f} g/day)\n\n"
        "AUTHORITATIVE MATERIAL DIRECTORY — this is the ONLY source of truth.\n"
        "Cite the EXACT annexure number shown here for each material. Use ONLY the\n"
        "supplier shown here; if it says 'supplier not stated in annexure', do NOT\n"
        "invent or guess a manufacturer — write 'the manufacturer' instead.\n"
        f"{directory_str}\n\n"

        "STRICT GROUNDING RULES (regulatory audit requirement):\n"
        "1. Every statement must be traceable to the directory above or the product\n"
        "   details. Do NOT add generic claims that are not supported by the data.\n"
        "2. Annexure numbers in your narrative MUST match the directory exactly.\n"
        "   Never renumber. If a material is 'Annexure 3' above, call it Annexure 3.\n"
        "3. Never invent a supplier/manufacturer name. Use only what the directory states.\n"
        "4. Do NOT claim a vendor 'confirmed no elemental impurities are intentionally\n"
        "   added' unless that material's directory entry lists no intentionally-added\n"
        "   elements. If elements are listed as detected, describe them factually.\n"
        "5. Describe ONLY manufacturing steps appropriate to the dosage form (below).\n"
        "6. The ONLY annexures that exist are the numbered entries in the directory\n"
        "   above. Do NOT reference, name, or invent any annexure number or title\n"
        "   that is not in the directory. If you would cite an annexure that is not\n"
        "   listed, omit the citation entirely.\n\n"

        "Now write each section:\n\n"

        "abstract: 2-3 sentences. This report presents the risk assessment for elemental "
        "impurities in [PRODUCT] [STRENGTH] conducted per ICH Q3D (R2) and USP <232>. "
        "State the assessment aimed to determine likelihood of EI and establish controls. "
        "State the outcome factually based on the data (e.g. all below Option 1 limits; "
        "or confirmatory exhibit-batch testing recommended if any element exceeds 30% PDE).\n\n"

        "objective: Exactly: 'The objective of this report is to provide risk assessment "
        "for elemental impurities in [PRODUCT] [DOSAGE FORM] [STRENGTH].'\n\n"

        "study_location: Exactly: 'Not Applicable'\n\n"

        "background: Leave this field as an empty string \"\" — the Background "
        "section is authored by the user and inserted by the system, not by you.\n\n"

        "sources_intro: 1 sentence: 'Each category and the potential to contribute elemental "
        "impurities to the drug product are discussed in the following sections. As per USP <232> "
        "and ICH Q3D, considering the production of a drug product following are broad categories "
        "of potential sources of elemental impurities.'\n\n"

        "drug_substance_section: One paragraph for the drug substance (the active). Bold its "
        "name. State its manufacturer ONLY if the directory provides one. State which elements "
        "(if any) were intentionally added per the directory. State the vendor tested process "
        "validation batches per ICH Q3D with a validated analytical method, and detected levels "
        "were below the Option 1 limit / not detected as applicable. Cite the EXACT annexure "
        "number from the directory.\n\n"

        "excipient_intro: One paragraph PER excipient in the directory. Bold the name. "
        "Use this pattern, substituting ONLY directory facts: '[Name]: [Name] is manufactured "
        "by [exact supplier from directory, or \"the manufacturer\" if not stated]. The vendor "
        "has tested three batches of [Name] using a validated ICP-MS method in accordance with "
        "USP <232> and <233>. All test results demonstrated that the levels of elemental "
        f"impurities were below the Option 1 limits specified in ICH Q3D for {route} products. "
        "Therefore, no additional controls are required. The risk associated with this material "
        "is considered negligible. A declaration from the manufacturer is provided in Annexure "
        "[EXACT number from directory].' Repeat for EVERY material in the directory, using its "
        "OWN annexure number. Do NOT renumber sequentially — use the directory numbers.\n\n"

        "manufacturing_section: Describe equipment as a potential EI source and the quality "
        f"system controlling it. The product is {mfg_process_hint} "
        "Write 3-4 sentences. End with the quality-system controls: equipment design and "
        "installation qualification; equipment cleaning verification and validation; visual "
        "inspection and line clearance; routine maintenance inspections and schedules.\n\n"

        "container_closure_section: 'The ICH Q3D(R1) guideline contains recommendations on "
        "applying a risk-based approach to control elemental impurities. This guideline does not "
        "apply directly to container closure systems; however elemental impurities that have the "
        "potential to leach into the drug product are considered in the risk assessment. The "
        "determination of elemental impurities content is assessed in the drug product, and the "
        "container closure system is not representative of content in the final drug product. The "
        "vendor declaration is provided in the relevant annexure.'\n\n"

        "utilities_section: 'The risk of inclusion of elemental impurities from water is reduced "
        "as it complies with compendial (e.g. USP) water requirements.'\n\n"

        "control_strategy: 'Evaluation concluded that appropriate controls were in place to "
        "produce drug product with desired quality. Hence, no additional controls for testing "
        "and limits are required.'\n\n"

        "Write SYSTEM_OVERRIDE for: observation, conclusion, testing_recommendation, reference.\n"
        "Return ONLY valid JSON, no markdown:\n"
        '{"abstract":"","objective":"","study_location":"Not Applicable","background":"",\n'
        '"sources_intro":"","drug_substance_section":"","excipient_intro":"",\n'
        '"manufacturing_section":"","container_closure_section":"","utilities_section":"",\n'
        '"control_strategy":"","testing_recommendation":"SYSTEM_OVERRIDE",\n'
        '"conclusion":"SYSTEM_OVERRIDE","observation":"SYSTEM_OVERRIDE",'
        '"reference":"SYSTEM_OVERRIDE"}'
    )
    raw    = claude_text(prompt, max_tokens=6000)
    parsed = safe_json_parse(raw, {})
    if not isinstance(parsed, dict):
        logger.error("Text generation returned no valid JSON; using empty sections")
        return empty
    for k, v in empty.items():
        parsed.setdefault(k, v)

    # ── Override critical fields with deterministic values ────────────────────
    # These fields MUST reflect the actual calculation results — not Claude's guess.
    parsed["testing_recommendation"] = forced_testing_rec
    parsed["conclusion"]             = forced_conclusion
    parsed["observation"]            = forced_observation
    parsed["reference"]              = STANDARD_REFERENCES

    # ── Background is authored by the user, not the AI ────────────────────────
    # Compose it deterministically from the user-entered fields. Each structured
    # value goes on its own line, followed by the one-line description, so the
    # rendered Background reads as clean separate lines (no bullet symbols).
    bg_desc = safe_str(header.get("background_description", "")).strip()
    bg_lines = []
    if route:
        bg_lines.append(f"Route of administration: {route}")
    if dosage_form:
        bg_lines.append(f"Dosage form: {dosage_form}")
    if mdd_mg > 0:
        bg_lines.append(f"Maximum daily dose (MDD): {mdd_mg:.3f} mg/day")
    if bg_desc:
        bg_lines.append(bg_desc)
    if bg_lines:
        parsed["background"] = "\n".join(bg_lines)

    # ── Strip decorative / markdown artifacts from all generated prose ────────
    # Regulatory text must be clean: no **bold**, *italics*, backticks, bullet
    # glyphs, or stray asterisks. This does not touch scientific notation.
    def _clean_prose(text: str) -> str:
        if not isinstance(text, str) or not text:
            return text
        t = text
        t = re.sub(r"\*\*(.+?)\*\*", r"\1", t)      # **bold** → bold
        t = re.sub(r"(?<!\d)\*(?!\d)(.+?)(?<!\d)\*(?!\d)", r"\1", t)  # *italic*
        t = t.replace("`", "")                        # backticks
        t = re.sub(r"^[\s]*[•▪◦‣*\-]\s+", "", t, flags=re.MULTILINE)  # bullet glyphs
        t = re.sub(r"[ \t]*\*+[ \t]*", " ", t)        # stray asterisks → space
        t = re.sub(r"_{2,}", "", t)                   # markdown underscores
        t = re.sub(r"[ \t]{2,}", " ", t)              # collapse runs of spaces
        return t.strip()

    for _k, _v in list(parsed.items()):
        if isinstance(_v, str):
            parsed[_k] = _clean_prose(_v)

    logger.info(
        f"Text sections generated: needs_confirmatory={needs_confirmatory}, "
        f"crossing_elements={list(crossing.keys())}, "
        f"unmatched={len(unmatched)}, zero_conc={len(zero_conc)}"
    )
    return parsed


# ── Assemble and invoke Node.js ───────────────────────────────────────────────
def assemble_and_generate(ref_structure: Dict, page_images: List[bytes],
                          figure_pages: List[Dict], annexure_data: List[Dict],
                          comp_data: Dict, calc_tables: Dict, text_sections: Dict,
                          ref_bytes: bytes = b"", logo_b64: str = "",
                          logo_type: str = "") -> bytes:

    # Figures already carry their own base64 data — either an uploaded image
    # or an AI-generated SVG fishbone. No PDF rasterization needed.
    figures_b64: List[Dict] = []
    for fig in figure_pages:
        if not isinstance(fig, dict): continue
        data_b64 = fig.get("data_b64", "")
        if not data_b64: continue
        figures_b64.append({
            "page_index":   fig.get("page_index", 0),
            "description":  fig.get("description", ""),
            "figure_label": fig.get("figure_label", "Figure 1"),
            "data_b64":     data_b64,
            "media_type":   fig.get("media_type", "image/png"),
        })

    def _clean_annexure_name(s: str, fallback: str) -> str:
        """Keep annexure names exact but bounded — strip control chars and cap
        length so a verbose/garbled extraction cannot produce a hallucinated-
        looking long title. Never fabricate: empty stays as the neutral fallback."""
        s = safe_str(s)
        s = re.sub(r"\s+", " ", s).strip(" .,-—|")
        if not s:
            return fallback
        # A real material/vendor name is short; cap to avoid pasted paragraphs
        if len(s) > 80:
            s = s[:77].rstrip() + "…"
        return s

    annexure_list = [{"material": _clean_annexure_name(a.get("material_name",""),
                                                       "(material not stated)"),
                      "supplier": _clean_annexure_name(a.get("supplier_name",""),
                                                       "(vendor not stated)"),
                      "annexure": f"Annexure {a.get('annexure_number','?')}"}
                     for a in annexure_data if isinstance(a, dict)]

    # ── Source-traceability table: each ingredient → its matched annexure ─────
    # Lets a reviewer trace every calculated row back to a specific source.
    ann_no_by_material = {
        safe_str(a.get("material_name","")): a.get("annexure_number","?")
        for a in annexure_data if isinstance(a, dict)
    }
    traceability: List[Dict] = []
    for a in (calc_tables.get("_match_audit") or []):
        mkey = a.get("matched_key","")
        traceability.append({
            "ingredient":  a.get("ingredient",""),
            "section":     a.get("section",""),
            "daily_g":     a.get("daily_g",0),
            "matched_to":  mkey or "—",
            "annexure":    (f"Annexure {ann_no_by_material.get(mkey,'?')}"
                            if mkey else "No annexure match"),
            "match_type":  a.get("match_type",""),
            "confidence":  a.get("match_confidence",""),
            "detected_brand": a.get("detected_brand",""),
            "material_family": a.get("material_family",""),
            "match_reason": a.get("match_reason",""),
            "validation_flags": a.get("validation_flags", []),
            "status":      ("Matched" if a.get("matched") and a.get("n_nonzero_conc",0)>0
                            else ("Zero conc" if a.get("matched") else "No match")),
        })

    additional_tables = extract_additional_tables([])

    report_data = {
        "meta":              ref_structure.get("meta",{}) or {},
        "toc_entries":       ref_structure.get("toc_entries",[]) or [],
        "logo_b64":          logo_b64,
        "logo_type":         logo_type,
        "text_sections":     text_sections or {},
        # Composition (Table 1): prefer the verbatim display schema when the
        # injection flow provides it; otherwise use the OSD sections/columns.
        # Table 1 must reflect the uploaded Excel EXACTLY in both flows.
        "composition":       (comp_data.get("_display_sections")
                              or comp_data.get("sections",[]) or []),
        "comp_columns":      (comp_data.get("_display_columns")
                              or comp_data.get("columns",[]) or []),
        "comp_meta":         {"route": comp_data.get("route","oral"),
                              "mdd_g": comp_data.get("mdd_g",1.0),
                              "doses_per_day": comp_data.get("doses_per_day",1),
                              "unit": comp_data.get("unit",""),
                              "ingredient_col": comp_data.get("ingredient_col",""),
                              "amount_col": comp_data.get("amount_col",""),
                              "amount_unit": comp_data.get("amount_unit","mg")},
        "annexure_list":     annexure_list,
        "calc_tables":       calc_tables or {},
        "unit_config":       (calc_tables or {}).get("unit_config", {}),
        "traceability":      traceability,
        "revision_history":  ref_structure.get("revision_history",[]) or [],
        "signatures":        ref_structure.get("signatures",[]) or [],
        "figures":           figures_b64,
        "pde_values":        dict(ICH_PDE),
        # All non-EI tables extracted verbatim from reference PDF
        "additional_tables": additional_tables,
    }

    with tempfile.TemporaryDirectory() as tmpdir:
        json_path = Path(tmpdir) / "report_data.json"
        docx_path = Path(tmpdir) / "report.docx"
        js_script = Path(__file__).parent / "generate_report.js"
        with open(json_path,"w",encoding="utf-8") as f:
            _dump_payload_json(report_data, f)
        result = subprocess.run(
            ["node", str(js_script), str(json_path), str(docx_path)],
            capture_output=True, text=True, timeout=180)
        if result.returncode != 0:
            raise RuntimeError(
                f"Node.js failed (exit {result.returncode}).\n"
                f"STDERR: {result.stderr[-2000:]}\nSTDOUT: {result.stdout[-500:]}")
        if not docx_path.exists():
            raise RuntimeError(f"Node.js OK but no DOCX written.\nSTDOUT: {result.stdout}")
        docx_bytes = docx_path.read_bytes()
        if len(docx_bytes) < 5000:
            raise RuntimeError(f"DOCX too small ({len(docx_bytes)} bytes).")
        return docx_bytes


