            # Step 0: Pre-flight
            log.info("🔍 Validating uploads…")
            annexure_uploads = [(af.name, af.getvalue()) for af in annexure_files]
            errors = validate_inputs(ref_pdf.getvalue(), excel_file.getvalue(), annexure_uploads)
            if errors:
                for err in errors: st.error(f"❌ {err}")
                st.stop()
            st.success("✅ Pre-flight OK.")
            progress.progress(4)

            # Step 1: Rasterize PDF
            log.info("📄 Rasterizing reference PDF…")
            ref_bytes   = ref_pdf.getvalue()
            page_images = rasterize_pdf_pages(ref_bytes, dpi=150)
            st.success(f"Reference PDF: {len(page_images)} pages.")
            progress.progress(7)

            # Step 2: Logo
            log.info("🖼 Loading logo from assets/…")
            logo_bytes, logo_mt = load_logo_from_assets()
            logo_b64  = base64.standard_b64encode(logo_bytes).decode() if logo_bytes else ""
            logo_type = logo_mt
            if logo_b64: st.success("✅ Logo loaded from assets/logo.png")
            else: st.info("ℹ️ No logo in assets/. Save as assets/logo.png for logo in report.")
            progress.progress(10)

            # Step 3: Figure pages
