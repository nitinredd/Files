    }
    logo_bytes, logo_mt = load_logo_from_assets()
    logo_b64 = base64.standard_b64encode(logo_bytes).decode() if logo_bytes else ""
    return assemble_and_generate(
        ref_structure, [], [_build_fishbone_figure(header)], annexure_data, comp,
        calc_tables, text_sections, ref_bytes=b"", logo_b64=logo_b64,
        logo_type=logo_mt)


