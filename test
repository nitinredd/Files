// ── NUMBER FORMATTER ──────────────────────────────────────────────────────────
function fmt(val, dec) {
  if (dec==null) dec=4;
  if (val==null||val==="") return "";
  var n=parseFloat(String(val).replace(/[^0-9.eE+\-]/g,""));
  if (isNaN(n)||!isFinite(n)) return "";
  return n.toFixed(dec);
}

// ── CALCULATION TABLES 5/6/7 ─────────────────────────────────────────────────
// Formula: Daily exposure (µg/day) = daily_intake_g × conc_µg_per_g
// Responsive: font shrinks for wide tables
function buildTraceabilityTable(trace) {
  trace = Array.isArray(trace) ? trace : [];
  if (trace.length === 0) return [];
  var W = [Math.round(CW*0.24), Math.round(CW*0.11), Math.round(CW*0.08),
           Math.round(CW*0.24), Math.round(CW*0.14), 0];
  W[5] = CW - W[0] - W[1] - W[2] - W[3] - W[4];
  var hdr = new TableRow({children:[
    cell("Ingredient",       {bold:true,fill:CLR.HDR_GREY,w:W[0],size:SZ.SM}),
    cell("Section",          {bold:true,fill:CLR.HDR_GREY,w:W[1],size:SZ.SM}),
    cell("Daily (g)",        {bold:true,fill:CLR.HDR_GREY,w:W[2],size:SZ.SM}),
    cell("Source annexure",  {bold:true,fill:CLR.HDR_GREY,w:W[3],size:SZ.SM}),
    cell("Match / status",   {bold:true,fill:CLR.HDR_GREY,w:W[4],size:SZ.SM}),
    cell("Identity evidence", {bold:true,fill:CLR.HDR_GREY,w:W[5],size:SZ.SM}),
  ]});
  var rows = trace.map(function(t){
    var flags = Array.isArray(t.validation_flags) ? t.validation_flags : [];
    var evidence = [];
    if (t.detected_brand) evidence.push("Brand: " + t.detected_brand);
    if (t.material_family) evidence.push("Family: " + t.material_family);
    if (flags.length) evidence.push("Flags: " + flags.join(", "));
    if (t.match_reason) evidence.push(String(t.match_reason).slice(0, 180));
    return new TableRow({children:[
      cellL(String(t.ingredient||""),{w:W[0],size:SZ.XS}),
      cellL(String(t.section||""),   {w:W[1],size:SZ.XS}),
      cell(fmt(t.daily_g!=null?t.daily_g:0,5),{w:W[2],size:SZ.XS}),
      cellL(String(t.annexure||"")+(t.matched_to&&t.matched_to!=="\u2014"?(" ("+t.matched_to+")"):""),
            {w:W[3],size:SZ.XS}),
      cellL(String(t.status||"")+(t.match_type?(" / "+t.match_type):"")+
            (t.confidence!==""&&t.confidence!=null?(" "+t.confidence):""),
            {w:W[4],size:SZ.XS}),
      cellL(evidence.join("; "),{w:W[5],size:SZ.XS}),
    ]});
  });
  var tbl = new Table({width:{size:CW,type:WidthType.DXA}, columnWidths:W,
    rows:[hdr].concat(rows)});
  return [secHd("Source Traceability (ingredient \u2192 annexure)"),
          lftPara("Each calculated ingredient row and the annexure its elemental "+
                  "impurity values were taken from. Rows marked 'No match' contribute "+
                  "zero to all elements.",false,SZ.SM),
          tbl, pgBrk()];
}


function buildCalcTable(tableNum, tableData, pdeValues, unitConfig) {
  var uc = (unitConfig && typeof unitConfig==="object") ? unitConfig : {};
  var intakeUnit = uc.daily_intake_unit || "g/day";          // "g/day" | "mL/day"
  var intakeShort = intakeUnit.indexOf("mL")>=0 ? "mL" : "g"; // for the column header
  var concLabel  = uc.conc_header_label || "Measured Concentration (\u00B5g/g)";
  var qtyLabel   = uc.qty_col_label || "mg/tab";             // mg/tab | mg/dose
  var d=(tableData&&typeof tableData==="object")?tableData:{};
  var elements  = Array.isArray(d.elements)?d.elements:[];
  var rows      = Array.isArray(d.rows)?d.rows:[];
  var total     = d.total_daily_intake||0;
  var eTotals   = d.element_totals||{};
  var pde       = d.pde||{};
  var thresh    = d.threshold_30pct||{};
  var route     = d.route||"oral";

  if (elements.length===0) return [lftPara("Table "+tableNum+": No elements data.",false,SZ.SM)];

  var N=elements.length;
  var totalCols=3+2*N;
  var sz=totalCols<=12?SZ.SM:(totalCols<=18?SZ.XS:SZ.XXS);
  // Fixed columns scale with column count so wide tables (many elements) leave
  // enough room for the element columns without overflowing the page boundary.
  var fixedFrac = totalCols > 16 ? 0.26 : (totalCols > 12 ? 0.30 : 0.35);
  var INGR=Math.round(CW*fixedFrac*0.63);   // Component
  var MGT =Math.round(CW*fixedFrac*0.20);   // mg/tab
  var DI  =Math.round(CW*fixedFrac*0.17);   // Daily Intake (g)
  // Element columns share ALL remaining width equally; the last one absorbs the
  // rounding remainder so the column widths sum EXACTLY to CW (no overflow).
  var nElemCols=2*N;
  var remaining=CW-INGR-MGT-DI;
  var EW=nElemCols>0?Math.floor(remaining/nElemCols):remaining;
  var colW=[INGR,MGT,DI];
  for(var ci=0;ci<nElemCols;ci++) colW.push(EW);
  // Fix rounding so the total equals CW precisely
  var widthSum=colW.reduce(function(a,b){return a+b;},0);
  if(colW.length>0) colW[colW.length-1]+=(CW-widthSum);

  // Group consecutive same-class elements
  var grps=[];
  for(var gi=0;gi<elements.length;gi++){
    var sym=elements[gi];
    var cls=((pdeValues||{})[sym]||{}).class||"?";
    if(grps.length&&grps[grps.length-1].cls===cls) grps[grps.length-1].count++;
    else grps.push({cls:cls,count:1});
  }

  // Header rows
  var h1=new TableRow({children:[
    cell("Component",        {bold:true,fill:CLR.HDR_GREY,w:INGR,size:sz}),
    cell(qtyLabel,           {bold:true,fill:CLR.HDR_GREY,w:MGT, size:sz}),
    cell("Daily\nIntake\n("+intakeShort+")",{bold:true,fill:CLR.HDR_GREY,w:DI,  size:sz}),
    new TableCell({columnSpan:N,borders:allBdr(4),shading:shade(CLR.HDR_GREY),margins:mg(),
      children:[ctrPara(concLabel,true,sz)]}),
    new TableCell({columnSpan:N,borders:allBdr(4),shading:shade(CLR.HDR_GREY),margins:mg(),
      children:[ctrPara("Daily Exposure (\u00B5g/day)",true,sz)]}),
  ]});

  var h2cells=[emptyCell(CLR.HDR_GREY,INGR),emptyCell(CLR.HDR_GREY,MGT),emptyCell(CLR.HDR_GREY,DI)];
  for(var h=0;h<2;h++) grps.forEach(function(g){
    h2cells.push(new TableCell({columnSpan:g.count,borders:allBdr(4),shading:shade(CLR.HDR_GREY),
      margins:mg(),children:[ctrPara("Class "+g.cls,true,sz)]}));
  });
  var h2=new TableRow({children:h2cells});

  var h3cells=[emptyCell(CLR.HDR_GREY,INGR),emptyCell(CLR.HDR_GREY,MGT),emptyCell(CLR.HDR_GREY,DI)];
  for(var hh=0;hh<2;hh++) elements.forEach(function(s){
    h3cells.push(cell(s,{bold:true,fill:CLR.HDR_GREY,w:EW,size:sz}));
  });
  var h3=new TableRow({children:h3cells});

  var dataRows=rows.filter(Boolean).map(function(row){
    var mc=row.measured_conc||{}, tm=row.total_mass||{};
    var cells=[
      cellL(row.ingredient||"",{w:INGR,size:sz}),
      cell(fmt(row.mg_per_unit!=null?row.mg_per_unit:0,3),{w:MGT,size:sz}),
      cell(fmt(row.daily_intake_g!=null?row.daily_intake_g:0,6),{w:DI,size:sz}),
    ];
    elements.forEach(function(s){ cells.push(cell(fmt(mc[s]!=null?mc[s]:0,4),{w:EW,size:sz})); });
    elements.forEach(function(s){ cells.push(cell(fmt(tm[s]!=null?tm[s]:0,6),{w:EW,size:sz})); });
    return new TableRow({children:cells});
  });

  function footerRow(label,vals,fill,isThresh){
    var fc=[
      cell(label,{bold:true,fill:fill,align:AlignmentType.LEFT,w:INGR,size:sz}),
      emptyCell(fill,MGT),
      cell(label===totalLabel?fmt(total,6):"",{fill:fill,w:DI,size:sz}),
    ];
    elements.forEach(function(){ fc.push(emptyCell(fill,EW)); });
    elements.forEach(function(s){
      var val=vals[s]!=null?vals[s]:null;
      var tot=eTotals[s]!=null?eTotals[s]:null;
      var ex=isThresh&&val!=null&&tot!=null&&isFinite(val)&&isFinite(tot)&&tot>val;
      fc.push(cell(val!=null?fmt(val,3):"\u2013",{
        fill:ex?CLR.EXCEED_BG:fill, w:EW, size:sz,
        color:ex?CLR.EXCEED_TXT:CLR.BLACK,
      }));
    });
    return new TableRow({children:fc});
  }

  var totalLabel="TOTAL daily intake ("+intakeUnit+")";
  var lbls={5:"Class 1 and Class 2A",6:"Class 2B",7:"Class 3"};
  var caption="Table "+tableNum+": Theoretical Elemental Impurity Assessment ("
    +(lbls[tableNum]||"")+")"
    +" \u2014 Evaluation of Daily Exposure [Route: "+route+"]";

  var tbl=new Table({
    width:{size:CW,type:WidthType.DXA}, columnWidths:colW,
    rows:[h1,h2,h3].concat(dataRows).concat([
      footerRow(totalLabel,eTotals,CLR.HDR_GREY,false),
      footerRow("PDE (\u00B5g/day)",         pde,    CLR.HDR_GREY,false),
      footerRow("Threshold (30% PDE)",       thresh, CLR.THRESH_BG,true),
    ]),
  });
  return [lftPara(caption,true,SZ.SM), tbl, blk()];
}

