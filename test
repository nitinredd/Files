def call_claude(messages: List[Dict], max_tokens: int = 8192) -> str:
    for attempt in range(3):
        try:
            r = client.messages.create(model=MODEL, max_tokens=max_tokens, messages=messages)
            return "".join(b.text for b in r.content if hasattr(b, "text"))
        except Exception as e:
            logger.warning(f"Claude attempt {attempt+1} failed: {e}")
            if attempt < 2:
                time.sleep(2 ** attempt)
    return ""


def claude_text(prompt: str, max_tokens: int = 8192) -> str:
    return call_claude([{"role": "user", "content": prompt}], max_tokens)


def claude_vision(image_bytes: bytes, prompt: str, media_type: str = "image/png") -> str:
    if not image_bytes:
        return ""
    b64 = base64.standard_b64encode(image_bytes).decode()
    return call_claude([{"role": "user", "content": [
        {"type": "image", "source": {"type": "base64", "media_type": media_type, "data": b64}},
        {"type": "text", "text": prompt},
    ]}])


