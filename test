  var tbl = new Table({
    width:{size:CW,type:WidthType.DXA}, columnWidths:W,
    rows:[hdr].concat(rows),
  });
  ch.push(tbl);
  ch.push(blk());
  return ch;
}

// Number formatter
function fmt(val, dec) {
  if (dec==null) dec=4;
  if (val==null||val==="") return "";
  var n=parseFloat(String(val).replace(/[^0-9.eE+\-]/g,""));
  if (isNaN(n)||!isFinite(n)) return "";
  return n.toFixed(dec);
}

// Tables 4/5/6: Residual Solvent risk Assessment tables
// Each table covers a group of solvents with columns:
//   Components | Quantity/unit (mg) | *Amount in Max Dose (mg) |
//   [For each solvent: Limit (ppm) | Daily Exposure (mg)]
// Footer rows: Total Daily Exposure, Residual solvent Limit as per current USP <467>
function buildSolventAssessmentTable(tableNum, tableData) {
  var d = (tableData && typeof tableData === "object") ? tableData : {};
  var solvents    = Array.isArray(d.solvents) ? d.solvents : [];
  var rows        = Array.isArray(d.rows) ? d.rows : [];
  var totals      = d.totals || {};
  var usp_limits  = d.usp_limits || {};
  var caption     = d.caption || ("Table " + tableNum + ": Residual Solvent risk Assessment in drug product and comparison against the control levels");

  if (solvents.length === 0 && rows.length === 0) return [];

  var N = solvents.length;
  var totalCols = 3 + 2 * N; // Components, Qty, Amount, then 2 cols per solvent

  var sz = totalCols <= 10 ? SZ.SM : (totalCols <= 16 ? SZ.XS : SZ.XXS);

  var COMP_W = Math.round(CW * 0.22);
  var QTY_W  = Math.round(CW * 0.06);
  var AMT_W  = Math.round(CW * 0.07);
  var fixedW = COMP_W + QTY_W + AMT_W;
  var solW   = N > 0 ? Math.max(180, Math.floor((CW - fixedW) / (2 * N))) : 200;

  var colWidths = [COMP_W, QTY_W, AMT_W];
  for (var ci = 0; ci < 2 * N; ci++) colWidths.push(solW);

  // Header row 1: Components | Qty | Amount | [Solvent name spanning 2 cols each]
  var h1cells = [
    cell("Components", {bold:true, fill:CLR.HDR_GREY, w:COMP_W, size:sz}),
    cell("Quantity\n/ unit\n(mg)", {bold:true, fill:CLR.HDR_GREY, w:QTY_W, size:sz}),
    cell("*Amount\nin\nMaximum\nDose (mg)", {bold:true, fill:CLR.HDR_GREY, w:AMT_W, size:sz}),
  ];
  for (var si = 0; si < N; si++) {
    h1cells.push(new TableCell({
      columnSpan: 2,
      borders: allBdr(4),
      shading: shade(CLR.HDR_GREY),
      margins: mg(),
      verticalAlign: VerticalAlign.CENTER,
      children:[new Paragraph({
        alignment:AlignmentType.CENTER, spacing:{before:0,after:0},
        children:[new TextRun({text:String(solvents[si]||""), bold:true, size:sz, font:F, noProof:true})],
      })],
    }));
  }
  var h1 = new TableRow({children: h1cells});

  // Header row 2: empty | empty | empty | [Limit (ppm) | Daily Exposure (mg)] for each
  var h2cells = [
    emptyCell(CLR.HDR_GREY, COMP_W),
    emptyCell(CLR.HDR_GREY, QTY_W),
    emptyCell(CLR.HDR_GREY, AMT_W),
  ];
  for (var si2 = 0; si2 < N; si2++) {
    h2cells.push(cell("Limit\n(ppm)", {bold:true, fill:CLR.HDR_GREY, w:solW, size:sz}));
    h2cells.push(cell("Daily\nExposure\n(mg)", {bold:true, fill:CLR.HDR_GREY, w:solW, size:sz}));
  }
  var h2 = new TableRow({children: h2cells});

  // Data rows
  var dataRows = rows.filter(Boolean).map(function(row) {
