# ── Alias index (built once) ──────────────────────────────────────────────────
def _norm(text: str) -> str:
    s = (text or "").lower().strip()
    s = s.replace("\u00ad", "")
    s = re.sub(r"[^a-z0-9]+", " ", s)
    return re.sub(r"\s+", " ", s).strip()


_ALIAS_INDEX: Dict[str, str] = {}
for _canon, _info in RESIDUAL_SOLVENTS.items():
    _ALIAS_INDEX[_norm(_canon)] = _canon
    for _al in _info.get("aliases", []):
        _ALIAS_INDEX[_norm(_al)] = _canon


def resolve_solvent(name: str) -> Optional[str]:
    """Resolve a free-text solvent name to its canonical key, else None.
    Uses exact-alias match first, then a contained-token fallback."""
    if not name:
        return None
    n = _norm(name)
    if not n:
        return None
    if n in _ALIAS_INDEX:
        return _ALIAS_INDEX[n]
    # Token-contained fallback: alias fully contained in the input (or vice versa)
    best = None
    best_len = 0
    for alias_norm, canon in _ALIAS_INDEX.items():
        if not alias_norm:
            continue
        if (f" {alias_norm} " in f" {n} ") or (f" {n} " in f" {alias_norm} "):
            if len(alias_norm) > best_len:
                best, best_len = canon, len(alias_norm)
    return best


def get_solvent_info(name: str) -> Optional[Dict[str, Any]]:
    """Return the master record for a (possibly non-canonical) solvent name."""
    canon = resolve_solvent(name)
    if canon is None:
        return None
    info = dict(RESIDUAL_SOLVENTS[canon])
    info["canonical_name"] = canon
    return info


def get_limit_ppm(name: str) -> Optional[float]:
    info = get_solvent_info(name)
    return float(info["limit_ppm"]) if info and info.get("limit_ppm") is not None else None


def get_pde_mg_day(name: str) -> Optional[float]:
    info = get_solvent_info(name)
    return float(info["pde_mg_day"]) if info and info.get("pde_mg_day") is not None else None


def all_canonical_names() -> List[str]:
    return list(RESIDUAL_SOLVENTS.keys())
