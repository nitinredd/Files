# RS-RF2: DENSITY AUTO-ESTIMATION (liquid drug products)
# Approximate a liquid drug-product density (g/mL) from composition so the UI can
# pre-fill an OPTIONAL, overridable density field. Product-agnostic; never blocks.
# ══════════════════════════════════════════════════════════════════════════════
def estimate_density_from_composition(components: List[Dict]) -> float:
    """density ≈ 1.000 + solids_g_per_mL × 0.65, where solids_g_per_mL sums the
    per-mL mass (mg/mL ÷ 1000) of every non-q.s. component. Adjustments: >30% w/v
    sugar → 0.75 factor; >15% w/v alcohol → −0.05; emulsion → cap 1.02; >50% solids
    → cap 1.35. Clamped to [0.90, 1.35]. Each component: {name, mg_per_ml, is_qs}.
    (Epinephrine: 14.35 mg/mL solids → 1.000 + 0.01435×0.65 ≈ 1.009.)"""
    solids_mg = alcohol_mg = sugar_mg = 0.0
    emulsion = False
    for c in components or []:
        if not isinstance(c, dict) or c.get("is_qs") or c.get("_is_qs"):
            continue
        mg = c.get("mg_per_ml", c.get("qty_per_unit"))
        try:
            mg = float(mg)
        except (TypeError, ValueError):
            continue
        if mg <= 0:
            continue
        solids_mg += mg
        name = str(c.get("component") or c.get("name") or "").lower()
        if any(k in name for k in ("alcohol", "ethanol", "propylene glycol",
                                   "glycerin", "glycerol")):
            alcohol_mg += mg
        if any(k in name for k in ("sucrose", "sugar", "sorbitol", "syrup",
                                   "dextrose", "fructose", "maltitol")):
            sugar_mg += mg
        if any(k in name for k in ("oil", "lipid", "lecithin", "emulsion",
                                   "triglyceride")):
            emulsion = True
    solids_g = solids_mg / 1000.0
    density = 1.000 + solids_g * (0.75 if sugar_mg / 1000.0 > 0.30 else 0.65)
    if alcohol_mg / 1000.0 > 0.15:
        density -= 0.05
    if emulsion:
        density = min(density, 1.02)
    if solids_g > 0.50:
        density = min(density, 1.35)
    return round(max(0.90, min(density, 1.35)), 3)


def estimate_density_from_classified(classified: Dict) -> float:
    """Light-touch composition extraction from a classified Excel → density
    estimate. Defensive: returns 1.0 on any doubt (the value is overridable)."""
    comps: List[Dict] = []
    try:
        for r in (classified.get("rows") or []):
            if not isinstance(r, (list, tuple)):
                continue
            name, mg = "", None
            for cell in r:
                s = _s(cell)
                if not s:
                    continue
                if not name and re.search(r"[A-Za-z]", s) and not re.search(r"\d", s):
                    name = s
                n = _num_or_none(_strip_footnote_markers(s))
                if n is not None and 0 < n and (mg is None or n > mg):
                    mg = n
            if name and mg is not None and not _is_qs_ingredient(name):
                comps.append({"name": name, "mg_per_ml": mg, "is_qs": False})
    except Exception:
        return 1.0
    return estimate_density_from_composition(comps) if comps else 1.0


def parse_single_strength_unit_composition(classified: Dict,
                                           mdd_mg_day: Optional[float] = None,
                                           unit_basis: Optional[str] = None,
                                           salt_factor: float = 1.0,
                                           density_g_per_ml: float = 1.0,
                                           api_component: Optional[str] = None,
                                           no_of_doses: Optional[int] = None,
                                           dose_volume_ml: Optional[float] = None,
                                           overage_pct: float = 0.0) -> Dict:
    """Single-strength unit composition parser (RS RF1).

    Composition has ONE quantity column with a unit basis (mg/vial, mg/mL,
    mg/tablet, mg/sachet, mg/dose). The API row is auto-detected (its
    Function/Role cell reads Active / API / Drug Substance, else the first
    non-q.s. numeric row) and its per-unit quantity yields the dose multiplier.

    Solids (mg/vial, mg/tablet, …): the user supplies the API's Maximum Daily
    Dose (MDD, mg/day) and

        multiplier               = MDD_mg_day × salt_factor / api_qty_per_unit

    Volume-dosed liquids (mg/mL basis — RS Bug 1): the user supplies the daily
    dose VOLUME (mL/day) and the multiplier IS that volume directly — it is not
    derived from MDD ÷ strength, so a formulation strength that bakes in an API
    overage (e.g. 1.1 mg/mL for a 1 mg/mL label with 10% overage) does not skew
    the dose. In both cases:

        amount_in_maximum_dose_mg[i] = quantity_per_unit[i] × multiplier

    overage_pct (0.0 = none) only affects the DISPLAYED label strength (RS Bug
    6b): effective strength = api_qty / (1 + overage_pct); component amounts keep
    using the formulation strength as printed in the composition.

    salt_factor (default 1.0) reconciles a salt composition with a free-base MDD
    label. Drug-product mass: liquids use multiplier × 1000 × density (no summing
    of dissolved solids); solids sum the non-q.s. component amounts. A legacy
    no_of_doses path is retained only when MDD/volume are not supplied.
    """
    header = classified["header"]
    rows = classified["rows"]
    comp_idx = classified.get("comp_idx")
    qty_idx = classified.get("qty_idx")
    if qty_idx is None:
        qty_idx = _col_index(header, _QTY_HINTS)
    unit_basis = unit_basis or classified.get("unit_basis") or "unit"
    salt_factor = float(salt_factor) if salt_factor else 1.0
    density_g_per_ml = float(density_g_per_ml) if density_g_per_ml else 1.0
    overage_pct = float(overage_pct) if overage_pct else 0.0
    dose_volume_ml = float(dose_volume_ml) if dose_volume_ml else None
    is_liquid = unit_basis == "ml"

    if comp_idx is None or qty_idx is None:
        return {"mode": "single_strength_unit_composition", "rows": [],
                "needs_dose_basis": True,
                "error": "missing component or quantity column"}

    # Optional display columns
    matcode_idx = _col_index(header, ("material code", "mat code", "material_code",
                                      "sap code", "sap_code"))
    func_idx = _col_index(header, ("function", "role", "category"))
    stage_idx = _col_index(header, _STAGE_HINTS)
    compendia_idx = _col_index(header, _COMPENDIA_HINTS)

    qty_label = header[qty_idx]
    comp_label = header[comp_idx]

    display_columns = []
    if matcode_idx is not None:
        display_columns.append(header[matcode_idx])
    display_columns.append(comp_label)
    if func_idx is not None:
        display_columns.append(header[func_idx])
    if compendia_idx is not None:
        display_columns.append(header[compendia_idx])
    display_columns.append(qty_label)
    if stage_idx is not None:
        display_columns.append(header[stage_idx])

    # ── Pre-scan: locate the API row + its per-unit quantity ──────────────────
    prescan: List[Tuple[str, Optional[float], bool, str]] = []
    for r in rows:
        if comp_idx >= len(r):
            continue
        nm_raw = _s(r[comp_idx])
        if not nm_raw or _is_footer_row(nm_raw):
            continue
        nm = re.sub(r"\s*@\s*$", "", nm_raw).strip()
        raw_q = _s(r[qty_idx]) if qty_idx < len(r) else ""
        isqs = _is_qs_ingredient(nm_raw) or _is_qs_quantity(raw_q)
        q = _num_or_none(_strip_footnote_markers(raw_q)) if not isqs else None
        fv = _s(r[func_idx]) if (func_idx is not None and func_idx < len(r)) else ""
        prescan.append((nm, q, isqs, fv))

    api_name, api_qty = "", None
    if api_component:                       # explicit user/caller choice
        for nm, q, isqs, fv in prescan:
            if q and _rs_norm(nm) == _rs_norm(api_component):
                api_name, api_qty = nm, q
                break
    if api_qty is None and func_idx is not None:   # Function/Role = Active/API
        for nm, q, isqs, fv in prescan:
            if q and _API_FUNC_RE.search(fv):
                api_name, api_qty = nm, q
                break
    if api_qty is None:                     # fallback: first non-q.s. numeric row
        for nm, q, isqs, fv in prescan:
            if (not isqs) and q:
                api_name, api_qty = nm, q
                break

    # RS Bug 2: auto-reconcile a salt-form API with a free-base MDD label. When the
    # caller did not pass a salt factor, derive it from a base-equivalent asterisk
    # footnote: salt_factor = api_qty(salt) / base_weight. This covers the common
    # Trilaciclib format where the footnote gives only the base weight ("* 349 mg
    # dihydrochloride equivalent to 300 mg base" OR just "* equivalent to 300 mg
    # base") and the salt weight (349) is the API's Qty cell. Without this the
    # multiplier wrongly used the salt weight (432/349 = 1.238 instead of 1.44).
    salt_auto_applied = False
    if abs(salt_factor - 1.0) < 1e-9 and api_qty and api_qty > 0:
        for cell in _iter_classified_cells(classified):
            bw = _footnote_base_weight(cell)
            if bw and 0 < bw < api_qty:
                salt_factor = round(api_qty / bw, 6)
                salt_auto_applied = True
                break

    # ── Dose multiplier ───────────────────────────────────────────────────────
    # Volume-dosed liquids (RS Bug 1): the daily dose is a VOLUME (mL/day); the
    # multiplier IS that volume — never MDD ÷ strength — so an API overage baked
    # into the mg/mL strength does not inflate it.
    # Solids (RF2): multiplier = MDD × salt × (1 + overage) / api_qty. When the
    # solid strength is inclusive of a manufacturing overage, the number of units
    # per day = MDD_label ÷ effective_strength = MDD ÷ (api_qty / (1+overage)).
    # overage_pct = 0 (default) leaves the classic MDD ÷ api_qty behaviour intact
    # (no regression for Esomeprazole / Trilaciclib).
    if is_liquid and dose_volume_ml and dose_volume_ml > 0:
        multiplier = float(dose_volume_ml)
        mult_basis = "dose_volume_ml"
    elif mdd_mg_day and api_qty and api_qty > 0:
        multiplier = (float(mdd_mg_day) * salt_factor * (1.0 + overage_pct)) / float(api_qty)
        mult_basis = "mdd_over_api_qty"
    elif no_of_doses:
        multiplier = float(no_of_doses)
        mult_basis = "no_of_doses_legacy"
    else:
        multiplier = 1.0
        mult_basis = "default_multiplier_1"

    comp_rows: List[Dict] = []
    display_rows: List[Dict] = []
    for r in rows:
        if comp_idx >= len(r):
            continue
        name_raw = _s(r[comp_idx])
        if not name_raw:
            continue
        # Skip Total / Drug Product / Limit footer rows
        if _is_footer_row(name_raw):
            continue

        # display name: strip trailing '@' so the report reads cleanly
        name = re.sub(r"\s*@\s*$", "", name_raw).strip()

        # q.s. determination — name/quantity/ingredient hints
        raw_qty_cell = _s(r[qty_idx]) if qty_idx < len(r) else ""
        is_qs = (_is_qs_ingredient(name_raw)
                 or _is_qs_quantity(raw_qty_cell))

        cleaned_qty = _strip_footnote_markers(raw_qty_cell)
        qty = _num_or_none(cleaned_qty) if not is_qs else None

        amount_mg = None
        basis = "qs"
        if not is_qs and qty is not None and qty > 0:
            amount_mg = round(qty * multiplier, 6)
            basis = f"qty_times_multiplier_per_{unit_basis}"

        row_cols = {}
        if matcode_idx is not None and matcode_idx < len(r):
            mc = _s(r[matcode_idx])
            row_cols[header[matcode_idx]] = "" if mc in ("-", "—") else mc
        row_cols[comp_label] = name
        if func_idx is not None and func_idx < len(r):
            row_cols[header[func_idx]] = _s(r[func_idx])
        if compendia_idx is not None and compendia_idx < len(r):
            row_cols[header[compendia_idx]] = _s(r[compendia_idx])
        row_cols[qty_label] = raw_qty_cell
        if stage_idx is not None and stage_idx < len(r):
            row_cols[header[stage_idx]] = _s(r[stage_idx])

        comp_rows.append({
            "component": name,
            "quantity": qty if qty is not None else None,
            "amount_in_maximum_dose_mg": amount_mg,
            "amount_basis": basis,
            "_is_qs": is_qs,
            "solvents": {},
            "columns": row_cols,
        })
        display_rows.append({"ingredient": name, "columns": row_cols})

    known = [c["amount_in_maximum_dose_mg"] for c in comp_rows
             if (not c["_is_qs"]) and c["amount_in_maximum_dose_mg"] is not None]
    solid_mass = round(sum(known), 6) if known else None
    needs_dose_basis = any((not c["_is_qs"])
                           and c["amount_in_maximum_dose_mg"] is None
                           for c in comp_rows)

    # Drug-product mass per daily dose. Liquids (mL basis): the daily dose is a
    # VOLUME — mass = multiplier(mL/day) × 1000 × density; never sum dissolved
    # solids. Solids: sum of the non-q.s. component amounts. (is_liquid computed
    # once, up front.)
    if is_liquid:
        drug_product_mass_mg = round(multiplier * 1000.0 * density_g_per_ml, 6)
    else:
        drug_product_mass_mg = solid_mass
    # The API's own amount in the maximum daily dose (salt basis).
    api_amount_mg = (round(api_qty * multiplier, 6)
                     if api_qty is not None else None)

    # RF6 metadata: strength string + inferred dosage form (never a column header).
    # RS Bug 6b: for an overage product the DISPLAYED strength is the EFFECTIVE
    # (label) strength = api_qty / (1 + overage), e.g. 1.1 mg/mL → "1 mg/mL"; a
    # footnote records the overage. Component amounts still use the formulation
    # strength as printed. The API name is included for liquids per the approved
    # convention ("1 mg/mL Epinephrine").
    strength_note = ""
    if api_qty is not None:
        # Effective LABEL strength backs out (a) any manufacturing overage and
        # (b) a salt-form conversion, so the displayed strength is the free-base
        # label value, never the salt formulation weight (RS Bug 2 — Trilaciclib
        # 349 mg dihydrochloride → 300 mg base). salt_factor/overage default to
        # neutral, so Esomeprazole and other free-base APIs are unchanged (RF9).
        _sf = salt_factor if salt_factor else 1.0
        eff_qty = api_qty / (1.0 + overage_pct) / _sf
        if is_liquid:
            strength_label = f"{eff_qty:g} mg/mL"
            if api_name:
                strength_label = f"{strength_label} {api_name}"
        else:
            strength_label = f"{eff_qty:g} mg/{unit_basis}"
        if abs(_sf - 1.0) > 1e-9:
            # Salt-form footnote takes precedence: it records the salt weight and
            # its free-base equivalent (memory acceptance point 6).
            strength_note = (f"* {api_qty:g} mg {api_name or 'salt'} equivalent to "
                             f"{eff_qty:g} mg base")
        elif overage_pct:
            strength_note = (f"* API strength inclusive of {overage_pct * 100:g}% "
                             "overage")
    else:
        strength_label = ""
    dosage_form_inferred = _DOSAGE_BY_BASIS.get(unit_basis, "")

    return {
        "mode": "single_strength_unit_composition",
        "no_of_doses": round(multiplier, 6),   # kept for legacy display only
        "multiplier": round(multiplier, 6),
        "multiplier_basis": mult_basis,
        "mdd_mg_day": (float(mdd_mg_day) if mdd_mg_day else None),
        "salt_factor": salt_factor,
        "density_g_per_ml": density_g_per_ml,
        "api_component": api_name,
        "api_qty_per_unit": api_qty,
        "api_amount_mg": api_amount_mg,
        "unit_basis": unit_basis,
        "component_col": comp_label,
        "quantity_col": qty_label,
        "amount_col": "Amount in Maximum Dose (mg)",
        "mdi_col": "", "mdi_unit": "",
        "columns": [comp_label, qty_label, "Amount in Maximum Dose (mg)"],
        "solvents_display": [],
        "solvent_canon": {},
        "rows": comp_rows,
        "footer_total": {}, "footer_limit": {}, "drug_product_row": {},
        "has_calculated_values": False,
        "needs_dose_basis": needs_dose_basis,
        # Nominal MDD (mg/day): solids use the supplied MDD; a volume-dosed liquid
        # uses the label dose = effective strength × volume (e.g. 1 mg/mL × 8 mL =
        # 8 mg/day), never the sum of dissolved solids.
        "product_mdd_mg": (
            float(mdd_mg_day) if mdd_mg_day
            else round((api_qty / (1.0 + overage_pct) if overage_pct else api_qty)
                       * multiplier, 6)
            if (is_liquid and mult_basis == "dose_volume_ml" and api_qty is not None)
            else solid_mass),
        "drug_product_mass_mg": drug_product_mass_mg,
        "mdd_source": ("dose_volume_ml" if mult_basis == "dose_volume_ml"
                       else "mdd_over_api_qty" if mdd_mg_day else "legacy_doses"),
        "dose_volume_ml": dose_volume_ml,
        "overage_pct": overage_pct,
        "strength_label": strength_label,
        "strength_note": strength_note,
        "dosage_form_inferred": dosage_form_inferred,
        "_display_columns": display_columns,
        "_display_sections": [{"name": "Composition", "rows": display_rows}],
        "audit": {"unit_basis": unit_basis, "multiplier": round(multiplier, 6),
                  "api_component": api_name, "api_qty_per_unit": api_qty,
                  "mdd_mg_day": mdd_mg_day, "salt_factor": salt_factor},
        "warnings": [],
    }


def parse_component_mdd_only_excel(classified: Dict) -> Dict:
    """
    Mode C parser. Component name + a direct daily-amount column
    (Amount in Maximum Dose, or MDD/Maximum Daily Intake). Uses it directly,
    converting g→mg when needed. No strength / no_of_doses required.
    """
    header = classified["header"]
    rows = classified["rows"]
    comp_idx = classified.get("comp_idx")
    amount_idx = _col_index(header, _AMOUNT_HINTS)
    mdd_idx = _col_index(header, _MDD_HINTS)
    use_idx = amount_idx if amount_idx is not None else mdd_idx
    if comp_idx is None or use_idx is None:
        return {"mode": "component_mdd_only", "rows": [], "needs_dose_basis": True}

    use_label = header[use_idx].lower()
    unit = "mg"
    if re.search(r"\(\s*g\s*\)|\bgram", use_label) and not re.search(r"mg|µg|mcg|ug", use_label):
        unit = "g"
    elif re.search(r"µg|mcg|ug", use_label):
        unit = "ug"

    comp_rows = []
    display_rows = []
    for r in rows:
        if comp_idx >= len(r):
            continue
        name = _s(r[comp_idx])
        if not name:
            continue
        is_qs = any(h in name.lower() for h in _QS_HINTS)
        if _is_qs_ingredient(name):
            is_qs = True
        raw_val = _s(r[use_idx]) if use_idx < len(r) else ""
        if _is_qs_quantity(raw_val):
            is_qs = True
        val = _clean_num(_strip_footnote_markers(raw_val)) if use_idx < len(r) else None
        amount_mg = None
        basis = "none"
        if not is_qs and val is not None and val > 0:
            if unit == "g":
                amount_mg = val * 1000.0; basis = "mdi_grams"
            elif unit == "ug":
                amount_mg = val / 1000.0; basis = "mdi_micrograms"
            else:
                amount_mg = val; basis = "component_mdd_mg"
        comp_rows.append({
            "component": name, "quantity": None,
            "amount_in_maximum_dose_mg": amount_mg, "amount_basis": basis,
            "_is_qs": is_qs, "solvents": {}, "columns": {header[comp_idx]: name,
                                                         header[use_idx]: _s(r[use_idx])},
        })
        display_rows.append({"ingredient": name,
                             "columns": {header[comp_idx]: name,
                                         header[use_idx]: _s(r[use_idx])}})

    needs = any((not c["_is_qs"]) and c["amount_in_maximum_dose_mg"] is None for c in comp_rows)
    known = [c["amount_in_maximum_dose_mg"] for c in comp_rows
             if (not c["_is_qs"]) and c["amount_in_maximum_dose_mg"] is not None]
    return {
        "mode": "component_mdd_only", "no_of_doses": None,
        "component_col": header[comp_idx], "quantity_col": "",
        "amount_col": "Amount in Maximum Dose (mg)", "mdi_col": header[use_idx],
        "mdi_unit": unit,
        "columns": ["Components", "Amount in Maximum Dose (mg)"],
        "solvents_display": [], "solvent_canon": {},
        "rows": comp_rows, "footer_total": {}, "footer_limit": {},
        "drug_product_row": {}, "has_calculated_values": False,
        "needs_dose_basis": needs,
        "product_mdd_mg": round(sum(known), 6) if known else None,
        "mdd_source": "component_mdd_direct",
        "_display_columns": [header[comp_idx], header[use_idx]],
        "_display_sections": [{"name": "Composition", "rows": display_rows}],
        "audit": {"amount_unit": unit}, "warnings": [],
    }


def parse_rs_excel(raw: Dict, no_of_doses_override: int = 0) -> Dict:
    """
    Convert the raw extracted RS spreadsheet into a structured model.

    Implements the daily-intake hierarchy, normalising every quantitative
    component to `amount_in_maximum_dose_mg`:
      1. Amount in Maximum Dose (mg)            → use directly
      2. Maximum Daily Intake (g) / MDD (g)     → ×1000 → mg
      3. MDD (mg) / component daily amount (mg) → use directly
      4. Quantity/unit (mg) × No. of doses      → compute
      5. none of the above                      → needs_dose_basis = True
    """
    if not isinstance(raw, dict):
        raw = {}
    audit: Dict[str, Any] = {}
    warnings: List[str] = []

    component_col = _s(raw.get("component_col"))
    quantity_col  = _s(raw.get("quantity_col"))
    amount_col    = _s(raw.get("amount_col"))
    mdi_col       = _s(raw.get("mdi_col"))
    columns       = [_s(c) for c in (raw.get("columns") or []) if _s(c)]
    solvents_raw  = [_s(s) for s in (raw.get("solvents") or []) if _s(s)]
    has_calc      = bool(raw.get("has_calculated_values"))

    no_of_doses = no_of_doses_override or _num_or_none(raw.get("no_of_doses")) or 1
    no_of_doses = int(no_of_doses) if no_of_doses else 1

    # Determine mdi unit from header
    mdi_unit = ""
    if mdi_col:
        h = mdi_col.lower()
        if re.search(r"\(\s*g\s*\)|\bgram", h) and not re.search(r"mg|µg|mcg|ug", h):
            mdi_unit = "g"
        elif re.search(r"µg|mcg|ug", h):
            mdi_unit = "ug"
        else:
            mdi_unit = "mg"

    # Canonicalise solvent names against the master
    solvents: List[str] = []
    solvent_canon: Dict[str, str] = {}
    for s in solvents_raw:
        canon = RSM.resolve_solvent(s) or s
        solvents.append(s)             # preserve the sheet's display label
        solvent_canon[s] = canon

    def cell(row: Dict, col: str, fallbacks: List[str] = None) -> str:
        cols = row.get("columns", {})
        if isinstance(cols, dict):
            if col and col in cols:
                return _s(cols[col])
            for fb in (fallbacks or []):
                for k, v in cols.items():
                    if fb.lower() in k.lower():
                        return _s(v)
        # Also check top-level row keys (some LLM outputs flatten the row)
        if col and col in row:
            return _s(row[col])
        for fb in (fallbacks or []):
            for k, v in row.items():
                if k == "columns":
                    continue
                if fb.lower() in str(k).lower():
                    return _s(v)
        return ""

    # Walk rows: classify footer rows, build component rows
    comp_rows: List[Dict] = []
    footer_total: Dict[str, Any] = {}
    footer_limit: Dict[str, Any] = {}
    drug_product_row: Dict[str, Any] = {}

    for r in (raw.get("rows") or []):
        if not isinstance(r, dict):
            continue
        name = (_s(r.get("component"))
                or _s(r.get("ingredient"))
                or _s(r.get("name"))
                or cell(r, component_col, ["component", "name", "ingredient", "material"]))
        kind = _is_footer_row(name)

        # Per-solvent subvalues for this row.
        # IMPORTANT: match the solvent name to the column's solvent portion with
        # word boundaries, because some solvent names are substrings of others
        # (e.g. "Ethanol" ⊂ "Methanol"). Without this, Methanol's column would
        # wrongly satisfy a naive "ethanol in header" test.
        solvent_vals: Dict[str, Dict[str, Any]] = {}
        cols = r.get("columns", {})
        cols = cols if isinstance(cols, dict) else {}
        for disp in solvents:
            limit_v = None
            de_v = None
            d_low = disp.lower().strip()
            for k, v in cols.items():
                kl = str(k).lower()
                # Strip the role words to isolate the solvent portion of the header
                solvent_part = re.sub(
                    r"\b(limit|ppm|daily|exposure|mg|\(.*?\))\b", " ", kl)
                solvent_part = re.sub(r"[^a-z0-9 ]+", " ", solvent_part)
                tokens = solvent_part.split()
                # Match only if the solvent name appears as a whole token sequence
                disp_tokens = re.sub(r"[^a-z0-9 ]+", " ", d_low).split()
                is_match = disp_tokens and _seq_in(disp_tokens, tokens)
                if not is_match:
                    continue
                if "limit" in kl or "ppm" in kl:
                    limit_v = _num_or_none(v)
                elif "exposure" in kl or "daily" in kl:
                    de_v = _num_or_none(v)
            solvent_vals[disp] = {"limit": limit_v, "daily_exposure": de_v}

        if kind == "total":
            footer_total = {disp: solvent_vals[disp] for disp in solvents}
            continue
        if kind == "limit":
            footer_limit = {disp: solvent_vals[disp] for disp in solvents}
            continue
        if kind == "drug_product":
            drug_product_row = {
                "component": name,
                "quantity": _num_or_none(cell(r, quantity_col, ["quantity"])),
                "amount_max_dose": _num_or_none(cell(r, amount_col, ["amount in maximum", "amount"])),
                "solvents": solvent_vals,
            }
            continue
        if not name:
            continue

        is_qs = any(h in name.lower() for h in _QS_HINTS)
        if _is_qs_ingredient(name):
            is_qs = True
        # If ALL three quantity cells (amount/qty/mdi) are q.s.-like, force q.s.
        raw_amount = cell(r, amount_col, ["amount in maximum", "amount"])
        raw_qty = cell(r, quantity_col, ["quantity"])
        raw_mdi = cell(r, mdi_col, ["maximum daily intake", "mdd"]) if mdi_col else ""
        _qs_cells = [raw_amount, raw_qty, raw_mdi]
        if all(_is_qs_quantity(v) for v in _qs_cells if v):
            is_qs = True

        # ── daily-intake hierarchy → amount_in_maximum_dose_mg ───────────────
        amount_mg: Optional[float] = None
        basis = "none"
        amt = _num_or_none(_strip_footnote_markers(raw_amount))
        qty = _num_or_none(_strip_footnote_markers(raw_qty))
        mdi = (_num_or_none(_strip_footnote_markers(raw_mdi))
               if mdi_col else None)

        if is_qs:
            pass                        # calc-exempt
        elif amt is not None and amt > 0:
            amount_mg = amt
            basis = "amount_in_maximum_dose"
        elif mdi is not None and mdi > 0:
            if mdi_unit == "g":
                amount_mg = mdi * 1000.0
                basis = "mdi_grams"
            elif mdi_unit == "ug":
                amount_mg = mdi / 1000.0
                basis = "mdi_micrograms"
            else:
                amount_mg = mdi
                basis = "mdd_mg"
        elif qty is not None and qty > 0:
            amount_mg = qty * no_of_doses
            basis = "qty_times_doses"

        comp_rows.append({
            "component": name,
            "quantity": qty,
            "amount_in_maximum_dose_mg": amount_mg,
            "amount_basis": basis,
            "_is_qs": is_qs,
            "solvents": solvent_vals,     # sheet-provided limits/exposures (detailed mode)
            "columns": dict(r.get("columns", {})) if isinstance(r.get("columns"), dict) else {},
        })

    # Determine whether any quantitative row lacks a dose basis
    needs_dose_basis = any(
        (not cr["_is_qs"]) and cr["amount_in_maximum_dose_mg"] is None
        for cr in comp_rows
    )

    mode = "detailed" if (has_calc and solvents) else "basic"

    # ── Infer product-level Maximum Daily Dose from the Excel (no user input) ──
    # Priority: an explicit "Drug Product" total row → else the sum of component
    # amounts in maximum dose. This is shown on the verification screen and is
    # editable, mirroring the injection workflow (no forced MDD/strength entry).
    product_mdd_mg: Optional[float] = None
    mdd_source = "not_determinable"
    dp_amt = None
    if drug_product_row:
        dp_amt = drug_product_row.get("amount_max_dose")
    if dp_amt is not None and dp_amt > 0:
        product_mdd_mg = float(dp_amt)
        mdd_source = "excel_drug_product_row"
    else:
        known = [cr["amount_in_maximum_dose_mg"] for cr in comp_rows
                 if (not cr["_is_qs"]) and cr["amount_in_maximum_dose_mg"] is not None]
        if known:
            product_mdd_mg = round(sum(known), 6)
            mdd_source = "sum_of_component_amounts"

    return {
        "mode": mode,
        "no_of_doses": no_of_doses,
        "component_col": component_col,
        "quantity_col": quantity_col,
        "amount_col": amount_col,
        "mdi_col": mdi_col,
        "mdi_unit": mdi_unit,
        "columns": columns,
        "solvents_display": solvents,
        "solvent_canon": solvent_canon,
        "rows": comp_rows,
        "footer_total": footer_total,
        "footer_limit": footer_limit,
        "drug_product_row": drug_product_row,
        "has_calculated_values": has_calc,
        "needs_dose_basis": needs_dose_basis,
        "product_mdd_mg": product_mdd_mg,
        "mdd_source": mdd_source,
        "audit": audit,
        "warnings": warnings,
    }


