import html as _html
from typing import Any, Dict, List, Optional


def _e(s: Any) -> str:
    return _html.escape(str(s) if s is not None else "")


def _render_source(c: Dict) -> str:
    st = c.get("source_type", "")
    src = c.get("source", {}) or {}
    formula = c.get("formula", "")
    inputs_c = c.get("inputs", {}) or {}
    flags = c.get("flags", []) or []

    parts: List[str] = []

    if st == "annexure":
        parts.append(f"<b>Annexure {_e(src.get('annexure_index','?'))}</b>"
                     f" — {_e(src.get('filename',''))}<br>")
        parts.append(f"Material: {_e(src.get('material_name',''))}<br>")
        parts.append(f"Supplier: {_e(src.get('supplier',''))}<br>")
        parts.append(f"Element: <b>{_e(src.get('element_symbol',''))}</b><br>")
        parts.append(f"Field path: <code>{_e(src.get('field_path',''))}</code><br>")
        parts.append(f"Raw value: {_e(src.get('raw_value',''))}<br>")
        parts.append(f"Unit: {_e(src.get('unit',''))}<br>")
        parts.append(f"Analytical method: {_e(src.get('analytical_method',''))}")

    elif st == "excel_row":
        parts.append(f"<b>{_e(src.get('filename',''))}</b><br>")
        parts.append(f"Sheet: <em>{_e(src.get('sheet',''))}</em>, "
                     f"Row {_e(src.get('row_number','?'))}<br>")
        parts.append(f"Amount raw: {_e(src.get('amount_raw',''))}"
                     f" {_e(src.get('amount_unit',''))}<br>")
        parts.append(f"Column: <code>{_e(src.get('amount_col',''))}</code><br>")
        if formula:
            parts.append(f"Formula: <code>{_e(formula)}</code><br>")
        fi = c.get("formula_inputs", {}) or {}
        if fi:
            parts.append(f"MDD: {_e(fi.get('mdd_g',''))} g, "
                         f"Doses/day: {_e(fi.get('doses_per_day',''))}")

    elif st == "calculated":
        parts.append(f"Formula: <code>{_e(formula)}</code><br>")
        for key, val in inputs_c.items():
            cid_ref = _e(val.get("citation_id", ""))
            parts.append(
                f"{_e(key)}: {_e(val.get('value',''))}"
                + (f" [<a href='#cite-{cid_ref}'>{cid_ref}</a>]" if cid_ref else "")
                + "<br>"
            )

    elif st == "regulatory":
        parts.append(f"<b>ICH Q3D (R2)</b><br>")
        parts.append(f"Appendix Table: <b>{_e(src.get('table',''))}</b><br>")
        parts.append(f"Element: {_e(src.get('element',''))}, "
                     f"Class: {_e(src.get('class',''))}<br>")
        parts.append(f"Route: {_e(src.get('route',''))}<br>")
        parts.append(f"Unit: {_e(src.get('unit',''))}")

    elif st == "derived":
        parts.append(f"Formula: <code>{_e(formula)}</code><br>")
        pde_inp = inputs_c.get("pde_value", {})
        pde_cid = _e(pde_inp.get("citation_id", ""))
        parts.append(
            f"PDE: {_e(pde_inp.get('value',''))}"
            + (f" [<a href='#cite-{pde_cid}'>{pde_cid}</a>]" if pde_cid else "")
            + "<br>"
        )
        parts.append(f"Factor: {_e(inputs_c.get('factor', 0.30))}<br>")
        parts.append(f"Guideline: {_e(c.get('guideline','ICH Q3D (R2)'))}")

    elif st == "generated_text":
        parts.append(f"<b>Claude-generated text</b><br>")
        parts.append(f"Prompt: {_e(src.get('prompt_name',''))}<br>")
        parts.append(f"Prompt SHA-256 (first 16): "
                     f"<code>{_e(src.get('prompt_hash',''))}</code><br>")
        fields = src.get("meta_fields_used") or []
        if fields:
            parts.append(f"Meta fields: {_e(', '.join(str(f) for f in fields))}<br>")
        anns = src.get("annexure_numbers_referenced") or []
        if anns:
            parts.append(f"Annexures: {_e(', '.join(str(a) for a in anns))}<br>")
        calc = src.get("calc_results_referenced") or []
        if calc:
            parts.append(f"Calc refs: {_e(', '.join(str(r) for r in calc))}<br>")
        parts.append(f"Model: {_e(src.get('model',''))}<br>")
        parts.append(f"Timestamp: {_e(src.get('timestamp',''))}")

    elif st == "pdf_extraction":
        parts.append(f"PDF: <em>{_e(src.get('filename',''))}</em>, "
                     f"Page {_e(src.get('page_number','?'))}<br>")
        parts.append(f"Field: <code>{_e(src.get('field_path',''))}</code><br>")
        parts.append(f"Extraction: {_e(src.get('extraction_method',''))}")

    elif st == "ingredient_match":
        score = src.get("match_score", 0)
        method = src.get("match_method", "")
        matched = src.get("matched_annexure_material", "")
        ann_idx = src.get("annexure_index", "?")
        parts.append(f"Ingredient: <em>{_e(src.get('ingredient_name',''))}</em><br>")
        parts.append(f"Matched: <b>{_e(matched)}</b> (Annexure {_e(ann_idx)})<br>")
        conf_cls = "flag" if src.get("low_confidence") else "ok"
        parts.append(f"Score: {score:.3f} | Method: {_e(method)} "
                     f'<span class="{conf_cls}">'
                     f'{"⚠ LOW_CONFIDENCE" if src.get("low_confidence") else "✓ OK"}'
                     f"</span>")

    if "LOW_CONFIDENCE_MATCH" in flags and st != "ingredient_match":
        parts.append('<br><span class="flag">⚠ LOW_CONFIDENCE_MATCH</span>')

    return "".join(parts)


def generate_html(ledger: Dict) -> str:
    report_id = ledger.get("report_id", "unknown")
    generated_at = ledger.get("generated_at", "")
    inputs = ledger.get("inputs", {}) or {}
    citations = ledger.get("citations", []) or []
    summary = ledger.get("summary", {}) or {}

    total = summary.get("total_citations", len(citations))
    low_conf = summary.get("low_confidence_matches", 0)
    type_counts = summary.get("by_type", {}) or {}

    pdf_info = inputs.get("reference_pdf", {}) or {}
    excel_info = inputs.get("excel", {}) or {}
    annexures: List[Dict] = [a for a in (inputs.get("annexures") or []) if a]

    # Group by section
    by_section: Dict[str, List[Dict]] = {}
    for c in citations:
        sec = c.get("section", "Other")
        by_section.setdefault(sec, []).append(c)

    covered = len(by_section)

    # ── Input tables ──────────────────────────────────────────────────────────
    ann_rows = "".join(
        f"<tr>"
        f"<td>{_e(a.get('index',''))}</td>"
        f"<td>{_e(a.get('filename',''))}</td>"
        f"<td><code class='hash'>{_e(a.get('sha256','')[:24])}…</code></td>"
        f"<td>{_e(a.get('material_name',''))}</td>"
        f"<td>{_e(a.get('supplier',''))}</td>"
        f"</tr>"
        for a in annexures
    )

    type_rows = "".join(
        f"<tr><td>{_e(t)}</td><td class='num-cell'>{_e(cnt)}</td></tr>"
        for t, cnt in sorted(type_counts.items())
    )

    # ── Section blocks ────────────────────────────────────────────────────────
    section_blocks: List[str] = []
    for sec, cits in sorted(by_section.items()):
        rows_html = "".join(
            f'<tr id="cite-{_e(c.get("citation_id",""))}">'
            f'<td class="cid">{_e(c.get("citation_id",""))}</td>'
            f'<td>{_e((c.get("cell") or {}).get("row",""))} / '
            f'{_e((c.get("cell") or {}).get("col",""))}</td>'
            f'<td class="val">{_e(c.get("value",""))}</td>'
            f'<td>{_render_source(c)}</td>'
            f'</tr>'
            for c in cits
        )
        sec_id = re.sub(r"[^a-z0-9]", "-", sec.lower())
        section_blocks.append(
            f'<div class="sec-block">'
            f'<div class="sec-hdr" onclick="tog(\'{sec_id}\')">'
            f'▶ {_e(sec)} <span class="badge">{len(cits)}</span></div>'
            f'<div id="{sec_id}" class="sec-body">'
            f'<table><thead><tr>'
            f'<th>ID</th><th>Row / Column</th><th>Value</th><th>Source</th>'
            f'</tr></thead><tbody>{rows_html}</tbody></table>'
            f'</div></div>'
        )

    flag_style = "color:#b00;font-weight:bold" if low_conf > 0 else "color:#060"
    flag_text = (f"⚠ {low_conf} low-confidence ingredient match(es)"
                 if low_conf > 0 else "✓ All ingredient matches high confidence")

    return f"""<!DOCTYPE html>
