import React, { useState, useRef, useEffect } from 'react'
import { motion, AnimatePresence } from 'framer-motion'
import { FiSend } from 'react-icons/fi'
import Message from './Message'
import TypingIndicator from './TypingIndicator'
import { chatRequest, getDownloadUrl } from '../api'

const QUICK_PROMPTS = [
  { label: 'RMG Capacities', text: 'What are the various Capacities of RMG available in IPDO?' },
  { label: 'Hot Melt Extrusion', text: 'What is the Make and Model for Hot Melt Extrusion in IPDO?' },
  { label: 'Sifting Mesh Sizes', text: 'Which all the various mesh sizes available in IPDO for Sifting?' },
  { label: 'DRL Equipment', text: 'Which all plants do we have Alexenderwerk WP 200 in DRL?' },
]

function cleanText(raw) {
  if (!raw) return raw
  return raw
    .replace(/\*\*(.*?)\*\*/g, '$1')
    .replace(/\*(.*?)\*/g, '$1')
    .replace(/^\*+\s*/gm, '')
    .replace(/\s*\*+$/gm, '')
}

export default function ChatScreen() {
  const [messages, setMessages] = useState([])
  const [input, setInput] = useState('')
  const [loading, setLoading] = useState(false)
  const scrollRef = useRef(null)
  const inputRef = useRef(null)

  useEffect(() => {
    const t = setTimeout(() => {
      scrollRef.current?.scrollIntoView({ behavior: 'smooth', block: 'end' })
    }, 120)
    return () => clearTimeout(t)
  }, [messages, loading])

  function appendMsg(from, text, extra = {}) {
    setMessages(prev => [
      ...prev,
      { id: crypto.randomUUID?.() ?? String(Date.now()), from, text, ...extra },
    ])
  }

  async function send(promptText) {
    const q = typeof promptText === 'string' ? promptText.trim() : input.trim()
    if (!q || loading) return
    setInput('')
    appendMsg('user', q)
    setLoading(true)
    try {
      const resp = await chatRequest(q)
      const ans = cleanText(resp?.response ?? 'No relevant information found.')
      if (resp?.formula_download) {
        appendMsg('agent', ans, {
          downloadUrl: getDownloadUrl(),
          downloadName: resp.formula_filename ?? 'Formulas.xlsx',
        })
      } else {
        appendMsg('agent', ans)
      }
    } catch {
      appendMsg('agent', 'Something went wrong. Please try again.')
    } finally {
      setLoading(false)
    }
  }

  const isEmpty = messages.length === 0 && !loading

  return (
    <div
      className="flex flex-col bg-slate-50 overflow-hidden"
      style={{ height: '100dvh' }}
    >
      {/* ── Header ── */}
      <header
        className="flex-shrink-0 flex items-center gap-3 px-5 shadow-lg z-10"
        style={{
          background: 'linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%)',
          paddingTop: 'max(18px, env(safe-area-inset-top))',
          paddingBottom: '16px',
        }}
      >
        <div className="w-10 h-10 rounded-2xl bg-white/20 backdrop-blur-sm flex items-center justify-center text-white font-bold text-sm flex-shrink-0 shadow-inner">
          SP
        </div>
        <div className="flex-1 min-w-0">
          <div className="text-white font-semibold text-base leading-tight">Scaleup Predictor</div>
          <div className="text-white/65 text-xs mt-0.5">Pharmaceutical AI Assistant</div>
        </div>
        <div className="flex items-center gap-1.5 flex-shrink-0">
          <span className="relative flex h-2.5 w-2.5">
            <span className="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-300 opacity-75" />
            <span className="relative inline-flex h-2.5 w-2.5 rounded-full bg-green-400" />
          </span>
          <span className="text-white/75 text-xs">Online</span>
        </div>
      </header>

      {/* ── Messages ── */}
      <main className="flex-1 overflow-y-auto px-4 py-4">

        {/* Welcome screen — shown when no messages */}
        <AnimatePresence>
          {isEmpty && (
            <motion.div
              key="welcome"
              initial={{ opacity: 0, y: 16 }}
              animate={{ opacity: 1, y: 0 }}
              exit={{ opacity: 0, y: -10 }}
              transition={{ duration: 0.3 }}
              className="flex flex-col items-center pt-4 pb-2"
            >
              <div
                className="w-20 h-20 rounded-3xl flex items-center justify-center text-white font-bold text-2xl shadow-xl mb-5"
                style={{ background: 'linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%)' }}
              >
                SP
              </div>
              <h2 className="text-xl font-bold text-slate-800 mb-1">Hello there</h2>
              <p className="text-sm text-slate-500 text-center px-6 mb-7 leading-relaxed">
                Ask me anything about pharmaceutical scaleup, formulations, or equipment.
              </p>

              <div className="w-full space-y-2.5">
                <p className="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-2 px-1">
                  Quick questions
                </p>
                {QUICK_PROMPTS.map((p, i) => (
                  <motion.button
                    key={i}
                    initial={{ opacity: 0, x: -8 }}
                    animate={{ opacity: 1, x: 0 }}
                    transition={{ delay: 0.1 + i * 0.07 }}
                    whileTap={{ scale: 0.98 }}
                    onClick={() => send(p.text)}
                    className="w-full text-left px-4 py-3.5 rounded-2xl bg-white border border-slate-200 shadow-sm active:bg-indigo-50 active:border-indigo-200 transition-colors"
                  >
                    <div className="text-xs font-semibold text-indigo-500 mb-0.5">{p.label}</div>
                    <div className="text-sm text-slate-600 leading-snug">{p.text}</div>
                  </motion.button>
                ))}
              </div>
            </motion.div>
          )}
        </AnimatePresence>

        {/* Message bubbles */}
        <div className="space-y-3">
          <AnimatePresence initial={false}>
            {messages.map(m => (
              <Message key={m.id} {...m} />
            ))}
          </AnimatePresence>
          {loading && <TypingIndicator />}
        </div>

        <div ref={scrollRef} className="h-2" />
      </main>

      {/* ── Input bar ── */}
      <footer
        className="flex-shrink-0 bg-white border-t border-slate-200 px-4 py-3"
        style={{ paddingBottom: 'max(14px, env(safe-area-inset-bottom))' }}
      >
        <div className="flex items-center gap-2">
          <input
            ref={inputRef}
            value={input}
            onChange={e => setInput(e.target.value)}
            onKeyDown={e => {
              if (e.key === 'Enter') { e.preventDefault(); send() }
            }}
            placeholder="Ask a question…"
            disabled={loading}
            className="flex-1 bg-slate-100 rounded-2xl px-4 py-3 text-sm text-slate-800 placeholder-slate-400 outline-none focus:ring-2 focus:ring-indigo-200 transition-shadow disabled:opacity-60"
          />
          <motion.button
            whileTap={{ scale: 0.87 }}
            onClick={() => send()}
            disabled={!input.trim() || loading}
            aria-label="Send"
            className="w-11 h-11 rounded-2xl flex items-center justify-center text-white shadow-md disabled:opacity-40 flex-shrink-0 transition-opacity"
            style={{ background: 'linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%)' }}
          >
            <FiSend size={17} style={{ transform: 'rotate(45deg)' }} />
          </motion.button>
        </div>
      </footer>
    </div>
  )
}
