"use strict";

var fs    = require("fs");
var JSZip = require("jszip");
var docx  = require("docx");

var Document            = docx.Document;
var Packer              = docx.Packer;
var Paragraph           = docx.Paragraph;
var TextRun             = docx.TextRun;
var Table               = docx.Table;
var TableRow            = docx.TableRow;
var TableCell           = docx.TableCell;
var ImageRun            = docx.ImageRun;
var Header              = docx.Header;
var Footer              = docx.Footer;
var AlignmentType       = docx.AlignmentType;
var BorderStyle         = docx.BorderStyle;
var WidthType           = docx.WidthType;
var ShadingType         = docx.ShadingType;
var VerticalAlign       = docx.VerticalAlign;
var PageNumber          = docx.PageNumber;
var PageBreak           = docx.PageBreak;
var convertInchesToTwip = docx.convertInchesToTwip;

// ── Page geometry: A5 Landscape (210×148 mm) ─────────────────────────────────
var PAGE_W = convertInchesToTwip(8.27);
var PAGE_H = convertInchesToTwip(5.83);
var MAR_L  = convertInchesToTwip(0.47);
var MAR_R  = convertInchesToTwip(0.47);
var MAR_T  = convertInchesToTwip(0.98);
var MAR_B  = convertInchesToTwip(0.39);
var CW     = PAGE_W - MAR_L - MAR_R;

// ── Colors ───────────────────────────────────────────────────────────────────
var CLR = {
  BLACK:       "000000", WHITE:      "FFFFFF",
  HDR_GREY:    "D9D9D9", SEC_BLUE:   "BDD7EE",
  THRESH_BG:   "FFE699", EXCEED_BG:  "FFCCCC", EXCEED_TXT: "FF0000",
};

// ── Font & sizes (half-points) ────────────────────────────────────────────────
var F    = "Times New Roman";
var SZ   = { XXS:10, XS:12, SM:14, TEXT:24, MD:20, LG:22, XL:26 };
var CHAR_SP = 15; // body text character spacing (+0.75pt)

// ── Borders ───────────────────────────────────────────────────────────────────
function bdr(sz, clr) {
  return { style: BorderStyle.SINGLE, size: sz||4, color: clr||CLR.BLACK };
}
function allBdr(sz) {
  var b = bdr(sz);
  return { top:b, bottom:b, left:b, right:b, insideHorizontal:b, insideVertical:b };
}
function noBdr() {
  var n = { style:BorderStyle.NIL, size:0, color:CLR.WHITE };
  return { top:n, bottom:n, left:n, right:n };
}
function shade(fill) { return { fill:fill, type:ShadingType.CLEAR, color:"auto" }; }
function mg() { return { top:30, right:60, bottom:30, left:60 }; }

// ── Text run (noProof = no spell-check underline) ─────────────────────────────
function run(text, opts) {
  opts = opts||{};
  return new TextRun({
    text:             String(text==null?"":text),
    bold:             !!opts.bold,
    size:             opts.size||SZ.TEXT,
    font:             F,
    color:            opts.color||CLR.BLACK,
    italics:          !!opts.italics,
    characterSpacing: opts.cs||0,
    noProof:          true,
  });
}

// ── Paragraph helpers ─────────────────────────────────────────────────────────
function para(content, opts) {
  opts = opts||{};
  var children;
  if (typeof content==="string") children=[run(content,opts)];
  else if (Array.isArray(content)) children=content;
  else if (content) children=[content];
  else children=[run("",opts)];
  return new Paragraph({
    alignment: opts.align||AlignmentType.LEFT,
    spacing: { before:opts.before==null?40:opts.before,
               after: opts.after ==null?40:opts.after,
               line:  opts.line||264 },
    children: children,
  });
}

function bodyPara(text, opts) {
  opts = opts||{};
  return new Paragraph({
    alignment: AlignmentType.BOTH,
    spacing: { before:opts.before||20, after:opts.after||20, line:288 },
    children: [new TextRun({
      text:String(text==null?"":text), bold:!!opts.bold,
      size:opts.size||SZ.TEXT, font:F, color:CLR.BLACK,
      characterSpacing:CHAR_SP, noProof:true,
    })],
  });
}

function bodyParas(text) {
  if (!text) return [];
  return String(text).trim().split(/\n+/)
    .filter(function(l){return l.trim();})
    .map(function(l){return bodyPara(l.trim());});
}

function ctrPara(text, bold, size) {
  return para(text, {align:AlignmentType.CENTER, bold:!!bold, size:size||SZ.TEXT, before:40, after:40});
}
function lftPara(text, bold, size) {
  return para(text, {align:AlignmentType.LEFT, bold:!!bold, size:size||SZ.TEXT, before:20, after:20});
}
function blk() { return para("",{before:20,after:20}); }
function pgBrk() { return new Paragraph({children:[new PageBreak()]}); }
function secHd(text) {
  return para(text,{align:AlignmentType.LEFT, bold:true, size:SZ.MD, before:80, after:40, line:264});
}

// ── Cell helpers ──────────────────────────────────────────────────────────────
function cell(text, opts) {
  opts = opts||{};
  return new TableCell({
    columnSpan:    opts.cs||1,
    width:         opts.w?{size:opts.w,type:WidthType.DXA}:undefined,
    borders:       opts.nb?noBdr():allBdr(4),
    shading:       opts.fill?shade(opts.fill):undefined,
    margins:       mg(),
    verticalAlign: VerticalAlign.CENTER,
    children:[new Paragraph({
      alignment:opts.align||AlignmentType.CENTER,
      spacing:{before:0,after:0},
      children:[new TextRun({
        text:String(text==null?"":text), bold:!!opts.bold,
        size:opts.size||SZ.SM, font:F, color:opts.color||CLR.BLACK, noProof:true,
      })],
    })],
  });
}

function cellL(text, opts) { opts=opts||{}; opts.align=AlignmentType.LEFT; return cell(text,opts); }

function cellML(lines, opts) {
  opts=opts||{};
  var arr=Array.isArray(lines)?lines:[lines];
  return new TableCell({
    columnSpan:    opts.cs||1,
    width:         opts.w?{size:opts.w,type:WidthType.DXA}:undefined,
    borders:       opts.nb?noBdr():allBdr(4),
    shading:       opts.fill?shade(opts.fill):undefined,
    margins:       mg(),
    verticalAlign: VerticalAlign.CENTER,
    children:arr.filter(Boolean).map(function(l){
      return new Paragraph({
        alignment:AlignmentType.LEFT, spacing:{before:0,after:0},
        children:[new TextRun({text:String(l),bold:!!opts.bold,size:opts.size||SZ.XS,font:F,noProof:true})],
      });
    }),
  });
}

function emptyCell(fill,w) {
  return new TableCell({
    width:w?{size:w,type:WidthType.DXA}:undefined,
    borders:allBdr(4), shading:fill?shade(fill):undefined, margins:mg(),
    children:[new Paragraph({children:[new TextRun({text:"",noProof:true})]})],
  });
}

