        </div>
      </header>

      {/* ── Body: sidebar + main ── */}
      <div className="app-body">
        {/* History sidebar — always rendered when backend is ready */}
        {backendStatus !== 'checking' && (
          <HistorySidebar
            history={history}
            activeId={activeHistoryId}
            onSelect={handleHistorySelect}
            onClear={handleClearHistory}
          />
        )}

        {/* Main content */}
        <main className="app-main">
          {/* Loading screen */}
          {backendStatus === 'checking' && (
            <div className="loading-screen" aria-label="Loading">
              <div className="loading-content">
                <span className="loading-app-name">Prompt Coach</span>
                <div className="loading-bar-track">
                  <div className="loading-bar-fill" />
                </div>
              </div>
            </div>
          )}

          {backendStatus !== 'checking' && (
            <>
              {/* INPUT + DISSOLVING — share the PromptInput card */}
              <div
                className={isInputOrDissolving ? 'state-visible' : 'state-hidden'}
                aria-hidden={!isInputOrDissolving}
              >
                <PromptInput
                  onSubmit={handleSubmit}
                  isDissolving={appState === APP_STATE.DISSOLVING}
                  progressPercent={progressPercent}
                  progressStatus={progressStatus}
                />
              </div>

              {/* Sand dissolve canvas overlay */}
              {appState === APP_STATE.DISSOLVING && (
                <SandDissolve
                  text={dissolveText}
                  sourceRect={dissolveRect}
                  onComplete={handleAnimationComplete}
                />
              )}

              {/* REVEAL */}
              {appState === APP_STATE.REVEAL && (
                <div className="reveal-state" aria-live="polite">
                  <ReconstructedPrompt
                    data={reconstructionData}
                    error={reconstructionError}
                    instant={revealMode === 'history'}
                  />

                  <div className="reveal-footer">
                    <button className="new-prompt-btn" onClick={handleReset}>
                      NEW PROMPT
                    </button>
                  </div>
                </div>
              )}
            </>
          )}
        </main>
      </div>
    </div>
  )
}
