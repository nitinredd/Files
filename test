.panel-left {
  padding: 32px;
  border-left: 2px solid var(--success);
  display: flex;
  flex-direction: column;
  gap: 16px;
  min-width: 0;
}
.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  flex-shrink: 0;
}
.panel-label {
  font-family: var(--font-mono);
  font-size: 9px;
  color: var(--text-secondary);
  letter-spacing: 3px;
  text-transform: uppercase;
}
.copy-btn {
  background: none;
  border: none;
  cursor: pointer;
  color: var(--border-mid);
  padding: 4px;
  border-radius: 4px;
  transition: color 150ms ease;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.copy-btn:hover { color: var(--primary); }
.copy-tooltip {
  position: absolute;
  bottom: calc(100% + 6px);
  right: 0;
  font-family: var(--font-mono);
  font-size: 9px;
  color: #FFFFFF;
  background: var(--success);
  border-radius: 4px;
  padding: 3px 8px;
  white-space: nowrap;
  pointer-events: none;
  animation: tooltipFade 0.15s ease;
}
@keyframes tooltipFade {
  from { opacity: 0; transform: translateY(3px); }
  to { opacity: 1; transform: translateY(0); }
}

.reconstructed-text {
  font-family: var(--font-body);
  font-weight: 400;
  font-size: 15px;
  color: var(--text-primary);
  line-height: 1.75;
  white-space: pre-wrap;
  word-break: break-word;
  flex: 1;
}

.error-state {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.error-label {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--warning);
  letter-spacing: 1px;
}
.error-detail {
  font-family: var(--font-body);
  font-size: 13px;
  color: var(--text-secondary);
  line-height: 1.6;
}

.metadata-row {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  flex-shrink: 0;
}
.meta-chip {
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 0.5px;
  padding: 3px 8px;
  border-radius: 4px;
}
.meta-confidence { background: #ECFDF5; color: var(--success); }
.meta-strategy { background: #EFF6FF; color: var(--primary); }
.meta-technique { background: #FFF7ED; color: var(--warning); }

/* ─── Right Panel (Response) ────────────────────────────────────────────────── */
.panel-right {
  padding: 32px;
  border-left: 2px solid var(--secondary);
  display: flex;
  flex-direction: column;
  gap: 16px;
  min-width: 0;
}
.streaming-status {
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 1px;
}
.streaming-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}
.streaming-dot.active {
  background: var(--secondary);
  animation: pulse-dot 1.2s ease-in-out infinite;
}
.streaming-dot.done {
  background: var(--success);
}
.streaming-label.active { color: var(--secondary); }
.streaming-label.done { color: var(--success); }

.response-scroll {
  flex: 1;
  overflow-y: auto;
  max-height: 520px;
  scroll-behavior: smooth;
}
.response-text {
  font-family: var(--font-body);
  font-weight: 300;
  font-size: 15px;
  color: var(--text-primary);
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-word;
}
.token-batch {
  animation: tokenFadeIn 40ms ease both;
}
@keyframes tokenFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
.cursor-blink {
  display: inline-block;
  width: 2px;
  height: 1em;
  background: var(--secondary);
  margin-left: 2px;
  vertical-align: text-bottom;
  animation: blink 1s step-end infinite;
}
@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

/* ─── Reveal Footer ─────────────────────────────────────────────────────────── */
.reveal-footer {
  display: flex;
  justify-content: center;
  margin-top: 24px;
}
.new-prompt-btn {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 1.5px;
  color: var(--text-secondary);
  background: transparent;
  border: 1.5px solid var(--border);
  border-radius: var(--radius-pill);
  padding: 12px 32px;
  cursor: pointer;
  transition: border-color 200ms ease, color 200ms ease;
}
.new-prompt-btn:hover {
  border-color: var(--primary);
  color: var(--primary);
}

/* ─── Sand Dissolve Canvas ──────────────────────────────────────────────────── */
.dissolve-canvas {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 1000;
}

/* ─── Responsive ────────────────────────────────────────────────────────────── */
@media (max-width: 768px) {
  .app-header { padding: 0 16px; }
  .hero-headline { font-size: 32px; }
  .hero-sub { font-size: 14px; }
  .input-state { padding: 32px 16px 48px; }
  .reveal-state { padding: 16px 12px 32px; }
  .reveal-panels {
    grid-template-columns: 1fr;
    grid-template-rows: auto auto auto;
  }
  .panel-divider {
    flex-direction: row;
    height: 32px;
    padding: 0 32px;
  }
  .divider-line {
    flex: 1;
    width: auto;
    height: 1px;
  }
  .diamond { padding: 0 8px; }
  .panel-left, .panel-right { padding: 24px 20px; }
  .card-footer { flex-wrap: wrap; }
}

@media (max-width: 480px) {
  .hero-headline { font-size: 26px; }
  .reconstruct-btn { padding: 10px 20px; font-size: 10px; }
  .scenario-chips { justify-content: flex-start; }
}
