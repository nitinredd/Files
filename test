    run.font.size = Pt(size_pt)
    return run


def add_page_header(doc: Document):
    """
    Build the IPDO standard two-row header that appears on every page.
    (Implemented as a table in the actual header section.)
    """
    section = doc.sections[0]
    header  = section.header
    header.is_linked_to_previous = False

    # Clear existing
    for p in header.paragraphs:
        p.clear()

    # Outer table: IPDO | Title | Dr. Reddy's
    tbl = header.add_table(rows=1, cols=3, width=Inches(7.5))
    tbl.style = "Table Grid"

    left_cell   = tbl.cell(0, 0)
    center_cell = tbl.cell(0, 1)
    right_cell  = tbl.cell(0, 2)

    left_cell.width   = Inches(1.2)
    center_cell.width = Inches(4.6)
    right_cell.width  = Inches(1.7)

    left_cell.paragraphs[0].add_run("IPDO").bold = True
    left_cell.paragraphs[0].runs[0].font.size = Pt(9)

    cp = center_cell.paragraphs[0]
    cp.alignment = WD_ALIGN_PARAGRAPH.CENTER
    run = cp.add_run("Technical Summary Report")
    run.bold = True; run.font.size = Pt(9)

    rp = right_cell.paragraphs[0]
    rp.alignment = WD_ALIGN_PARAGRAPH.RIGHT
    run = rp.add_run("Dr. Reddy's")
    run.bold = True; run.font.size = Pt(9)

    # Row 2: document info table
    info_tbl = header.add_table(rows=1, cols=6, width=Inches(7.5))
    info_tbl.style = "Table Grid"
    labels = ["Title", "Document No:", "Product Name:", "Dosage Form:", "Version:", ""]
    values = [
        PRODUCT["title"], PRODUCT["doc_no"], PRODUCT["product_name"],
        PRODUCT["dosage_form"], PRODUCT["version"], ""
    ]
    for i, (lbl, val) in enumerate(zip(labels, values)):
        cell = info_tbl.cell(0, i)
        p = cell.paragraphs[0]
        r = p.add_run(f"{lbl}\n{val}")
        r.font.size = Pt(7)

    header.add_paragraph()  # spacing


def add_page_footer(doc: Document):
    """Standard IPDO footer: left blank | Page X of Y | right blank."""
    section = doc.sections[0]
    footer  = section.footer
    footer.is_linked_to_previous = False

    for p in footer.paragraphs:
        p.clear()

    fp = footer.paragraphs[0]
    fp.alignment = WD_ALIGN_PARAGRAPH.CENTER
    fp.add_run(f"Page ").font.size = Pt(8)
    # Add PAGE field
    fld = OxmlElement("w:fldChar")
    fld.set(qn("w:fldCharType"), "begin")
    fp.runs[-1]._r.append(fld)
    instrText = OxmlElement("w:instrText")
    instrText.text = " PAGE "
    r = OxmlElement("w:r")
    r.append(instrText)
    fp._p.append(r)
    fld2 = OxmlElement("w:fldChar")
    fld2.set(qn("w:fldCharType"), "end")
    r2 = OxmlElement("w:r"); r2.append(fld2)
    fp._p.append(r2)
    run = fp.add_run(" of ")
    run.font.size = Pt(8)
    # Add NUMPAGES field
    fld3 = OxmlElement("w:fldChar")
    fld3.set(qn("w:fldCharType"), "begin")
    fp.runs[-1]._r.append(fld3)
    instrText2 = OxmlElement("w:instrText")
    instrText2.text = " NUMPAGES "
    r3 = OxmlElement("w:r"); r3.append(instrText2)
    fp._p.append(r3)
    fld4 = OxmlElement("w:fldChar")
    fld4.set(qn("w:fldCharType"), "end")
    r4 = OxmlElement("w:r"); r4.append(fld4)
    fp._p.append(r4)


