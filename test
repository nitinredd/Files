def parse_composition_excel(excel_bytes: bytes) -> Dict:
    """
    Parse the composition Excel file.
    Uses Claude to understand the sheet structure rather than assuming column positions.
    Returns {
      "sections": [{"name": "Seal coating", "rows": [{"ingredient","status","40mg","20mg","10mg"}]}],
      "mdd_strength": "40mg",
      "mdd_sachets": 6,
      "raw_rows": [...]
    }
    """
    wb = openpyxl.load_workbook(BytesIO(excel_bytes), data_only=True)
    ws = wb.worksheets[0]  # Use first sheet

    # Dump all rows to text for Claude
    rows_text = []
    all_rows = []
    for i, row in enumerate(ws.iter_rows(values_only=True)):
        if any(c is not None for c in row):
            row_str = [str(c) if c is not None else "" for c in row]
            rows_text.append(f"Row {i+1}: {' | '.join(row_str)}")
            all_rows.append(row_str)
    wb.close()

    sheet_dump = "\n".join(rows_text[:80])  # first 80 rows

    prompt = f"""Below is spreadsheet data from a pharmaceutical product composition Excel file.
Each row is a formula ingredient. The columns typically are:
Row number | Ingredient Name | Function | Amount for strength1 | Amount for strength2 | Amount for strength3

Identify and extract:
1. Which column holds the ingredient name
2. Which columns hold amounts per strength (e.g., 40mg, 20mg, 10mg)
3. Which rows are section headers (e.g., "Seal coating", "Drug Loading") vs ingredient rows
4. Which strength represents the maximum daily dose (highest strength)
5. How many sachets per day for worst-case MDD

Return ONLY this JSON (no markdown, no explanation):
{{
  "ingredient_col": 1,
  "strength_cols": {{"40mg": 3, "20mg": 4, "10mg": 5}},
  "mdd_strength": "40mg",
  "mdd_sachets": 6,
  "section_header_rows": [3, 12, 18],
  "data_start_row": 2,
  "sections": [
    {{
      "name": "Seal coating",
      "rows": [
        {{"ingredient": "Purified water", "status": "USP", "40mg": "q.s.", "20mg": "q.s.", "10mg": "q.s."}}
      ]
    }}
  ]
}}

Spreadsheet data:
{sheet_dump}"""

    raw = claude_text(prompt)
    try:
        s = raw.find("{"); e = raw.rfind("}") + 1
        result = json.loads(raw[s:e])
        result["all_rows"] = all_rows
        return result
    except Exception as ex:
        logger.error(f"Excel parse error: {ex}")
        # Fallback: return raw rows
        return {
            "sections": [],
            "mdd_strength": "40mg",
            "mdd_sachets": 6,
            "all_rows": all_rows,
            "ingredient_col": 1,
            "strength_cols": {"40mg": 3, "20mg": 4, "10mg": 5}
        }

