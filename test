# FDA high-risk excipients for DEG/EG (Glycerin, Propylene Glycol, sugar alcohols
# and other hydrogenation-derived / polyol excipients). Matched as substrings on
# the normalized material name.
_DEG_EG_FDA_HIGH_RISK = (
    "glycerin", "glycerine", "glycerol", "propylene glycol", "maltitol",
    "sorbitol", "neosorb", "sorbogem", "mannitol", "pearlitol",
    "hydrogenated starch hydrolysate", "hsh", "polysorbate", "tween",
    "polyethylene glycol", "peg", "macrogol", "polyethylene oxide",
    "hydrogenated castor oil",
)
_DEG_EG_SUGAR_ALCOHOLS = (
    "mannitol", "pearlitol", "sorbitol", "neosorb", "maltitol", "xylitol",
    "isomalt", "lactitol", "erythritol", "hydrogenated",
)


def _deg_eg_observations(observation_items: List[Dict]) -> str:
    """Deterministic Observations prose that, for EVERY material carrying DEG/EG
    evidence (confirmed OR vendor guarantee ceiling), states FDA high-risk
    membership, the vendor mechanism (from CoA raw_text where present), and the
    control strategy (specification + per-batch testing, or guarantee ceiling
    below the USP <469> Option 1 limit). RF6 / opening Fix 5."""
    if not observation_items:
        return ""
    sents: List[str] = []
    for it in observation_items:
        name = it.get("name", "")
        nlow = name.lower()
        glycols = []
        if it.get("deg_present") == "Yes" or it.get("deg_guarantee_ceiling"):
            glycols.append("Diethylene Glycol")
        if it.get("eg_present") == "Yes" or it.get("eg_guarantee_ceiling"):
            glycols.append("Ethylene Glycol")
        gtxt = " and ".join(glycols) or "DEG/EG"
        # Label each limit with its own glycol. An unlabelled join reads as if a
        # single limit covered both, which is wrong whenever only one glycol is
        # actually controlled (Polysorbate 80: EG only).
        limit = "; ".join([f"{lbl}: {v}" for lbl, v in
                           (("DEG", safe_str(it.get("deg_limit"))),
                            ("EG", safe_str(it.get("eg_limit")))) if v])
        rt = (it.get("raw_text") or "").lower()
        mlow = (it.get("matched_material") or "").lower()
        is_sugar_alcohol = any(h in nlow or h in mlow for h in _DEG_EG_SUGAR_ALCOHOLS)
        # Prefer the authoritative FDA high-risk flag set by the mapper; fall back
        # to a name/matched-material substring match.
        is_fda = (bool(it.get("high_risk_deg_eg"))
                  or any(h in nlow or h in mlow for h in _DEG_EG_FDA_HIGH_RISK)
                  or is_sugar_alcohol)
        # Vendor mechanism — prefer the CoA raw_text, else infer for polyols.
        if "hydrogenation" in rt or "hydrogenated" in rt:
            mech = " as a by-product of the hydrogenation manufacturing process"
        elif "by-product" in rt or "byproduct" in rt or "residue" in rt:
            mech = " as a manufacturing by-product"
        elif is_sugar_alcohol:
            mech = (" as a potential by-product of the catalytic hydrogenation "
                    "step used to manufacture sugar alcohols")
        else:
            mech = ""
        # FDA high-risk framing.
        if is_sugar_alcohol:
            fda_clause = (" This material falls under the FDA high-risk category "
                          "for DEG/EG (grouped with D-Sorbitol and other "
                          "hydrogenation-derived sugar alcohols).")
        elif is_fda:
            fda_clause = (f" {name} is recognised as an FDA high-risk excipient for "
                          "DEG/EG.")
        else:
            fda_clause = ""
        if it.get("guarantee_ceiling"):
            ceil = (f" The vendor guarantees the residual level below the USP <469> "
                    f"Option 1 limit"
                    + (f" ({limit})" if limit else "")
                    + "; the by-product is not quantified per batch and is "
                    "therefore not confirmed present.")
            sents.append(f"{name}: {gtxt} may occur{mech}.{fda_clause}{ceil}")
        else:
            ctrl = (f" The presence is confirmed and controlled by specification"
                    + (f" ({limit})" if limit else "")
                    + " with routine per-batch testing; the residual level is "
                    "within the applicable specification limit.")
            sents.append(f"{name} was identified as a potential source of "
                         f"{gtxt}{mech}.{fda_clause}{ctrl}")
    return " ".join(sents)


def _deg_eg_generate_text(meta: Dict, composition: Dict, assessment: Dict,
                          validation: Dict) -> Dict:
    """Generate DEG/EG narrative from STRUCTURED DATA only (no invented numbers).
    Presence is strictly Yes/No, so the conclusion is always DEFINITIVE — no
    regulatory hedging, no 'manual review', no 'Unknown'."""
    product = meta.get("product_name", "the drug product")
    status = validation.get("conclusion_status", "no_risk")
    at = assessment.get("assessment_table", [])
    positives = [r for r in at if r["deg_present"] == "Yes" or r["eg_present"] == "Yes"]

    if status == "positive_controlled" and positives:
        pos_names = ", ".join(sorted({r["ingredient"] for r in positives}))
        spec_bits = "; ".join(sorted({r["specification_limit"] for r in positives
                                      if r.get("specification_limit")
                                      and r["specification_limit"] != "Not applicable"}))
        spec_clause = (f" The presence is controlled through specification "
                       f"({spec_bits})." if spec_bits
                       else " The presence is controlled through specification.")
        conclusion = (f"Based on the overall assessment, Diethylene Glycol and/or "
                      f"Ethylene Glycol may be present in {pos_names}.{spec_clause} "
                      "As the residual levels are controlled through specification, "
                      "there is no requirement of additional drug product testing for "
                      "DEG and EG.")
    else:
        conclusion = (f"Based on the overall assessment, there is no potential risk "
                      f"of Diethylene Glycol and Ethylene Glycol in {product}. Hence, "
                      "there is no requirement of drug product testing for DEG and "
                      "EG.")

    intro = (f"This report presents a theoretical risk assessment for the potential "
             f"presence of Diethylene Glycol (DEG) and Ethylene Glycol (EG) in the "
             f"API and excipients used in {product}. The assessment is based on "
             "Certificates of Analysis, in-house specifications, and applicable "
             "regulatory guidance (USP <469>, USFDA guidance). No exposure "
             "calculations are performed; the assessment establishes presence "
             "(Yes/No) and applicable specification limits per material.")

    risk_intro = ("API and excipients were assessed for the potential presence of "
                  "Diethylene Glycol and Ethylene Glycol based on the COAs received "
                  "from the respective manufacturers, in-house specifications, and "
                  "applicable regulatory guidance. Summary of outcome is tabulated "
                  "below.")

    prompt = (
        "Write concise, factual, DEFINITIVE regulatory prose for a Diethylene "
        "Glycol (DEG) & Ethylene Glycol (EG) Risk Assessment. Do NOT invent numeric "
        "DEG/EG limits. Do NOT use any hedging language such as 'manual review', "
        "'assessment incomplete', 'unresolved', 'cannot conclude', 'Unknown', or "
        "'supplier engagement needed'. Every material has a definitive Yes or No "
        "outcome. There are NO exposure calculations. Return ONLY JSON with keys "
        "abstract, objective, background, observations, post_assessment_narrative.\n\n"
        f"Product: {product}\nDosage form: {meta.get('dosage_form','')}\n"
        f"Strength: {meta.get('strength','')}\n"
        f"Total materials assessed: {len(at)}\n"
        f"Materials with DEG/EG presence = Yes: {len(positives)}\n"
        "DEG/EG presence is evidenced from CoA / specification / USP <469>; generic "
        "policy statements are NOT material-specific limits.\n"
        "Do not state the final conclusion in these sections; it is set separately."
    )
    try:
        raw = claude_text(prompt, max_tokens=2000)
        data = _rs_safe_text_json(raw)
    except Exception:
        data = {}

    def clean(s: str) -> str:
        s = re.sub(r"\*\*(.+?)\*\*", r"\1", s or "")
        s = s.replace("`", "").replace("*", "")
        return s.strip()

    # Guard: strip any hedging the LLM may still emit.
    _HEDGE_RE = re.compile(
        r"(manual[\s-]*review|assessment incomplete|unresolved|cannot (?:be )?"
        r"draw|material-specific evidence not available|supplier engagement|"
        r"USP <469> testing required|unknown)", re.IGNORECASE)

    def de_hedge(s: str) -> str:
        return "" if s and _HEDGE_RE.search(s) else s

    pos_count = len(positives)
    obs_items = assessment.get("observation_items", []) or []
    gc_count = sum(1 for it in obs_items if it.get("guarantee_ceiling"))
    # Summary lead sentence, then the mandatory per-material mechanism narrative.
    lead = (
        f"Of {len(at)} material(s) assessed, {pos_count} showed the confirmed "
        "presence of Diethylene Glycol and/or Ethylene Glycol controlled through "
        f"specification"
        + (f", {gc_count} carried a vendor guarantee ceiling below the applicable "
           "regulatory limit (not confirmed present)" if gc_count else "")
        + f", and the remaining material(s) showed no potential DEG/EG risk."
        if (pos_count or gc_count) else
        f"All {len(at)} assessed material(s) showed no potential presence of "
        "Diethylene Glycol or Ethylene Glycol.")
    mechanism_narrative = _deg_eg_observations(obs_items)
    default_obs = (lead + " " + mechanism_narrative).strip() if mechanism_narrative \
        else lead

    return {
        "abstract": de_hedge(clean(data.get("abstract"))) or intro,
        "objective": de_hedge(clean(data.get("objective"))) or
                     (f"To assess the potential risk of Diethylene Glycol and "
                      f"Ethylene Glycol presence in the API and excipients of "
                      f"{product}."),
        "study_location": "Theoretical assessment",
        "background": de_hedge(clean(data.get("background"))) or
                      (f"{product} ({meta.get('dosage_form','')}). Diethylene Glycol "
                       "and Ethylene Glycol are known contaminants associated with "
                       "certain glycerin/glycol-based excipients and require risk "
                       "evaluation per regulatory guidance."),
        "risk_analysis_intro": risk_intro,
        "post_assessment_narrative": de_hedge(clean(data.get("post_assessment_narrative"))) or "",
        # When any material carries DEG/EG evidence, the deterministic mechanism
        # narrative is authoritative (guarantees FDA-risk + mechanism + control
        # content the LLM may omit). Only fall back to the LLM prose when there is
        # nothing to explain.
        "observations": (default_obs if obs_items
                         else (de_hedge(clean(data.get("observations"))) or default_obs)),
        "summary_conclusion": conclusion,
        "reference": [
            "USP General Chapter <469> Ethylene Glycol, Diethylene Glycol, and "
            "Triethylene Glycol in Ethoxylated Substances.",
            "USFDA Guidance for Industry — Testing of Glycerin, Propylene Glycol, "
            "and other high-risk excipients for Diethylene Glycol and Ethylene "
            "Glycol.",
        ],
    }


def _benoc_read_rows(upload) -> List[Dict]:
    """Read an OPTIONAL BE NOC gap-fill Excel/CSV upload into a list of
    {lower_header: value} dict rows. Tolerant: the first non-empty row is the
    header. Returns [] on any failure — a bad upload never blocks generation."""
    try:
        data = upload.getvalue()
        name = (getattr(upload, "name", "") or "").lower()
        if name.endswith(".csv"):
            import csv
            from io import StringIO
            text = data.decode("utf-8-sig", "replace")
            grid = [r for r in csv.reader(StringIO(text))]
        else:
            wb = openpyxl.load_workbook(BytesIO(data), data_only=True)
            ws = wb.active
            grid = [["" if c is None else str(c) for c in row]
                    for row in ws.iter_rows(values_only=True)]
        grid = [r for r in grid if any(str(c).strip() for c in r)]
        if not grid:
            return []
        headers = [str(h).strip().lower() for h in grid[0]]
        rows: List[Dict] = []
        for r in grid[1:]:
            row = {}
            for i, h in enumerate(headers):
                if h:
                    row[h] = (str(r[i]).strip() if i < len(r) and r[i] is not None else "")
            if any(row.values()):
                rows.append(row)
        return rows
    except Exception:
        logger.exception("BE NOC gap-fill tabular read failed")
        return []


def _benoc_pick(row: Dict, *needles: str) -> str:
    for n in needles:
        for h, v in row.items():
            if n in h:
                return v
    return ""


def _benoc_map_composition(rows: List[Dict]) -> List[Dict]:
    """Map optional composition rows into the multi-stage composition shape."""
    stages: Dict[str, List[Dict]] = {}
    order: List[str] = []
    for row in rows:
        ing = _benoc_pick(row, "ingredient", "material", "name")
        if not ing:
            continue
        stage = _benoc_pick(row, "stage")
        key = stage or "__default__"
        if key not in stages:
            stages[key] = []
            order.append(key)
        stages[key].append({
            "ingredient": ing,
            "role": _benoc_pick(row, "role", "function"),
            "mg_per_tab": _benoc_pick(row, "mg", "quantity", "amount", "qty"),
        })
    return [{"stage_name": ("" if s == "__default__" else s), "rows": stages[s]}
            for s in order]


def _benoc_map_equipment(rows: List[Dict]) -> List[Dict]:
    out: List[Dict] = []
    for i, row in enumerate(rows, 1):
        nm = _benoc_pick(row, "equipment", "name")
        if not nm:
            continue
        out.append({"sno": _benoc_pick(row, "sno", "s.no", "sr") or str(i),
                    "name": nm,
                    "make_model": _benoc_pick(row, "make", "model")})
    return out


def _benoc_map_dissolution(rows: List[Dict]) -> Dict:
    pts: List[Dict] = []
    for row in rows:
        t = _benoc_pick(row, "time", "minute", "min")
        if not t:
            continue
        pts.append({
            "time": t,
            "ref_pct_dr": _benoc_pick(row, "ref %dr", "reference %dr", "ref_pct_dr",
                                      "reference dr", "ref dr"),
            "ref_pct_rsd": _benoc_pick(row, "ref %rsd", "reference %rsd", "ref_pct_rsd",
                                       "ref rsd"),
            "test_pct_dr": _benoc_pick(row, "test %dr", "test_pct_dr", "test dr"),
            "test_pct_rsd": _benoc_pick(row, "test %rsd", "test_pct_rsd", "test rsd"),
        })
    if not pts:
        return {}
    return {"tables": [{"caption": "Comparative Dissolution Profile",
                        "x_axis_label": "Time (minutes)", "data_points": pts}]}


def _run_benoc_workflow() -> None:
    """Fully isolated BE NOC (Bio-Equivalence import NOC) workflow.
    100% assembly from annexures + metadata — NO calculations. Warning-first:
    generation is blocked only on the three structural failures (main document
    missing, no APIs, empty composition); everything else is a UI-only warning."""
    import benoc as _bn

