        neo4j_client = st.session_state.neo4j

        async def run_extraction():
            semaphore = asyncio.Semaphore(5)
            loop = asyncio.get_event_loop()

            async def process_one(para):
                async with semaphore:
                    try:
                        result = await loop.run_in_executor(
                            None, _call_azure_concepts, para["text"]
                        )
                        concepts = result.get("concepts", [])
                        relationships = result.get("relationships", [])
                        if concepts:
                            neo4j_client.store_concepts(
                                para["paragraph_id"], concepts, relationships
                            )
                            total_concepts_ref[0] += len(concepts)
                            total_relationships_ref[0] += len(relationships)
                        checkpoint[para["paragraph_id"]] = "done"
                        done_count_ref[0] += 1
                    except Exception as e:
                        logger.error(
                            f"Concept extraction failed for {para['paragraph_id']}: {e}"
                        )
                        done_count_ref[0] += 1

            completed = 0
            for coro in asyncio.as_completed(
                [asyncio.create_task(process_one(p)) for p in remaining]
            ):
                await coro
                completed += 1
                if completed % 50 == 0 or completed == len(remaining):
                    pct = min(done_count_ref[0] / max(total, 1), 1.0)
                    extraction_bar.progress(pct)
                    extraction_status.caption(
                        f"Processed {done_count_ref[0]}/{total} paragraphs | "
                        f"{total_concepts_ref[0]} concepts | "
                        f"{total_relationships_ref[0]} relationships"
                    )
                if completed % 100 == 0:
                    with open(checkpoint_path, "w") as f:
                        json.dump(checkpoint, f)

            # Final checkpoint save
            with open(checkpoint_path, "w") as f:
                json.dump(checkpoint, f)

        asyncio.run(run_extraction())

        st.success(
            f"Concept extraction complete -- {total_concepts_ref[0]} concepts and "
            f"{total_relationships_ref[0]} relationships stored in Neo4j."
        )


