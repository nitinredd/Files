# ═══════════════════════════════════════════════════════════════

_DECOMPOSE_PROMPT = """You are an expert HPLC analytical chemistry assistant.
Decompose the question into 2-4 atomic sub-questions covering all aspects of the full answer.
Each sub-question must target one specific retrievable fact from HPLC textbooks.

Respond ONLY with valid JSON:
{"sub_questions": ["question 1", "question 2", "question 3"]}

No preamble. Only JSON."""


def decompose_query(llm, query: str) -> List[str]:
    try:
        response = llm.create_chat_completion(
            messages=[
                {"role": "system", "content": _DECOMPOSE_PROMPT},
                {"role": "user", "content": f"Decompose: {query}"}
            ],
            max_tokens=200, temperature=0.05,
            response_format={"type": "json_object"}
        )
        parsed = json.loads(response["choices"][0]["message"]["content"])
        sub_questions = parsed.get("sub_questions", [query])
        return sub_questions if sub_questions else [query]
    except Exception as e:
        logger.warning(f"Decomposition failed: {e}. Using original query.")
        return [query]


