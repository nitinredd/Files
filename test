def _route_files(files: List, doc_type: str) -> Tuple[Optional[bytes], List, Optional[bytes]]:
"""Route uploaded files to appropriate handlers.
Returns (excel_bytes, annexure_files, fishbone_bytes)."""
excel_bytes = None
fishbone_bytes = None
annexure_files = []

for f in files:
name = f.name.lower()
if name.endswith((".xlsx", ".xls")):
if excel_bytes is None: # first Excel wins
excel_bytes = f.getvalue()
elif name.endswith((".png", ".jpg", ".jpeg")):
if fishbone_bytes is None:
fishbone_bytes = f.getvalue()
elif name.endswith((".pdf", ".docx", ".doc", ".json")):
annexure_files.append(f)

return excel_bytes, annexure_files, fishbone_bytes

