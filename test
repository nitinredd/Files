def ingest_pdf(pdf_path: Path, neo4j: Neo4jClient,
               progress_callback: Optional[Callable] = None) -> Dict:
    """
    Stage 1: PDF -> SQLite -> Neo4j paragraph nodes only.
    Concept extraction and FAISS build happen separately after all books are loaded.
    Resumable: skips already-ingested documents automatically.
    """
    def progress(step, pct, detail=""):
        if progress_callback:
            progress_callback(step, pct, detail)
        logger.info(f"[{pct:.0%}] {step} {detail}")

    doc_id = pdf_path.stem

    if is_document_ingested(doc_id):
        return {"success": True, "skipped": True, "filename": pdf_path.name}

    progress("Extracting PDF text...", 0.10)
    pages = extract_pdf(pdf_path)
    if not pages:
        return {"success": False, "error": "No text extracted from PDF"}
    progress("PDF extraction complete", 0.25, f"-> {len(pages)} pages")

    progress("Chunking into paragraphs...", 0.30)
    paragraphs = chunk_document(pages)
    if not paragraphs:
        return {"success": False, "error": "No paragraphs generated"}
    progress("Chunking complete", 0.50, f"-> {len(paragraphs)} paragraphs from {len(pages)} pages")

    progress("Storing paragraphs in database...", 0.55)
    stored_count = sum(1 for p in paragraphs if db_store_paragraph(p))
    progress("Database storage complete", 0.70, f"-> {stored_count}/{len(paragraphs)} stored")

    if neo4j.is_connected:
        progress("Creating Neo4j paragraph nodes...", 0.75)
        for para in paragraphs:
            neo4j.store_paragraph(para.paragraph_id, para.doc_id, para.page_num, para.text[:200])
        progress("Neo4j nodes created", 0.90, f"-> {stored_count} paragraph nodes")

    db_store_document(doc_id, pdf_path.name, len(pages), stored_count)
    mark_document_ingested(doc_id, pdf_path.name, len(pages), stored_count)

    progress("Ingestion complete!", 1.0, f"-> {stored_count} paragraphs stored in SQLite + Neo4j")

    return {
        "success": True, "skipped": False, "filename": pdf_path.name,
        "pages": len(pages), "paragraphs": stored_count
    }


