                    "protocol":                header["protocol"],
                    "sop_format_number":       header["sop_format_number"],
                    "route_of_administration": header["route"],
                },
                "toc_entries":      [],
                "revision_history": [],
                "signatures":       [],
            }
            st.success("✅ Header built from form — no reference PDF required.")
            progress.progress(25)

            # Step 4: Parse Excel
            log.info("📊 Parsing composition Excel…")
            comp_data = parse_composition_excel(excel_file.getvalue())
            # User-entered values always override Excel-extracted values
            comp_data["route"]                = header["route"]
            comp_data["doses_per_day"]        = header["doses_per_day"]
            comp_data["mdd_total_mg_per_day"] = header["mdd_mg_per_day"]
            n_ing = sum(len(s.get("rows",[])) for s in comp_data.get("sections",[])
                        if isinstance(s, dict))
            st.success(
                f"Excel: {n_ing} ingredients | "
                f"Route: {comp_data['route']} | "
                f"MDD: {header['mdd_mg_per_day']:.1f}mg/day × "
                f"{header['doses_per_day']} dose(s)")
            progress.progress(38)

            # Step 6: Process annexures (PDF → Claude Vision, JSON → text extraction)
            log.info(f"🔬 Processing {len(annexure_files)} annexure(s)…")
            annexure_data: List[Dict] = []
            sorted_files = sorted(annexure_files, key=lambda f: f.name)
            for i, af in enumerate(sorted_files):
                is_pdf = af.name.lower().endswith(".pdf")

                if is_pdf:
                    log.info(f"  Annexure {i+1}: PDF → Claude Vision")
                    ann = process_annexure_pdf(af.getvalue(), i+1)
                else:
                    try:
                        raw_json = json.loads(
                            af.getvalue().decode("utf-8","replace").lstrip("\ufeff")
                        )
                    except Exception as e:
                        st.warning(f"  ⚠️ Annexure {i+1} ({af.name}): bad JSON — {e}")
                        annexure_data.append({
                            "annexure_number": i+1,
                            "supplier_name":   "",
                            "material_name":   "",
                            "elements":        [],
                        })
                        continue
                    ann = process_annexure(raw_json, i+1)

                annexure_data.append(ann)

                els    = ann.get("elements", []) or []
                n_real = sum(1 for e in els if isinstance(e,dict) and
                             e.get("concentration_value",0) > 0)
                n_zero = sum(1 for e in els if isinstance(e,dict) and
                             e.get("concentration_value",0) == 0.0)
                n_005  = sum(1 for e in els if isinstance(e,dict) and
                             abs(e.get("concentration_value",-1)-0.05)<0.001)
                has_warn = ann.get("_warning_placeholder_values", False)
                mode   = "📄 PDF" if is_pdf else "📋 JSON"
                status = "⚠️" if (has_warn or (is_pdf and n_real==0)) else "✅"

                st.write(
                    f"  {status} {mode} Annexure {i+1}: "
                    f"**{ann.get('material_name','(unknown)')}** "
                    f"({ann.get('supplier_name','(unknown)')}) — "
                    f"{len(els)} elements | non-zero: {n_real} | zero: {n_zero}"
                    + (f" | placeholders: {n_005}" if n_005 > 0 else "")
                )
                if has_warn:
                    st.warning(
                        f"  ⚠️ Annexure {i+1}: {n_005}/{len(els)} values=0.05. "
                        "Try uploading as PDF for accurate extraction."
                    )
                if is_pdf and n_real == 0:
                    st.warning(
                        f"  ⚠️ Annexure {i+1} PDF: no non-zero concentrations. "
                        "Check the PDF contains a readable EI table."
                    )
                progress.progress(42 + int(20*(i+1)/len(sorted_files)))

            # Step 7: Calculate EI tables
            log.info("🧮 Calculating EI tables (formula: daily_g × conc_µg/g)…")
            calc_tables = calculate_ei_tables(comp_data, annexure_data)
            t5 = safe_calc_table(calc_tables,"class1_2a")

            # ── Match audit display ──────────────────────────────────────────
            match_audit = calc_tables.get("_match_audit", [])
            if match_audit:
                unmatched_ings  = [a for a in match_audit if not a["matched"]]
                zero_conc_ings  = [a for a in match_audit
                                   if a.get("matched") and a.get("n_nonzero_conc",0)==0]
                matched_ok      = [a for a in match_audit
                                   if a.get("matched") and a.get("n_nonzero_conc",0)>0]

                st.markdown("**📊 Ingredient → Annexure Match Audit:**")
                # Show as a table
                audit_rows = []
                for a in match_audit:
                    status = "✅ Matched" if (a["matched"] and a.get("n_nonzero_conc",0)>0)                              else ("⚠️ Zero conc" if a["matched"] else "❌ No match")
                    audit_rows.append({
                        "Ingredient":     a["ingredient"][:45],
                        "Daily g/day":    f"{a['daily_g']:.5f}",
                        "% of total":     f"{a['pct_of_total']:.1f}%",
                        "Status":         status,
                        "Non-zero conc":  a.get("n_nonzero_conc", 0),
                    })
                st.dataframe(audit_rows, use_container_width=True, height=250)

                if unmatched_ings:
                    unmatched_mass = sum(a["daily_g"] for a in unmatched_ings)
                    total_mass = sum(a["daily_g"] for a in match_audit)
                    pct_unmatched = unmatched_mass/total_mass*100 if total_mass else 0
                    st.error(
                        f"❌ {len(unmatched_ings)} ingredient(s) have NO annexure match "
                        f"({pct_unmatched:.1f}% of total daily mass = {unmatched_mass:.4f}g/day). "
                        f"These contribute ZERO to all element totals, causing underestimation.\n"
                        f"Unmatched: {[a['ingredient'] for a in unmatched_ings[:6]]}"
                    )
                if zero_conc_ings:
                    st.warning(
                        f"⚠️ {len(zero_conc_ings)} ingredient(s) matched an annexure but "
                        f"ALL concentrations = 0. This suggests the annexure JSON has no "
                        f"real concentration data.\n"
                        f"Affected: {[a['ingredient'] for a in zero_conc_ings[:6]]}"
                    )
                if not unmatched_ings and not zero_conc_ings:
                    st.success(f"✅ All {len(matched_ok)} ingredients matched with real concentrations."
                               )

            # ── Calculation diagnostics ──────────────────────────────────────────
            n_rows_5    = len(t5.get("rows",[]))
            ann_materials = [a.get("material_name","?") for a in annexure_data
                             if isinstance(a,dict)]
            strength_mg = comp_data.get("mdd_strength_mg", 0)
            doses_day   = comp_data.get("doses_per_day", 1)
            total_mg    = comp_data.get("mdd_total_mg_per_day", 0)
            route_used  = comp_data.get("route","?")
            total_g_calc= sum(r.get("daily_intake_g",0) for r in t5.get("rows",[]))

            st.write(
                f"  📊 **MDD**: {strength_mg}mg × {doses_day} dose(s)/day "
                f"= {total_mg}mg/day | Route: {route_used}"
            )
            st.write(
                f"  📊 **Calc check**: sum of daily intakes = {total_g_calc:.4f}g/day | "
                f"Class1+2A rows: {n_rows_5}"
            )
            if n_rows_5 == 0:
                st.warning("⚠️ No ingredient rows — check ingredient_col / "
                           "amount_col / annexure matching.")

            # ── Full transparency expander ────────────────────────────────────
            match_audit = calc_tables.get("_match_audit", [])
            with st.expander("🔬 Full Calculation Audit — click to verify every value", expanded=False):

                # 1. Annexure concentrations table
                st.markdown("**Annexure concentrations loaded (µg/g = ppm):**")
                conc_rows = []
                for ann in annexure_data:
                    if not isinstance(ann, dict): continue
                    mat = ann.get("material_name","?")
                    for el in (ann.get("elements") or []):
                        if not isinstance(el, dict): continue
                        cv = el.get("concentration_value", 0)
                        if cv > 0:
                            conc_rows.append({
                                "Material":   mat,
                                "Element":    el.get("symbol",""),
                                "Class":      el.get("class",""),
                                "Conc (ppm)": cv,
                                "Observed":   el.get("observed_level",""),
                            })
                if conc_rows:
                    st.dataframe(
                        sorted(conc_rows, key=lambda r: -r["Conc (ppm)"]),
                        use_container_width=True, height=250
                    )
                else:
                    st.error("❌ No non-zero concentrations in any annexure — "
                             "all EI calculations will be zero. "
                             "Re-run annexure_converter.py on the vendor PDFs.")

                # 2. Ingredient matching audit
                st.markdown("**Ingredient → Annexure matching:**")
                audit_rows = []
                for a in match_audit:
                    audit_rows.append({
                        "Ingredient":      a["ingredient"],
                        "Daily intake (g)":f"{a['daily_g']:.6f}",
                        "% of total":      f"{a.get('pct_of_total',0):.1f}%",
                        "Matched":         "✅" if a["matched"] else "❌ NO MATCH",
                        "Non-zero concs":  a.get("n_nonzero_conc", 0),
                    })
                st.dataframe(
                    sorted(audit_rows, key=lambda r: -float(r["Daily intake (g)"])),
                    use_container_width=True, height=300
                )
                unmatched_list = [a["ingredient"] for a in match_audit if not a["matched"]]
                if unmatched_list:
                    st.warning(
                        f"⚠️ {len(unmatched_list)} ingredient(s) had NO annexure match "
                        f"→ contribute 0 to all elements:\n"
                        + "\n".join(f"  • {n}" for n in unmatched_list)
                    )

                # 3. Element totals vs thresholds
                st.markdown("**Class 1 + 2A daily exposures vs 30% PDE threshold:**")
                threshold_rows = []
                for sym in TABLE5_ELEMENTS:
                    total_exp = t5["element_totals"].get(sym, 0) or 0
                    pde_v     = t5["pde"].get(sym) or 0
                    thr_v     = t5["threshold_30pct"].get(sym) or 0
                    pct       = round(total_exp / pde_v * 100, 2) if pde_v else 0
                    exceeds   = total_exp > thr_v if thr_v else False
                    # Find dominant contributor
                    dom = max(
                        (r for r in t5.get("rows",[]) if isinstance(r, dict)),
                        key=lambda r: r.get("total_mass",{}).get(sym, 0),
                        default={}
                    )
                    threshold_rows.append({
                        "Element":          sym,
                        "Total (µg/day)":   round(total_exp, 6),
                        "PDE (µg/day)":     pde_v,
                        "30% PDE":          round(thr_v, 4) if thr_v else "N/A",
                        "% of PDE":         pct,
                        "Exceeds 30% PDE":  "❌ YES" if exceeds else "✅ No",
                        "Top contributor":  dom.get("ingredient","")[:30],
                    })
                st.dataframe(threshold_rows, use_container_width=True, height=300)

            crossing = [sym for sym in TABLE5_ELEMENTS
                        if t5["pde"].get(sym) and
                        t5["element_totals"].get(sym,0) > t5["pde"].get(sym,0)*0.30]
            if crossing:
                st.warning(f"Elements > 30% PDE: {', '.join(crossing)}")
            else:
                st.success("All Class 1+2A elements ≤ 30% PDE." if n_rows_5>0
                           else "⚠️ Tables empty — check diagnostics above.")
            progress.progress(72)

            # Step 8: Generate text
            log.info("✍️ Generating report text with Claude…")
            text_sections = generate_text_sections(
                header, annexure_data, calc_tables, comp_data)
            progress.progress(82)

            # Step 9: Build DOCX
            log.info("📝 Building DOCX…")
            docx_bytes = assemble_and_generate(
                ref_structure, [], figure_pages,
                annexure_data, comp_data, calc_tables, text_sections,
                ref_bytes=b"", logo_b64=logo_b64, logo_type=logo_type)
            progress.progress(100)
            log.success("✅ Report generated!")

            _meta  = ref_structure.get("meta", {}) or {}
            doc_no = safe_str(_meta.get("document_no","TSR")).replace("/","_").replace(" ","_")
            ver    = safe_str(_meta.get("version","v")).split(",")[0].replace(" ","").replace(".","_")
            fname  = f"{doc_no}_{ver}_{datetime.now().strftime('%Y%m%d_%H%M%S')}.docx"
            st.download_button("📥 Download Report (DOCX)", data=docx_bytes, file_name=fname,
                mime="application/vnd.openxmlformats-officedocument.wordprocessingml.document")

        except Exception as e:
            st.error(f"Pipeline error: {e}")
            logger.exception("Pipeline error")

    with st.expander("ℹ️ Setup & Formula"):
        st.markdown("""
**Formula:** `Daily exposure (µg/day) = Amount_in_MDD (g/day) × Conc (µg/g)`

This works for **any product**:
- Oral sachets: amount per sachet × sachets/day → g/day
- Injections: amount per injection → g/day
- Topical: amount per application × applications/day → g/day

**PDE values used:** Automatically selected based on route of administration
(oral vs parenteral vs other).

**npm deps (once):** `npm install docx jszip`

**Logo:** Save as `assets/logo.png` next to `app.py`

**TOC:** Extracted automatically from the reference PDF — matches the product's actual sections.
""")


if __name__ == "__main__":
    main()
