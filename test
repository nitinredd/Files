def _generate_benoc_report() -> None:
    """Assemble the BE NOC payload (with structures + charts) and render via
    generate_benoc.js. Warning-first: blocks only on the structural hard errors."""
    import benoc as _bn
    try:
        annexures = st.session_state["benoc_annexures"]
        meta = st.session_state["benoc_meta"]
        gen_images = st.session_state.get("bn_gen_structures", True)
        gen_charts = st.session_state.get("bn_gen_charts", True)

        with st.spinner("Assembling payload (generating molecular structures and "
                        "dissolution charts)…"):
            payload, validation = _bn.build_benoc_payload(
                meta, annexures, generate_images=gen_images,
                generate_charts=gen_charts)

        if not validation.get("can_generate"):
            st.error("❌ Generation blocked (structural errors only): "
                     + " ".join(validation.get("errors", [])[:3]))
            return

        logo_bytes, logo_mt = load_logo_from_assets()
        if logo_bytes:
            payload["logo_b64"] = base64.standard_b64encode(logo_bytes).decode()
            payload["logo_type"] = logo_mt

        with st.spinner("Rendering A4 DOCX…"):
            with tempfile.NamedTemporaryFile("w", suffix=".json", delete=False,
                                             encoding="utf-8") as jf:
                json.dump(payload, jf, ensure_ascii=False)
                json_path = jf.name
            out_path = json_path.replace(".json", ".docx")
            script = str(Path(__file__).parent / "generate_benoc.js")
            r = subprocess.run(["node", script, json_path, out_path],
                               capture_output=True, text=True, timeout=180)
            if r.returncode != 0:
                raise RuntimeError(f"Renderer failed: {r.stderr[:500]}")
            with open(out_path, "rb") as f:
                docx_bytes = f.read()

        fname = (f"{meta['document_no'].replace('/','_').replace(' ','_')}_"
                 f"{datetime.now().strftime('%Y%m%d_%H%M%S')}.docx")
        st.session_state["benoc_docx_bytes"] = docx_bytes
        st.session_state["benoc_fname"] = fname
        st.session_state["benoc_report_ready"] = True
        st.success("✅ BE NOC report generated.")
    except Exception as e:
        st.error(f"Generation failed: {e}")
        logger.exception("BE NOC generate error")


