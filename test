            </motion.g>
          </svg>
        </div>

        {/* Labels */}
        <div className="text-center">
          <div className="text-sm font-semibold" style={{ letterSpacing: 0.2 }}>{label}</div>
          {subtitle && <div className="text-xs text-gray-500 mt-1">{subtitle}</div>}
