    comp_summary = []
    primary_key = safe_str(comp_data.get("mdd_amount_key", comp_data.get("mdd_strength", "")))
    for section in comp_data.get("sections", []) or []:
        if not isinstance(section, dict):
            continue
        for row in section.get("rows", []) or []:
            if isinstance(row, dict) and safe_str(row.get("ingredient", "")):
                comp_summary.append({
                    "ingredient": row.get("ingredient", ""),
                    "function": row.get("function", ""),
                    "amount": row.get(primary_key, ""),
