import React, { useState } from 'react';
import { motion } from 'framer-motion';
import { FiVolume2, FiDownload } from 'react-icons/fi';
import { parseResponseToTable } from '../utils/parseResponseToTable';

/**
 * Utility function to convert file size to human-readable format.
 */
function humanFileSize(bytes) {
  if (bytes === null || bytes === undefined) return ''; // Handle null/undefined
  const thresh = 1024;
  if (Math.abs(bytes) < thresh) return bytes + ' B'; // Bytes less than 1024
  const units = ['KB', 'MB', 'GB', 'TB'];
  let u = -1;
  do {
    bytes /= thresh;
    ++u;
  } while (Math.abs(bytes) >= thresh && u < units.length - 1);
  return bytes.toFixed(bytes >= 100 ? 0 : bytes >= 10 ? 1 : 2) + ' ' + units[u];
}

/**
 * Download file utility using fetch API.
 */
async function downloadFileViaFetch(url, filename) {
  try {
    const resp = await fetch(url, {
      method: 'GET',
      credentials: 'same-origin',
    });

    if (!resp.ok) {
      throw new Error(`Download failed: ${resp.status} ${resp.statusText}`);
    }

    // Convert response to ArrayBuffer for binary data handling
    const arrayBuffer = await resp.arrayBuffer();

    const blob = new Blob([arrayBuffer]); // Create a Blob without altering the content
    const objectUrl = URL.createObjectURL(blob);

    // Create the download link
    const a = document.createElement('a');
    a.href = objectUrl;
    a.download = filename || 'downloaded-file.xlsx';
    document.body.appendChild(a);
    a.click();
    a.remove();

    // Clean up memory
    URL.revokeObjectURL(objectUrl);
  } catch (error) {
    console.error('Error downloading file:', error.message || error);
  }
}

/**
 * Message component
 * - Accepts layoutId (string). When present, the outer wrapper uses that layoutId so it can
 * morph from a loader element that used the same layoutId.
 */
export default function Message({
  from,
  text,
  onReadAloud,
  layoutId,
  downloadUrl,
  downloadName,
  downloadSizeBytes,
}) {
  const table = parseResponseToTable(text);
  const isUser = from === 'user';
  const [isConfirmOpen, setConfirmOpen] = useState(false);
  const [pendingDownload, setPendingDownload] = useState(null);

  const variants = {
    initial: { opacity: 0, scale: 0.98, y: 6 },
    enter: { opacity: 1, scale: 1, y: 0, transition: { duration: 0.28, ease: 'easeOut' } },
    exit: { opacity: 0, scale: 0.98, y: 6, transition: { duration: 0.18 } },
  };

  const bubbleClass = isUser
    ? 'msg-user p-4 rounded-2xl text-white'
    : 'msg-agent p-4 rounded-2xl bg-white glass text-gray-900';

  const handleDownloadClick = () => {
    setPendingDownload({
      url: downloadUrl,
      name: downloadName,
      size: downloadSizeBytes,
    });
    setConfirmOpen(true);
  };

  async function onConfirmDownload() {
    if (!pendingDownload) return;
    const { url, name, size } = pendingDownload;

    try {
      await downloadFileViaFetch(url, name);
    } catch (e) {
      // Fallback: Open link in a new tab if the fetch fails
      window.open(url, '_blank', 'noopener');
    } finally {
      setConfirmOpen(false);
      setPendingDownload(null);
    }
  }

  return (
    <div className={`flex ${isUser ? 'justify-end' : 'justify-start'}`}>
      <motion.div
        layoutId={layoutId}
        initial="initial"
        animate="enter"
        exit="exit"
        variants={variants}
        className={`max-w-[78%] shadow-soft ${bubbleClass}`}
        style={{ overflow: 'hidden' }}
      >
        <div className="prose-sm whitespace-pre-wrap break-words">
          {!table && <div>{text}</div>}
          {table?.type === 'json' && (
            <div className="overflow-auto">
              <table className="min-w-full text-sm table-auto">
                <thead>
                  <tr className="text-left">
                    {Object.keys(table.data[0]).map((h) => (
                      <th key={h} className="px-3 py-2 border-b">
                        {h}
                      </th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {table.data.map((row, idx) => (
                    <tr key={idx}>
                      {Object.keys(table.data[0]).map((k) => (
                        <td key={k} className="px-3 py-2 border-b align-top">
                          {String(row[k] ?? '')}
                        </td>
                      ))}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
          {table?.type === 'matrix' && (
            <div className="overflow-auto">
              <table className="min-w-full text-sm table-auto">
                <thead>
                  <tr>
                    {table.headers.map((h) => (
                      <th key={h} className="px-3 py-2 border-b">
                        {h}
                      </th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {table.rows.map((r, i) => (
                    <tr key={i}>
                      {r.map((c, j) => (
                        <td key={j} className="px-3 py-2 border-b">
                          {c}
                        </td>
                      ))}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>

        {/* Agent controls: Read aloud + Download (when available) */}
        {!isUser && (
          <div className="mt-2 flex items-center justify-end gap-2">
            {onReadAloud && (
              <button
                onClick={() => onReadAloud?.(text)}
                className="px-3 py-1 text-xs rounded read-btn flex items-center gap-2"
              >
                <FiVolume2 /> Read
              </button>
            )}
            {downloadUrl && (
              <button
                onClick={handleDownloadClick}
                className="px-3 py-1 text-xs rounded bg-accent/5 border flex items-center gap-2 hover:bg-accent/10"
              >
                <FiDownload />
                <span>Download</span>
                {downloadName && (
                  <span className="text-xs text-gray-500 ml-2">
                    ({downloadName}
                    {downloadSizeBytes ? ` · ${humanFileSize(downloadSizeBytes)}` : ''})
                  </span>
                )}
              </button>
            )}
          </div>
        )}
      </motion.div>

      {/* Confirmation Modal */}
      {isConfirmOpen && (
        <div className="modal-backdrop flex items-center justify-center">
          <div className="modal-container bg-white p-4 rounded shadow-lg">
            <p className="text-sm">
              Are you sure you want to download{' '}
              <strong>{pendingDownload?.name || 'this file'}</strong>? (
              {humanFileSize(pendingDownload?.size)})
            </p>
            <div className="flex justify-end gap-2 mt-4">
              <button
                className="px-3 py-1 text-xs rounded bg-red-500 text-white"
                onClick={() => setConfirmOpen(false)}
              >
                Cancel
              </button>
              <button
                className="px-3 py-1 text-xs rounded bg-green-500 text-white"
                onClick={onConfirmDownload}
              >
                Confirm
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
