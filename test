 *
 * Fixes in this version:
 *  1. Page borders — JSZip post-processing injects pgBorders XML reliably
 *  2. Spell/grammar check disabled globally (settings) + noProof on every run
 *  3. Header: Department, Strength, Market, Protocol in separate stacked rows
 *     (nested table) — each field visually separated with borders
 *  4. Title page: Title centered in large box; SOP Format Number in own row below
 *  5. Body text: 12pt (SZ.TEXT); table cells remain 7pt (SZ.SM)
 *  6. Word spacing: characterSpacing:15 (+0.75pt) on body runs only
 *  7. Figure: 38% top crop (header fully removed)
 *  8. Logo: loaded from assets/logo.png — never extracted from PDF
 *
 * Usage: node generate_report.js <data.json> <out.docx>
 */
"use strict";

var fs     = require("fs");
var JSZip  = require("jszip");
var docx   = require("docx");

var Document            = docx.Document;
var Packer              = docx.Packer;
var Paragraph           = docx.Paragraph;
var TextRun             = docx.TextRun;
var Table               = docx.Table;
var TableRow            = docx.TableRow;
var TableCell           = docx.TableCell;
var ImageRun            = docx.ImageRun;
var Header              = docx.Header;
var Footer              = docx.Footer;
var AlignmentType       = docx.AlignmentType;
var BorderStyle         = docx.BorderStyle;
var WidthType           = docx.WidthType;
var ShadingType         = docx.ShadingType;
var VerticalAlign       = docx.VerticalAlign;
var PageNumber          = docx.PageNumber;
var PageBreak           = docx.PageBreak;
var convertInchesToTwip = docx.convertInchesToTwip;


// ============================================================================
// PAGE GEOMETRY  —  A5 Landscape: 210 mm × 148 mm
// ============================================================================
var PAGE_W = convertInchesToTwip(8.27);   // 210 mm
var PAGE_H = convertInchesToTwip(5.83);   // 148 mm
var MAR_L  = convertInchesToTwip(0.47);
var MAR_R  = convertInchesToTwip(0.47);
var MAR_T  = convertInchesToTwip(0.98);   // space for header table
var MAR_B  = convertInchesToTwip(0.39);
var CW     = PAGE_W - MAR_L - MAR_R;      // usable content width ≈ 10260 twips


// ============================================================================
// COLORS
// ============================================================================
var COLOR = {
  BLACK:        "000000",
  WHITE:        "FFFFFF",
  HEADER_GREY:  "D9D9D9",
  SECTION_BLUE: "BDD7EE",
  THRESHOLD_BG: "FFE699",
  EXCEEDED_BG:  "FFCCCC",
  EXCEEDED_TXT: "FF0000",
};


// ============================================================================
// FONTS & SIZES  (docx uses half-points: 1pt = 2 half-pts)
// ============================================================================
var FONT = "Times New Roman";

var SZ = {
  XXS:  10,   //  5pt — very wide table columns
  XS:   12,   //  6pt — wide table columns
  SM:   14,   //  7pt — table headers & data
  TEXT: 24,   // 12pt — generated body text ONLY (not tables, not header)
  HDR:  18,   //  9pt — section headings inside document
  MD:   20,   // 10pt — section number headings
  LG:   22,   // 11pt — large heading
  XL:   26,   // 13pt — title page title
};

// Character spacing for body text (+0.75pt = 15 twentieths-of-a-point)
var BODY_CHAR_SPACING = 15;


// ============================================================================
// BORDER HELPERS
// ============================================================================
function bdr(size, color) {
  return { style: BorderStyle.SINGLE, size: size || 4, color: color || COLOR.BLACK };
}

function allBorders(size) {
  var b = bdr(size);
  return { top: b, bottom: b, left: b, right: b,
           insideHorizontal: b, insideVertical: b };
}

function noBorders() {
  var nb = { style: BorderStyle.NIL, size: 0, color: COLOR.WHITE };
  return { top: nb, bottom: nb, left: nb, right: nb };
}

function cellShade(fill) {
  return { fill: fill, type: ShadingType.CLEAR, color: "auto" };
}

function cm() { return { top: 30, right: 60, bottom: 30, left: 60 }; }


// ============================================================================
// TEXT RUN — noProof disables Word red/blue underlines
// ============================================================================
function mkRun(text, opts) {
  opts = opts || {};
  return new TextRun({
    text:             String(text == null ? "" : text),
    bold:             !!opts.bold,
    size:             opts.size  || SZ.TEXT,
    font:             FONT,
    color:            opts.color || COLOR.BLACK,
    italics:          !!opts.italics,
    characterSpacing: opts.characterSpacing || 0,
    noProof:          true,   // disables spell check underline on every run
  });
}


// ============================================================================
// PARAGRAPH HELPERS
// ============================================================================
function mkPara(content, opts) {
  opts = opts || {};
  var runs;
  if (typeof content === "string") {
    runs = [mkRun(content, opts)];
  } else if (Array.isArray(content)) {
    runs = content;
  } else if (content) {
    runs = [content];
  } else {
    runs = [mkRun("", opts)];
  }
  return new Paragraph({
    alignment: opts.align || AlignmentType.LEFT,
    spacing: {
      before: (opts.before == null ? 40 : opts.before),
      after:  (opts.after  == null ? 40 : opts.after),
      line:   opts.line || 264,
    },
    children: runs,
  });
}

// Justified body paragraph — 12pt, +0.75pt char spacing, 1.2 line spacing
function bodyPara(text, opts) {
  opts = opts || {};
  return new Paragraph({
    alignment: AlignmentType.BOTH,
    spacing: { before: opts.before || 20, after: opts.after || 20, line: 288 },
    children: [new TextRun({
      text:             String(text == null ? "" : text),
      bold:             !!opts.bold,
      size:             opts.size || SZ.TEXT,
      font:             FONT,
      color:            COLOR.BLACK,
      characterSpacing: BODY_CHAR_SPACING,
      noProof:          true,
    })],
  });
}

function bodyParagraphs(text) {
  if (!text) return [];
  var lines = String(text).trim().split(/\n+/);
  var result = [];
  for (var i = 0; i < lines.length; i++) {
    var line = lines[i].trim();
    if (line) result.push(bodyPara(line));
  }
  return result;
}

function centerPara(text, bold, size) {
  return mkPara(text, { align: AlignmentType.CENTER, bold: !!bold,
                         size: size || SZ.TEXT, before: 40, after: 40 });
}

function leftPara(text, bold, size) {
  return mkPara(text, { align: AlignmentType.LEFT, bold: !!bold,
                         size: size || SZ.TEXT, before: 20, after: 20 });
}

function blankPara() { return mkPara("", { before: 20, after: 20 }); }

function pgBreak() { return new Paragraph({ children: [new PageBreak()] }); }

function sectionHeading(text) {
  return mkPara(text, { align: AlignmentType.LEFT, bold: true,
                         size: SZ.MD, before: 80, after: 40, line: 264 });
}


// ============================================================================
// TABLE CELL HELPERS
// (table cells use SZ.SM / SZ.XS — NOT SZ.TEXT; noProof still applied)
// ============================================================================
function mkCell(text, opts) {
  opts = opts || {};
  return new TableCell({
    columnSpan:    opts.colSpan || 1,
    width:         opts.w ? { size: opts.w, type: WidthType.DXA } : undefined,
    borders:       opts.noBorder ? noBorders() : allBorders(4),
    shading:       opts.fill ? cellShade(opts.fill) : undefined,
    margins:       cm(),
    verticalAlign: VerticalAlign.CENTER,
    children: [new Paragraph({
      alignment: opts.align || AlignmentType.CENTER,
      spacing: { before: 0, after: 0 },
      children: [new TextRun({
        text:    String(text == null ? "" : text),
        bold:    !!opts.bold,
        size:    opts.size || SZ.SM,
        font:    FONT,
        color:   opts.color || COLOR.BLACK,
        noProof: true,
      })],
    })],
  });
}

function mkCellL(text, opts) {
  opts = opts || {};
  opts.align = AlignmentType.LEFT;
  return mkCell(text, opts);
}

// Multi-line cell — each line is a separate paragraph within one cell
function mkCellML(lines, opts) {
  opts = opts || {};
  var arr = Array.isArray(lines) ? lines : [lines];
  return new TableCell({
    columnSpan:    opts.colSpan || 1,
    width:         opts.w ? { size: opts.w, type: WidthType.DXA } : undefined,
    borders:       opts.noBorder ? noBorders() : allBorders(4),
    shading:       opts.fill ? cellShade(opts.fill) : undefined,
    margins:       cm(),
    verticalAlign: VerticalAlign.CENTER,
    children: arr.filter(function (l) { return l != null; }).map(function (l) {
      return new Paragraph({
        alignment: AlignmentType.LEFT,
        spacing: { before: 0, after: 0 },
        children: [new TextRun({
          text: String(l), bold: !!opts.bold,
          size: opts.size || SZ.XS, font: FONT, noProof: true,
        })],
      });
    }),
  });
}

function emptyCell(fill, w) {
  return new TableCell({
    width:    w ? { size: w, type: WidthType.DXA } : undefined,
    borders:  allBorders(4),
    shading:  fill ? cellShade(fill) : undefined,
    margins:  cm(),
    children: [new Paragraph({ children: [new TextRun({ text: "", noProof: true })] })],
  });
}


// ============================================================================
// PAGE HEADER
//
// Structure matching original Dr. Reddy's IPDO document:
//
// ┌──────────┬────────────────────────────────────┬──────────────────────────┐
// │ IPDO     │   Technical Summary Report          │  [Logo / Dr. Reddy's]   │
// ├──────────┴─────────────────────────┬───────────┼──────────────────────────┤
// │ Title: [full title text]           │ Dept: FR&D│                          │
// │                                    ├───────────┤                          │
// │                                    │ Str: 10mg │                          │
// │                                    ├───────────┤                          │
// │                                    │ Mkt: USA  │                          │
// │                                    ├───────────┤                          │
// │                                    │ Prot: NA  │                          │
// ├──────────┬──────────────────┬──────┴───────────┴──────────────────────────┤
// │ Doc No   │ Product Name     │ Dosage Form       │ Version                 │
// └──────────┴──────────────────┴───────────────────┴─────────────────────────┘
//
// The right-side "nested" column uses a nested table for Dept/Strength/Market/Protocol.
// ============================================================================
function buildPageHeader(meta, logoB64, logoType) {
  meta = meta || {};
  var title      = meta.title        || "";
  var docNo      = meta.document_no  || "";
  var prodName   = meta.product_name || "";
  var dosage     = meta.dosage_form  || "";
  var version    = meta.version      || "";
  var strength   = meta.strength     || "";
  var department = meta.department   || "";
  var market     = meta.market       || "";
  var protocol   = meta.protocol     || "";

  // Column widths — 4 main cols summing to CW
  var C1 = 900;    // IPDO label
  var C4 = 1700;   // Logo column
  var C2 = 5200;   // Title / Doc No / Product Name
  var C3 = CW - C1 - C2 - C4;  // Department/Strength/Market/Protocol

  // ── Logo cell ─────────────────────────────────────────────────────────────
  var logoCell;
  if (logoB64 && logoB64.length > 100) {
    try {
      var logoBuf = Buffer.from(logoB64, "base64");
      var imgType = (logoType || "").indexOf("jpeg") >= 0 ? "jpg" : "png";
      var logoImg = new ImageRun({
        type: imgType, data: logoBuf,
        transformation: { width: 110, height: 44 },
      });
      logoCell = new TableCell({
        width: { size: C4, type: WidthType.DXA },
        borders: allBorders(4), margins: cm(), verticalAlign: VerticalAlign.CENTER,
        children: [new Paragraph({
          alignment: AlignmentType.RIGHT, spacing: { before: 0, after: 0 },
          children: [logoImg],
        })],
      });
    } catch (e) {
      logoCell = mkCell("Dr. Reddy's",
        { bold: true, size: SZ.XS, w: C4, align: AlignmentType.RIGHT });
    }
  } else {
    logoCell = mkCell("Dr. Reddy's",
      { bold: true, size: SZ.XS, w: C4, align: AlignmentType.RIGHT });
  }

  // ── Row 1: IPDO | Technical Summary Report | Logo ────────────────────────
  var row1 = new TableRow({
    children: [
      mkCell("IPDO", { bold: true, size: SZ.MD, align: AlignmentType.LEFT, w: C1 }),
      new TableCell({
        columnSpan: 2, width: { size: C2 + C3, type: WidthType.DXA },
        borders: allBorders(4), margins: cm(), verticalAlign: VerticalAlign.CENTER,
        children: [centerPara("Technical Summary Report", true, SZ.MD)],
      }),
      logoCell,
    ],
  });

  // ── Right nested table: Department / Strength / Market / Protocol ─────────
  // Each field gets its own row so they are visually separated with cell borders
  var rightNestedW = C3 + C4;  // right nested table spans both C3 and C4 cols
  function rightRow(label, value) {
    var labelW = Math.round(rightNestedW * 0.45);
    var valueW = rightNestedW - labelW;
    return new TableRow({
      children: [
        mkCellL(label, { size: SZ.XS, bold: true, w: labelW }),
        mkCellL(value, { size: SZ.XS, w: valueW }),
      ],
    });
  }
  var rightNestedTable = new Table({
    width: { size: rightNestedW, type: WidthType.DXA },
    columnWidths: [Math.round(rightNestedW * 0.45), rightNestedW - Math.round(rightNestedW * 0.45)],
    rows: [
      rightRow("Department:", department),
      rightRow("Strength:",   strength),
      rightRow("Market:",     market),
      rightRow("Protocol:",   protocol),
    ],
  });

  // ── Row 2: Title (left wide) | Dept/Str/Mkt/Prot nested table (right) ────
  var row2 = new TableRow({
    children: [
      new TableCell({
        columnSpan: 2, width: { size: C1 + C2, type: WidthType.DXA },
        borders: allBorders(4), margins: cm(), verticalAlign: VerticalAlign.CENTER,
        children: [new Paragraph({
          alignment: AlignmentType.LEFT, spacing: { before: 0, after: 0 },
          children: [new TextRun({
            text: "Title: " + title, bold: false, size: SZ.XS, font: FONT, noProof: true,
          })],
        })],
      }),
      // Right side: nested table inside a single spanning cell
      new TableCell({
        columnSpan: 2, width: { size: C3 + C4, type: WidthType.DXA },
        borders: allBorders(4), margins: { top: 0, right: 0, bottom: 0, left: 0 },
        verticalAlign: VerticalAlign.CENTER,
        children: [rightNestedTable],
      }),
    ],
  });

  // ── Row 3: Doc No | Product Name | Dosage Form | Version ─────────────────
  // Each field in its own cell, widths proportional
  var r3w1 = Math.round(CW * 0.18);
  var r3w2 = Math.round(CW * 0.35);
  var r3w3 = Math.round(CW * 0.22);
  var r3w4 = CW - r3w1 - r3w2 - r3w3;

  var row3 = new TableRow({
    children: [
      mkCellL("Document No: " + docNo,     { size: SZ.XS, w: r3w1 }),
      mkCellL("Product Name: " + prodName, { size: SZ.XS, w: r3w2 }),
      mkCellL("Dosage Form: " + dosage,    { size: SZ.XS, w: r3w3 }),
      mkCellL("Version: " + version,       { size: SZ.XS, w: r3w4 }),
    ],
  });

  var hdrTable = new Table({
    width: { size: CW, type: WidthType.DXA },
    columnWidths: [C1, C2, C3, C4],
    rows: [row1, row2, row3],
  });

  return new Header({ children: [hdrTable, blankPara()] });
}


