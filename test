    prompt = f"""You are a pharmaceutical regulatory writer generating a Technical Summary Report (TSR)
for an ICH Q3D (R2) Elemental Impurities Risk Assessment.

Reference report structure (extracted from previous version):
{json.dumps(ref_structure.get("meta", {}), indent=2)}

