function generateReport(dataPath, outPath) {
  var raw  = fs.readFileSync(dataPath, "utf-8");
  var data = JSON.parse(raw);

  var meta                = data.rs_meta              || data.meta || {};
  var tocEntries          = data.toc_entries          || [];
  var logoB64             = data.logo_b64             || "";
  var logoType            = data.logo_type            || "";
  var txt                 = data.text_sections        || {};
  var productDetails      = data.product_details      || {};
  var composition         = data.composition_table    || data.composition || [];
  var compColumns         = data.comp_columns         || [];
  var compMeta            = data.comp_meta            || {};
  var supplierDeclarations= data.supplier_declaration_table || data.supplier_declarations || [];
  var solventTables       = data.solvent_matrix_tables || data.solvent_tables || {};
  var annList             = data.annexure_list_deduplicated || data.annexure_list || [];
  var revHistory          = data.revision_history     || [];
  var signatures          = data.signatures           || [];
  var riskSummaryTable    = data.risk_summary_table   || null;
  var validationWarnings  = data.validation_warnings  || [];
  var manualReviewItems   = data.manual_review_items  || [];
  var conclusionStatus    = data.conclusion_status    || "";

  var ch = [];

  buildTitlePage(meta).forEach(function(x){ch.push(x);});
  buildAbstract(txt).forEach(function(x){ch.push(x);});
  buildTOC(tocEntries, meta).forEach(function(x){ch.push(x);});
  buildObjective(txt).forEach(function(x){ch.push(x);});
  buildDetailsOfProduct(productDetails).forEach(function(x){ch.push(x);});
  buildBackground(txt).forEach(function(x){ch.push(x);});
  ch.push(pgBrk());
  buildCompositionTable(composition, compColumns, compMeta).forEach(function(x){ch.push(x);});
  buildSection5(txt, supplierDeclarations, solventTables, meta).forEach(function(x){ch.push(x);});
  buildConclusion(txt).forEach(function(x){ch.push(x);});
  buildSummaryAndConclusion(txt, riskSummaryTable, validationWarnings, manualReviewItems, conclusionStatus).forEach(function(x){ch.push(x);});
  buildReferences(txt).forEach(function(x){ch.push(x);});
  buildAnnexureList(annList).forEach(function(x){ch.push(x);});
  buildRevision(revHistory).forEach(function(x){ch.push(x);});
  buildSignatures(meta, signatures).forEach(function(x){ch.push(x);});

  var doc = new Document({
    settings:{hideSpellingErrors:true, hideGrammaticalErrors:true},
    styles:{default:{document:{run:{font:F,size:SZ.TEXT,color:CLR.BLACK}}}},
    sections:[{
