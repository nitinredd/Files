/**
 * ReconstructedPrompt — left panel in REVEAL state.
 * Shows the typewriter-animated reconstructed prompt and metadata chips.
 *
 * Props:
 *   data  — { reconstructed_prompt, confidence, strategy_used, technique }
 *   error — error message string (if reconstruction failed)
 */
export default function ReconstructedPrompt({ data, error }) {
  const [displayText, setDisplayText] = useState('')
  const [copied, setCopied] = useState(false)
  const timerRef = useRef(null)

  const fullText = data?.reconstructed_prompt ?? ''

  // Typewriter animation
  useEffect(() => {
    if (!fullText) return
    setDisplayText('')
    let i = 0
    timerRef.current = setInterval(() => {
      i += 1
      setDisplayText(fullText.slice(0, i))
      if (i >= fullText.length) clearInterval(timerRef.current)
    }, TYPEWRITER_INTERVAL_MS)
    return () => clearInterval(timerRef.current)
  }, [fullText])

  const handleCopy = async () => {
    try {
      await navigator.clipboard.writeText(fullText)
      setCopied(true)
      setTimeout(() => setCopied(false), 2000)
    } catch {
      // fallback — execCommand
      const el = document.createElement('textarea')
      el.value = fullText
      document.body.appendChild(el)
      el.select()
      document.execCommand('copy')
      document.body.removeChild(el)
      setCopied(true)
      setTimeout(() => setCopied(false), 2000)
    }
  }

  const confidencePct = data ? Math.round(data.confidence * 100) : null
  const strategy = data?.strategy_used ?? ''
  const technique = data?.technique ?? ''

  return (
    <div className="panel-left">
      {/* Header */}
      <div className="panel-header">
        <span className="panel-label">Reconstructed Prompt</span>
        {!error && fullText && (
          <button
            className="copy-btn"
            onClick={handleCopy}
            aria-label="Copy reconstructed prompt"
          >
            {copied ? (
              <span className="copy-tooltip">✓ COPIED</span>
            ) : null}
            <CopyIcon />
          </button>
        )}
      </div>

      {/* Content */}
      {error ? (
        <div className="error-state">
          <span className="error-label">RECONSTRUCTION FAILED</span>
          <p className="error-detail">{error}</p>
        </div>
      ) : (
        <p className="reconstructed-text">{displayText}</p>
      )}

      {/* Metadata chips */}
      {!error && confidencePct !== null && (
        <div className="metadata-row">
          <span className="meta-chip meta-confidence">
            CONFIDENCE: {confidencePct}%
          </span>
          {strategy && (
            <span className="meta-chip meta-strategy">
              STRATEGY: {strategy}
            </span>
          )}
          {technique && (
            <span className="meta-chip meta-technique">
              TECHNIQUE: {technique}
            </span>
          )}
        </div>
      )}
    </div>
  )
}
