function buildAdditionalTables(additionalTables) {
  if (!Array.isArray(additionalTables) || !additionalTables.length) return [];
  var ch = [];
  for (var i = 0; i < additionalTables.length; i++) {
    var tbl = additionalTables[i];
    if (!tbl || typeof tbl !== "object") continue;
    var cols = Array.isArray(tbl.columns) ? tbl.columns : [];
