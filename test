def process_query(query: str) -> Dict:
    llm = st.session_state.phi4
    embedder = Embedder(st.session_state.embedder)
    retriever = Retriever(embedder, st.session_state.faiss_store, st.session_state.neo4j)
    nli_model = st.session_state.nli
    mode = st.session_state.mode

    with st.status("Processing query...", expanded=True) as status:
        st.write("Decomposing query into sub-questions...")
        sub_questions = decompose_query(llm, query)
        st.write(f"Generated {len(sub_questions)} sub-questions")

        st.write("Retrieving paragraphs (FAISS + Neo4j concept graph)...")
        all_paragraphs, seen_ids = [], set()
        for sq in sub_questions:
            for p in retriever.retrieve(sq, top_k=8):
                if p["paragraph_id"] not in seen_ids:
                    all_paragraphs.append(p)
                    seen_ids.add(p["paragraph_id"])
        all_paragraphs = all_paragraphs[:15]

        faiss_count = sum(1 for p in all_paragraphs if p.get("source") == "faiss")
        graph_count = sum(1 for p in all_paragraphs if p.get("source") == "graph")
        st.write(f"{len(all_paragraphs)} paragraphs retrieved ({faiss_count} semantic + {graph_count} graph-expanded)")

        if not all_paragraphs:
            status.update(label="No relevant paragraphs found", state="error")
            return {
                "type": "refusal", "answer": None,
                "message": "No relevant paragraphs found. Please ensure documents are ingested.",
                "verified_claims": [], "rejected_claims": []
            }

        st.write(f"Generating answer ({mode.upper()} mode)...")
        generated = generate_answer(llm, query, all_paragraphs, mode=mode)
        st.write(f"Answer generated with {len(generated['claims'])} claims")

        st.write(f"Verifying {len(generated['claims'])} claims through 3-tier firewall...")
        verification_results = verify_all_claims(nli_model, generated["claims"])
        response = assemble_response(generated["answer_text"], generated["claims"], verification_results)

        verified_count = len(response.get("verified_claims", []))
        status.update(
            label=f"Complete -- {verified_count}/{len(generated['claims'])} claims verified",
            state="complete"
        )

    log_query_cost(mode, gpt4o_calls=2 if mode == "hybrid" else 0)
    return response


def _render_verification_report(response: Dict):
    verified = response.get("verified_claims", [])
    rejected = response.get("rejected_claims", [])
    total = len(verified) + len(rejected)
    if total == 0:
        return
    with st.expander(f"Verification Report -- {len(verified)}/{total} claims verified"):
        if verified:
            st.markdown("**Verified Claims**")
            for r in verified:
                st.success(
                    f"**{r.claim_text}**\n\n"
                    f"Confidence: {r.confidence:.1%} | Source: `{r.source_paragraph_id}`"
                )
                if r.source_text:
                    st.caption(f"{r.source_text[:300]}...")
        if rejected:
            st.markdown("**Rejected Claims**")
            for r in rejected:
                st.error(f"**{r.claim_text}**\n\nTier {r.tier_reached} rejection: {r.reason}")


