                    f"  {status} {mode} Annexure {i+1}: "
                    f"**{ann.get('material_name','(unknown)')}** "
                    f"({ann.get('supplier_name','(unknown)')}) — "
                    f"{len(els)} elements | non-zero: {n_real} | zero: {n_zero}"
                    + (f" | placeholders: {n_005}" if n_005 > 0 else "")
                )
                if has_warn:
                    st.warning(
                        f"  ⚠️ Annexure {i+1}: {n_005}/{len(els)} values=0.05. "
                        "Try uploading as PDF for accurate extraction."
                    )
                if is_pdf and n_real == 0:
                    st.warning(
                        f"  ⚠️ Annexure {i+1} PDF: no non-zero concentrations. "
                        "Check the PDF contains a readable EI table."
                    )
                progress.progress(42 + int(20*(i+1)/len(sorted_files)))

            # Step 7: Calculate EI tables
            log.info("🧮 Calculating EI tables (formula: daily_g × conc_µg/g)…")
            calc_tables = calculate_ei_tables(comp_data, annexure_data)
            t5 = safe_calc_table(calc_tables,"class1_2a")

            # ── Match audit display ──────────────────────────────────────────
            match_audit = calc_tables.get("_match_audit", [])
            if match_audit:
                unmatched_ings  = [a for a in match_audit if not a["matched"]]
                zero_conc_ings  = [a for a in match_audit
                                   if a.get("matched") and a.get("n_nonzero_conc",0)==0]
                matched_ok      = [a for a in match_audit
                                   if a.get("matched") and a.get("n_nonzero_conc",0)>0]

                st.markdown("**📊 Ingredient → Annexure Match Audit:**")
                audit_rows = []
                for a in match_audit:
                    status = "✅ Matched" if (a["matched"] and a.get("n_nonzero_conc",0)>0) \
                             else ("⚠️ Zero conc" if a["matched"] else "❌ No match")
                    audit_rows.append({
                        "Ingredient":     a["ingredient"][:42],
                        "Section":        a.get("section","")[:18],
                        "Daily g/day":    f"{a['daily_g']:.5f}",
                        "% total":        f"{a['pct_of_total']:.1f}%",
                        "Matched to":     (a.get("matched_key","") or "—")[:30],
                        "Match type":     a.get("match_type",""),
                        "Conf":           a.get("match_confidence",""),
                        "Brand":          a.get("detected_brand",""),
                        "Family":         a.get("material_family","")[:28],
                        "Reason":         a.get("match_reason","")[:80],
                        "Status":         status,
                        "Non-zero":       a.get("n_nonzero_conc", 0),
                    })
                st.dataframe(audit_rows, use_container_width=True, height=260)

                # ── Validation warnings (scientific-accuracy gate) ───────────
                warns = calc_tables.get("_warnings", [])
                if warns:
                    with st.expander(f"⚠️ {len(warns)} validation warning(s) — review before trusting the report",
                                     expanded=True):
                        for w in warns[:40]:
                            st.warning(w)
                else:
                    st.success("✅ No validation warnings — units, matches, and totals look consistent.")

                if unmatched_ings:
                    unmatched_mass = sum(a["daily_g"] for a in unmatched_ings)
                    total_mass = sum(a["daily_g"] for a in match_audit)
                    pct_unmatched = unmatched_mass/total_mass*100 if total_mass else 0
                    st.error(
                        f"❌ {len(unmatched_ings)} ingredient(s) have NO annexure match "
                        f"({pct_unmatched:.1f}% of total daily mass = {unmatched_mass:.4f}g/day). "
                        f"These contribute ZERO to all element totals, causing underestimation.\n"
                        f"Unmatched: {[a['ingredient'] for a in unmatched_ings[:6]]}"
                    )
                if zero_conc_ings:
                    st.warning(
                        f"⚠️ {len(zero_conc_ings)} ingredient(s) matched an annexure but "
                        f"ALL concentrations = 0. This suggests the annexure JSON has no "
                        f"real concentration data.\n"
                        f"Affected: {[a['ingredient'] for a in zero_conc_ings[:6]]}"
                    )
                if not unmatched_ings and not zero_conc_ings:
                    st.success(f"✅ All {len(matched_ok)} ingredients matched with real concentrations."
                               )

            # ── Calculation diagnostics ──────────────────────────────────────────
            n_rows_5    = len(t5.get("rows",[]))
            ann_materials = [a.get("material_name","?") for a in annexure_data
                             if isinstance(a,dict)]
            strength_mg = comp_data.get("mdd_strength_mg", 0)
            doses_day   = comp_data.get("doses_per_day", 1)
            total_mg    = comp_data.get("mdd_total_mg_per_day", 0)
            route_used  = comp_data.get("route","?")
            total_g_calc= sum(r.get("daily_intake_g",0) for r in t5.get("rows",[]))

            st.write(
                f"  📊 **MDD**: {strength_mg}mg × {doses_day} dose(s)/day "
                f"= {total_mg}mg/day | Route: {route_used}"
            )
            st.write(
                f"  📊 **Calc check**: sum of daily intakes = {total_g_calc:.4f}g/day | "
                f"Class1+2A rows: {n_rows_5}"
            )
            if n_rows_5 == 0:
                st.warning("⚠️ No ingredient rows — check ingredient_col / "
                           "amount_col / annexure matching.")

            # ── Full transparency expander ────────────────────────────────────
            match_audit = calc_tables.get("_match_audit", [])
            with st.expander("🔬 Full Calculation Audit — click to verify every value", expanded=False):

                # 1. Annexure concentrations table
                st.markdown("**Annexure concentrations loaded (µg/g = ppm):**")
                conc_rows = []
                for ann in annexure_data:
                    if not isinstance(ann, dict): continue
                    mat = ann.get("material_name","?")
                    for el in (ann.get("elements") or []):
                        if not isinstance(el, dict): continue
                        cv = el.get("concentration_value", 0)
                        if cv > 0:
                            conc_rows.append({
                                "Material":   mat,
                                "Element":    el.get("symbol",""),
                                "Class":      el.get("class",""),
                                "Conc (ppm)": cv,
                                "Observed":   el.get("observed_level",""),
                            })
                if conc_rows:
                    st.dataframe(
                        sorted(conc_rows, key=lambda r: -r["Conc (ppm)"]),
                        use_container_width=True, height=250
                    )
                else:
                    st.error("❌ No non-zero concentrations in any annexure — "
                             "all EI calculations will be zero. "
                             "Re-run annexure_converter.py on the vendor PDFs.")

                # 2. Ingredient matching audit
                st.markdown("**Ingredient → Annexure matching:**")
                audit_rows = []
                for a in match_audit:
                    audit_rows.append({
                        "Ingredient":      a["ingredient"],
                        "Daily intake (g)":f"{a['daily_g']:.6f}",
                        "% of total":      f"{a.get('pct_of_total',0):.1f}%",
                        "Matched":         "✅" if a["matched"] else "❌ NO MATCH",
                        "Non-zero concs":  a.get("n_nonzero_conc", 0),
                    })
                st.dataframe(
                    sorted(audit_rows, key=lambda r: -float(r["Daily intake (g)"])),
                    use_container_width=True, height=300
                )
                unmatched_list = [a["ingredient"] for a in match_audit if not a["matched"]]
                if unmatched_list:
                    st.warning(
                        f"⚠️ {len(unmatched_list)} ingredient(s) had NO annexure match "
                        f"→ contribute 0 to all elements:\n"
                        + "\n".join(f"  • {n}" for n in unmatched_list)
                    )

                # ── Build source-traceability CSV (offered as download below, ──
                # NOT in the document). Stored in session_state so the download
                # button persists across reruns.
                ann_no_map = {
                    safe_str(a.get("material_name","")): a.get("annexure_number","?")
                    for a in annexure_data if isinstance(a, dict)
                }
                import csv as _csv, io as _io
                _buf = _io.StringIO()
                _w = _csv.writer(_buf)
                _w.writerow(["Ingredient","Section","Daily intake (g)","Matched annexure",
                             "Matched material","Match type","Confidence","Status"])
                for a in match_audit:
                    mkey = a.get("matched_key","")
                    _w.writerow([
                        a.get("ingredient",""),
                        a.get("section",""),
                        f"{a.get('daily_g',0):.6f}",
