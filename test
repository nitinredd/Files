      ]}),
    ].concat(revisions.filter(function(r){return r&&typeof r==="object";}).map(function(r){
      return new TableRow({children:[
        cellL(r.document_version||r["Document and Version Number"]||"",{w:W[0],size:SZ.SM}),
        cellL(r.changes||r["Brief details of changes"]||"",{w:W[1],size:SZ.SM}),
      ]});
    })),
  });
  return [secHd("9. Revision history:"), tbl, pgBrk()];
}

// ── ELECTRONIC SIGNATURES ─────────────────────────────────────────────────────
function buildSignatures(meta, signatures) {
  meta=meta||{};
  var W=[Math.round(CW*0.25),Math.round(CW*0.15),Math.round(CW*0.32),0];
  W[3]=CW-W[0]-W[1]-W[2];
  var sigs=(Array.isArray(signatures)&&signatures.length)?signatures:[
    {intention:"Prepared by R&D",employee_id:"",user_name:"",date:""},
    {intention:"Reviewed by R&D",employee_id:"",user_name:"",date:""},
    {intention:"Approved by DQA",employee_id:"",user_name:"",date:""},
  ];
  var tbl=new Table({
    width:{size:CW,type:WidthType.DXA}, columnWidths:W,
    rows:[
      new TableRow({children:[
        cell("Intention",  {bold:true,fill:CLR.HDR_GREY,w:W[0],size:SZ.SM}),
        cell("Employee ID",{bold:true,fill:CLR.HDR_GREY,w:W[1],size:SZ.SM}),
        cell("User Name",  {bold:true,fill:CLR.HDR_GREY,w:W[2],size:SZ.SM}),
        cell("Date (IST)", {bold:true,fill:CLR.HDR_GREY,w:W[3],size:SZ.SM}),
      ]}),
    ].concat(sigs.map(function(s){
      return new TableRow({children:[
        cellL(s.intention||"",  {w:W[0],size:SZ.SM}),
        cell(s.employee_id||"", {w:W[1],size:SZ.SM}),
        cellL(s.user_name||"",  {w:W[2],size:SZ.SM}),
        cell(s.date||"",        {w:W[3],size:SZ.SM}),
      ]});
    })),
  });
  return [ctrPara("ELECTRONIC SIGNATURES",true,SZ.MD), blk(), tbl];
}

// ── PAGE BORDER + SPELL-OFF INJECTION (JSZip post-processing) ────────────────
function injectBordersAndSpellOff(buf) {
  var pgBXml=(
    '<w:pgBorders w:display="notFirstPage" w:offsetFrom="text">'+
    '<w:top    w:val="single" w:sz="6" w:space="4" w:color="000000"/>'+
    '<w:left   w:val="single" w:sz="6" w:space="4" w:color="000000"/>'+
    '<w:bottom w:val="single" w:sz="6" w:space="4" w:color="000000"/>'+
    '<w:right  w:val="single" w:sz="6" w:space="4" w:color="000000"/>'+
    '</w:pgBorders>'
  );
  var spellOff='<w:hideSpellingErrors/><w:hideGrammaticalErrors/>';

  return JSZip.loadAsync(buf).then(function(zip){
    return zip.file("word/document.xml").async("string").then(function(xml){
      var idx=xml.lastIndexOf("</w:sectPr>");
      if (idx>=0 && !xml.includes("pgBorders"))
        xml=xml.slice(0,idx)+pgBXml+xml.slice(idx);
      zip.file("word/document.xml",xml);

      var sf=zip.file("word/settings.xml");
      var sp;
      if (sf) {
        sp=sf.async("string").then(function(sxml){
          if (!sxml.includes("hideSpellingErrors"))
            sxml=sxml.replace("</w:settings>",spellOff+"</w:settings>");
          zip.file("word/settings.xml",sxml);
        });
      } else {
        zip.file("word/settings.xml",
          '<?xml version="1.0" encoding="UTF-8" standalone="yes"?>'+
          '<w:settings xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main">'+
          spellOff+'</w:settings>');
        sp=Promise.resolve();
      }
      return (sp||Promise.resolve()).then(function(){
        return zip.generateAsync({type:"nodebuffer",compression:"DEFLATE",
          compressionOptions:{level:6}});
      });
    });
  });
}

// ── MAIN ASSEMBLY ─────────────────────────────────────────────────────────────
function generateReport(dataPath, outPath) {
  var raw  = fs.readFileSync(dataPath,"utf-8");
  var data = JSON.parse(raw);

  var meta        = data.meta            ||{};
  var tocEntries  = data.toc_entries     ||[];
  var logoB64     = data.logo_b64        ||"";
  var logoType    = data.logo_type       ||"";
  var txt         = data.text_sections   ||{};
  var composition       = data.composition      ||[];
  var compColumns       = data.comp_columns      ||[];
  var compMeta          = data.comp_meta         ||{};
  var additionalTables  = data.additional_tables ||[];
  var annList     = data.annexure_list   ||[];
  var calcTables  = data.calc_tables     ||{};
  var revHistory  = data.revision_history||[];
  var signatures  = data.signatures      ||[];
  var figures     = Array.isArray(data.figures)?data.figures:[];
  var pdeValues   = data.pde_values      ||{};

  // Citation layer control flag (false by default)
  var enableInlineCitations = !!data.enable_inline_citations;

  var ch=[];

  var tp=buildTitlePage(meta);
  tp.forEach(function(x){ch.push(x);});

  var toc=buildTOC(tocEntries, figures.length);
  toc.forEach(function(x){ch.push(x);});

  // Sections 1-4
  var s14=buildTextSections(txt, enableInlineCitations);
  s14.forEach(function(x){ch.push(x);});

  // Composition table (exact columns from Excel)
  var comp=buildCompositionTable(composition, compColumns, compMeta);
  comp.forEach(function(x){ch.push(x);});

  // Figures
  figures.forEach(function(fig){
    buildFigure(fig).forEach(function(x){ch.push(x);});
  });

  // Table 2: Annexure details
  var annTbl2=buildSourcesSection(txt, annList);
  annTbl2.forEach(function(x){ch.push(x);});

  // Post-composition narrative sections
  var postComp=buildPostCompSections(txt);
  postComp.forEach(function(x){ch.push(x);});

  function safeT(key){
    var e={elements:[],rows:[],total_daily_intake:0,
           element_totals:{},pde:{},threshold_30pct:{},route:"oral",pde_sources:{}};
    if (!calcTables||typeof calcTables!=="object"||!calcTables[key]) return e;
    var m={};
    Object.keys(e).forEach(function(k){m[k]=e[k];});
    Object.keys(calcTables[key]).forEach(function(k){m[k]=calcTables[key][k];});
    return m;
  }

  try {
    buildCalcTable(5,safeT("class1_2a"),pdeValues,enableInlineCitations)
      .forEach(function(x){ch.push(x);});
    buildCalcTable(6,safeT("class2b"),  pdeValues,enableInlineCitations)
      .forEach(function(x){ch.push(x);});
    buildCalcTable(7,safeT("class3"),   pdeValues,enableInlineCitations)
      .forEach(function(x){ch.push(x);});
    ch.push(pgBrk());
  } catch(err){
    console.error("Calc table error:",err.message);
    ch.push(lftPara("Calc table error: "+err.message)); ch.push(pgBrk());
  }

  // Additional verbatim tables from reference PDF
  buildAdditionalTables(additionalTables).forEach(function(x){ch.push(x);});

  buildSummary(txt, enableInlineCitations).forEach(function(x){ch.push(x);});

  ch.push(secHd("7. Reference"));
  ch.push(bodyPara(txt.reference||"NA"));
  ch.push(blk());

  buildAnnexureList(annList).forEach(function(x){ch.push(x);});
  buildRevision(revHistory).forEach(function(x){ch.push(x);});
  buildSignatures(meta, signatures).forEach(function(x){ch.push(x);});

  var doc=new Document({
    settings:{hideSpellingErrors:true, hideGrammaticalErrors:true},
    styles:{default:{document:{run:{font:F,size:SZ.TEXT,color:CLR.BLACK}}}},
    sections:[{
      properties:{page:{
        size:{width:PAGE_W,height:PAGE_H},
        margin:{top:MAR_T,right:MAR_R,bottom:MAR_B,left:MAR_L,header:360,footer:360},
      }},
      headers:{default:buildHeader(meta,logoB64,logoType)},
      footers:{default:buildFooter()},
      children:ch,
    }],
  });

  return Packer.toBuffer(doc)
    .then(injectBordersAndSpellOff)
    .then(function(finalBuf){
      fs.writeFileSync(outPath,finalBuf);
      console.log("Report written: "+outPath+" ("+Math.round(finalBuf.length/1024)+" KB)");
    });
}

// ── Entry point ───────────────────────────────────────────────────────────────
var dp=process.argv[2], op=process.argv[3];
if (!dp||!op){console.error("Usage: node generate_report.js <data.json> <out.docx>"); process.exit(1);}
generateReport(dp,op).catch(function(err){
  console.error("FATAL:",err.message||err);
  if (err.stack) console.error(err.stack.split("\n").slice(0,8).join("\n"));
  process.exit(1);
});
