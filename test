            calc_tables = calculate_ei_tables(comp_data, annexure_data)
            t5 = safe_calc_table(calc_tables,"class1_2a")
            quality_flags = calc_tables.get("data_quality_flags", []) if isinstance(calc_tables, dict) else []
            for flag in quality_flags:
                if not isinstance(flag, dict):
