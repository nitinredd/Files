# ── Ingestion log (resume support) ────────────────────────────
def load_ingestion_log() -> Dict:
    if not INGESTION_LOG_PATH.exists():
        return {}
    with open(INGESTION_LOG_PATH) as f:
        return json.load(f)


def save_ingestion_log(log: Dict):
    with open(INGESTION_LOG_PATH, "w") as f:
        json.dump(log, f, indent=2, default=str)


def mark_document_ingested(doc_id: str, filename: str, pages: int, paragraphs: int):
    log = load_ingestion_log()
    log[doc_id] = {
        "filename": filename, "pages": pages, "paragraphs": paragraphs,
        "status": "complete", "timestamp": str(datetime.datetime.now())
    }
    save_ingestion_log(log)


def is_document_ingested(doc_id: str) -> bool:
    return load_ingestion_log().get(doc_id, {}).get("status") == "complete"


