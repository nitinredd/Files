// ── MAIN ─────────────────────────────────────────────────────────────────────
async function generateReport(dataPath,outPath){
const data=JSON.parse(fs.readFileSync(dataPath,‘utf-8’));
const{meta={},text_sections:txt={},composition=[],annexure_list=[],
calc_tables={},revision_history=[],signatures=[],figures=[],pde_values={}}=data;

const ch=[];
ch.push(…buildTitlePage(meta));
ch.push(…buildTOC(data.toc_entries||[]));
ch.push(…buildTextSections(txt));
ch.push(…buildCompositionTable(composition));
(figures||[]).forEach(fig=>ch.push(…buildFigure(fig)));
ch.push(…buildSourcesSection(txt,annexure_list));

const safeT=(key)=>{
const E={elements:[],rows:[],total_daily_intake:0,element_totals:{},pde:{},threshold_30pct:{}};
return(!calc_tables||!calc_tables[key])?E:Object.assign({},E,calc_tables[key]);
};
try{
ch.push(…buildCalcTable(5,safeT(‘class1_2a’),pde_values));
ch.push(…buildCalcTable(6,safeT(‘class2b’),  pde_values));
ch.push(…buildCalcTable(7,safeT(‘class3’),   pde_values));
ch.push(pageBreak());
}catch(e){
console.error(‘Calc table error:’,e.message);
ch.push(pL(’⚠ Calculation table error: ’+e.message)); ch.push(pageBreak());
}

ch.push(…buildSummarySection(txt));
ch.push(sHd(‘7. Reference’));
ch.push(pL(txt.reference||‘NA’));
ch.push(blank());
ch.push(…buildAnnexureList(annexure_list));
ch.push(…buildRevision(revision_history));
ch.push(…buildSignatures(meta,signatures));

