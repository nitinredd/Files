// ── ADDITIONAL TABLES ────────────────────────────────────────────────────────
function buildAdditionalTables(additionalTables) {
  if (!Array.isArray(additionalTables) || !additionalTables.length) return [];
  var ch = [];
  for (var i = 0; i < additionalTables.length; i++) {
    var tbl = additionalTables[i];
    if (!tbl || typeof tbl !== "object") continue;
    var cols = Array.isArray(tbl.columns) ? tbl.columns : [];
    var rows = Array.isArray(tbl.rows) ? tbl.rows : [];
    if (!cols.length || !rows.length) continue;
    var parts = renderGenericTable(tbl.caption || "", cols, rows);
    parts.forEach(function(p) { ch.push(p); });
  }
  return ch;
}

function renderGenericTable(caption, columns, rows) {
  if (!Array.isArray(columns)||!columns.length) return [];
  if (!Array.isArray(rows)||!rows.length) return [];

  var N = columns.length;
  var firstW = Math.round(CW * 0.30);
  var restW  = N > 1 ? Math.floor((CW - firstW) / (N - 1)) : CW;
  var colWidths = [firstW];
  for (var ci = 1; ci < N - 1; ci++) colWidths.push(restW);
  if (N > 1) colWidths.push(CW - firstW - restW * (N - 2));

  var sz = N <= 4 ? SZ.SM : (N <= 8 ? SZ.XS : SZ.XXS);

  var hdrCells = columns.map(function(col, i) {
    return cell(String(col||""), {bold:true, fill:CLR.HDR_GREY, w:colWidths[i], size:sz});
  });
  var hdrRow = new TableRow({children: hdrCells});

  var dataRows = rows.filter(Boolean).map(function(row) {
    var rowArr = Array.isArray(row) ? row : [];
    var cells = colWidths.map(function(w, i) {
      var val = rowArr[i] != null ? String(rowArr[i]) : "";
      return i === 0 ? cellL(val, {w:w, size:sz}) : cell(val, {w:w, size:sz});
    });
    return new TableRow({children: cells});
  });

  var tbl = new Table({
    width: {size:CW, type:WidthType.DXA},
    columnWidths: colWidths,
    rows: [hdrRow].concat(dataRows),
  });

  var result = [];
  if (caption) result.push(lftPara(caption, true, SZ.SM));
  result.push(tbl);
  result.push(blk());
  return result;
}

// ── PAGE BORDER + SPELL-OFF INJECTION (JSZip post-processing) ────────────────
function injectBordersAndSpellOff(buf) {
  var pgBXml=(
    '<w:pgBorders w:display="notFirstPage" w:offsetFrom="text">'+
    '<w:top    w:val="single" w:sz="6" w:space="4" w:color="000000"/>'+
    '<w:left   w:val="single" w:sz="6" w:space="4" w:color="000000"/>'+
    '<w:bottom w:val="single" w:sz="6" w:space="4" w:color="000000"/>'+
    '<w:right  w:val="single" w:sz="6" w:space="4" w:color="000000"/>'+
    '</w:pgBorders>'
  );
  var spellOff='<w:hideSpellingErrors/><w:hideGrammaticalErrors/>';

  return JSZip.loadAsync(buf).then(function(zip){
    return zip.file("word/document.xml").async("string").then(function(xml){
      var idx=xml.lastIndexOf("</w:sectPr>");
      if (idx>=0 && !xml.includes("pgBorders"))
        xml=xml.slice(0,idx)+pgBXml+xml.slice(idx);
      zip.file("word/document.xml",xml);

      var sf=zip.file("word/settings.xml");
      var sp;
      if (sf) {
        sp=sf.async("string").then(function(sxml){
          if (!sxml.includes("hideSpellingErrors"))
            sxml=sxml.replace("</w:settings>",spellOff+"</w:settings>");
          zip.file("word/settings.xml",sxml);
        });
      } else {
        zip.file("word/settings.xml",
          '<?xml version="1.0" encoding="UTF-8" standalone="yes"?>'+
          '<w:settings xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main">'+
          spellOff+'</w:settings>');
        sp=Promise.resolve();
      }
      return (sp||Promise.resolve()).then(function(){
        return zip.generateAsync({type:"nodebuffer",compression:"DEFLATE",
          compressionOptions:{level:6}});
      });
    });
  });
}

// ── MAIN ASSEMBLY ─────────────────────────────────────────────────────────────
function generateReport(dataPath, outPath) {
  var raw  = fs.readFileSync(dataPath, "utf-8");
  var data = JSON.parse(raw);

  var meta                = data.meta                 || {};
  var tocEntries          = data.toc_entries           || [];
  var logoB64             = data.logo_b64              || "";
  var logoType            = data.logo_type             || "";
  var txt                 = data.text_sections         || {};
  var productDetails      = data.product_details       || {};
  var composition         = data.composition           || [];
  var compColumns         = data.comp_columns          || [];
  var compMeta            = data.comp_meta             || {};
  var supplierDeclarations= data.supplier_declarations || [];
  var solventTables       = data.solvent_tables         || {};
  var additionalTables    = data.additional_tables     || [];
  var annList             = data.annexure_list         || [];
  var revHistory          = data.revision_history      || [];
  var signatures          = data.signatures            || [];

  var ch = [];

  // Title Page
  buildTitlePage(meta).forEach(function(x){ch.push(x);});

  // ABSTRACT (before TOC, matching approved format)
  buildAbstract(txt).forEach(function(x){ch.push(x);});

  // Table of Contents
  buildTOC(tocEntries).forEach(function(x){ch.push(x);});

  // 1.0 Objective
  buildObjective(txt).forEach(function(x){ch.push(x);});

  // 2.0 Details of Product (Table 1)
  buildDetailsOfProduct(productDetails).forEach(function(x){ch.push(x);});

  // 3.0 Background
  buildBackground(txt).forEach(function(x){ch.push(x);});

  ch.push(pgBrk());

  // 4.0 Drug Product Composition (Table 2)
  buildCompositionTable(composition, compColumns, compMeta).forEach(function(x){ch.push(x);});

  // 5.0 Residual Solvent Risk Assessment (Table 3: supplier declarations + Tables 4/5/6)
  buildSection5(txt, supplierDeclarations, solventTables).forEach(function(x){ch.push(x);});

  // Additional tables (if any extra tables from reference)
  buildAdditionalTables(additionalTables).forEach(function(x){ch.push(x);});

  // 6.0 Conclusion
  buildConclusion(txt).forEach(function(x){ch.push(x);});

  // 7.0 Summary and Conclusion (with Table 7: Risk Summary)
  buildSummaryAndConclusion(txt).forEach(function(x){ch.push(x);});

  // 8.0 References
  buildReferences(txt).forEach(function(x){ch.push(x);});

  // 9.0 List of Annexures
  buildAnnexureList(annList).forEach(function(x){ch.push(x);});

  // 10.0 Revision History
  buildRevision(revHistory).forEach(function(x){ch.push(x);});

  // Electronic Signatures
  buildSignatures(meta, signatures).forEach(function(x){ch.push(x);});

  var doc = new Document({
    settings:{hideSpellingErrors:true, hideGrammaticalErrors:true},
    styles:{default:{document:{run:{font:F,size:SZ.TEXT,color:CLR.BLACK}}}},
    sections:[{
      properties:{page:{
        size:{width:PAGE_W,height:PAGE_H},
        margin:{top:MAR_T,right:MAR_R,bottom:MAR_B,left:MAR_L,header:360,footer:360},
      }},
      headers:{default:buildHeader(meta,logoB64,logoType)},
      footers:{default:buildFooter()},
      children:ch,
    }],
  });

  return Packer.toBuffer(doc)
    .then(injectBordersAndSpellOff)
    .then(function(finalBuf){
      fs.writeFileSync(outPath, finalBuf);
      console.log("Report written: "+outPath+" ("+Math.round(finalBuf.length/1024)+" KB)");
    });
}

