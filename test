  return [sectionHeading("9. Revision history:"), tbl, pgBreak()];
}


// ============================================================================
// ELECTRONIC SIGNATURES
// ============================================================================
function buildSignatures(meta, signatures) {
  meta = meta || {};
  var W = [Math.round(CW*0.25), Math.round(CW*0.15), Math.round(CW*0.32), 0];
  W[3] = CW - W[0] - W[1] - W[2];

  var sigList = (Array.isArray(signatures) && signatures.length) ? signatures : [
    { intention: "Prepared by R&D", employee_id: "", user_name: "", date: "" },
    { intention: "Reviewed by R&D", employee_id: "", user_name: "", date: "" },
    { intention: "Approved by DQA", employee_id: "", user_name: "", date: "" },
  ];

  var tbl = new Table({
    width: { size: CW, type: WidthType.DXA },
    columnWidths: W,
    rows: [
      new TableRow({
        children: [
          mkCell("Intention",   { bold: true, fill: COLOR.HEADER_GREY, w: W[0], size: SZ.SM }),
          mkCell("Employee ID", { bold: true, fill: COLOR.HEADER_GREY, w: W[1], size: SZ.SM }),
          mkCell("User Name",   { bold: true, fill: COLOR.HEADER_GREY, w: W[2], size: SZ.SM }),
          mkCell("Date (IST)",  { bold: true, fill: COLOR.HEADER_GREY, w: W[3], size: SZ.SM }),
        ],
      }),
    ].concat(sigList.map(function (s) {
      return new TableRow({
        children: [
          mkCellL(s.intention   || "", { w: W[0], size: SZ.SM }),
          mkCell(s.employee_id  || "", { w: W[1], size: SZ.SM }),
          mkCellL(s.user_name   || "", { w: W[2], size: SZ.SM }),
          mkCell(s.date         || "", { w: W[3], size: SZ.SM }),
        ],
      });
    })),
  });

  return [centerPara("ELECTRONIC SIGNATURES", true, SZ.MD), blankPara(), tbl];
}


// ============================================================================
// POST-PROCESS: inject pgBorders XML + remove proofErr via JSZip
// (docx 9.6.1 pageBorders in section properties is silently ignored in XML;
//  this approach reliably inserts it directly into word/document.xml)
// ============================================================================
function injectPageBordersAndSpellOff(buf) {
  var pgBordersXml = (
    '<w:pgBorders w:display="allPages" w:offsetFrom="page">' +
    '<w:top w:val="single" w:sz="18" w:space="24" w:color="000000"/>' +
    '<w:left w:val="single" w:sz="18" w:space="24" w:color="000000"/>' +
    '<w:bottom w:val="single" w:sz="18" w:space="24" w:color="000000"/>' +
    '<w:right w:val="single" w:sz="18" w:space="24" w:color="000000"/>' +
    '</w:pgBorders>'
  );

  return JSZip.loadAsync(buf).then(function (zip) {
    // ── Patch word/document.xml: inject pgBorders ────────────────────────
    return zip.file("word/document.xml").async("string").then(function (xml) {
      // Insert before last </w:sectPr>
      var lastIdx = xml.lastIndexOf("</w:sectPr>");
      if (lastIdx >= 0) {
        xml = xml.slice(0, lastIdx) + pgBordersXml + xml.slice(lastIdx);
      }
      zip.file("word/document.xml", xml);

      // ── Patch word/settings.xml: disable spell + grammar check ──────────
      var settingsFile = zip.file("word/settings.xml");
      var settingsPromise;
      if (settingsFile) {
        settingsPromise = settingsFile.async("string").then(function (sxml) {
          // Inject hideSpellingErrors + hideGrammaticalErrors before </w:settings>
          var injection =
            '<w:hideSpellingErrors/>' +
            '<w:hideGrammaticalErrors/>';
          var closeTag = "</w:settings>";
          if (sxml.includes(closeTag) && !sxml.includes("hideSpellingErrors")) {
            sxml = sxml.replace(closeTag, injection + closeTag);
          }
          zip.file("word/settings.xml", sxml);
        });
      } else {
        // Create settings.xml from scratch
        var newSettings = (
          '<?xml version="1.0" encoding="UTF-8" standalone="yes"?>' +
          '<w:settings xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main">' +
          '<w:hideSpellingErrors/>' +
          '<w:hideGrammaticalErrors/>' +
          '</w:settings>'
        );
        zip.file("word/settings.xml", newSettings);
        settingsPromise = Promise.resolve();
      }

      return settingsPromise;
    });
  }).then(function (zip_) {
    // zip_ is undefined because then() chain consumed it — use outer zip
    return JSZip.loadAsync(buf).then(function (zip2) {
      // Re-apply all patches cleanly
      return zip2.file("word/document.xml").async("string").then(function (xml) {
        var lastIdx = xml.lastIndexOf("</w:sectPr>");
        if (lastIdx >= 0 && !xml.includes("pgBorders")) {
          xml = xml.slice(0, lastIdx) + pgBordersXml + xml.slice(lastIdx);
        }
        zip2.file("word/document.xml", xml);

        var sf = zip2.file("word/settings.xml");
        var sp;
        if (sf) {
          sp = sf.async("string").then(function (sxml) {
            if (!sxml.includes("hideSpellingErrors")) {
              sxml = sxml.replace("</w:settings>",
                '<w:hideSpellingErrors/><w:hideGrammaticalErrors/></w:settings>');
            }
            zip2.file("word/settings.xml", sxml);
          });
        } else {
          zip2.file("word/settings.xml",
            '<?xml version="1.0" encoding="UTF-8" standalone="yes"?>' +
            '<w:settings xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main">' +
            '<w:hideSpellingErrors/><w:hideGrammaticalErrors/></w:settings>');
          sp = Promise.resolve();
        }
        return (sp || Promise.resolve()).then(function () {
          return zip2.generateAsync({
            type: "nodebuffer",
            compression: "DEFLATE",
            compressionOptions: { level: 6 },
          });
        });
      });
    });
  });
}


// ============================================================================
// MAIN REPORT ASSEMBLY
// ============================================================================
function generateReport(dataPath, outPath) {
  var raw  = fs.readFileSync(dataPath, "utf-8");
  var data = JSON.parse(raw);

  var meta            = data.meta             || {};
  var logoB64         = data.logo_b64         || "";
  var logoType        = data.logo_type        || "";
  var txt             = data.text_sections    || {};
  var composition     = data.composition      || [];
  var annexureList    = data.annexure_list    || [];
  var calcTables      = data.calc_tables      || {};
  var revisionHistory = data.revision_history || [];
  var signatures      = data.signatures       || [];
  var figures         = Array.isArray(data.figures) ? data.figures : [];
  var pdeValues       = data.pde_values       || {};

  var ch = [];

  var tp = buildTitlePage(meta);
  for (var ti = 0; ti < tp.length; ti++) ch.push(tp[ti]);

  var toc = buildTOC(data.toc_entries || []);
  for (var toci = 0; toci < toc.length; toci++) ch.push(toc[toci]);

  var s14 = buildTextSections(txt);
  for (var s14i = 0; s14i < s14.length; s14i++) ch.push(s14[s14i]);

  var comp = buildCompositionTable(composition);
  for (var ci = 0; ci < comp.length; ci++) ch.push(comp[ci]);

  for (var fi = 0; fi < figures.length; fi++) {
    var fp = buildFigure(figures[fi]);
    for (var fj = 0; fj < fp.length; fj++) ch.push(fp[fj]);
  }

  var src = buildSourcesSection(txt, annexureList);
  for (var sri = 0; sri < src.length; sri++) ch.push(src[sri]);

  function safeT(key) {
    var e = { elements:[], rows:[], total_daily_intake:0,
              element_totals:{}, pde:{}, threshold_30pct:{} };
    if (!calcTables || typeof calcTables !== "object" || !calcTables[key]) return e;
    var m = {};
    var ek = Object.keys(e);
    for (var i = 0; i < ek.length; i++) m[ek[i]] = e[ek[i]];
    var tk = Object.keys(calcTables[key]);
    for (var j = 0; j < tk.length; j++) m[tk[j]] = calcTables[key][tk[j]];
    return m;
  }

  try {
    var t5 = buildCalcTable(5, safeT("class1_2a"), pdeValues);
    for (var t5i = 0; t5i < t5.length; t5i++) ch.push(t5[t5i]);
    var t6 = buildCalcTable(6, safeT("class2b"), pdeValues);
    for (var t6i = 0; t6i < t6.length; t6i++) ch.push(t6[t6i]);
    var t7 = buildCalcTable(7, safeT("class3"), pdeValues);
    for (var t7i = 0; t7i < t7.length; t7i++) ch.push(t7[t7i]);
    ch.push(pgBreak());
  } catch (err) {
    console.error("Calc table error:", err.message);
    ch.push(leftPara("Calculation table error: " + err.message));
    ch.push(pgBreak());
  }

  var sum = buildSummarySection(txt);
  for (var smi = 0; smi < sum.length; smi++) ch.push(sum[smi]);

  ch.push(sectionHeading("7. Reference"));
  ch.push(bodyPara(txt.reference || "NA"));
  ch.push(blankPara());

  var anl = buildAnnexureList(annexureList);
  for (var ali = 0; ali < anl.length; ali++) ch.push(anl[ali]);

  var rev = buildRevisionHistory(revisionHistory);
  for (var rvi = 0; rvi < rev.length; rvi++) ch.push(rev[rvi]);

  var sig = buildSignatures(meta, signatures);
  for (var sgi = 0; sgi < sig.length; sgi++) ch.push(sig[sgi]);

  // ── Build Document ───────────────────────────────────────────────────────
  var doc = new Document({
    // Disable spell check at document level (belt-and-suspenders with noProof on runs)
    settings: {
      hideSpellingErrors:    true,
      hideGrammaticalErrors: true,
    },
    styles: {
      default: {
        document: { run: { font: FONT, size: SZ.TEXT, color: COLOR.BLACK } },
      },
    },
    sections: [{
      properties: {
        page: {
          size:   { width: PAGE_W, height: PAGE_H },
          margin: { top: MAR_T, right: MAR_R, bottom: MAR_B, left: MAR_L,
                    header: 360, footer: 360 },
        },
        // Note: pageBorders here is silently ignored by docx 9.6.1 in XML output.
        // Real injection is done below via injectPageBordersAndSpellOff().
      },
      headers: { default: buildPageHeader(meta, logoB64, logoType) },
      footers: { default: buildPageFooter() },
      children: ch,
    }],
  });

  return Packer.toBuffer(doc)
    .then(function (rawBuf) {
      // Post-process: inject page borders + ensure spell-off in settings.xml
      return injectPageBordersAndSpellOff(rawBuf);
    })
    .then(function (finalBuf) {
      fs.writeFileSync(outPath, finalBuf);
      console.log("Report written: " + outPath + "  (" + Math.round(finalBuf.length / 1024) + " KB)");
    });
}


// ============================================================================
// ENTRY POINT
// ============================================================================
var dataPath = process.argv[2];
var outPath  = process.argv[3];

if (!dataPath || !outPath) {
  console.error("Usage: node generate_report.js <data.json> <out.docx>");
  process.exit(1);
}

generateReport(dataPath, outPath).catch(function (err) {
  console.error("FATAL:", err.message || err);
  if (err.stack) console.error(err.stack.split("\n").slice(0, 8).join("\n"));
  process.exit(1);
});
