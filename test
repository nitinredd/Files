def _process_files_with_progress(files: List, doc_type: str, meta: Dict) -> Any:
"""Process files with visible progress bar. All backend logic silent."""
progress_bar = st.progress(0, text="Analyzing files...")

n_files = len(files)
processed_annexures = []

for i, f in enumerate(files):
# Update progress
pct = int((i / n_files) * 90)
progress_bar.progress(
pct, 
text=f"Processing file {i+1} of {n_files}: {f.name} ({pct}%)"
)

# Call backend processing (silent, all logs to logger)
try:
result = dispatch_annexures(doc_type, [f])
if result:
processed_annexures.extend(result)
except Exception:
logger.exception(f"Processing failed for {f.name}")

progress_bar.progress(95, text="Building payload...")

# Build payload and generate (silent)
with st.spinner("Generating document..."):
try:
payload = _build_payload(doc_type, meta, processed_annexures)
docx_bytes = _render_document(doc_type, payload)
except Exception as e:
logger.exception("Document generation failed")
st.error("Document generation failed. Please try again.")
return None

progress_bar.progress(100, text="Complete")

return docx_bytes

