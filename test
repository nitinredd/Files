# ══════════════════════════════════════════════════════════════════════════════
# NORMALIZATION + LOOKUP  (do not edit to add an API — edit CHEMISTRY above)
# ══════════════════════════════════════════════════════════════════════════════
_SALT_TAIL = re.compile(
    r"\b(hydrochloride|hydrobromide|sulfate|sulphate|besylate|besilate|maleate|"
    r"citrate|phosphate|sodium|potassium|calcium|magnesium|hcl|hbr|dihydrochloride|"
    r"dihydrobromide|monohydrate|dihydrate|trihydrate|hemihydrate|anhydrous)\b",
    re.IGNORECASE)


def _normalize(name: str) -> str:
    """Canonical match key — reuse the NDPS normalizer when available (strips
    salts/hydrates/esters), else a minimal local fallback."""
    if not name:
        return ""
    if _ndps_normalize is not None:
        try:
            return _ndps_normalize(name)
        except Exception:
            pass
    s = unicodedata.normalize("NFKD", str(name))
    s = "".join(c for c in s if not unicodedata.combining(c)).lower()
    s = _SALT_TAIL.sub(" ", s)
    s = re.sub(r"[^a-z0-9]+", " ", s)
    return re.sub(r"\s+", " ", s).strip()


def _phrase_in(needle: str, haystack: str) -> bool:
    if not needle or not haystack:
        return False
    if needle == haystack:
        return True
    return re.search(rf"(?:^|\s){re.escape(needle)}(?:\s|$)", haystack) is not None


def _build_index() -> List[Dict[str, Any]]:
    index: List[Dict[str, Any]] = []
    for e in CHEMISTRY:
        keys = set()
        for raw in [e["name"]] + list(e.get("aliases", [])):
            k = _normalize(raw)
            if k:
                keys.add(k)
        index.append({"entry": e, "keys": sorted(keys, key=lambda k: -len(k))})
    return index


_INDEX = _build_index()


def lookup(name: str) -> Optional[Dict[str, str]]:
    """Return the chemistry dict for an API name (any salt/variant), or None.

    Bidirectional whole-phrase containment on normalized keys — 'Pseudoephedrine
    Sulfate' resolves to the canonical 'Pseudoephedrine'. The longest matching key
    wins so the most specific API is preferred. Returns a COPY; callers may mutate.
    """
    q = _normalize(name)
    if not q:
        return None
    best: Optional[Dict[str, Any]] = None
    best_len = -1
    for rec in _INDEX:
        for key in rec["keys"]:
            if _phrase_in(key, q) or _phrase_in(q, key):
                if len(key) > best_len:
                    best_len = len(key)
                    best = rec["entry"]
                break
    if best is None:
        return None
    return {
        "canonical_name": best["name"],
        "iupac_name": best["iupac_name"],
        "molecular_formula": best["molecular_formula"],
        "molecular_weight": best["molecular_weight"],
        "cas_number": best["cas_number"],
        "therapeutic_category": best["therapeutic_category"],
    }


