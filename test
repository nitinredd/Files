# CONCEPT EXTRACTOR (Phi-4-mini)
# ═══════════════════════════════════════════════════════════════

_CONCEPT_PROMPT = """You are an HPLC analytical chemistry concept extractor.
Extract all HPLC-relevant concepts from the paragraph and their relationships.

Respond ONLY with valid JSON:
{
  "concepts": [
    {"name": "Van Deemter equation", "category": "equation"},
    {"name": "plate height", "category": "parameter"}
  ],
  "relationships": [
    {"from": "Van Deemter equation", "relation": "DESCRIBES", "to": "plate height"}
  ]
}

Categories: equation / parameter / technique / equipment / compound / phenomenon / method
If no HPLC concepts found, return: {"concepts": [], "relationships": []}
No preamble. Only JSON."""


def extract_concepts(llm, paragraph_text: str) -> Dict:
    """Falls back to empty on any failure — ingestion must not crash."""
    try:
        response = llm.create_chat_completion(
            messages=[
                {"role": "system", "content": _CONCEPT_PROMPT},
                {"role": "user", "content": f"Extract concepts from:\n\n{paragraph_text[:800]}"}
            ],
            max_tokens=300, temperature=0.05,
            response_format={"type": "json_object"}
        )
        parsed = json.loads(response["choices"][0]["message"]["content"])
        return {"concepts": parsed.get("concepts", []),
                "relationships": parsed.get("relationships", [])}
    except Exception as e:
        logger.warning(f"Concept extraction failed: {e}")
        return {"concepts": [], "relationships": []}


