def dispatch_annexures(doc_type: str, uploaded_files: List[Any],
                       progress=None) -> List[Dict]:
    """Auto-convert/normalise uploaded annexure files for the given document type.
    PDFs are routed to that doc type's converter; JSON files are normalised via
    that doc type's schema. The user never picks a converter. Never raises —
    per-file failures degrade to structured error objects so the run continues."""
    wf = DOCUMENT_WORKFLOWS.get(doc_type)
    if not wf or not uploaded_files:
        return []
    pdf_convert = wf["pdf_convert"]
    json_normalise = wf["json_normalise"]
    out: List[Dict] = []
    files = sorted(uploaded_files, key=lambda f: f.name)
    for i, af in enumerate(files):
        idx = i + 1
        name = af.name
        try:
            # PDFs (all workflows) and DOCX (BE NOC supporting files) route to the
            # doc type's converter; everything else is treated as pre-converted JSON.
            if name.lower().endswith((".pdf", ".docx", ".doc")):
                if progress:
                    progress(f"Converting annexure {idx}: {name}", idx / max(len(files), 1))
                ann = pdf_convert(af.getvalue(), name, idx, None)
            else:
                raw = af.getvalue().decode("utf-8", "replace").lstrip("\ufeff")
                try:
                    obj = json.loads(raw)
                except Exception as e:
                    obj = {"_error": True, "extraction_notes": f"Bad JSON: {e}"}
                ann = json_normalise(obj, idx)
            if isinstance(ann, dict):
                ann.setdefault("filename", name)
                ann["annexure_number"] = idx
            else:
                ann = {"_error": True, "annexure_number": idx, "filename": name,
                       "extraction_notes": "Converter returned non-dict."}
            out.append(ann)
        except Exception as e:
            logger.exception(f"Annexure dispatch failed for {name}")
            out.append({"_error": True, "annexure_number": idx, "filename": name,
                        "extraction_notes": f"Dispatch error: {e}"})
    return out


def claude_vision(image_bytes: bytes, prompt: str, media_type: str = "image/png") -> str:
    if not image_bytes:
        return ""
    b64 = base64.standard_b64encode(image_bytes).decode()
    return call_claude([{"role": "user", "content": [
        {"type": "image", "source": {"type": "base64", "media_type": media_type, "data": b64}},
        {"type": "text", "text": prompt},
    ]}])


