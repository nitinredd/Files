  background: var(--secondary);
  border-radius: 1px;
  animation: loading-sweep 1.4s ease-in-out infinite;
}
@keyframes loading-sweep {
  0%   { width: 0%;   margin-left: 0%; }
  50%  { width: 60%;  margin-left: 20%; }
  100% { width: 0%;   margin-left: 100%; }
}

/* ─── INPUT STATE ───────────────────────────────────────────────────────────── */
.input-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 32px 64px;
  min-height: 100%;
}

.hero-area {
  text-align: center;
  max-width: 660px;
  margin-bottom: 28px;
}
.hero-headline {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 44px;
  color: var(--text-primary);
  letter-spacing: -1.5px;
  line-height: 1.1;
  margin-bottom: 14px;
}
.hero-sub {
  font-family: var(--font-body);
  font-weight: 300;
  font-size: 16px;
  color: var(--text-secondary);
  max-width: 520px;
  margin: 0 auto;
  line-height: 1.7;
}

/* ─── Input Card ────────────────────────────────────────────────────────────── */
.input-card {
  width: 100%;
  max-width: 660px;
  background: var(--surface);
  border-radius: var(--radius);
  box-shadow: var(--shadow-card);
  border-left: 2px solid var(--primary);
  overflow: hidden;
  transition: box-shadow 200ms ease;
}
.input-card:focus-within {
  box-shadow: var(--shadow-active);
}

/* Progress bar */
.card-progress-bar {
  height: 2px;
  background: var(--border);
  position: relative;
  overflow: hidden;
}
.card-progress-fill {
  position: absolute;
  top: 0; left: 0;
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--secondary));
}

.textarea-wrap { padding: 20px 20px 0; }
.prompt-textarea {
  width: 100%;
  min-height: 120px;
  max-height: 280px;
  border: none;
  outline: none;
  resize: vertical;
  font-family: var(--font-body);
  font-weight: 400;
  font-size: 16px;
  color: var(--text-primary);
  line-height: 1.65;
  background: transparent;
  caret-color: var(--secondary);
}
.prompt-textarea::placeholder {
  font-style: italic;
  color: var(--text-muted);
}
.prompt-textarea:disabled {
  opacity: 0;
  transition: opacity 150ms ease;
}

.card-divider {
  height: 1px;
  background: var(--border);
  margin: 14px 0 0;
}
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 20px 16px;
  gap: 12px;
}
.card-hint {
  font-family: var(--font-mono);
  font-size: 9px;
  color: var(--text-muted);
  letter-spacing: 0.3px;
}

/* ─── Reconstruct Button ────────────────────────────────────────────────────── */
.reconstruct-btn {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 2px;
  color: #FFFFFF;
  background: var(--primary);
  border: none;
  border-radius: var(--radius-pill);
  padding: 12px 28px;
  cursor: pointer;
  transition: background 200ms ease, box-shadow 200ms ease, transform 100ms ease;
  white-space: nowrap;
  flex-shrink: 0;
}
.reconstruct-btn:hover:not(:disabled) {
  background: var(--secondary);
  box-shadow: 0 4px 16px rgba(14,165,233,0.3);
}
.reconstruct-btn:active:not(:disabled) { transform: translateY(1px); }
.reconstruct-btn:disabled { opacity: 0.6; cursor: not-allowed; }
.reconstruct-btn.loading {
  display: flex;
  align-items: center;
  gap: 9px;
  background: var(--secondary);
  opacity: 1;
  cursor: default;
}

/* ─── Spinner ───────────────────────────────────────────────────────────────── */
.spinner {
  width: 11px;
  height: 11px;
  border: 2px solid rgba(255,255,255,0.35);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: spin 0.65s linear infinite;
  flex-shrink: 0;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ─── Status Cycling ────────────────────────────────────────────────────────── */
.status-cycling-wrap {
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 14px;
}
.status-cycling {
  font-family: var(--font-mono);
  font-size: 9px;
  color: var(--text-muted);
  letter-spacing: 2px;
  animation: status-appear 0.3s ease both;
}
@keyframes status-appear {
  from { opacity: 0; transform: translateY(4px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ─── Sand Dissolve Canvas ──────────────────────────────────────────────────── */
.dissolve-canvas {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 1000;
}

/* ─── REVEAL STATE ──────────────────────────────────────────────────────────── */
.reveal-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40px 36px 56px;
  animation: reveal-enter 350ms ease-out both;
  flex: 1;
}
@keyframes reveal-enter {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ─── Reveal Panel ──────────────────────────────────────────────────────────── */
.reveal-panel {
  width: 100%;
  max-width: 820px;
  background: var(--surface);
  border-radius: var(--radius);
  border-left: 2px solid var(--success);
  box-shadow: var(--shadow-active);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.reveal-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 28px 0;
  flex-shrink: 0;
}
.reveal-panel-title {
  display: flex;
  align-items: center;
  gap: 10px;
}
.reveal-panel-label {
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 3px;
  color: var(--text-secondary);
}

/* Copy button */
.copy-wrap {
  position: relative;
  display: flex;
  align-items: center;
}
.copy-btn {
  background: none;
  border: none;
  cursor: pointer;
  color: var(--border-mid);
  padding: 6px;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: color 150ms ease, background 150ms ease;
}
.copy-btn:hover {
  color: var(--primary);
  background: rgba(15,76,138,0.06);
}
.copy-tooltip {
  position: absolute;
  bottom: calc(100% + 6px);
  right: 0;
  font-family: var(--font-mono);
  font-size: 8px;
  letter-spacing: 0.5px;
  color: #FFFFFF;
  background: var(--success);
  border-radius: 4px;
  padding: 3px 8px;
  white-space: nowrap;
  pointer-events: none;
  animation: tooltip-appear 0.15s ease both;
}
@keyframes tooltip-appear {
  from { opacity: 0; transform: translateY(2px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Panel body — the actual reconstructed text */
.reveal-panel-body {
  padding: 20px 28px 24px;
  flex: 1;
}
.reveal-text {
  font-family: var(--font-body);
  font-weight: 400;
  font-size: 15px;
  color: var(--text-primary);
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-word;
}
.reveal-text-conversational {
  font-weight: 300;
  color: var(--text-secondary);
  font-size: 14px;
  line-height: 1.85;
}

/* Typewriter cursor */
.typewriter-cursor {
  display: inline-block;
  width: 2px;
  height: 0.95em;
  background: var(--secondary);
  margin-left: 2px;
  vertical-align: text-bottom;
  border-radius: 1px;
  animation: cursor-blink 1s step-end infinite;
}
@keyframes cursor-blink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0; }
}

/* Error state */
.reveal-error {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.reveal-error-label {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 1.5px;
  color: var(--warning);
}
.reveal-error-detail {
  font-family: var(--font-body);
  font-size: 13px;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* Metadata chips */
.reveal-panel-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  padding: 14px 28px 22px;
  flex-shrink: 0;
  border-top: 1px solid var(--border);
  margin-top: 4px;
}
.meta-chip {
  font-family: var(--font-mono);
  font-size: 8.5px;
  letter-spacing: 0.5px;
  padding: 3px 9px;
  border-radius: 4px;
}
.meta-confidence-high { background: #ECFDF5; color: var(--success); }
.meta-confidence-mid  { background: #EFF6FF; color: var(--primary); }
.meta-confidence-low  { background: #FFF7ED; color: var(--warning); }
.meta-strategy        { background: #EFF6FF; color: var(--primary); }
.meta-technique       { background: #FFF7ED; color: var(--warning); }

/* ─── Reveal Footer ─────────────────────────────────────────────────────────── */
.reveal-footer {
  display: flex;
  justify-content: center;
  margin-top: 24px;
}
.new-prompt-btn {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 1.5px;
  color: var(--text-secondary);
  background: transparent;
  border: 1.5px solid var(--border);
  border-radius: var(--radius-pill);
  padding: 11px 32px;
  cursor: pointer;
  transition: border-color 200ms ease, color 200ms ease;
}
.new-prompt-btn:hover {
  border-color: var(--primary);
  color: var(--primary);
}

/* ─── Responsive ────────────────────────────────────────────────────────────── */
@media (max-width: 900px) {
  .sidebar { width: 220px; }
  :root { --sidebar-w: 220px; }
  .reveal-state { padding: 28px 24px 48px; }
}

@media (max-width: 768px) {
  .sidebar { display: none; }
  .app-header { padding: 0 16px; }
  .hero-headline { font-size: 32px; }
  .hero-sub { font-size: 14px; }
  .input-state { padding: 32px 16px 48px; }
  .reveal-state { padding: 20px 16px 40px; }
  .reveal-panel-header,
  .reveal-panel-body,
  .reveal-panel-meta { padding-left: 20px; padding-right: 20px; }
}

@media (max-width: 480px) {
  .hero-headline { font-size: 26px; }
  .reconstruct-btn { padding: 10px 22px; font-size: 10px; }
}
