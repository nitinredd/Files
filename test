"""
injection_support.py — Injection / parenteral support for the EI pipeline.

This module is ADDITIVE. It does not touch the OSD workflow. It provides:

  • parse_injection_excel(excel_bytes, product_name, claude_call)
        Intelligent parser for injection composition Excel files. Supports:
          - Medroxy-style ratio headers   ("Qty/unit (mg / 0.65 mL)")
          - Aprepitant-style multi-strength tables with an MDD column
        Returns a structured dict with inferred dosing + component quantities,
        every value carrying its source/method for the audit trail.

  • detect_calculation_model(annexure_data)
        Inspect annexure concentration units and decide mass-based (µg/g) vs
        volume-based (µg/mL). Returns (model, concentration_unit, evidence).

  • build_unit_config(dosage_category, route, calculation_model)
        Produce the unit_config object consumed by generate_report.js so the
        same renderer dynamically labels "Daily Intake (g/day)" vs "(mL/day)"
        and "Measured Concentration (µg/g)" vs "(µg/mL)".

  • build_injection_comp_data(parsed, annexure_data, model_info)
        Convert the parsed injection table into the comp_data structure the
        existing calculate_ei_tables() understands, pre-computing component
        daily intake so the engine stays product-agnostic.

  • validate_injection(parsed, model_info, comp_data, annexure_data)
        Strict validation gate. Returns (errors, warnings). Report generation
        is blocked when errors is non-empty.

All scientific decisions (route, PDE route, selected MDD, model, units,
component quantities) are made here in the backend.
"""

from __future__ import annotations
import re
import json
import logging
from typing import Any, Dict, List, Optional, Tuple, Callable

logger = logging.getLogger(__name__)


# ── Small local helpers (kept self-contained so this module has no app.py dep) ─
def _sstr(v: Any) -> str:
    return str(v).strip() if v is not None else ""


def _sfloat(v: Any, default: float = 0.0) -> float:
    if isinstance(v, (int, float)):
        return float(v)
    try:
        return float(str(v).strip().replace(",", ""))
    except Exception:
        return default


def _sint(v: Any, default: int = 1) -> int:
    try:
        return int(float(str(v).strip()))
    except Exception:
        return default


# ── Ratio / quantity parsing ──────────────────────────────────────────────────
# Matches "104 mg / 0.65 mL", "32 mg/4.4 mL", "130 mg / 18 mL", "160 mg/mL"
_RATIO_RE = re.compile(
    r"([0-9]*\.?[0-9]+)\s*(mg|mcg|µg|ug|g)\s*/\s*([0-9]*\.?[0-9]+)?\s*(ml|mL|l|L)",
    re.IGNORECASE,
)
# Matches a volume in a header like "(mg / 0.65 mL)" or "per 18 mL"
_VOL_RE = re.compile(r"([0-9]*\.?[0-9]+)\s*(ml|mL|l|L)", re.IGNORECASE)
# Matches mg/mL concentration headers
_CONC_RE = re.compile(
    r"([0-9]*\.?[0-9]+)\s*(mg|mcg|µg|ug|g)\s*/\s*(ml|mL)", re.IGNORECASE
)


def _mass_to_mg(value: float, unit: str) -> float:
    u = unit.lower()
    if u in ("g",):
        return value * 1000.0
    if u in ("mcg", "µg", "ug"):
        return value / 1000.0
    return value  # mg


def _vol_to_ml(value: float, unit: str) -> float:
    return value * 1000.0 if unit.lower() in ("l",) else value


def parse_ratio(text: str) -> Optional[Dict[str, float]]:
    """
    Parse a "mass / volume" ratio. Returns {mass_mg, volume_ml, conc_mg_per_ml}
    or None. "160 mg/mL" → volume_ml=1.0. "104 mg / 0.65 mL" → both present.
    """
    if not text:
        return None
    m = _RATIO_RE.search(text)
    if not m:
        return None
    mass = _mass_to_mg(_sfloat(m.group(1)), m.group(2))
    vol_raw = m.group(3)
    vol_unit = m.group(4)
    if vol_raw is None or vol_raw == "":
        volume_ml = 1.0  # "mg/mL" form
    else:
        volume_ml = _vol_to_ml(_sfloat(vol_raw), vol_unit)
    if volume_ml <= 0:
        return None
    return {
        "mass_mg": round(mass, 6),
        "volume_ml": round(volume_ml, 6),
        "conc_mg_per_ml": round(mass / volume_ml, 6),
    }


def parse_volume_from_header(header: str) -> Optional[float]:
    """Extract a dose volume in mL from a header like 'Qty/unit (mg / 0.65 mL)'."""
    if not header:
        return None
    # Prefer the volume that follows a slash (ratio denominator)
    r = parse_ratio(header)
    if r and r["volume_ml"] != 1.0:
        return r["volume_ml"]
    m = _VOL_RE.search(header)
    if m:
        return _vol_to_ml(_sfloat(m.group(1)), m.group(2))
    return None


# ── Excel → structured injection model ────────────────────────────────────────
def make_injection_excel_prompt() -> str:
    """Prompt for Claude Vision/text to extract an injection composition table."""
    return (
        "You are extracting the composition table from an INJECTION / PARENTERAL "
        "drug product spreadsheet. Extract the table EXACTLY as printed — do not "
        "calculate or infer dosing.\n\n"
        "Identify and return:\n"
        "1. ingredient_col: exact header of the ingredient/component-name column.\n"
        "2. function_col: exact header of the Function/Role column if present "
        "(e.g. values like 'Active', 'Active ingredient', 'API', 'Buffer').\n"
        "3. qty_columns: a list of every quantity column header, each may be a "
        "ratio like 'Qty/unit (mg / 0.65 mL)' or 'Qty/vial (32 mg/4.4 mL)'.\n"
        "4. mgml_col: exact header of an explicit mg/mL concentration column if "
        "present, else empty string.\n"
        "5. mdd_col: exact header of an explicit MDD (maximum daily dose) column "
        "if present (per-component daily quantity), else empty string.\n"
        "6. density_value + density_unit: if a density is stated anywhere "
        "(e.g. '1.039 g/mL'), else 0 and empty.\n"
        "7. columns: list of ALL column headers in order.\n"
        "8. sections: list of {name, rows:[{ingredient, function, columns:{header:value}}]}.\n\n"
        "RULES:\n"
        "- Include EVERY row, including q.s. rows (Water for Injection, HCl, NaOH, "
        "Nitrogen) and pH adjusters — keep their literal cell text (e.g. 'q.s.', "
        "'q.s. to 18 mL').\n"
        "- Map each cell to its exact column header.\n"
        "- Do NOT compute MDD, strength, or totals — extract only.\n"
        "- Return ONLY valid JSON, no markdown.\n"
    )


_API_FUNCTION_HINTS = (
    "active ingredient", "active pharmaceutical ingredient", "active",
    "api", "drug substance",
)
_QS_HINTS = ("q.s", "qs ", "q.s.", "qs to", "q.s to", "adjust", "ph adjust")
_QS_MATERIALS = (
    "water for injection", "hydrochloric acid", "sodium hydroxide", "nitrogen",
    "water for injections", "wfi",
)


def _row_field(row: Dict, col: str, fallbacks: List[str] = None) -> str:
    cols = row.get("columns", {})
    if isinstance(cols, dict):
        if col and col in cols:
            return _sstr(cols[col])
        for fb in (fallbacks or []):
            for k, v in cols.items():
                if fb.lower() in k.lower():
                    return _sstr(v)
    for fb in (fallbacks or []):
        if fb in row:
            return _sstr(row[fb])
    return ""


def _is_qs_row(name: str, qty_text: str, function: str) -> bool:
    n = name.lower()
    q = qty_text.lower()
    if any(h in n for h in _QS_MATERIALS):
        # Water/HCl/NaOH/N2 are q.s./process aids unless a real number is given
        if any(h in q for h in _QS_HINTS) or not re.search(r"[0-9]", q):
            return True
    if any(h in q for h in _QS_HINTS):
        return True
    return False


def _identify_api_row(rows: List[Dict], product_name: str,
                      function_col: str) -> Tuple[Optional[int], str]:
    """
    Identify the API row using robust signals (not position).
    Returns (row_index, method).
    """
    pname = product_name.lower().strip()
    # 1. Function column says active
    for i, r in enumerate(rows):
        fn = _row_field(r, function_col, ["function", "role"]).lower()
        if any(h in fn for h in _API_FUNCTION_HINTS):
            return i, "function_column"
    # 2. Product-name ↔ material-name match
    if pname:
        for i, r in enumerate(rows):
            nm = _sstr(r.get("ingredient", "")).lower()
            # token overlap between product name and ingredient
            ptoks = {t for t in re.split(r"[\s\-,/()]+", pname) if len(t) > 3}
            ntoks = {t for t in re.split(r"[\s\-,/()]+", nm) if len(t) > 3}
            if ptoks and ntoks and (ptoks & ntoks):
                return i, "product_name_match"
    return None, "not_found"


def parse_injection_excel(parsed_raw: Dict, product_name: str,
                          doses_per_day: int = 1) -> Dict:
    """
    Convert the raw extracted injection table (from Claude) into a structured
    model with inferred dosing + per-component quantities. Every inferred value
    carries its source method for the audit trail.

    `parsed_raw` is the JSON dict from make_injection_excel_prompt().
    """
    audit: Dict[str, Any] = {}
    warnings: List[str] = []

    ingredient_col = _sstr(parsed_raw.get("ingredient_col", ""))
    function_col   = _sstr(parsed_raw.get("function_col", ""))
    mgml_col       = _sstr(parsed_raw.get("mgml_col", ""))
    mdd_col        = _sstr(parsed_raw.get("mdd_col", ""))
    qty_columns    = [_sstr(c) for c in (parsed_raw.get("qty_columns") or []) if _sstr(c)]
    density_value  = _sfloat(parsed_raw.get("density_value", 0))
    density_unit   = _sstr(parsed_raw.get("density_unit", ""))
    columns        = [_sstr(c) for c in (parsed_raw.get("columns") or []) if _sstr(c)]

    # Flatten rows (preserve section)
    rows: List[Dict] = []
    for sec in (parsed_raw.get("sections") or []):
        if not isinstance(sec, dict):
            continue
        sname = _sstr(sec.get("name", ""))
        for r in (sec.get("rows") or []):
            if isinstance(r, dict):
                r = dict(r)
                r["_section"] = sname
                # normalise ingredient key
                if "ingredient" not in r:
                    r["ingredient"] = _row_field(r, ingredient_col,
                                                 ["ingredient", "name", "component"])
                rows.append(r)

    # ── Detect table style ────────────────────────────────────────────────────
    has_mdd_col = bool(mdd_col)
    has_mgml    = bool(mgml_col)
    multi_strength = len(qty_columns) > 1
    table_style = ("aprepitant_multistrength"
                   if (has_mdd_col or multi_strength or has_mgml)
                   else "medroxy_ratio")
    audit["table_style"] = table_style
    audit["qty_columns"] = qty_columns

    # ── Identify API row ──────────────────────────────────────────────────────
    api_idx, api_method = _identify_api_row(rows, product_name, function_col)
    audit["api_row_method"] = api_method
    if api_idx is not None:
        audit["api_row_name"] = _sstr(rows[api_idx].get("ingredient", ""))

    # ── Select dose volume + presentation ─────────────────────────────────────
    dose_volume_ml = 0.0
    selected_qty_col = ""
    strength_mg_per_ml = 0.0
    api_per_dose_mg = 0.0
    mdd_source = "none"

    # Style A: explicit per-component MDD / Maximum Daily Intake column is the
    # source of truth. Detect its unit from the header — it may be given directly
    # in grams ("Maximum Daily Intake (g)") or in mg ("MDD (mg)"). When grams are
    # provided, the value IS the final daily intake and needs no derivation.
    component_mdd: Dict[int, float] = {}
    mdd_col_unit = "mg"
    if has_mdd_col:
        hdr = mdd_col.lower()
        # Unit precedence: explicit (g) in header → grams; µg → micrograms; else mg
        if re.search(r"\(\s*g\s*\)|\bg/day\b|\(g\)|intake\s*\(g\)|\bgram", hdr) \
           and not re.search(r"mg|µg|mcg|ug", hdr):
            mdd_col_unit = "g"
        elif re.search(r"µg|mcg|ug", hdr):
            mdd_col_unit = "ug"
        else:
            mdd_col_unit = "mg"
        for i, r in enumerate(rows):
            mtxt = _row_field(r, mdd_col, ["mdd", "maximum daily", "daily intake"])
            mval = _sfloat(re.sub(r"[^0-9.\-]", "", mtxt)) if mtxt else 0.0
            if mval > 0:
                component_mdd[i] = mval
        if api_idx is not None and api_idx in component_mdd:
            # Normalise the API MDD to mg for strength/consistency math
            raw_api = component_mdd[api_idx]
            api_per_dose_mg = _mass_to_mg(raw_api, mdd_col_unit)
            mdd_source = ("explicit_mdd_column_g" if mdd_col_unit == "g"
                          else "explicit_mdd_column")

    # Determine candidate presentations from qty columns (ratios)
    presentations: List[Dict] = []
    for qc in qty_columns:
        ratio = parse_ratio(qc)
        if ratio:
            presentations.append({
                "column": qc,
                "mass_mg": ratio["mass_mg"],
                "volume_ml": ratio["volume_ml"],
                "conc_mg_per_ml": ratio["conc_mg_per_ml"],
            })

    # Style B (multi-strength): pick the presentation with the largest MDD/mass
    if presentations:
        # Prefer the one whose API mass is largest (worst case)
        chosen = max(presentations, key=lambda p: p["mass_mg"])
        selected_qty_col = chosen["column"]
        dose_volume_ml = chosen["volume_ml"]
        strength_mg_per_ml = chosen["conc_mg_per_ml"]
        if api_per_dose_mg <= 0:
            api_per_dose_mg = chosen["mass_mg"]
            mdd_source = "ratio_header"
        audit["selected_presentation"] = chosen

    # Medroxy-style: single ratio header on the qty column
    if dose_volume_ml <= 0 and qty_columns:
        vol = parse_volume_from_header(qty_columns[0])
        if vol:
            dose_volume_ml = vol
            selected_qty_col = qty_columns[0]
            # API qty from that column on the API row
            if api_idx is not None:
                qtxt = _row_field(rows[api_idx], qty_columns[0])
                qv = _sfloat(re.sub(r"[^0-9.\-]", "", qtxt)) if qtxt else 0.0
                if qv > 0 and api_per_dose_mg <= 0:
                    api_per_dose_mg = qv
                    mdd_source = "ratio_header"
            if dose_volume_ml > 0 and api_per_dose_mg > 0:
                strength_mg_per_ml = api_per_dose_mg / dose_volume_ml

    # explicit mg/mL column overrides strength if present
    if has_mgml and api_idx is not None:
        mtxt = _row_field(rows[api_idx], mgml_col, ["mg/ml"])
        mv = _sfloat(re.sub(r"[^0-9.\-]", "", mtxt)) if mtxt else 0.0
        if mv > 0:
            strength_mg_per_ml = mv

    # ── MDD ───────────────────────────────────────────────────────────────────
    doses = max(1, _sint(doses_per_day, 1))
    mdd_mg = api_per_dose_mg * doses if api_per_dose_mg > 0 else 0.0

    # density normalisation → g/mL
    density_g_per_ml = 0.0
    if density_value > 0:
        if density_unit.lower() in ("mg/ml",):
            density_g_per_ml = density_value / 1000.0
        else:
            density_g_per_ml = density_value  # assume g/mL

    return {
        "table_style":          table_style,
        "ingredient_col":       ingredient_col,
        "function_col":         function_col,
        "mgml_col":             mgml_col,
        "mdd_col":              mdd_col,
        "qty_columns":          qty_columns,
        "selected_qty_col":     selected_qty_col,
        "columns":              columns,
        "rows":                 rows,
        "api_row_index":        api_idx,
        "api_row_method":       api_method,
