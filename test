# ── Core converter ────────────────────────────────────────────────────────────
def convert_pdf_to_json(
    pdf_bytes: bytes,
    filename: str,
    index: int,
    progress_callback=None,
) -> Dict:
    """
    Convert one annexure PDF to a structured EI JSON.

    Steps:
    1. Rasterize all pages at 250 DPI
    2. Extract metadata (supplier, material) from page 1
    3. Extract EI table from every page independently
    4. Consolidate: merge element lists, take max concentration per element
    5. Fill in any missing ICH Q3D elements with 0.0
    6. Final consolidation pass with Claude to clean up any inconsistencies
    """

    def _progress(msg: str, pct: float = 0.0):
        if progress_callback:
            progress_callback(msg, pct)
        logger.info(f"[{filename}] {msg}")

    _progress("Rasterizing PDF pages…", 0.05)

    try:
        page_images = rasterize_pdf(pdf_bytes, dpi=250)
    except Exception as e:
        return {
            "annexure_number":  index,
            "filename":         filename,
            "supplier_name":    "",
            "material_name":    "",
            "source_type":      "",
            "date_filled":      "",
            "analytical_method":"",
            "lot_number":       "",
            "specification_reference": "",
            "extraction_notes": f"PDF rasterization failed: {e}",
            "elements":         [],
            "_error":           True,
        }

    n_pages = len(page_images)
    _progress(f"PDF has {n_pages} page(s). Extracting metadata…", 0.10)

    # ── Step 2: Metadata from page 1 ─────────────────────────────────────────
    meta_raw = claude_vision(page_images[0], META_PROMPT)
    meta     = safe_json_parse(meta_raw, {})
    if not isinstance(meta, dict):
        logger.warning("Metadata parse returned non-dict; using empty metadata.")
        meta = {}

    supplier    = safe_str(meta.get("supplier_name", ""))
    material    = safe_str(meta.get("material_name", ""))
    doc_title   = safe_str(meta.get("document_title", ""))
    candidates  = meta.get("material_name_candidates", []) or []
    candidates  = [safe_str(c) for c in candidates if safe_str(c)]
    source_type = safe_str(meta.get("source_type", ""))
    date_filled = safe_str(meta.get("date_filled", ""))
    global_method = safe_str(meta.get("analytical_method", ""))
    lot_number  = safe_str(meta.get("lot_number", ""))
    spec_ref    = safe_str(meta.get("specification_reference", ""))

    # ── Strip generic document descriptors (Issue 3) ─────────────────────────
    # "Material Characterization for X" → "X"; a bare descriptor → "".
    material = strip_document_descriptor(material)
    candidates = [c for c in (strip_document_descriptor(c) for c in candidates) if c]

    # ── Material-name fallback chain (Issue 1: non-standard formats) ──────────
    # If the primary material_name came back empty (common for E&L / material
    # characterization / container-closure reports), fall back to the best
    # available identity signal so the annexure is never silently discarded.
    if not material:
        if candidates:
            material = candidates[0]
        elif doc_title:
            material = strip_document_descriptor(doc_title)
        elif supplier:
            material = supplier
    if not material:
        logger.warning(f"Annexure: no material identity could be extracted "
                       f"(candidates={candidates}, title={doc_title!r}).")

    _progress(f"Metadata: supplier={supplier!r}, material={material!r}", 0.20)

    # ── Step 3: Extract EI table from each page ───────────────────────────────
    # Accumulate: symbol → list of concentration values seen across pages
    accumulated: Dict[str, List[float]] = {}
    element_meta: Dict[str, Dict] = {}   # store extra metadata per element
    page_summaries: List[str] = []
    unit_warnings: List[str] = []        # RF7: suspicious-magnitude (unit?) flags

    for pi, page_img in enumerate(page_images):
        pct = 0.20 + 0.55 * ((pi + 1) / n_pages)
        _progress(f"Reading page {pi + 1}/{n_pages}…", pct)

        ei_raw    = claude_vision(page_img, make_ei_prompt(pi + 1, n_pages))
        ei_parsed = safe_json_parse(ei_raw, {})
        if not isinstance(ei_parsed, dict):
            ei_parsed = {}
        page_els  = ei_parsed.get("elements", [])

        if not isinstance(page_els, list):
            page_summaries.append(f"Page {pi + 1}: no valid JSON returned")
            continue

        # Capture page-level LOQ + its unit
        page_loq      = safe_float(ei_parsed.get("page_loq", 0.0))
        page_loq_unit = safe_str(ei_parsed.get("page_loq_unit", "ppm"))
        page_loq_ppm  = normalize_to_ppm(page_loq, page_loq_unit) if page_loq > 0 else 0.0

        page_found = []
        for el in page_els:
            if not isinstance(el, dict):
                continue

            raw_sym = safe_str(el.get("symbol", ""))
            sym = normalise_symbol(raw_sym)
            if not sym:
                continue

            raw_unit = safe_str(el.get("concentration_unit", "ppm")) or "ppm"
            observed = safe_str(el.get("observed_level", ""))
            comments = safe_str(el.get("comments", ""))

            # ── RF4: "% of permitted concentration" results ────────────────────
            # A CoA that reports "<30% of Perm. Conc." (Roquette Dextrose class)
            # states a FRACTION of the ICH Q3D Option-1 concentration, NOT an
            # absolute number. Interpret it per element BEFORE any generic numeric
            # parse — otherwise "<30%" normalizes as 30 × 10000 = 300000 µg/g
            # (a 1e6× overstatement that dominated the Esomeprazole totals).
            perm = perm_conc_to_ppm(" ".join((observed, raw_unit, comments)), sym)
            if perm is not None:
                conc_ppm, _pct = perm
                use_value = conc_ppm
                eff_unit = "ug/g"
                status = "percent_of_permitted"
            else:
                # ── Determine the raw numeric value + data status ──────────────
                conc_raw = el.get("concentration_value")
                try:
                    raw_value = float(conc_raw) if conc_raw is not None else None
                except (TypeError, ValueError):
                    raw_value = None

                # Re-parse observed_level for robust status + bracketed-limit
                # handling. Catches BDL (0.034 ppm), <0.5, ND, Not Tested.
                obs_value, status, obs_unit_hint = parse_observed_level(observed, page_loq)

                # Choose the authoritative raw value:
                #  - if Claude gave a numeric concentration_value, trust it for "actual"
                #  - otherwise fall back to the observed-level parse
                if raw_value is not None and raw_value > 0 and status in ("actual", "less_than"):
                    use_value = raw_value
                elif status in ("bdl", "derived_loq", "less_than", "actual"):
                    use_value = obs_value
                elif raw_value is not None and raw_value > 0:
                    use_value = raw_value
                    status = "actual"
                else:
                    use_value = 0.0  # nd / not_tested / blq-without-limit

                # Unit hint from observed_level overrides the column unit if it is
                # more specific (e.g. observed "285 ppb" but column said ppm).
                eff_unit = obs_unit_hint if obs_unit_hint else raw_unit

                # ── NORMALIZE TO µg/g (ppm) ── THE CRITICAL FIX ────────────────
                conc_ppm = normalize_to_ppm(use_value, eff_unit)

            # RF7: sanity-check magnitude. A single-element concentration above
            # 10000 µg/g (1%) in a raw material is almost always a unit misread
            # (e.g. ppb reported as ppm, or "% of permitted" read as a bare %).
            # Log + record it for the audit trail; never silently trust it.
            if conc_ppm > 10000 and status != "percent_of_permitted":
                msg = (f"{sym}={conc_ppm:.1f} µg/g exceeds 10000 — possible unit "
                       f"misinterpretation (raw {use_value} {eff_unit}, "
                       f"observed {observed!r})")
                unit_warnings.append(msg)
                logger.warning(f"[{filename}] {msg}")

            if sym not in accumulated:
                accumulated[sym] = []
            # Accumulate the NORMALIZED value (µg/g) — never the raw ppb number
            accumulated[sym].append({
                "conc_ppm":   conc_ppm,
                "raw_value":  use_value,
                "raw_unit":   eff_unit,
                "status":     status,
                "observed":   observed,
            })

            if sym not in element_meta:
                element_meta[sym] = {
                    "name":               safe_str(el.get("name",
                                          ICH_PDE.get(sym, {}).get("name", sym))),
                    "class":              safe_str(el.get("class",
                                          ICH_PDE.get(sym, {}).get("class", ""))),
                    "analytical_method":  safe_str(el.get("analytical_method",
                                          global_method)),
                    "intentionally_added":safe_str(el.get("intentionally_added", "No")),
                    "listed_in_coa":      safe_str(el.get("listed_in_coa", "")),
                    "comments":           safe_str(el.get("comments", "")),
                }
            page_found.append(f"{sym}={conc_ppm}µg/g({eff_unit}:{use_value},{status})")

        loq_note = f" [page LOQ={page_loq}{page_loq_unit}={page_loq_ppm}µg/g]" if page_loq > 0 else ""
        page_summaries.append(
            f"Page {pi + 1}{loq_note}: {len(page_found)} elements — "
            + (", ".join(page_found) if page_found else "none")
        )

    _progress("Consolidating elements…", 0.80)

    # ── Step 4: Consolidate — take MAX per element by NORMALIZED µg/g value ────
    elements: List[Dict] = []
    for sym in ALL_SYMBOLS:
        info = ICH_PDE[sym]
        if sym in accumulated and accumulated[sym]:
            # Pick the record with the highest normalized concentration (worst case)
            best = max(accumulated[sym], key=lambda r: r["conc_ppm"])
            emeta = element_meta.get(sym, {})
            elements.append({
                "symbol":               sym,
                "name":                 emeta.get("name", info["name"]),
                "class":                emeta.get("class", info["class"]),
                # concentration_value is ALWAYS in µg/g (ppm) — normalized at source
                "concentration_value":  round(best["conc_ppm"], 6),
                "concentration_unit":   "ug/g",
                # Full audit trail preserved through to app.py
                "raw_value":            round(best["raw_value"], 6),
                "raw_unit":             best["raw_unit"],
                "data_status":          best["status"],
                "observed_level":       best["observed"] or str(best["raw_value"]),
                "analytical_method":    emeta.get("analytical_method", global_method),
                "intentionally_added":  emeta.get("intentionally_added", "No"),
                "listed_in_coa":        emeta.get("listed_in_coa", ""),
                "comments":             emeta.get("comments", ""),
            })
        else:
            elements.append({
                "symbol":               sym,
                "name":                 info["name"],
                "class":                info["class"],
                "concentration_value":  0.0,
                "concentration_unit":   "ug/g",
                "raw_value":            0.0,
                "raw_unit":             "",
                "data_status":          "not_tested",
                "observed_level":       "Not tested",
                "analytical_method":    global_method,
                "intentionally_added":  "No",
                "listed_in_coa":        "",
                "comments":             "Not found in vendor document",
            })

    extraction_notes = "\n".join(page_summaries)
    if unit_warnings:
        extraction_notes += ("\n⚠️ Unit sanity warnings:\n  "
                             + "\n  ".join(unit_warnings))
    n_nonzero = sum(1 for e in elements if e["concentration_value"] > 0)

    _progress(f"Done — {n_nonzero}/25 elements have non-zero values.", 1.0)

    return {
        "annexure_number":        index,
        "filename":               filename,
        "supplier_name":          supplier,
        "material_name":          material,
        "material_name_candidates": candidates,
        "document_title":         doc_title,
        "source_type":            source_type,
        "date_filled":            date_filled,
        "analytical_method":      global_method,
        "lot_number":             lot_number,
        "specification_reference":spec_ref,
        "extraction_notes":       extraction_notes,
        "elements":               elements,
    }


# ── ZIP builder ───────────────────────────────────────────────────────────────
def build_zip(results: List[Dict]) -> bytes:
    """Package all JSONs into a single ZIP file."""
    buf = BytesIO()
    with zipfile.ZipFile(buf, "w", zipfile.ZIP_DEFLATED) as zf:
        for result in results:
            fname_stem = Path(result.get("filename", f"annexure_{result.get('annexure_number',1)}")).stem
            json_name  = f"{fname_stem}.json"
            json_bytes = json.dumps(result, indent=2, ensure_ascii=False).encode("utf-8")
            zf.writestr(json_name, json_bytes)
        # Also write a manifest
        manifest = {
            "created_at": datetime.now().isoformat(),
            "total_files": len(results),
            "files": [
                {
                    "filename":      r.get("filename", ""),
                    "material_name": r.get("material_name", ""),
                    "supplier_name": r.get("supplier_name", ""),
                    "n_nonzero":     sum(1 for e in r.get("elements", [])
                                        if e.get("concentration_value", 0) > 0),
                    "error":         r.get("_error", False),
                }
                for r in results
            ],
        }
        zf.writestr("_manifest.json", json.dumps(manifest, indent=2))
    return buf.getvalue()


# ── Streamlit UI ──────────────────────────────────────────────────────────────
def main() -> None:
    st.set_page_config(
        page_title="Annexure PDF → JSON Converter",
        page_icon="🧪",
        layout="wide",
    )

    st.title("🧪 Annexure PDF → JSON Converter")
    st.caption(
        "Dr. Reddy's IPDO | ICH Q3D (R2) | "
        "Claude Opus 4.6 via Vertex AI"
    )
    st.markdown(
        "Upload vendor elemental impurity declaration PDFs. "
        "Claude Vision reads each page, extracts the full EI table with exact values, "
        "and outputs structured JSONs ready for the **TSR Report Generator**."
    )
    st.markdown("---")

    # ── File upload ───────────────────────────────────────────────────────────
    uploaded = st.file_uploader(
        "Upload annexure PDF(s) — one per vendor material",
        type=["pdf"],
        accept_multiple_files=True,
        key="annexure_pdfs",
    )

    if not uploaded:
        st.info("📁 Upload one or more annexure PDFs to begin.")
        with st.expander("ℹ️ How it works"):
            st.markdown("""
**Step 1** — Upload annexure PDFs (scanned or digital, any number)

**Step 2** — Claude Vision reads each page at 250 DPI:
- Page 1: extracts supplier name, material name, date, method
- All pages: extracts every element's measured concentration exactly as printed
- Multiple pages with same element → takes the maximum (conservative)
- All 25 ICH Q3D elements included (0.0 if not tested)

**Step 3** — Download ZIP containing one JSON per PDF

**Step 4** — Upload the JSONs to the TSR Report Generator

**Unit handling (critical):** every value is normalized to µg/g (ppm).
- `ppm / µg/g / mg/kg` → as-is
- `ppb / ng/g / µg/kg` → ÷ 1000  (so 285 ppb = 0.285 µg/g)
- `%` → × 10000

**Reading rules** (applied automatically):
- `0.30` → 0.30 µg/g
- `<0.30` → 0.30 (conservative upper bound)
- `BDL (0.034 ppm)` → 0.034 (uses the bracketed reporting limit)
- `BLQ / Below LOQ` (no bracket) → the document's own LOQ, else 0.0
- `ND / Not Detected / Below LOD` → 0.0 (true non-detect)
- `NA / blank / Not Tested` → 0.0
- Never uses a hardcoded 0.05 placeholder

Each element keeps a full audit trail: raw value, raw unit, converted µg/g,
data status (actual / less_than / bdl / nd / not_tested), and observed text.
""")
        return

    st.markdown(f"**{len(uploaded)} file(s) selected:**")
    for f in uploaded:
        size_kb = len(f.getvalue()) / 1024
        st.write(f"  📄 {f.name} ({size_kb:.0f} KB)")

    st.markdown("---")

    if st.button("🚀 Convert All PDFs", type="primary"):
        results: List[Dict] = []
        errors: List[str]   = []

        overall_bar = st.progress(0.0)
        overall_txt = st.empty()

        for idx, uploaded_file in enumerate(uploaded):
            overall_txt.info(
                f"Processing {idx + 1}/{len(uploaded)}: **{uploaded_file.name}**"
            )

            # Per-file status area
            with st.expander(f"📄 {uploaded_file.name}", expanded=True):
                status_line = st.empty()
                file_bar    = st.progress(0.0)

                def _progress(msg: str, pct: float = 0.0,
                               _sl=status_line, _fb=file_bar):
                    _sl.write(f"  ⏳ {msg}")
                    _fb.progress(min(pct, 1.0))

                try:
                    result = convert_pdf_to_json(
                        pdf_bytes        = uploaded_file.getvalue(),
                        filename         = uploaded_file.name,
                        index            = idx + 1,
                        progress_callback= _progress,
                    )
                    results.append(result)

                    # Summary
                    els     = result.get("elements", [])
                    nonzero = [e for e in els if e.get("concentration_value", 0) > 0]
                    zero    = [e for e in els if e.get("concentration_value", 0) == 0]

                    file_bar.progress(1.0)
                    if result.get("_error"):
                        status_line.error(
                            f"❌ Error: {result.get('extraction_notes','unknown')}"
                        )
                        errors.append(uploaded_file.name)
                    else:
                        status_line.success(
                            f"✅ {result.get('material_name','?')} "
                            f"({result.get('supplier_name','?')}) — "
                            f"{len(nonzero)} elements with values, "
                            f"{len(zero)} not detected / not tested"
                        )

                    # Show element table
                    if els:
                        nonzero_els = [e for e in els if e.get("concentration_value",0) > 0]
                        zero_els    = [e for e in els if e.get("concentration_value",0) == 0.0]
                        st.markdown(
                            f"**Extracted concentrations:** "
                            f"{len(nonzero_els)} non-zero, {len(zero_els)} zero/ND"
                        )
                        # Show non-zero first, then zero
                        rows = []
                        for e in sorted(els, key=lambda x: -x.get("concentration_value",0)):
                            cv = e.get("concentration_value", 0)
                            raw_v = e.get("raw_value", cv)
                            raw_u = e.get("raw_unit", "")
                            # Flag suspicious unit conversions (raw ppb but value unchanged)
                            unit_flag = ""
                            if raw_u and raw_u.lower() in ("ppb","ng/g","µg/kg","ug/kg") and abs(raw_v - cv) < 1e-9 and cv > 0:
                                unit_flag = " ⚠️UNIT?"
                            rows.append({
                                "Symbol":        e.get("symbol", ""),
                                "Name":          e.get("name", ""),
                                "Class":         e.get("class", ""),
                                "µg/g (ppm)":    cv,
                                "Raw value":     raw_v,
                                "Raw unit":      raw_u,
                                "Status":        e.get("data_status", "") + unit_flag,
                                "Observed":      e.get("observed_level", ""),
                                "Method":        e.get("analytical_method", ""),
                            })
                        st.dataframe(rows, use_container_width=True, height=350)
                        if not nonzero_els:
                            st.error(
                                "❌ ALL concentrations are 0.0 — this annexure will "
                                "contribute NOTHING to EI calculations. "
                                "Check: (1) the PDF has a readable EI table, "
                                "(2) vendor results show actual numbers not all ND."
                            )

                    # Show extraction notes
                    notes = result.get("extraction_notes", "")
                    if notes:
                        with st.expander("📋 Page-by-page extraction log"):
                            st.text(notes)

                except Exception as e:
                    err_msg = f"Unexpected error: {e}"
                    logger.exception(err_msg)
                    status_line.error(f"❌ {err_msg}")
                    errors.append(uploaded_file.name)
                    results.append({
                        "annexure_number":  idx + 1,
                        "filename":         uploaded_file.name,
                        "supplier_name":    "",
                        "material_name":    "",
                        "source_type":      "",
                        "date_filled":      "",
                        "analytical_method":"",
                        "lot_number":       "",
                        "specification_reference": "",
                        "extraction_notes": err_msg,
                        "elements":         [],
                        "_error":           True,
                    })

            overall_bar.progress((idx + 1) / len(uploaded))

        overall_txt.success(
            f"✅ Conversion complete: "
            f"{len(results) - len(errors)}/{len(uploaded)} succeeded"
        )

        # ── Build and offer ZIP download ──────────────────────────────────────
        if results:
            st.markdown("---")
            st.subheader("📦 Download JSONs")

            zip_bytes = build_zip(results)
            ts        = datetime.now().strftime("%Y%m%d_%H%M%S")
            zip_name  = f"annexure_jsons_{ts}.zip"

            st.download_button(
                label  = "📥 Download ZIP (all JSONs)",
                data   = zip_bytes,
                file_name = zip_name,
                mime   = "application/zip",
            )

            st.markdown(
                f"ZIP contains **{len(results)} JSON file(s)** + `_manifest.json`. "
                "Upload the JSON files to the **TSR Report Generator** (app.py)."
            )

            if errors:
                st.warning(
                    f"⚠️ {len(errors)} file(s) had errors: {', '.join(errors)}. "
                    "Their JSONs are included with empty elements lists."
                )

            # Show manifest summary
            st.markdown("**Manifest summary:**")
            manifest_rows = []
            for r in results:
                n_nz = sum(1 for e in r.get("elements",[])
                           if e.get("concentration_value",0) > 0)
                manifest_rows.append({
                    "File":          r.get("filename",""),
                    "Material":      r.get("material_name",""),
                    "Supplier":      r.get("supplier_name",""),
                    "Non-zero vals": n_nz,
                    "Status": "❌ Error" if r.get("_error") else "✅ OK",
                })
            st.dataframe(manifest_rows, use_container_width=True)


if __name__ == "__main__":
    main()
