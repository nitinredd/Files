function fmt(val, decimals) {
if (decimals == null) decimals = 4;
if (val == null || val === “”) return “”;
const cleaned = String(val).replace(/[^0-9.eE+-]/g, “”);
const n = parseFloat(cleaned);
if (isNaN(n) || !isFinite(n)) return “”;
return n.toFixed(decimals);
}

function buildCalcTable(tableNum, tableData, pdeValues) {
const data = (tableData && typeof tableData === “object”) ? tableData : {};
const elements         = Array.isArray(data.elements) ? data.elements : [];
const rows             = Array.isArray(data.rows)     ? data.rows     : [];
const totalDailyIntake = data.total_daily_intake || 0;
const elementTotals    = data.element_totals || {};
const pde              = data.pde             || {};
const threshold30pct   = data.threshold_30pct || {};

// Empty-elements early return
if (elements.length === 0) {
return [makePara(“Table “ + tableNum + “: No elements data available.”,
{ size: SIZE.SM })];
}

const N = elements.length;
const INGR_W = Math.round(CONTENT_W * 0.27);
const DI_W   = Math.round(CONTENT_W * 0.07);
const remain = CONTENT_W - INGR_W - DI_W;
const baseEW = Math.floor(remain / (2 * N));
const EW     = Math.max(280, baseEW);
const colWidths = [INGR_W, DI_W];
for (let i = 0; i < 2 * N; i++) colWidths.push(EW);

// Group consecutive same-class elements
const groups = [];
for (let i = 0; i < elements.length; i++) {
const sym = elements[i];
const cls = (pdeValues && pdeValues[sym] && pdeValues[sym].class) || “?”;
if (groups.length && groups[groups.length - 1].cls === cls) {
groups[groups.length - 1].count++;
} else {
groups.push({ cls: cls, count: 1 });
}
}

// Header row 1: Component | Daily Intake | Measured Conc (merged) | Total Mass (merged)
const h1 = new TableRow({
children: [
makeCell(“Component”,
{ bold: true, fill: COLOR.HEADER_GREY, w: INGR_W, size: SIZE.XS }),
makeCell(“Daily\nIntake\n(g)”,
{ bold: true, fill: COLOR.HEADER_GREY, w: DI_W, size: SIZE.XS }),
new TableCell({
columnSpan: N,
borders: makeBorders(4),
shading: makeShading(COLOR.HEADER_GREY),
margins: makeMargins(),
children: [makePara(“Measured Concentration (\u00B5g/g)”, {
bold: true, size: SIZE.XS, align: AlignmentType.CENTER,
})],
}),
new TableCell({
columnSpan: N,
borders: makeBorders(4),
shading: makeShading(COLOR.HEADER_GREY),
margins: makeMargins(),
children: [makePara(“Total Mass of Elemental Impurity (\u00B5g/day)”, {
bold: true, size: SIZE.XS, align: AlignmentType.CENTER,
})],
}),
],
});

// Header row 2: class groupings under each major header
const h2cells = [
makeEmptyCell(COLOR.HEADER_GREY, INGR_W),
makeEmptyCell(COLOR.HEADER_GREY, DI_W),
];
for (let half = 0; half < 2; half++) {
for (let g = 0; g < groups.length; g++) {
h2cells.push(new TableCell({
columnSpan: groups[g].count,
borders: makeBorders(4),
shading: makeShading(COLOR.HEADER_GREY),
margins: makeMargins(),
children: [makePara(“Class “ + groups[g].cls, {
bold: true, size: SIZE.XS, align: AlignmentType.CENTER,
})],
}));
}
}
const h2 = new TableRow({ children: h2cells });

// Header row 3: element symbols
const h3cells = [
makeEmptyCell(COLOR.HEADER_GREY, INGR_W),
makeEmptyCell(COLOR.HEADER_GREY, DI_W),
];
for (let half = 0; half < 2; half++) {
for (let i = 0; i < elements.length; i++) {
h3cells.push(makeCell(elements[i], {
bold: true, fill: COLOR.HEADER_GREY, w: EW, size: SIZE.XS,
}));
}
}
const h3 = new TableRow({ children: h3cells });

// Data rows
const dataRows = [];
for (let r = 0; r < rows.length; r++) {
const row = rows[r];
if (!row || typeof row !== “object”) continue;
const mc = row.measured_conc || {};
const tm = row.total_mass    || {};
const cells = [
makeCellLeft(row.ingredient || “”, { w: INGR_W, size: SIZE.XS }),
makeCell(fmt(row.daily_intake_g != null ? row.daily_intake_g : 0, 3),
{ w: DI_W, size: SIZE.XS }),
];
for (let i = 0; i < elements.length; i++) {
const sym = elements[i];
cells.push(makeCell(fmt(mc[sym] != null ? mc[sym] : 0, 4),
{ w: EW, size: SIZE.XS }));
}
for (let i = 0; i < elements.length; i++) {
const sym = elements[i];
cells.push(makeCell(fmt(tm[sym] != null ? tm[sym] : 0, 4),
{ w: EW, size: SIZE.XS }));
}
dataRows.push(new TableRow({ children: cells }));
}

// Footer row builder
function makeFooterRow(label, valMap, fillColor, isThreshold) {
const sv = valMap || {};
const st = elementTotals || {};
const cells = [
makeCell(label, {
bold: true, fill: fillColor, align: AlignmentType.LEFT,
w: INGR_W, size: SIZE.XS,
}),
makeCell(label === “TOTAL (daily intake) g/day” ? fmt(totalDailyIntake, 3) : “”,
{ fill: fillColor, w: DI_W, size: SIZE.XS }),
];
// blank cells for measured concentration half
for (let i = 0; i < elements.length; i++) {
cells.push(makeEmptyCell(fillColor, EW));
}
// value cells for total mass half
for (let i = 0; i < elements.length; i++) {
const sym = elements[i];
const val = sv[sym] != null ? sv[sym] : null;
const tot = st[sym];
const exceeded = isThreshold
&& val != null && tot != null
&& isFinite(val) && isFinite(tot) && tot > val;
cells.push(makeCell(val != null ? fmt(val, 3) : “\u2013”, {
fill: exceeded ? COLOR.EXCEEDED_BG : fillColor,
w: EW,
size: SIZE.XS,
color: exceeded ? COLOR.EXCEEDED_TXT : COLOR.BLACK,
}));
}
return new TableRow({ children: cells });
}

const allRows = [h1, h2, h3].concat(dataRows).concat([
makeFooterRow(“TOTAL (daily intake) g/day”, elementTotals, COLOR.HEADER_GREY, false),
makeFooterRow(“PDE (\u00B5g/day)”,          pde,           COLOR.HEADER_GREY, false),
makeFooterRow(“Threshold Limit (30% of PDE)”, threshold30pct, COLOR.THRESHOLD_BG, true),
]);

const calcTable = new Table({
width: { size: CONTENT_W, type: WidthType.DXA },
columnWidths: colWidths,
rows: allRows,
});

const classLabels = {
5: “Class 1 and Class 2A”,
6: “Class 2B”,
7: “Class 3”,
};
const caption = “Table “ + tableNum
+ “: Theoretical Elemental Impurity Assessment (”
+ (classLabels[tableNum] || “”)
+ “) \u2014 Evaluation of Daily Contribution of the Total Mass”;

return [
makePara(caption, { bold: true, size: SIZE.SM, before: 60, after: 20 }),
calcTable,
blankPara(),
];
}

