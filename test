# ============================================================================
def _parse_conc(val: Any) -> float:
    """Parse a concentration value to µg/g. BLQ → 0.05 (LOQ)."""
    if val is None:
        return 0.0
    if isinstance(val, (int, float)):
        return max(0.0, float(val))
    s = str(val).strip().lower()
    s_compact = re.sub(r"\s+", "", s)
    if s_compact in (
        "", "na", "n/a", "nd", "notdetected", "notanalyzed",
        "notanalysed", "nq", "notquantified", "none", "null",
    ):
        return 0.0
    if s_compact in ("blq", "bdl", "<loq", "<lod"):
        return 0.05
    s = s.replace("µ", "u")
    s = re.sub(r"(ppm|ug/g|mcg/g|<|>|,)", "", s).replace(" ", "")
    try:
        return max(0.0, float(s))
    except (ValueError, TypeError):
        return 0.05


def _parse_amount(val: Any) -> float:
    """Parse an ingredient amount (mg) to float. q.s. → 0."""
    if val is None:
        return 0.0
    if isinstance(val, (int, float)):
        return max(0.0, float(val))
    s = str(val).strip().lower()
    if s in ("", "q.s.", "q.s", "qs", "q.s. to", "na", "n/a"):
        return 0.0
    if "qs" in s or "q.s" in s or "adjust" in s:
        return 0.0
    m = re.search(r"[-+]?\d*\.?\d+(?:[eE][-+]?\d+)?", s.replace(",", ""))
    if m:
        try:
            return max(0.0, float(m.group(0)))
        except Exception:
            return 0.0
    try:
        return float(s)
    except Exception:
        return 0.0


def _amount_to_daily_g(amount: float, unit: str, daily_units: float) -> float:
    """Convert one-unit amount to daily intake in g/day."""
    unit_l = safe_str(unit, "mg").lower().replace("µ", "u")
    amount_f = max(0.0, float(amount or 0.0))
    if "ug" in unit_l or "mcg" in unit_l:
        per_unit_g = amount_f / 1_000_000.0
    elif re.search(r"(^|[^a-z])g([^a-z]|$)", unit_l) and "mg" not in unit_l:
        per_unit_g = amount_f
    else:
        per_unit_g = amount_f / 1000.0
    return per_unit_g * max(0.0, float(daily_units or 0.0))


def _build_conc_map(annexure_data: List[Dict]) -> Dict[str, Dict[str, float]]:
    """Build {material_name: {element_symbol: conc_µg/g}} from all annexures."""
    conc_map: Dict[str, Dict[str, float]] = {}
    for ann in annexure_data:
        if not isinstance(ann, dict):
            continue
        material = safe_str(ann.get("material_name", ""))
        if not material:
            continue
        elem_dict: Dict[str, float] = {}
        for el in ann.get("elements", []) or []:
            if not isinstance(el, dict):
                continue
            sym = safe_str(el.get("symbol", ""))
            if sym:
                elem_dict[sym] = _parse_conc(el.get("concentration_value", 0))
        conc_map[material] = elem_dict
    return conc_map


def _match_ingredient(name: str,
                      conc_map: Dict[str, Dict[str, float]]) -> Dict[str, float]:
    """Fuzzy-match an ingredient name to the closest annexure material."""
    if not conc_map or not name:
        return {}
    name_lower = name.lower().strip()
    best_key: Optional[str] = None
    best_score = 0.0
    for key in conc_map:
        if not key:
            continue
        key_lower = key.lower().strip()
        if key_lower in name_lower or name_lower in key_lower:
            return conc_map.get(key, {})
        name_tokens = set(t for t in re.split(r"[\s\(\)\-,]+", name_lower) if t)
        key_tokens  = set(t for t in re.split(r"[\s\(\)\-,]+", key_lower)  if t)
        if not name_tokens or not key_tokens:
            continue
        overlap = len(name_tokens & key_tokens)
        score = overlap / max(len(name_tokens), len(key_tokens))
        if score > best_score:
            best_score = score
            best_key   = key
    return conc_map.get(best_key, {}) if best_key and best_score >= 0.45 else {}


def calculate_ei_tables(comp_data: Dict, annexure_data: List[Dict],
                        pde_values: Optional[Dict[str, Dict]] = None) -> Dict:
    """Calculate Tables 5 (Class 1+2A), 6 (2B), 7 (3)."""
    pde_values = pde_values or ICH_PDE
    daily_units = comp_data.get("daily_units", comp_data.get("mdd_sachets", 1))
    try:
        daily_units = float(daily_units)
    except Exception:
        daily_units = 1.0
    if daily_units <= 0:
        daily_units = 1.0

    amount_key = safe_str(
        comp_data.get("mdd_amount_key", comp_data.get("mdd_strength", "")),
    )
    amount_columns = comp_data.get("amount_columns", []) or []
    amount_unit = "mg"
    if isinstance(amount_columns, list):
        for col in amount_columns:
            if isinstance(col, dict) and safe_str(col.get("key")) == amount_key:
                amount_unit = safe_str(col.get("unit", "mg")) or "mg"
                break
    if not amount_key and isinstance(amount_columns, list) and amount_columns:
        first_col = amount_columns[0] if isinstance(amount_columns[0], dict) else {}
        amount_key = safe_str(first_col.get("key", ""))
        amount_unit = safe_str(first_col.get("unit", "mg")) or "mg"

    ingredients: List[Dict] = []
    for section in comp_data.get("sections") or []:
        if not isinstance(section, dict):
            continue
        for row in section.get("rows", []) or []:
            if not isinstance(row, dict):
                continue
            ingredient_name = safe_str(row.get("ingredient", ""))
            if not ingredient_name:
                continue
            amt = _parse_amount(row.get(amount_key, row.get("40mg", 0)))
            daily = _amount_to_daily_g(amt, amount_unit, daily_units)
            ingredients.append({
                "name": ingredient_name,
                "daily_g": daily,
                "amount_value": amt,
                "amount_unit": amount_unit,
            })

    conc_map = _build_conc_map(annexure_data)

    def build_one_table(elements: List[str]) -> Dict:
        rows:          List[Dict] = []
        elem_totals:   Dict[str, float] = {sym: 0.0 for sym in elements}
        total_intake = 0.0

        for ing in ingredients:
            if ing["daily_g"] == 0:
                continue
            ing_concs = _match_ingredient(ing["name"], conc_map)
            measured:    Dict[str, float] = {}
            total_mass:  Dict[str, float] = {}
            for sym in elements:
                conc              = ing_concs.get(sym, 0.0)
                measured[sym]     = round(conc, 6)
                mass              = ing["daily_g"] * conc
                total_mass[sym]   = round(mass, 9)
                elem_totals[sym]  = elem_totals[sym] + mass
            total_intake += ing["daily_g"]
            rows.append({
                "ingredient":     ing["name"],
                "daily_intake_g": round(ing["daily_g"], 9),
                "amount_value":   ing["amount_value"],
                "amount_unit":    ing["amount_unit"],
                "measured_conc":  measured,
                "total_mass":     total_mass,
            })

        table_pde = {sym: pde_values[sym]["pde"] for sym in elements}
        threshold  = {
            sym: round(table_pde[sym] * 0.30, 3) if table_pde[sym] else None
            for sym in elements
        }
        return {
            "elements":           elements,
            "rows":               rows,
            "total_daily_intake": round(total_intake, 9),
            "element_totals":     {sym: round(v, 9) for sym, v in elem_totals.items()},
            "pde":                table_pde,
            "threshold_30pct":    threshold,
            "formula":            "Daily exposure (ug/day) = Daily intake (g/day) x measured concentration (ug/g)",
        }

    return {
        "class1_2a": build_one_table(TABLE5_ELEMENTS),
        "class2b":   build_one_table(TABLE6_ELEMENTS),
        "class3":    build_one_table(TABLE7_ELEMENTS),
    }


