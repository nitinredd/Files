# 3b. CALCULATION IDENTITY AGGREGATION (Red Flag 3)
#     Composition stays stage-wise for Section 4; Section 5 calculation collapses
#     repeated / synonymous material rows into ONE calculation identity each.
# ════════════════════════════════════════════════════════════════════════════
def aggregate_calculation_identities(parsed: Dict) -> Dict:
    """
    Collapse repeated/synonymous component rows into one calculation identity,
    summing quantity_per_unit and amount_in_maximum_dose. Uses the same family
    recognition as the mapper (with negative-pair protection) so e.g. HPC/Klucel
    variants merge but Triethyl citrate never merges with ATBC. q.s. rows are
    NOT aggregated (kept separate, calculation-exempt). Returns a parsed-like
    dict whose 'rows' are the aggregated identities, plus an audit trail.
    """
    rows = parsed.get("rows", []) or []
    no_of_doses = parsed.get("no_of_doses")

    buckets: List[Dict] = []          # each: {family, key, ident, members[]}
    qs_rows: List[Dict] = []

    def bucket_for(name: str):
        ident = _rs_identity(name)
        fam = ident.get("family", "")
        dist = _rs_distinctive(ident.get("tokens", set()))
        for b in buckets:
            bfam = b["ident"].get("family", "")
            # Block chemically distinct families that share weak generic tokens
            if _rs_pair_blocked(fam, bfam):
                continue
            # Strong merge: identical recognised family
            if fam and bfam and fam == bfam:
                return b
            # Else merge only on distinctive (non-generic) token equality
            if not fam and not bfam:
                bdist = _rs_distinctive(b["ident"].get("tokens", set()))
                if dist and bdist and dist == bdist:
                    return b
        return None

    for r in rows:
        if r.get("_is_qs"):
            qs_rows.append(r)
            continue
        name = r.get("component", "")
        b = bucket_for(name)
        if b is None:
            b = {"ident": _rs_identity(name), "members": []}
            buckets.append(b)
        b["members"].append(r)

    agg_rows: List[Dict] = []
    aggregation_warnings: List[str] = []
    for b in buckets:
        members = b["members"]
        qty_sum = 0.0
        had_qty = False
        amt_sum = 0.0
        had_amt = False
        stages, names, src = [], [], []
        for m in members:
            q = m.get("quantity")
            if isinstance(q, (int, float)):
                qty_sum += q; had_qty = True
            a = m.get("amount_in_maximum_dose_mg")
            if isinstance(a, (int, float)):
                amt_sum += a; had_amt = True
            names.append(m.get("component", ""))
            st = m.get("stage") or (m.get("columns", {}) or {}).get("Stage")
            if st:
                stages.append(_s(st))
            src.append(m.get("component", ""))

        # Recompute amount from summed qty × doses when possible (authoritative)
        amount = None
        basis = members[0].get("amount_basis", "none")
        if had_qty and no_of_doses:
            amount = round(qty_sum * no_of_doses, 6)
            basis = "aggregated_quantity_times_doses"
        elif had_amt:
            amount = round(amt_sum, 6)
            basis = "aggregated_amount_sum"

        primary = members[0].get("component", "")
        # Prefer the recognised family label as the canonical display name
        canon_name = b["ident"].get("family") or primary
        canon_name = canon_name if canon_name else primary
        if len(members) > 1:
            aggregation_warnings.append(
                f"Aggregated {len(members)} rows into '{canon_name}' "
                f"(stages: {', '.join(stages) or 'n/a'}).")
        agg_rows.append({
            "component": canon_name if len(members) > 1 else primary,
            "quantity": round(qty_sum, 6) if had_qty else None,
            "amount_in_maximum_dose_mg": amount,
            "amount_basis": basis,
            "_is_qs": False,
            "solvents": members[0].get("solvents", {}) or {},
            "columns": {},
            "_aggregation": {
                "source_rows": len(members),
                "stages": stages,
                "original_names": names,
                "aggregation_reason": (b["ident"].get("family") and "family identity")
                                      or "distinctive-token identity",
            },
        })

    # q.s. rows preserved as separate calculation-exempt rows
    for q in qs_rows:
        agg_rows.append({
            "component": q.get("component", ""),
            "quantity": q.get("quantity"),
            "amount_in_maximum_dose_mg": None,
            "amount_basis": "qs",
            "_is_qs": True,
            "solvents": {}, "columns": {},
            "_aggregation": {"source_rows": 1, "stages": [], "original_names":
                             [q.get("component", "")], "aggregation_reason": "q.s. row"},
        })

    out = dict(parsed)
    out["rows"] = agg_rows
    out["aggregation_warnings"] = aggregation_warnings
    out["needs_dose_basis"] = any(
        (not r["_is_qs"]) and r["amount_in_maximum_dose_mg"] is None for r in agg_rows)
    return out


# ════════════════════════════════════════════════════════════════════════════
# 4. CALCULATOR — exposure = amount_mg × limit_ppm / 1e6
# ════════════════════════════════════════════════════════════════════════════
def _rs_display_name(name: str) -> str:
    """Readable display key for a solvent. Canonical names are used directly;
    non-USP names keep short all-caps acronyms (CPME, TFA, MTBE) as-is and
    title-case longer free text (RF2)."""
    name = _s(name).strip()
    if not name:
        return ""
    if name.isupper() and len(name) <= 6:
        return name
    return name.title() if (name.islower() or " " in name) else name


def _rs_solvent_disp(sv: Dict) -> Optional[str]:
    """Display key for a solvent evidence entry, or None if it should not form a
    column. USP <467> solvents use the canonical name; a NON-USP solvent forms a
    column ONLY when it carries a numeric ppm (RF2)."""
    name = _s(sv.get("solvent_name"))
    if not name or is_generic_solvent_category(name):
        return None
    canon = sv.get("canonical") or RSM.resolve_solvent(name)
    if canon:
        return canon
    if sv.get("converted_ppm") is not None:
        return _rs_display_name(name)
    return None


def _annexure_solvent_universe(mapping: Dict[str, Dict]) -> List[str]:
    """Collect the distinct solvent display names across mapped annexures. USP
    <467> solvents use their canonical name; non-USP solvents that carry a real
    numeric ppm are included too (RF2). Generic categories are excluded."""
    seen: List[str] = []
    for m in mapping.values():
        ann = m.get("_annexure")
        if not ann:
            continue
        for sv in (ann.get("solvents") or []):
            disp = _rs_solvent_disp(sv)
            if disp and disp not in seen:
                seen.append(disp)
    return seen


def calculate_rs_exposures(parsed: Dict, mapping: Dict[str, Dict],
                           user_limits: Dict[str, Dict[str, float]] = None) -> Dict:
    """
    Compute per-component daily exposure per solvent.

    Two solvent-source paths:
      A) Excel solvent matrix: parsed['solvents_display'] is non-empty → use the
         sheet limits/exposures and validate against the formula.
      B) Annexure-driven: parsed['solvents_display'] is empty → derive the solvent
         universe and per-component limits from the matched annexures'
         solvents[] (converted_ppm). This makes unit-composition / MDD-only
         Excels (which have no solvent columns) produce real exposure tables.

    Daily Exposure (mg/day) = Amount in Maximum Dose (mg/day) × Limit (ppm) / 1e6.
    False zeros are never invented; negative declarations contribute nothing but
    are recorded; ambiguous evidence is flagged unresolved.
    """
    user_limits = user_limits or {}
    excel_solvents = parsed.get("solvents_display", []) or []
    solvent_canon = parsed.get("solvent_canon", {})
    consistency_flags: List[str] = []

    annexure_driven = len(excel_solvents) == 0
    if annexure_driven:
        solvents = _annexure_solvent_universe(mapping)
    else:
        solvents = excel_solvents

    rows_out: List[Dict] = []
    per_solvent_total: Dict[str, float] = {s: 0.0 for s in solvents}
    evidence_unresolved: List[str] = []

    def annexure_limit(comp: str, solvent_disp: str) -> Tuple[Optional[float], str, Dict]:
        """Pull a usable ppm limit for this component/solvent from its annexure."""
        m = mapping.get(comp, {})
        ann = m.get("_annexure")
        if not ann:
            return None, "missing", {}
        for sv in (ann.get("solvents") or []):
            disp = _rs_solvent_disp(sv)
            if disp is None or disp != solvent_disp:
                continue
            etype = sv.get("evidence_type")
            ppm = sv.get("converted_ppm")
            if etype in ("numerical_limit", "percentage_limit", "nmt",
                         "controlled_by_spec", "coa_statement") and ppm is not None:
                return float(ppm), "annexure", sv
            if ppm is not None:          # non-USP / other evidence carrying a ppm
                return float(ppm), "annexure", sv
            if etype in ("negative_declaration", "no_source"):
                return 0.0, "negative_declaration", sv
            if etype == "ambiguous":
                return None, "ambiguous", sv
        # No explicit per-solvent evidence. If the annexure carries an overall
        # negative declaration (e.g. "Class 1/2/3 residual solvents are not used"),
        # treat this solvent as a CONFIRMED no-contribution (0/0), not missing.
        if ann.get("negative_declaration"):
            return 0.0, "negative_declaration", {"evidence_type": "negative_declaration",
                                                 "raw_text": _s(ann.get("raw_text"))}
        return None, "missing", {}

    def excel_limit(disp: str, comp: str, sheet_limit: Optional[float]) -> Tuple[Optional[float], str]:
        # Ingredient-row CONTENT ppm is a vendor/measured value — the Excel cell or
        # a user override only. It must NEVER fall back to the USP <467> master
        # regulatory limit (that limit belongs solely in the final comparison row,
        # built from usp_limits below). Falling back to the master here filled
        # ingredient cells with the regulatory limit (e.g. Methanol 3000 instead of
        # the vendor content 29) and invented exposures. No vendor value → NA.
        if sheet_limit is not None and sheet_limit > 0:
            return sheet_limit, "excel"
        ul = user_limits.get(comp, {}).get(disp)
        if ul is not None and ul > 0:
            return ul, "user"
        return None, "missing"

    for cr in parsed.get("rows", []):
        if cr.get("_is_qs"):
            # RF5/RF9: q.s. rows are VISIBLE but not calculable. Emit them with
            # not_applicable solvent cells (rendered 'NA'), the raw q.s. quantity
            # text, and no exposure. Excluded from totals and solid DP mass (the
            # None amount is filtered out of the sums below).
            qs_text = (_s(cr.get("quantity_raw")) or _s(cr.get("quantity"))
                       or "q.s.")
            rows_out.append({
                "component": cr["component"],
                "quantity": qs_text,
                "amount_max_dose": None,
                "amount_basis": cr.get("amount_basis", "q.s."),
                "_is_qs": True,
                "solvents": {disp: {
                    "limit": None, "limit_source": "not_applicable",
                    "daily_exposure": None, "exposure_source": "not_applicable",
                    "evidence_type": "", "raw_text": "", "confidence": None,
                    "page": None, "cell_status": "not_applicable"}
                    for disp in solvents},
            })
            continue
        amount = cr.get("amount_in_maximum_dose_mg")
        comp = cr["component"]
        # RS Bug 4: a component whose annexure WAS matched but is silent on a
        # particular solvent renders "NA" (not applicable), not a blank. Only a
        # component with no matched annexure at all leaves the cell blank.
        has_annexure = bool(mapping.get(comp, {}).get("_annexure"))
        row_solvents: Dict[str, Dict] = {}

        for disp in solvents:
            if annexure_driven:
                limit_ppm, limit_src, sv_ev = annexure_limit(comp, disp)
                sheet_de = None
                raw_text = _s(sv_ev.get("raw_text")) if sv_ev else ""
                etype = _s(sv_ev.get("evidence_type")) if sv_ev else ""
                conf = sv_ev.get("confidence") if sv_ev else None
                page = sv_ev.get("page") if sv_ev else None
                if limit_src == "ambiguous":
                    evidence_unresolved.append(f"{comp}/{disp}")
            else:
                sv = (cr.get("solvents", {}) or {}).get(disp, {}) or {}
                sheet_limit = sv.get("limit")
                sheet_de = sv.get("daily_exposure")
                limit_ppm, limit_src = excel_limit(disp, comp, sheet_limit)
                raw_text = ""; etype = ""; conf = None; page = None

            computed_de = None
            if amount is not None and limit_ppm is not None:
                computed_de = round(amount * limit_ppm / 1_000_000.0, 6)

            if sheet_de is not None:
                daily_exp = sheet_de
                de_src = "excel"
                if computed_de is not None and sheet_de > 0:
                    if abs(computed_de - sheet_de) / max(sheet_de, 1e-9) > 0.05:
                        consistency_flags.append(
                            f"{comp}/{disp}: Excel exposure {sheet_de} vs computed "
                            f"{computed_de} differ >5%")
            elif computed_de is not None:
                daily_exp = computed_de
                de_src = "computed"
            elif limit_src == "negative_declaration":
                daily_exp = 0.0
                de_src = "negative_declaration"
            else:
                daily_exp = None
                de_src = "missing"

            if daily_exp is not None:
                per_solvent_total[disp] += daily_exp

            # Cell status drives rendering (Red Flag 4):
            #   value            → real number present
            #   confirmed_zero   → negative declaration / confirmed no contribution
            #   not_applicable   → annexure matched but silent on this solvent → NA
            #   unresolved       → no matched annexure (evidence genuinely missing)
            if de_src == "negative_declaration" or (daily_exp == 0.0
                                                    and limit_src == "negative_declaration"):
                cell_status = "confirmed_zero"
            elif daily_exp is not None:
                cell_status = "value"
            elif limit_src == "missing" and (
                    (annexure_driven and has_annexure) or not annexure_driven):
                # No vendor evidence for THIS solvent → NA. Covers a matched
                # annexure that is silent on the solvent (annexure-driven, RS Bug 4)
                # AND an empty cell in an Excel solvent matrix (which must render NA
                # rather than borrow the USP master limit). Ambiguous evidence and a
                # genuinely unmatched component still fall through to unresolved.
                cell_status = "not_applicable"
            else:
                cell_status = "unresolved"

            row_solvents[disp] = {
                "limit": limit_ppm,
                "limit_source": limit_src,
                "daily_exposure": daily_exp,
                "exposure_source": de_src,
                "evidence_type": etype,
                "raw_text": raw_text,
                "confidence": conf,
                "page": page,
                "cell_status": cell_status,
            }
        rows_out.append({
            "component": comp,
            "quantity": cr.get("quantity"),
            "amount_max_dose": amount,
            "amount_basis": cr.get("amount_basis"),
            "solvents": row_solvents,
        })

    # Drug Product totals. For a detailed/Excel-authoritative sheet, PREFER the
    # Excel's own 'Drug Product' row and 'Total Daily Exposure' footer verbatim
    # (Fix 3: Excel is authoritative — do not recompute/override). Fall back to
    # summed values only when the Excel does not carry those footers.
    dp_row = parsed.get("drug_product_row", {}) or {}
    footer_total = parsed.get("footer_total", {}) or {}
    dp_quantity = None
    dp_amount = None
    q_vals = [r.get("quantity") for r in rows_out if isinstance(r.get("quantity"), (int, float))]
    a_vals = [r.get("amount_max_dose") for r in rows_out
              if isinstance(r.get("amount_max_dose"), (int, float))]
    if isinstance(dp_row.get("quantity"), (int, float)):
        dp_quantity = dp_row["quantity"]
    elif q_vals:
        dp_quantity = round(sum(q_vals), 6)
    if isinstance(dp_row.get("amount_max_dose"), (int, float)):
        dp_amount = dp_row["amount_max_dose"]
    elif isinstance(parsed.get("drug_product_mass_mg"), (int, float)) and parsed.get("drug_product_mass_mg"):
        # RF1/RF12: the single-strength parser's Drug Product mass is authoritative
        # and drives the Total-row equivalent-ppm denominator. For a LIQUID it is
        # mL/day × density × 1000 (NOT the sum of dissolved solids — that sum, e.g.
        # 114.8 mg, gives equivalent-ppm ~70× too high); for a SOLID it equals the
        # sum of the non-q.s. component amounts (unchanged behaviour).
        dp_amount = round(float(parsed["drug_product_mass_mg"]), 6)
    elif a_vals:
        dp_amount = round(sum(a_vals), 6)

    # Excel-authoritative per-solvent totals override recomputed sums when the
    # sheet provides a 'Total Daily Exposure' footer with a numeric exposure.
    excel_authoritative = bool(parsed.get("solvents_display")) and (
        bool(footer_total) or parsed.get("has_calculated_values"))
    if excel_authoritative and footer_total:
        for disp in solvents:
            fv = footer_total.get(disp, {}) or {}
            de = fv.get("daily_exposure")
            if isinstance(de, (int, float)):
                per_solvent_total[disp] = de

    usp_limits: Dict[str, Dict] = {}
    solvent_compliance: Dict[str, Dict] = {}
    per_solvent_equiv_ppm: Dict[str, Optional[float]] = {}
    footer_limit = parsed.get("footer_limit", {}) or {}
    for disp in solvents:
        canon = solvent_canon.get(disp) or RSM.resolve_solvent(disp)
        mlim = RSM.get_limit_ppm(canon) if canon else None
        mpde = RSM.get_pde_mg_day(canon) if canon else None
        # Prefer the Excel's USP <467> limit footer when present (authoritative).
        fl = footer_limit.get(disp, {}) or {}
        if isinstance(fl.get("limit"), (int, float)):
            mlim = fl.get("limit")
        usp_limits[disp] = {"limit": mlim, "pde": mpde, "canonical": canon}
        total = round(per_solvent_total[disp], 6)
        # Total equivalent ppm: prefer the Excel footer's ppm if present, else
        # compute total_exposure_mg × 1e6 / DP amount.
        equiv_ppm = None
        fv = footer_total.get(disp, {}) or {}
        if isinstance(fv.get("limit"), (int, float)):
            equiv_ppm = fv.get("limit")
        elif dp_amount and dp_amount > 0:
            equiv_ppm = round(total * 1_000_000.0 / dp_amount, 6)
        per_solvent_equiv_ppm[disp] = equiv_ppm
        compliant = None
        if mpde is not None:
            compliant = total <= mpde
        solvent_compliance[disp] = {
            "total_exposure_mg": total, "pde_mg_day": mpde,
            "limit_ppm": mlim, "equivalent_ppm": equiv_ppm, "compliant": compliant,
        }

    return {
        "rows": rows_out,
        "solvents": solvents,
        "solvent_source": "annexure" if annexure_driven else "excel",
        "per_solvent_total": {k: round(v, 6) for k, v in per_solvent_total.items()},
        "per_solvent_equiv_ppm": per_solvent_equiv_ppm,
        "drug_product_quantity": dp_quantity,
        "drug_product_amount": dp_amount,
        "usp_limits": usp_limits,
        "solvent_compliance": solvent_compliance,
        "consistency_flags": consistency_flags,
        "evidence_unresolved": evidence_unresolved,
        "drug_product_row": parsed.get("drug_product_row", {}),
    }


# ════════════════════════════════════════════════════════════════════════════
# 5. VALIDATOR — WARNING-FIRST policy (Red Flag 10)
#    Hard-block ONLY for: no parsed rows, non-q.s. quantitative rows with no
#    amount basis, no calc rows, or a structurally-empty payload. Everything
#    else (unmapped component, missing/low-confidence annexure, no usable solvent
#    evidence, generic policy statements, q.s. unresolved, numbering mismatch,
#    duplicates) becomes a WARNING / manual-review item — never a blocker.
# ════════════════════════════════════════════════════════════════════════════
def validate_rs_full(parsed: Dict, calc: Dict, mapping: Dict[str, Dict],
                     annexures: List[Dict], payload: Dict = None) -> Dict:
    errors: List[str] = []
    warnings: List[str] = []
    unmapped_components: List[str] = []
    low_confidence_mappings: List[str] = []
    missing_annexure_evidence: List[str] = []
    duplicate_annexures: List[str] = []
    annexure_numbering_mismatches: List[str] = []
    unresolved_qs_rows: List[str] = []
    generic_policy_statements: List[str] = []
    manual_review_items: List[str] = []

    # ── HARD BLOCKS (only these) ──────────────────────────────────────────────
    if not parsed.get("rows"):
        errors.append("No component/composition rows were parsed from the Excel.")
    if parsed.get("needs_dose_basis"):
        errors.append("One or more non-q.s. quantitative components have no "
                      "determinable Amount in Maximum Dose (no MDD/strength/amount "
                      "basis).")
    if not calc.get("rows"):
        errors.append("No calculation rows were produced.")
    if payload is not None:
        comp_tbl = payload.get("composition_table") or []
        comp_rows_total = sum(len(s.get("rows", [])) for s in comp_tbl
                              if isinstance(s, dict))
        smt = payload.get("solvent_matrix_tables") or {}
        if comp_rows_total == 0 and not smt:
            errors.append("Final payload has no composition table and no solvent "
                          "tables — nothing reportable to render.")

    # ── WARNINGS / MANUAL REVIEW (never block) ────────────────────────────────
    for ann in annexures:
        if isinstance(ann, dict) and ann.get("_error"):
            warnings.append(f"Annexure {ann.get('annexure_number','?')} is malformed "
                            "and was skipped.")
            manual_review_items.append(
                f"Malformed annexure {ann.get('annexure_number','?')}")

    for comp, m in mapping.items():
        if m.get("matched_annexure") is None:
            unmapped_components.append(comp)
            warnings.append(f"Component '{comp}' has no matched annexure.")
            manual_review_items.append(f"Unmapped component: {comp}")
        elif m.get("needs_confirmation"):
            low_confidence_mappings.append(comp)
            warnings.append(f"Component '{comp}' annexure match is low-confidence.")
            manual_review_items.append(f"Low-confidence mapping: {comp}")

    # Components mapped but annexure has no usable solvent evidence and no neg-decl
    for row in calc.get("rows", []):
        comp = row["component"]
        m = mapping.get(comp, {})
        ann = m.get("_annexure")
        neg_decl = bool(ann and ann.get("negative_declaration"))
        scopes = bool(ann and ann.get("declaration_scopes"))
        row_has_value = any(sv.get("daily_exposure") is not None
                            for sv in row.get("solvents", {}).values())
        if ann and not row_has_value and not neg_decl:
            missing_annexure_evidence.append(comp)
            warnings.append(f"Component '{comp}' matched an annexure with no usable "
                            "material-specific solvent limit.")
            manual_review_items.append(f"Missing solvent evidence: {comp}")
        for disp, sv in row.get("solvents", {}).items():
            if sv.get("limit_source") == "ambiguous":
                warnings.append(f"Solvent '{disp}' for '{comp}' has ambiguous "
                                "evidence (manual review).")
                manual_review_items.append(f"Ambiguous solvent evidence: {comp}/{disp}")

    # Generic policy statements captured but not usable as material limits
    for ann in annexures:
        if isinstance(ann, dict) and ann.get("declaration_scopes") \
           and not ann.get("solvents"):
            for sc in ann.get("declaration_scopes", []):
                generic_policy_statements.append(
                    f"Annexure {ann.get('annexure_number','?')}: "
                    f"{sc.get('scope_text','')}")

    # q.s. rows that remain unresolved (display-valid, calculation-exempt)
    for r in parsed.get("rows", []):
        if r.get("_is_qs"):
            unresolved_qs_rows.append(r.get("component", ""))

    # Duplicate / numbering issues from the payload dedup pass
    if payload is not None:
        for w in payload.get("_dup_warnings", []):
            duplicate_annexures.append(w)
            warnings.append(w)
        for w in payload.get("_numbering_warnings", []):
            annexure_numbering_mismatches.append(w)
            warnings.append(w)

    for f in calc.get("consistency_flags", []):
        warnings.append(f)

    if parsed.get("aggregation_warnings"):
        for w in parsed["aggregation_warnings"]:
            warnings.append(w)

    # Missing equivalent ppm
    if calc.get("drug_product_amount") in (None, 0):
        warnings.append("Drug Product total amount is unavailable; total equivalent "
                        "ppm could not be computed.")
        manual_review_items.append("Missing drug-product amount for equivalent ppm")

    # ── conclusion status ─────────────────────────────────────────────────────
    if errors:
        conclusion_status = "blocked"
    elif (unmapped_components or low_confidence_mappings or missing_annexure_evidence
          or unresolved_qs_rows or manual_review_items or warnings):
        conclusion_status = "incomplete_manual_review"
    else:
        # All resolved → compliance can be asserted iff all exposures below limits
        comps = [c.get("compliant") for c in calc.get("solvent_compliance", {}).values()
                 if c.get("compliant") is not None]
        conclusion_status = ("complete_compliant"
                             if comps and all(comps) else "generated_with_warnings")

    return {
        "errors": errors,
        "warnings": warnings,
        "unmapped_components": unmapped_components,
        "low_confidence_mappings": low_confidence_mappings,
        "missing_annexure_evidence": missing_annexure_evidence,
        "duplicate_annexures": duplicate_annexures,
        "annexure_numbering_mismatches": annexure_numbering_mismatches,
        "unresolved_qs_rows": unresolved_qs_rows,
        "generic_policy_statements_not_used": generic_policy_statements,
        "manual_review_items": manual_review_items,
        "conclusion_status": conclusion_status,
    }


def validate_rs(parsed: Dict, calc: Dict, mapping: Dict[str, Dict],
                annexures: List[Dict], payload: Dict = None) -> Tuple[List[str], List[str]]:
    """Backward-compatible wrapper returning (errors, warnings)."""
    v = validate_rs_full(parsed, calc, mapping, annexures, payload)
    return v["errors"], v["warnings"]


# ════════════════════════════════════════════════════════════════════════════
# 6. PAYLOAD BUILDER — clean RS payload for generate_residual_solvent.js
# ════════════════════════════════════════════════════════════════════════════
def _chunk(lst: List[Any], n: int) -> List[List[Any]]:
    return [lst[i:i + n] for i in range(0, len(lst), n)]


def build_rs_payload(header: Dict, parsed: Dict, calc: Dict,
                     mapping: Dict[str, Dict], annexures: List[Dict],
                     text_sections: Dict, group_size: int = 3,
                     validation: Dict = None,
                     preserve_uploaded_annexure_numbers: bool = False,
                     framework: str = DEFAULT_RS_FRAMEWORK) -> Dict:
    """
    Assemble the RS renderer payload (warning-first). Solvents are grouped to fit
    A4. NO EI keys are emitted. Implements: reconciled supplier-table numbering,
    deduplicated annexure list, confirmed-zero cell rendering, total-row
    equivalent ppm, complete Drug Product row, and a risk summary table.
    """
    solvents = calc.get("solvents") or parsed.get("solvents_display", [])
    rows = calc.get("rows", [])
    usp_limits = calc.get("usp_limits", {})
    per_total = calc.get("per_solvent_total", {})
    per_equiv = calc.get("per_solvent_equiv_ppm", {})
    dp_quantity = calc.get("drug_product_quantity")
    dp_amount = calc.get("drug_product_amount")

    unresolved_display = ""

    def _na(v: Any) -> str:
        """Format a value, rendering None as 'NA' — used for the USP <467>
        comparison of a non-USP solvent (RF2)."""
        return "NA" if v is None else _fmt(v)

    def cell_pair(sv: Dict) -> Dict:
        """Render a solvent cell honouring the four-state cell_status (RF5):
          value          → real numeric limit + exposure
          confirmed_zero → negative declaration: Limit 'NA', Exposure '0.000'
          not_applicable → q.s. row (variable amount): Limit 'NA', Exposure 'NA'
          unresolved     → no evidence: both blank (warning lives in the UI)
        Matches the approved Epinephrine convention."""
        status = sv.get("cell_status")
        if status == "not_applicable":
            return {"limit": "NA", "daily_exposure": "NA"}
        if status == "confirmed_zero":
            return {"limit": "NA", "daily_exposure": "0.000"}
        if status == "value":
            return {"limit": _fmt(sv.get("limit")),
                    "daily_exposure": _fmt(sv.get("daily_exposure"))}
        return {"limit": unresolved_display, "daily_exposure": unresolved_display}

    # ── Deduplicate annexures (RF8) ───────────────────────────────────────────
    # Key on (normalized material, normalized supplier) ONLY — the same material
    # + supplier is one logical annexure regardless of filename/title (Trilaciclib
    # Annexure 1 & 6). On collision, merge non-conflicting solvent evidence and
    # keep the RICHER record (more solvents[], then higher confidence). Records
    # with no resolved material never merge (avoids collapsing distinct unknowns).
    def _norm_key(ann: Dict) -> Tuple[str, ...]:
        mat = _rs_norm(_s(ann.get("material_name")))
        sup = _rs_norm(_s(ann.get("supplier_name")))
        if not mat:
            return ("~unresolved",
                    _rs_norm(_s(ann.get("document_title")) or _s(ann.get("filename"))),
                    str(ann.get("annexure_number")))
        return (mat, sup)

    valid_anns = [a for a in annexures if isinstance(a, dict) and not a.get("_error")]
    deduped: List[Dict] = []
    key_to_idx: Dict[Tuple[str, ...], int] = {}
    dup_warnings: List[str] = []
    for ann in valid_anns:
        k = _norm_key(ann)
        if k in key_to_idx:
            idx = key_to_idx[k]
            kept = deduped[idx]
            challenger = dict(ann)
            merged_solvents = _dedup_rs_solvents(
                (kept.get("solvents") or []) + (challenger.get("solvents") or []),
                framework)
            winner = dict(_pick_richer_annexure(kept, challenger))
            winner["solvents"] = merged_solvents
            # negative declaration only survives if the winner has no numeric limit
            if any(s.get("converted_ppm") is not None for s in merged_solvents):
                winner["negative_declaration"] = False
            merged_from = list(kept.get("_merged_from", []))
            for num in (kept.get("annexure_number"), challenger.get("annexure_number")):
                if (num is not None and num != winner.get("annexure_number")
                        and num not in merged_from):
                    merged_from.append(num)
            if merged_from:
                winner["_merged_from"] = merged_from
            deduped[idx] = winner
            dup_warnings.append(
                f"Duplicate annexure for material '{_s(ann.get('material_name'))}' "
                f"/ supplier '{_s(ann.get('supplier_name'))}' "
                f"(Annexure {ann.get('annexure_number','?')}) merged into the "
                "richer record; solvent evidence combined.")
            continue
        key_to_idx[k] = len(deduped)
        deduped.append(dict(ann))

    # ── Display annexure numbering (Red Flag 1) ───────────────────────────────
    # Assign sequential display numbers based on deduped order, unless the caller
    # explicitly preserves uploaded numbers.
    numbering_warnings: List[str] = []
    uploaded_nums = [a.get("annexure_number") for a in deduped]
    if uploaded_nums != list(range(1, len(deduped) + 1)):
        numbering_warnings.append(
            "Uploaded annexure numbers are non-sequential/duplicated; display "
            "numbers were reconciled sequentially.")
    orig_to_display: Dict[Any, int] = {}
    for i, ann in enumerate(deduped, start=1):
        disp_no = (ann.get("annexure_number")
                   if preserve_uploaded_annexure_numbers else i)
        orig_to_display[ann.get("annexure_number")] = disp_no
        ann["_display_number"] = disp_no

    def display_ref(ann: Dict) -> str:
        n = ann.get("_display_number", ann.get("annexure_number", "?"))
        return f"Annexure {n}"

    # ── Solvent matrix tables (Red Flags 4,5,6) ───────────────────────────────
    solvent_tables: Dict[str, Dict] = {}
    groups = _chunk(solvents, max(1, group_size))
    for gi, group in enumerate(groups):
        table_rows = []
        for r in rows:
            if r.get("_is_qs"):
                # RF5: q.s. row visible with 'NA' solvent cells + raw q.s. text.
                sv = {s: cell_pair(r["solvents"].get(s, {})) for s in group}
                table_rows.append({"component": r["component"],
                                   "quantity": _s(r.get("quantity")) or "q.s.",
                                   "amount_max_dose": "NA", "solvents": sv,
                                   "is_qs": True})
                continue
            sv = {s: cell_pair(r["solvents"].get(s, {})) for s in group}
            table_rows.append({
                "component": r["component"],
                "quantity": _fmt(r.get("quantity")),
                "amount_max_dose": _fmt(r.get("amount_max_dose")),
                "solvents": sv, "is_qs": False,
            })
        # Total Daily Exposure row: equivalent ppm + exposure mg (Red Flag 5)
        totals = {s: {"limit_total": _fmt(per_equiv.get(s)),
                      "exposure_total": _fmt(per_total.get(s))} for s in group}
        # USP <467> comparison: a non-USP solvent has no master limit → 'NA' (RF2)
        usp = {s: {"limit": _na((usp_limits.get(s) or {}).get("limit")),
                   "pde": _na((usp_limits.get(s) or {}).get("pde"))} for s in group}
        # Drug Product row: total qty + amount; solvent limit dash, exposure=total
        drug_product_row = {
            "quantity": _fmt(dp_quantity),
            "amount_max_dose": _fmt(dp_amount),
            "solvents": {s: {"limit": "-", "daily_exposure": _fmt(per_total.get(s))}
                         for s in group},
        }
        solvent_tables[f"table_{4+gi}"] = {
            "table_number": 4 + gi,
            "caption": (f"Table {4+gi}: Residual Solvent risk Assessment in drug "
                        "product and comparison against the control levels"),
            "solvents": group,
            "rows": table_rows,
            "drug_product_row": drug_product_row,
            "totals": totals,
            "usp_limits": usp,
        }

    # ── Supplier declaration table from CALCULATION components (Red Flag 1) ────
    # RF9: q.s. status affects ONLY the solvent matrix (Tables 4-6), not this
    # table — every material with a matched annexure appears here, q.s. included.
    supplier_decls = []
    s_no = 0
    for comp in [r["component"] for r in rows]:
        m = mapping.get(comp, {})
        ann = m.get("_annexure")
        s_no += 1
        if ann and ann.get("annexure_number") in orig_to_display:
            ref = f"Annexure {orig_to_display[ann.get('annexure_number')]}"
            supplier = _s(ann.get("supplier_name")) or "(vendor not stated)"
        elif ann:
            ref = display_ref(ann)
            supplier = _s(ann.get("supplier_name")) or "(vendor not stated)"
        else:
            # Unmapped: no internal "manual review" language in the rendered doc.
            ref = "-"
            supplier = "-"
        supplier_decls.append({
            "s_no": s_no, "ingredient": comp,
            "supplier": supplier, "annexure": ref,
        })

    # ── Deduplicated annexure list, 3 columns (Red Flag 2) ────────────────────
    annexure_list = []
    for ann in deduped:
        annexure_list.append({
            "annexure": display_ref(ann),
            "material": _s(ann.get("material_name")) or "(material not stated)",
            "supplier": _s(ann.get("supplier_name")) or "(vendor not stated)",
            "_display_number": ann.get("_display_number"),
        })

    # ── Risk summary table (Table 7): always definitive, negligible-risk rows.
    # Internal validation state must never leak into the rendered document.
    v = validation or {}
    risk_summary_table = {
        "title": "Residual Solvent Assessment and Controls for Drug Product",
        "columns": ["Potential Risks", "Action / Mitigation"],
        "rows": [
            {"risk": "Residual solvents from Drug Substance",
             "action": "No action required, negligible risk"},
            {"risk": "Residual solvents from Excipients",
             "action": "No action required, negligible risk"},
            {"risk": "Residual solvents from Pharmaceutical aids / process solvents",
             "action": "No action required, negligible risk"},
        ],
    }

    conclusion_status = v.get("conclusion_status", "generated_with_warnings")
    all_warnings = list(v.get("warnings", [])) + dup_warnings + numbering_warnings

    return {
        "rs_meta": {
            "title": header.get("title", ""),
            "document_no": header.get("document_no", ""),
            "product_name": header.get("product_name", ""),
            "dosage_form": header.get("dosage_form", ""),
            "strength": header.get("strength", ""),
            "strength_note": header.get("strength_note", ""),
            "department": header.get("department", "FR&D"),
            "market": header.get("market", ""),
            "version": header.get("version", "1.0, CURRENT"),
            "protocol": header.get("protocol", "NA"),
            "sop_format_number": header.get("sop_format_number", ""),
        },
        "product_details": {
            "product_name": header.get("product_name", ""),
            "market": header.get("market", ""),
            "dosage_form": header.get("dosage_form", ""),
            "strengths": header.get("strength", ""),
            "maximum_daily_dose": header.get("maximum_daily_dose", ""),
        },
        "composition_table": parsed.get("_display_sections", []),
        "comp_columns": parsed.get("_display_columns", []),
        "comp_meta": {"caption": "Table 2: Unit Composition"},
        "supplier_declaration_table": supplier_decls,
        "solvent_matrix_tables": solvent_tables,
        "solvent_totals": per_total,
        "per_solvent_equiv_ppm": per_equiv,
        "drug_product_quantity": dp_quantity,
        "drug_product_amount": dp_amount,
        "solvent_limit_master": {s: (usp_limits.get(s) or {}) for s in solvents},
        "annexure_list": annexure_list,
        "annexure_list_deduplicated": annexure_list,
        "risk_summary_table": risk_summary_table,
        "text_sections": text_sections,
        "references": text_sections.get("reference", ""),
        "revision_history": header.get("revision_history", []),
        "signatures": header.get("signatures", []),
        # ALL internal validation signals live ONLY under a "_" prefixed key.
        # The renderer must not read anything prefixed with "_". This keeps
        # manual-review / unmapped / conclusion-status data out of the document.
        "_verification_audit": {
            "conclusion_status": conclusion_status,
            "validation_warnings": all_warnings,
            "manual_review_items": v.get("manual_review_items", []),
            "unmapped_components": v.get("unmapped_components", []),
            "low_confidence_mappings": v.get("low_confidence_mappings", []),
            "missing_annexure_evidence": v.get("missing_annexure_evidence", []),
            "duplicate_annexures": dup_warnings,
            "annexure_numbering_mismatches": numbering_warnings,
            "generic_policy_statements_not_used":
                v.get("generic_policy_statements_not_used", []),
            "mode": parsed.get("mode"),
            "no_of_doses": parsed.get("no_of_doses"),
            # Drop the internal object graphs before they reach the payload:
            # "_annexure" is the full source annexure and "_cluster" carries a
            # pooled identity whose `tokens` is a live set (needed for O(1)
            # scoring, but not JSON-serializable). This is the payload boundary.
            "mapping": {k: {kk: vv for kk, vv in v2.items()
                            if kk not in ("_annexure", "_cluster")}
                        for k, v2 in mapping.items()},
        },
        # validator-only channels (also "_" prefixed → renderer ignores them)
        "_dup_warnings": dup_warnings,
        "_numbering_warnings": numbering_warnings,
    }


def _fmt(v: Any) -> str:
    if v is None or v == "":
        return ""
    if isinstance(v, (int, float)):
        # trim trailing zeros but keep precision
        s = f"{v:.6f}".rstrip("0").rstrip(".")
        return s if s else "0"
    return _s(v)
