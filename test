    custom_conc = ""
    if not auto_gen:
        custom_obs  = st.text_area("Custom Observation text", height=150)
        custom_conc = st.text_area("Custom Conclusion text", height=150)

    # ── Generate ──────────────────────────────────────────────────────────────
    st.header("3. Generate Report")
    if st.button("🚀 Generate Report", type="primary"):

        if not annexure_files:
            st.warning("Please upload at least one annexure JSON file.")
            return
        if not excel_file:
            st.warning("Please upload the Excel file.")
            return

        progress = st.progress(0)
        status   = st.empty()

        # Step 1: Parse Excel
        status.info("Parsing Excel data…")
        try:
            excel_data = parse_excel(excel_file.getvalue())
            st.success(f"Excel parsed. Sheets found: {excel_data['raw_sheets']}")
        except Exception as e:
            st.error(f"Excel parsing failed: {e}")
            logger.exception("Excel error")
            excel_data = {"composition": [], "class1_2a": [], "class2b": [], "class3": []}
        progress.progress(10)

        # Step 2: Process Annexure JSONs with Claude
        status.info(f"Processing {len(annexure_files)} annexure(s) with Claude…")
        annexure_data = []
        for i, af in enumerate(annexure_files):
            try:
                raw_json = json.loads(af.read().decode("utf-8"))
                ann_num  = i + 1
                ann_result = extract_annexure_data(raw_json, ann_num)
                annexure_data.append(ann_result)
                st.write(f"  ✅ Annexure {ann_num}: {ann_result.get('material_name', 'N/A')} "
                         f"({ann_result.get('supplier_name', 'N/A')})")
            except Exception as e:
                st.warning(f"  ⚠️ Annexure {i+1} could not be fully processed: {e}")
                annexure_data.append({"annexure_number": i+1, "error": str(e)})
            progress.progress(10 + int(70 * (i + 1) / len(annexure_files)))

        # Step 3: Generate Obs/Conclusion
        obs_text  = custom_obs
        conc_text = custom_conc
        if auto_gen:
            status.info("Generating Observations & Conclusion with Claude…")
            try:
                summary = {
                    "annexure_count": len(annexure_data),
                    "materials": [a.get("material_name") for a in annexure_data],
                    "excel_sheets": excel_data.get("raw_sheets", []),
                }
                obs_text, conc_text = generate_observations_and_conclusion(summary)
                st.success("Observations & Conclusion generated.")
            except Exception as e:
                st.warning(f"Auto-generation failed ({e}); using default text.")
        progress.progress(85)

        # Step 4: Build DOCX
        status.info("Building the Word document…")
        try:
            report_buf = generate_report(annexure_data, excel_data, obs_text, conc_text)
            progress.progress(100)
            status.success("✅ Report generated successfully!")

            fname = f"TSR-SOM-01-00066_v5_{datetime.now().strftime('%Y%m%d_%H%M%S')}.docx"
            st.download_button(
                label="📄 Download Report (DOCX)",
                data=report_buf.getvalue(),
                file_name=fname,
                mime="application/vnd.openxmlformats-officedocument.wordprocessingml.document"
            )
        except Exception as e:
            st.error(f"Document generation failed: {e}")
            logger.exception("DOCX error")

