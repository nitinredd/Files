def _rs_parse_excel_raw(excel_bytes: bytes) -> Dict:
    """Detailed-mode helper: dump the workbook and let Claude extract the full
    solvent matrix (only used for detailed_rs_calculation Excels)."""
    import residual_solvent as _rs
    wb = openpyxl.load_workbook(BytesIO(excel_bytes), data_only=True)
    dump_parts = []
    for ws in wb.worksheets:
        dump_parts.append(f"=== Sheet: {ws.title} ===")
        for i, row in enumerate(ws.iter_rows(values_only=True)):
            if any(c is not None for c in row):
                cells = [str(c) if c is not None else "" for c in row]
                dump_parts.append(f"Row {i+1}: {' | '.join(cells)}")
            if i > 150:
                break
    wb.close()
    prompt = _rs.rs_excel_prompt() + "\n\nSpreadsheet:\n" + "\n".join(dump_parts[:250])
    raw = claude_text(prompt, max_tokens=8192)
    return _rs.rs_safe_json(raw, want="dict")


def _generate_rs_report() -> None:
    """Build the RS report from validated session state and render via the RS JS.
    Warning-first: generates unless there are TRUE hard errors or an empty payload."""
    import residual_solvent as _rs
    try:
        parsed = st.session_state.get("rs_parsed_calc") or st.session_state["rs_parsed"]
        calc = st.session_state["rs_calc"]
        mapping = st.session_state["rs_mapping"]
        annexures = st.session_state["rs_annexures"]
        header = st.session_state["rs_header"]
        validation = st.session_state.get("rs_validation")

        with st.spinner("Generating narrative…"):
            text_sections = _rs_generate_text(header, parsed, calc, validation)

        payload = _rs.build_rs_payload(header, parsed, calc, mapping, annexures,
                                       text_sections, group_size=3,
                                       validation=validation,
                                       framework=st.session_state.get(
                                           "rs_framework", _rs.DEFAULT_RS_FRAMEWORK))

        # FINAL HARD-STOP: only true hard errors or structurally-empty payload.
        final_val = _rs.validate_rs_full(parsed, calc, mapping, annexures, payload)
        comp_rows = sum(len(s.get("rows", [])) for s in payload.get("composition_table", [])
                        if isinstance(s, dict))
        if final_val["errors"] or (comp_rows == 0 and not payload.get("solvent_matrix_tables")):
            st.error("❌ Generation blocked (hard errors only): "
                     + (" ".join(final_val["errors"][:3]) if final_val["errors"]
                        else "structurally-empty payload"))
            return

        logo_bytes, logo_mt = load_logo_from_assets()
        if logo_bytes:
            payload["logo_b64"] = base64.standard_b64encode(logo_bytes).decode()
            payload["logo_type"] = logo_mt

        with st.spinner("Rendering A4 DOCX…"):
            import tempfile, subprocess
            with tempfile.NamedTemporaryFile("w", suffix=".json", delete=False) as jf:
                json.dump(payload, jf)
                json_path = jf.name
            out_path = json_path.replace(".json", ".docx")
            script = str(Path(__file__).parent / "generate_residual_solvent.js")
            r = subprocess.run(["node", script, json_path, out_path],
                               capture_output=True, text=True, timeout=120)
            if r.returncode != 0:
                raise RuntimeError(f"Renderer failed: {r.stderr[:500]}")
            with open(out_path, "rb") as f:
                docx_bytes = f.read()

        fname = (f"{header['document_no'].replace('/','_').replace(' ','_')}_"
                 f"{datetime.now().strftime('%Y%m%d_%H%M%S')}.docx")
        st.session_state["rs_docx_bytes"] = docx_bytes
        st.session_state["rs_docx_fname"] = fname
        st.session_state["rs_report_ready"] = True
    except Exception as e:
        st.error(f"Report generation failed: {e}")
        logger.exception("RS report error")


def _rs_generate_text(header: Dict, parsed: Dict, calc: Dict,
                      validation: Dict = None) -> Dict:
    """Generate RS narrative from STRUCTURED DATA only (no invented values).
    Narrative formula uses COMPONENT amount in maximum dose (RF7); conclusion
    follows USP <467> Option 2 / ICH Q3C logic and conclusion_status (RF8)."""
    product = header.get("product_name", "the drug product")
    validation = validation or {}
    status = validation.get("conclusion_status", "generated_with_warnings")
    no_of_doses = parsed.get("no_of_doses")
    strength = parsed.get("selected_strength_label") or header.get("strength", "")

    compliances = [c.get("compliant") for c in calc.get("solvent_compliance", {}).values()
                   if c.get("compliant") is not None]
    all_below = len(compliances) > 0 and all(c is True for c in compliances)
    has_solvents = bool(calc.get("solvents") or parsed.get("solvents_display"))

    # DEFINITIVE conclusion — no hedging, no manual-review language (B4).
    if all_below:
        conclusion = (f"All residual solvent daily exposures for {product} are below "
                      "the applicable USP <467> Option 2 / ICH Q3C limits. Based on "
                      "the assessed data, the product complies with USP <467> Option "
                      "2 and ICH Q3C for the residual solvents evaluated.")
    elif has_solvents:
        conclusion = (f"Based on the residual solvent assessment for {product}, the "
                      "evaluated residual solvents are controlled within the "
                      "applicable USP <467> and ICH Q3C limits. The product is "
                      "considered compliant with USP <467> Option 2 and ICH Q3C for "
                      "the residual solvents evaluated.")
    else:
        conclusion = (f"Based on the supplier declarations and specifications for the "
                      f"materials used in {product}, the residual solvents are "
                      "controlled within the applicable USP <467> and ICH Q3C limits. "
                      "The product is considered compliant with USP <467> and ICH "
                      "Q3C.")

    solvents = calc.get("solvents", []) or parsed.get("solvents_display", [])
    # RF7 — correct formula description (component amount, not product MDD × ppm)
    basis_line = (
        "Daily Exposure (mg/day) for each solvent is calculated as the amount of "
        "the component in the maximum daily dose (mg/day) × the solvent "
        "limit/concentration (ppm) ÷ 1,000,000. The component amount in the maximum "
        "daily dose is derived from the unit composition as quantity per unit (mg) × "
        "the dose multiplier (Maximum Daily Dose of API ÷ API quantity per unit).")
    # RF6c — prefer MDD-based phrasing; fall back to the legacy units/day line.
    mdd_val = parsed.get("mdd_mg_day")
    dp_mass = parsed.get("drug_product_mass_mg")
    multiplier = parsed.get("multiplier")
    dose_line = ""
    if mdd_val:
        bits = [f" The Maximum Daily Dose (API) is {mdd_val:g} mg/day"]
        if parsed.get("api_component"):
            bits.append(f", contributed by {parsed['api_component']}")
        bits.append(". Each component's amount in the maximum daily dose is scaled "
                    "from the API using the dose multiplier")
        if multiplier:
            bits.append(f" ({multiplier:g})")
        if dp_mass:
            bits.append(f"; the total drug product mass per daily dose is "
                        f"{dp_mass:g} mg/day")
        bits.append(".")
        dose_line = "".join(bits)
    elif strength and no_of_doses:
        dose_line = (f" For the {strength} strength, the assessment basis is "
                     f"{no_of_doses:g} units/day, corresponding to the maximum daily "
                     "dose; component-level daily amounts are calculated from the "
                     "unit composition and used for residual solvent exposure "
                     "calculations.")
    intro = (f"This report presents the residual solvent risk assessment for "
             f"{product} in accordance with USP <467> and ICH Q3C. {basis_line}"
             f"{dose_line}")

    prompt = (
        "Write concise, factual regulatory prose for a Residual Solvent Risk "
        "Assessment (USP <467> / ICH Q3C). Do NOT invent any numbers, solvent "
        "limits, supplier declarations, or compliance claims. Use only the facts "
        "given. CRITICAL: daily exposure is component amount in maximum dose × "
        "solvent ppm / 1e6 — NOT product MDD × ppm. Return ONLY JSON with keys "
        "abstract, objective, background, section5_intro, summary_and_conclusion.\n\n"
        f"Product: {product}\nDosage form: {header.get('dosage_form','')}\n"
        f"Maximum daily dose: {header.get('maximum_daily_dose','')}\n"
        f"Strength: {strength}\nUnits per day (no_of_doses): {no_of_doses}\n"
        f"Solvents assessed: {', '.join(solvents)}\n"
        f"Calculation basis: {basis_line}\n"
        "Do not state compliance in these sections; the conclusion is set separately."
    )
    try:
        raw = claude_text(prompt, max_tokens=2000)
        data = _rs_safe_text_json(raw)
    except Exception:
        data = {}

    def clean(s: str) -> str:
        s = re.sub(r"\*\*(.+?)\*\*", r"\1", s or "")
        s = s.replace("`", "").replace("*", "")
        return s.strip()

    # Strip any hedging the LLM may still emit in the prose sections (B4).
    _HEDGE_RE = re.compile(
        r"(manual[\s-]*review|assessment incomplete|unresolved|cannot (?:be )?"
        r"draw|material-specific evidence not available|supplier engagement|"
        r"review required before final|pending review|incomplete)", re.IGNORECASE)

    def de_hedge(s: str) -> str:
        return "" if s and _HEDGE_RE.search(s) else s

    return {
        "abstract": de_hedge(clean(data.get("abstract"))) or intro,
        "objective": de_hedge(clean(data.get("objective"))) or
                     f"To assess the residual solvent risk for {product} per USP <467> / ICH Q3C.",
        "background": de_hedge(clean(data.get("background"))) or
                      f"{product} ({header.get('dosage_form','')}). Maximum daily dose: "
                      f"{header.get('maximum_daily_dose','')}.",
        "section5_intro": de_hedge(clean(data.get("section5_intro"))) or intro,
        "conclusion": conclusion,
        # Always use the definitive conclusion — never the LLM's (may hedge).
        "summary_and_conclusion": conclusion,
        "reference": "1. USP <467> Residual Solvents.\n2. ICH Q3C (R8) Impurities: "
                     "Guideline for Residual Solvents.",
    }


def _rs_safe_text_json(raw: str) -> Dict:
    import residual_solvent as _rs
    d = _rs.rs_safe_json(raw, want="dict")
    return d if isinstance(d, dict) else {}


