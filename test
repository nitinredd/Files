def initialize_cost_tracker():
    if "cost_tracker" not in st.session_state:
        st.session_state.cost_tracker = {
            "total_queries": 0, "slm_queries": 0, "hybrid_queries": 0,
            "total_cost_inr": 0.0, "gpt4o_calls": 0
        }


def log_query_cost(mode: str, gpt4o_calls: int = 0):
    initialize_cost_tracker()
    t = st.session_state.cost_tracker
    t["total_queries"] += 1
    if mode == "slm":
        t["slm_queries"] += 1
    else:
        t["hybrid_queries"] += 1
        t["gpt4o_calls"] += gpt4o_calls
        t["total_cost_inr"] += gpt4o_calls * COST_PER_GPT4O_CALL_INR


def get_monthly_projection() -> Dict:
    initialize_cost_tracker()
    t = st.session_state.cost_tracker
    avg_cost = t["total_cost_inr"] / max(t["hybrid_queries"], 1)
    queries_per_month = max(t["total_queries"], 1) * 30
    hybrid_monthly = avg_cost * queries_per_month + 2000
    slm_monthly = 1500
    return {
        "slm_monthly": slm_monthly,
        "hybrid_monthly": hybrid_monthly,
        "copilot_monthly": COPILOT_BASELINE_MONTHLY_INR,
        "slm_savings_pct": round((1 - slm_monthly / COPILOT_BASELINE_MONTHLY_INR) * 100),
        "hybrid_savings_pct": round((1 - hybrid_monthly / COPILOT_BASELINE_MONTHLY_INR) * 100)
    }


