// ── SECTION 7 — MANUFACTURING PROCESS FLOW ───────────────────────────────────
// Renders either a flowchart image OR a text-based flow list
function buildProcessFlow(flow) {
  flow = flow || {};
  var ch = [];
  ch.push(secHd("7. Manufacturing Process Flow"));
  var hasFlow = (flow.image_b64 && flow.image_b64.length > 100)
    || (Array.isArray(flow.steps) && flow.steps.length) || flow.footnote;
  if (!hasFlow) { ch.push(phNote()); ch.push(blk()); return ch; }
  if (flow.image_b64 && flow.image_b64.length > 100) {
    try {
      var buf = Buffer.from(flow.image_b64, "base64");
      var t = (flow.image_media_type || "").indexOf("jpeg") >= 0 ? "jpg" : "png";
      ch.push(new Paragraph({
        alignment: AlignmentType.CENTER,
        spacing: {before:40, after:40},
        children: [new ImageRun({
          type: t, data: buf,
          transformation: {width:480, height:360},
        })],
      }));
    } catch(e) { /* fall through to text */ }
  }
  if (Array.isArray(flow.steps) && flow.steps.length) {
    for (var i = 0; i < flow.steps.length; i++) {
      var step = flow.steps[i];
      var line = (i > 0 ? "↓  " : "") + step;
      ch.push(ctrPara(line, true, SZ.SM));
    }
  }
  if (flow.footnote) {
    ch.push(blk());
    ch.push(bodyPara(flow.footnote, {italics:true}));
  }
  ch.push(blk());
  return ch;
}

