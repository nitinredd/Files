            ICH_PDE.get(el["symbol"], {}).get("pde") is None or
            _parse_conc(el.get("concentration_value", 0)) * comp_data.get("mdd_sachets", 6) *
            max(_parse_amount(row.get(comp_data.get("mdd_strength","40mg"), 0))
                for section in comp_data.get("sections",[])
