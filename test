# ASSEMBLE AND CALL Node.js GENERATOR
# ============================================================================
def assemble_and_generate(
    ref_structure: Dict,
    page_images:   List[bytes],
    figure_pages:  List[Dict],
    annexure_data: List[Dict],
    comp_data:     Dict,
    calc_tables:   Dict,
    text_sections: Dict,
    ref_bytes:     bytes = b"",
    logo_b64:      str   = "",
    logo_type:     str   = "",
) -> bytes:
    """Build report_data.json, run generate_report.js, return DOCX bytes."""

    # Encode figure images (header already cropped in extract_figure_from_page)
    figures_b64: List[Dict] = []
    for fig in figure_pages:
        if not isinstance(fig, dict):
            continue
        pi = fig.get("page_index")
        if pi is None:
            continue
        try:
            img_bytes = extract_figure_from_page(ref_bytes, pi, dpi=200)
        except Exception as e:
            logger.warning(f"Figure raster page {pi}: {e}")
            img_bytes = safe_list_get(page_images, pi, b"")
        if not img_bytes:
            continue
        figures_b64.append({
            "page_index":   pi,
            "description":  fig.get("description", ""),
            "figure_label": fig.get("figure_label", "Figure 1"),
            "data_b64":     base64.standard_b64encode(img_bytes).decode(),
            "media_type":   "image/png",
        })

    # Build annexure list for Table 8
    annexure_list: List[Dict] = []
    for ann in annexure_data:
        if isinstance(ann, dict):
            annexure_list.append({
                "material":  ann.get("material_name", "N/A"),
                "supplier":  ann.get("supplier_name", "N/A"),
                "annexure":  f"Annexure {ann.get('annexure_number', '?')}",
            })

    report_data = {
        "meta":             ref_structure.get("meta", {}) or {},
        "logo_b64":         logo_b64,
        "logo_type":        logo_type,
        "text_sections":    text_sections or {},
        "composition":      comp_data.get("sections", []) or [],
        "annexure_list":    annexure_list,
        "calc_tables":      calc_tables or {},
        "revision_history": ref_structure.get("revision_history", []) or [],
        "signatures":       ref_structure.get("signatures", []) or [],
        "figures":          figures_b64,
        "pde_values":       dict(ICH_PDE),
    }

    with tempfile.TemporaryDirectory() as tmpdir:
        json_path = Path(tmpdir) / "report_data.json"
        docx_path = Path(tmpdir) / "report.docx"
        js_script = Path(__file__).parent / "generate_report.js"

        with open(json_path, "w", encoding="utf-8") as f:
            json.dump(report_data, f, ensure_ascii=False)

        result = subprocess.run(
            ["node", str(js_script), str(json_path), str(docx_path)],
            capture_output=True, text=True, timeout=180,
        )
        if result.returncode != 0:
            raise RuntimeError(
                f"Node.js failed (exit {result.returncode}).\n"
                f"STDERR: {result.stderr[-2000:]}\n"
                f"STDOUT: {result.stdout[-500:]}"
            )
        if not docx_path.exists():
            raise RuntimeError(
                f"Node.js exited OK but DOCX was not created.\n"
                f"STDOUT: {result.stdout}"
            )
        docx_bytes = docx_path.read_bytes()
        if len(docx_bytes) < 5000:
            raise RuntimeError(
                f"Generated DOCX is too small ({len(docx_bytes)} bytes)."
            )
        return docx_bytes


