# DETERMINISTIC EXCEL READING + MODE CLASSIFICATION
# These read the workbook directly (no LLM-shape dependency) so unit-composition
# and component-MDD Excels are parsed reliably and product-agnostically.
# ════════════════════════════════════════════════════════════════════════════
_STRENGTH_RE = re.compile(r"^\s*\d+(?:\.\d+)?\s*mg\s*$", re.IGNORECASE)
_AMOUNT_HINTS = ("amount in maximum dose", "amount in max dose", "amount in maximum")
_MDD_HINTS = ("maximum daily intake", "max daily intake", "mdd", "maximum daily dose",
              "daily intake")
_QTY_HINTS = (
    # multi-word patterns FIRST so they win the header hint scan
    "quantity / unit", "quantity/unit", "qty/unit", "quantity per unit",
    "mg / vial", "mg / ml", "mg / tablet", "mg / capsule", "mg / sachet",
    "mg/vial", "mg/ml", "mg/tablet", "mg/capsule", "mg/sachet", "mg/dose",
    "amount per unit", "amount/unit",
    "per unit", "per vial", "per ml", "per tablet", "per capsule", "per sachet",
    "quantity mg", "amount mg", "quantity (", "qty (", "qty.",
    # broad fallbacks – checked last
    "mg/unit", "quantity", "qty ", "amount",
)

# Unit-basis hints — recognised in the qty column header to drive the dose
# basis prompt (mg/Vial, mg/mL, mg/tablet, mg/sachet, mg/dose, mg/capsule).
_UNIT_BASIS_PATTERNS = [
    (re.compile(r"mg\s*[/\(]\s*vial", re.IGNORECASE), "vial"),
    (re.compile(r"mg\s*[/\(]\s*ml", re.IGNORECASE), "ml"),
    (re.compile(r"mg\s*[/\(]\s*tablet", re.IGNORECASE), "tablet"),
    (re.compile(r"mg\s*[/\(]\s*capsule", re.IGNORECASE), "capsule"),
    (re.compile(r"mg\s*[/\(]\s*sachet", re.IGNORECASE), "sachet"),
    (re.compile(r"mg\s*[/\(]\s*dose", re.IGNORECASE), "dose"),
    (re.compile(r"per\s+vial", re.IGNORECASE), "vial"),
    (re.compile(r"per\s+ml", re.IGNORECASE), "ml"),
    (re.compile(r"per\s+tablet", re.IGNORECASE), "tablet"),
    (re.compile(r"per\s+capsule", re.IGNORECASE), "capsule"),
    (re.compile(r"per\s+sachet", re.IGNORECASE), "sachet"),
]


def _infer_unit_basis(header_label: str) -> str:
    if not header_label:
        return "unit"
    for rx, basis in _UNIT_BASIS_PATTERNS:
        if rx.search(header_label):
            return basis
    return "unit"
_COMP_HINTS = ("component", "ingredient", "material", "name of ingredient", "name")
_COMPENDIA_HINTS = ("compendia", "compendial", "status", "grade")
_STAGE_HINTS = ("stage", "step", "process step", "manufacturing stage")
_SOLVENT_HINTS = ("limit (ppm)", "daily exposure", "ppm", "residual solvent")

# Named residual solvents that headline a detailed RS calculation sheet.
_RS_SOLVENT_NAMES = (
    "ethanol", "methanol", "toluene", "acetone", "isopropyl alcohol",
    "iso propyl alcohol", "ethylene glycol", "1,4-dioxane", "1,4 dioxane",
    "heptane", "tert-butyl alcohol", "tertiary butyl alcohol", "t-butyl alcohol",
    "dehydrated alcohol", "dichloromethane", "n-hexane", "hexane",
    "ethyl acetate", "methylene chloride",
)


def _detailed_rs_signatures(sheet: Dict) -> int:
    """Count how many detailed-RS-calculation signatures are present in a sheet.
    Scans the header AND the whole grid (footers included) so signatures such as
    'Drug Product', 'Total Daily Exposure' and 'Residual solvent Limit as per
    current USP <467>' are detected even when they sit in footer rows. A sheet
    with >= 4 signatures is a detailed RS calculation sheet (Type B)."""
    header = sheet.get("header", []) or []
    rows = sheet.get("rows", []) or []
    # Flatten all cell text (header + body) into one lowercased blob.
    cells: List[str] = [_s(h).lower() for h in header]
    for r in rows:
        if isinstance(r, list):
            cells.extend(_s(c).lower() for c in r)
        elif isinstance(r, dict):
            cells.extend(_s(c).lower() for c in r.values())
    blob = " | ".join(cells)

    sig = 0
    # 1. "No. of doses"
    if re.search(r"no\.?\s*of\s*doses", blob):
        sig += 1
    # 2. "Quantity / unit (mg)"
    if any(h in blob for h in ("quantity / unit", "quantity/unit",
                               "quantity per unit", "qty/unit")):
        sig += 1
    # 3. "Amount in Maximum Dose (mg)"
    if any(h in blob for h in _AMOUNT_HINTS):
        sig += 1
    # 4. Named solvent group headers (count as one signature if >= 1 present)
    if any(nm in blob for nm in _RS_SOLVENT_NAMES):
        sig += 1
    # 5. Per-solvent sub-headers "Limit (ppm)" and "Daily Exposure (mg)"
    if "limit (ppm)" in blob or re.search(r"limit\s*\(?\s*ppm", blob):
        sig += 1
    if "daily exposure" in blob:
        sig += 1
    # 6. "Drug Product" footer row
    if "drug product" in blob:
        sig += 1
    # 7. "Total Daily Exposure" footer row
    if "total daily exposure" in blob:
        sig += 1
    # 8. "Residual solvent Limit as per current USP <467>" footer row
    if re.search(r"residual\s+solvent.*usp\s*<?\s*467", blob) or \
       re.search(r"usp\s*<?\s*467", blob):
        sig += 1
    return sig


def read_excel_grid(excel_bytes: bytes, max_rows: int = 400) -> List[Dict]:
    """
    Read every worksheet into a list of {sheet, header, rows} using openpyxl.
    Header = the first row that looks like column labels. Deterministic; no LLM.
    """
    import openpyxl
    from io import BytesIO
    wb = openpyxl.load_workbook(BytesIO(excel_bytes), data_only=True)
    sheets = []
    for ws in wb.worksheets:
        grid = []
        for i, row in enumerate(ws.iter_rows(values_only=True)):
            grid.append(["" if c is None else str(c).strip() for c in row])
            if i > max_rows:
                break
        if not grid:
            continue
        # Find the header row: the row with the most non-empty, text-ish cells
        # that also contains a component-like or strength-like or amount-like label.
        header_idx = 0
        best_score = -1
        for idx in range(min(len(grid), 15)):
            cells = grid[idx]
            nonempty = [c for c in cells if c]
            if not nonempty:
                continue
            low = " | ".join(c.lower() for c in nonempty)
            score = len(nonempty)
            if any(h in low for h in _COMP_HINTS):
                score += 5
            if any(_STRENGTH_RE.match(c) for c in nonempty):
                score += 5
            if any(h in low for h in _AMOUNT_HINTS + _MDD_HINTS):
                score += 4
            if score > best_score:
                best_score = score
                header_idx = idx
        header = grid[header_idx]
        data_rows = grid[header_idx + 1:]
        sheets.append({"sheet": ws.title, "header": header,
                       "rows": data_rows, "header_idx": header_idx,
                       "full_grid": grid})
    wb.close()
    return sheets


def parse_flat_detailed_rs_excel(excel_bytes: bytes) -> Dict:
    """
    Deterministically parse a FLAT single-header detailed RS calculation Excel
    (no LLM). Emits a raw dict compatible with parse_rs_excel(): component rows
    with a 'columns' map, plus footer rows (Drug Product / Total Daily Exposure /
    USP <467> limit) tagged so parse_rs_excel classifies them.

    Handles:
      - a 'No. of doses' cell (row 1) with the numeric value in an adjacent cell
      - a single-row header with 'Components', 'Quantity / unit (mg)',
        'Amount in Maximum Dose (mg)' and per-solvent 'X Limit (ppm)' /
        'X Daily Exposure (mg)' columns
      - solvent columns auto-detected via _RS_SOLVENT_NAMES
      - footer rows via _is_footer_row

    Returns {} (empty) if it cannot find a usable component header + rows, so the
    caller can fall back to the Claude extraction path.
    """
    try:
        import openpyxl
        from io import BytesIO
        wb = openpyxl.load_workbook(BytesIO(excel_bytes), data_only=True)
    except Exception:
        return {}

    best: Dict[str, Any] = {}
    for ws in wb.worksheets:
        grid = []
        for row in ws.iter_rows(values_only=True):
            grid.append(["" if c is None else str(c).strip() for c in row])
        if not grid:
            continue

        # ── Find 'No. of doses' anywhere in the grid ─────────────────────────
        no_of_doses = None
        for r_i, row in enumerate(grid):
            for c_i, cell in enumerate(row):
                if re.search(r"no\.?\s*of\s*doses", cell.lower()):
                    # numeric value in an adjacent cell (right, then below)
                    for (rr, cc) in ((r_i, c_i + 1), (r_i + 1, c_i),
                                     (r_i, c_i + 2)):
                        if rr < len(grid) and cc < len(grid[rr]):
                            v = _num_or_none(grid[rr][cc])
                            if v:
                                no_of_doses = int(v)
                                break
                if no_of_doses:
                    break
            if no_of_doses:
                break

        # ── Find the component header row ────────────────────────────────────
        header_idx = None
        comp_col_idx = None
        for idx in range(min(len(grid), 25)):
            row = grid[idx]
            low = [c.lower() for c in row]
            for ci, c in enumerate(low):
                if any(h == c or h in c for h in ("components", "component",
                                                  "ingredient", "name of ingredient")):
                    comp_col_idx = ci
                    break
            if comp_col_idx is not None:
                # confirm this row also has quantity/amount or a solvent name
                joined = " | ".join(low)
                if (any(h in joined for h in _QTY_HINTS + _AMOUNT_HINTS)
                        or any(nm in joined for nm in _RS_SOLVENT_NAMES)
                        or "ppm" in joined or "daily exposure" in joined):
                    header_idx = idx
                    break
                comp_col_idx = None
        if header_idx is None:
            continue

        header = grid[header_idx]
        # Some detailed sheets use TWO header rows (solvent name on row N,
        # 'Limit (ppm)'/'Daily Exposure (mg)' on row N+1). Merge them so each
        # column has a full 'Ethanol Limit (ppm)' style label.
        merged_header = list(header)
        if header_idx + 1 < len(grid):
            sub = grid[header_idx + 1]
            sub_low = " | ".join(s.lower() for s in sub)
            if ("limit" in sub_low and "ppm" in sub_low) or "daily exposure" in sub_low:
                # carry the last seen solvent/group label forward across blanks
                last_group = ""
                combined = []
                for i in range(max(len(header), len(sub))):
                    top = header[i] if i < len(header) else ""
                    bot = sub[i] if i < len(sub) else ""
                    if top:
                        last_group = top
                    label = (f"{last_group} {bot}".strip() if bot else top or last_group)
                    combined.append(label.strip())
                merged_header = combined
                data_start = header_idx + 2
            else:
                data_start = header_idx + 1
        else:
            data_start = header_idx + 1

        # ── Detect solvent columns via _RS_SOLVENT_NAMES ─────────────────────
        solvents: List[str] = []
        for h in merged_header:
            hl = h.lower()
            for nm in _RS_SOLVENT_NAMES:
                if nm in hl:
                    # display name = the solvent portion (strip role words)
                    disp = re.sub(r"\b(limit|ppm|daily|exposure|mg|\(.*?\))\b", " ", h,
                                  flags=re.IGNORECASE)
                    disp = re.sub(r"[^A-Za-z0-9,\- ]+", " ", disp)
                    disp = re.sub(r"\s+", " ", disp).strip()
                    if disp and disp not in solvents:
                        solvents.append(disp)
                    break

        # locate quantity / amount columns
        def _find_col(hints):
            for i, h in enumerate(merged_header):
                if any(hint in h.lower() for hint in hints):
                    return i, merged_header[i]
            return None, ""
        _qi, quantity_col = _find_col(_QTY_HINTS)
        _ai, amount_col = _find_col(_AMOUNT_HINTS)
        component_col = merged_header[comp_col_idx] if comp_col_idx < len(merged_header) else "Components"

        # ── Build rows (component + footer) as {columns:{label:value}} ───────
        out_rows: List[Dict] = []
        for r in grid[data_start:]:
            if comp_col_idx >= len(r):
                continue
            name = _s(r[comp_col_idx])
            if not name:
                # a row with values but no name in the component column is skipped
                if not any(_s(x) for x in r):
                    continue
            cols_map = {}
            for i, label in enumerate(merged_header):
                if not label:
                    continue
                val = _s(r[i]) if i < len(r) else ""
                cols_map[label] = val
            # ensure the component label carries the name
            if component_col:
                cols_map[component_col] = name
            out_rows.append({"columns": cols_map})

        if not out_rows or not solvents:
            continue

        raw = {
            "no_of_doses": no_of_doses,
            "component_col": component_col or "Components",
            "quantity_col": quantity_col,
            "amount_col": amount_col,
            "solvents": solvents,
            "columns": [h for h in merged_header if h],
            "has_calculated_values": True,
            "rows": out_rows,
            "_parser": "flat_deterministic",
        }
        # Prefer the sheet with the most component rows / solvents
        if (not best) or (len(out_rows) > len(best.get("rows", []))):
            best = raw

    wb.close()
    return best


def _col_index(header: List[str], hints: Tuple[str, ...]) -> Optional[int]:
    """Return the index of the first header cell matching any hint.

    Hints are scanned in ORDER, so earlier hints win. When matching the generic
    'material' hint, cells with 'code'/'no.' are skipped so a 'Material code'
    column never masquerades as the component (ingredient) column.
    """
    for hint in hints:
        for i, h in enumerate(header):
            hl = h.lower().strip()
            if hint == "material" and any(
                    bad in hl for bad in ("code", "no.", "no ", "no.")):
                continue
            if hint in hl:
                return i
    return None


def _strength_columns(header: List[str]) -> List[Tuple[int, str, float]]:
    """Return [(col_index, label, mg_value)] for every strength column like '40 mg'."""
    out = []
    for i, h in enumerate(header):
        if _STRENGTH_RE.match(h or ""):
            m = re.search(r"\d+(?:\.\d+)?", h)
            if m:
                out.append((i, h.strip(), float(m.group(0))))
    return out


# Instruction / notes / guidance tabs must never be classified as a calculation
# sheet — their prose contains RS keywords that falsely trip signatures (RF7a).
_INSTRUCTION_SHEET_TOKENS = (
    "instruction", "instructions", "note", "notes", "readme", "read me",
    "help", "guide", "guidance", "manual", "info", "information", "legend",
    "key", "cover", "index", "how to use", "definitions", "glossary",
)


def _is_instruction_sheet(sh: Dict) -> bool:
    """True for an instructions/notes/guidance tab, or any sheet dominated by
    long free-text prose cells (>80 chars, more than 3 of them)."""
    name = _s(sh.get("sheet")).lower().strip()
    name_tokens = set(re.split(r"[\s_\-]+", name))
    for tok in _INSTRUCTION_SHEET_TOKENS:
        if name == tok or tok in name_tokens or name.startswith(tok + " "):
            return True
    header = sh.get("header", []) or []
    rows = sh.get("rows", []) or []
    cells: List[str] = list(header)
    for r in rows:
        if isinstance(r, list):
            cells.extend(r)
        elif isinstance(r, dict):
            cells.extend(r.values())
    long_cells = sum(1 for c in cells if len(_s(c)) > 80)
    return long_cells > 3


def classify_rs_excel(excel_bytes: bytes) -> Dict:
    """
    Classify the Excel into one of:
      - detailed_rs_calculation
      - unit_composition_strength_columns
      - combined_workbook         (a unit-composition sheet AND a detailed sheet)
      - component_mdd_only
      - insufficient_material_names_only
    Returns a dict with mode, the chosen sheet, detected columns, and strengths.
    Deterministic and product-agnostic.
    """
    sheets = read_excel_grid(excel_bytes)
    if not sheets:
        return {"mode": "insufficient_material_names_only", "reason": "empty workbook",
                "sheets": []}

    # Classify each sheet's role independently first.
    sheet_roles = []        # (role, info)
    detailed_candidates = []   # RF7a: choose the highest-signature detailed sheet
    detailed_info = None
    unit_info = None
    mdd_info = None
    single_info = None
    for sh in sheets:
        # RF7a: never classify an instructions / notes / prose sheet.
        if _is_instruction_sheet(sh):
            continue
        header = sh["header"]
        low_join = " | ".join(h.lower() for h in header)
        has_solvent = any(h in low_join for h in _SOLVENT_HINTS)
        has_amount = _col_index(header, _AMOUNT_HINTS) is not None
        has_mdd = _col_index(header, _MDD_HINTS) is not None
        qty_idx = _col_index(header, _QTY_HINTS)
        has_qty = qty_idx is not None
        strengths = _strength_columns(header)
        comp_idx = _col_index(header, _COMP_HINTS)

        info = {
            "sheet": sh["sheet"], "header": header, "rows": sh["rows"],
            "comp_idx": comp_idx, "has_solvent": has_solvent,
            "has_amount": has_amount, "has_mdd": has_mdd, "has_qty": has_qty,
            "qty_idx": qty_idx, "strengths": strengths,
        }

        # Type B (detailed RS calculation) is detected FIRST, via a robust
        # signature count that scans header + footers. >= 4 signatures ⇒ detailed.
        # This ensures a complete pre-computed Excel is never misread as a unit-
        # composition sheet (which would wrongly prompt for MDD / strength).
        n_sig = _detailed_rs_signatures(sh)
        info["detailed_signatures"] = n_sig
        if n_sig >= 4:
            info["mode"] = "detailed_rs_calculation"
            sheet_roles.append(("detailed", info))
            detailed_candidates.append(info)
        elif has_solvent and (has_amount or has_qty):
            info["mode"] = "detailed_rs_calculation"
            sheet_roles.append(("detailed", info))
            detailed_candidates.append(info)
        elif strengths and comp_idx is not None and not has_amount and not has_mdd:
            info["mode"] = "unit_composition_strength_columns"
            sheet_roles.append(("unit", info))
            unit_info = unit_info or info
        elif (has_amount or has_mdd) and comp_idx is not None:
            info["mode"] = "component_mdd_only"
            sheet_roles.append(("mdd", info))
            mdd_info = mdd_info or info
        elif (has_qty and comp_idx is not None and not strengths
              and not has_solvent):
            # Single-strength unit composition: one quantity column with a
            # unit basis (mg/vial, mg/mL, mg/tablet, mg/sachet, mg/dose).
            info["mode"] = "single_strength_unit_composition"
            info["unit_basis"] = _infer_unit_basis(
                header[qty_idx] if qty_idx is not None and qty_idx < len(header) else "")
            info["qty_col_label"] = (header[qty_idx] if qty_idx is not None
                                     and qty_idx < len(header) else "")
            sheet_roles.append(("single", info))
            single_info = single_info or info
        else:
            info["mode"] = "insufficient_material_names_only"
            sheet_roles.append(("insufficient", info))

    # RF7a: among all detailed candidates, keep the one with the most signatures
    # (a full calculation sheet beats a thin one that merely mentions a solvent).
    if detailed_candidates:
        detailed_info = max(detailed_candidates,
                            key=lambda i: i.get("detailed_signatures", 0))

    # Combined workbook: BOTH a unit-composition sheet AND a detailed sheet exist.
    if unit_info is not None and detailed_info is not None:
        return {"mode": "combined_workbook",
                "sheet": unit_info["sheet"],
                "unit_sheet": unit_info, "detailed_sheet": detailed_info,
                "header": unit_info["header"], "rows": unit_info["rows"],
                "comp_idx": unit_info["comp_idx"], "strengths": unit_info["strengths"],
                "sheets": sheets}

    # Single-role priority: detailed > unit > mdd > single > insufficient
    if detailed_info is not None:
        return {**detailed_info, "sheets": sheets}
    if unit_info is not None:
        return {**unit_info, "sheets": sheets}
    if mdd_info is not None:
        return {**mdd_info, "sheets": sheets}
    if single_info is not None:
        return {**single_info, "sheets": sheets}
    return {"mode": "insufficient_material_names_only",
            **(sheet_roles[0][1] if sheet_roles else {}), "sheets": sheets,
            "mode_override": "insufficient_material_names_only"}


def _clean_num(v: Any) -> Optional[float]:
    return _num_or_none(v)


def parse_unit_composition_excel(classified: Dict, mdd_mg_day: float,
                                 selected_strength: Optional[float] = None) -> Dict:
    """
    Mode B parser. Strength-column unit composition:
        Ingredient | Compendia Status | 40 mg | 20 mg | 10 mg | Stage
    Auto-selects the MAX strength column (unless one is passed), derives
    no_of_doses = MDD / selected_strength, and computes
        amount_in_maximum_dose_mg = quantity_per_unit(max strength) × no_of_doses.
    Duplicate components across stages are aggregated for the quantitative total
    while stage rows are preserved for display.
    """
    header = classified["header"]
    rows = classified["rows"]
    comp_idx = classified.get("comp_idx")
    strengths = classified.get("strengths", [])
    compendia_idx = _col_index(header, _COMPENDIA_HINTS)
    stage_idx = _col_index(header, _STAGE_HINTS)

    if comp_idx is None or not strengths:
        return {"mode": "unit_composition_strength_columns", "rows": [],
                "needs_dose_basis": True, "error": "missing component or strength columns"}

    # Select max strength
    if selected_strength is None:
        sel = max(strengths, key=lambda x: x[2])
    else:
        sel = min(strengths, key=lambda x: abs(x[2] - selected_strength))
    sel_idx, sel_label, sel_mg = sel

    no_of_doses = None
    if mdd_mg_day and sel_mg > 0:
        no_of_doses = mdd_mg_day / sel_mg

    # Build display columns (verbatim) and quantitative aggregation
    display_columns = [header[comp_idx]]
    if compendia_idx is not None:
        display_columns.append(header[compendia_idx])
    display_columns += [lbl for (_i, lbl, _mg) in strengths]
    if stage_idx is not None:
        display_columns.append(header[stage_idx])

    display_rows: List[Dict] = []
    agg: Dict[str, Dict] = {}    # component -> aggregated quantity at selected strength
    order: List[str] = []

    for r in rows:
        if comp_idx >= len(r):
            continue
        name = _s(r[comp_idx])
        if not name:
            continue
        # Display row (verbatim)
        disp = {header[comp_idx]: name}
        if compendia_idx is not None and compendia_idx < len(r):
            disp[header[compendia_idx]] = _s(r[compendia_idx])
        for (si, lbl, _mg) in strengths:
            disp[lbl] = _s(r[si]) if si < len(r) else ""
        if stage_idx is not None and stage_idx < len(r):
            disp[header[stage_idx]] = _s(r[stage_idx])
        display_rows.append({"ingredient": name, "columns": disp})

        is_qs = any(h in name.lower() for h in _QS_HINTS)
        # Enhanced q.s. detection: ingredient hints (@ suffix, gases, process
        # aids) and non-numeric quantity cells are also q.s. rows.
        if _is_qs_ingredient(name):
            is_qs = True
        sel_cell_val = _s(r[sel_idx]) if sel_idx < len(r) else ""
        if _is_qs_quantity(sel_cell_val):
            is_qs = True
        qty = _clean_num(_strip_footnote_markers(sel_cell_val)) if sel_idx < len(r) else None

        key = name.strip().lower()
        if key not in agg:
            agg[key] = {"component": name, "qty_per_unit": 0.0, "_is_qs": is_qs,
                        "had_qty": False}
            order.append(key)
        if qty is not None:
            agg[key]["qty_per_unit"] += qty
            agg[key]["had_qty"] = True
        if is_qs:
            agg[key]["_is_qs"] = True

    comp_rows: List[Dict] = []
    for key in order:
        a = agg[key]
        qty_unit = a["qty_per_unit"] if a["had_qty"] else None
        amount_mg = None
        basis = "none"
        if (not a["_is_qs"]) and qty_unit is not None and no_of_doses:
            amount_mg = round(qty_unit * no_of_doses, 6)
            basis = "max_strength_column_times_derived_doses"
        comp_rows.append({
            "component": a["component"],
            "quantity": round(qty_unit, 6) if qty_unit is not None else None,
            "amount_in_maximum_dose_mg": amount_mg,
            "amount_basis": basis,
            "_is_qs": a["_is_qs"],
            "solvents": {},          # no Excel solvent columns in this mode
            "columns": {},
        })

    needs_dose_basis = any((not c["_is_qs"]) and c["amount_in_maximum_dose_mg"] is None
                           for c in comp_rows)
    product_mdd = round(mdd_mg_day, 6) if mdd_mg_day else None

    return {
        "mode": "unit_composition_strength_columns",
        "no_of_doses": no_of_doses,
        "selected_strength_mg": sel_mg,
        "selected_strength_label": sel_label,
        "detected_strengths": [(lbl, mg) for (_i, lbl, mg) in strengths],
        "component_col": header[comp_idx],
        "quantity_col": "Quantity / unit (mg)",
        "amount_col": "Amount in Maximum Dose (mg)",
        "mdi_col": "", "mdi_unit": "",
        "columns": ["Components", "Quantity / unit (mg)", "Amount in Maximum Dose (mg)"],
        "solvents_display": [],
        "solvent_canon": {},
        "rows": comp_rows,
        "footer_total": {}, "footer_limit": {}, "drug_product_row": {},
        "has_calculated_values": False,
        "needs_dose_basis": needs_dose_basis,
        "product_mdd_mg": product_mdd,
        "mdd_source": "user_mdd_over_max_strength",
        "_display_columns": display_columns,
        "_display_sections": [{"name": "Composition", "rows": display_rows}],
        "audit": {"selected_strength": sel_label, "no_of_doses": no_of_doses,
                  "mdd_mg_day": mdd_mg_day},
        "warnings": [],
    }


_QS_QUANTITY_STRINGS = {"", "-", "n/a", "na", "tbd", "q.s", "qs", "q s", "qs to",
                        "q.s.", "qsto", "q s to", "as required", "adjust ph"}
_QS_INGREDIENT_HINTS = ("nitrogen", "n2", "argon", "process aid", "process-aid",
                        "processing aid", "sparging gas")

_FOOTNOTE_MARKER_RE = re.compile(r"[\*#†‡§¶\^]+")


def _strip_footnote_markers(s: str) -> str:
    """Remove trailing footnote markers ('349*', '5.25#', '†', '‡', '§') so the
    numeric parse succeeds. Non-marker characters are preserved."""
    if not s:
        return s
    return _FOOTNOTE_MARKER_RE.sub("", s).strip()


# RS Bug 2: salt-form APIs carry an asterisk footnote reconciling the formulation
# (salt) weight with the label (free-base) strength, e.g. Trilaciclib 2HCl
# "349 mg dihydrochloride ≡ 300 mg base". The dose multiplier must use the BASE
# weight (432/300 = 1.44), NOT the salt weight (432/349 = 1.238). A different
# asterisk footnote encodes an OVERAGE ("10% overage") and is handled separately
# (multiplier uses the nominal strength). This parser classifies + extracts both.
_SALT_WORDS = (
    "2hcl", "3hcl", "hcl", "dihydrochloride", "trihydrochloride", "hydrochloride",
    "hydrobromide", "hbr", "sulfate", "sulphate", "bisulfate", "hemisulfate",
    "tartrate", "bitartrate", "mesylate", "methanesulfonate", "tosylate",
    "tosilate", "besylate", "besilate", "phosphate", "diphosphate", "maleate",
    "fumarate", "succinate", "acetate", "citrate", "sodium", "potassium",
    "calcium", "magnesium", "hydrate", "monohydrate", "dihydrate", "trihydrate",
    "salt",
)
_OVERAGE_RE_A = re.compile(r"(\d+(?:\.\d+)?)\s*%\s*(?:w\s*/?\s*w\s*)?over\s*age", re.I)
_OVERAGE_RE_B = re.compile(r"over\s*age\D{0,15}?(\d+(?:\.\d+)?)\s*%", re.I)
_MG_NUM_RE = re.compile(r"(\d+(?:\.\d+)?)\s*mg\b", re.I)
_BASE_CTX_RE = re.compile(r"\b(?:free[\s-]*)?base\b", re.I)


def parse_salt_base_footnote(text: str) -> Optional[Dict]:
    """Classify an asterisk footnote and extract its conversion (RS Bug 2).

    Returns None when nothing salt/base/overage is recognised, else a dict:
      kind='overage'   → {'overage_pct': fraction, 'salt_factor': 1.0}
      kind='salt_base' → {'salt_weight', 'base_weight',
                          'salt_factor'=salt/base (>1), 'overage_pct': 0.0}
    The multiplier is later computed as MDD × salt_factor / api_qty, so a
    free-base MDD applied to a salt formulation weight yields MDD / base_weight
    (Trilaciclib: 432 × (349/300) / 349 = 1.44)."""
    t = _s(text)
    if not t:
        return None
    # Replace footnote markers (*, #, †…) with a space so a glued '349* mg'
    # still parses; '=' and '≡' connectives are preserved (not markers).
    low = _FOOTNOTE_MARKER_RE.sub(" ", t.lower())

    # Overage first (distinct footnote content; must not be read as salt/base).
    om = _OVERAGE_RE_A.search(low) or _OVERAGE_RE_B.search(low)
    if om:
        try:
            pct = float(om.group(1))
        except (TypeError, ValueError):
            pct = 0.0
        return {"kind": "overage", "overage_pct": pct / 100.0, "salt_factor": 1.0,
                "salt_weight": None, "base_weight": None, "raw": t}

    has_salt = any(w in low for w in _SALT_WORDS)
    has_base = bool(_BASE_CTX_RE.search(low))
    equiv = bool(re.search(
        r"equivalent|equals?|corresponds?|is\s+equal|provid|deliver|contain|[=≡]",
        low))
    if not (equiv and (has_base or has_salt)):
        return None

    nums = [(float(m.group(1)), m.start(), m.end()) for m in _MG_NUM_RE.finditer(low)]
    if len(nums) < 2:
        return None

    # base = the mg-number sitting CLOSEST *before* a "base" token (e.g. the 300
    # in "…= 300 mg base"). Picking the nearest preceding number avoids a greedy
    # window tagging the leading salt weight as the base on short strings.
    base_val = None
    best_gap = 26                      # cap: ignore far-away "base" mentions
    for bm in _BASE_CTX_RE.finditer(low):
        bpos = bm.start()
        for val, _s0, e in nums:
            if e <= bpos and (bpos - e) < best_gap:
                base_val, best_gap = val, (bpos - e)
    salt_val = None
    if base_val is not None:
        others = [v for v, _s0, _e in nums if v != base_val]
        if others:
            salt_val = max(others)     # the salt is the heavier partner
    if base_val is None or salt_val is None:
        # Fallback: two distinct weights → salt is heavier, base is lighter.
        vals = sorted({v for v, _s0, _e in nums}, reverse=True)
        if len(vals) >= 2:
            salt_val, base_val = vals[0], vals[1]

    if not salt_val or not base_val or base_val <= 0 or salt_val < base_val:
        return None
    return {"kind": "salt_base", "salt_weight": salt_val, "base_weight": base_val,
            "salt_factor": round(salt_val / base_val, 6), "overage_pct": 0.0, "raw": t}


_SALT_EQUIV_CUE_RE = re.compile(
    r"equivalent|equals?|corresponds?|as\s+(?:the\s+)?(?:free\s+)?base|"
    r"provid\w*|calculated\s+as|expressed\s+as", re.IGNORECASE)


def _footnote_base_weight(text: str) -> Optional[float]:
    """Extract the free-BASE weight (mg) from a salt/base footnote that may carry
    ONLY the base number — the salt weight then lives in the API Qty cell (the
    common Trilaciclib format: Qty '349*' + footnote '* equivalent to 300 mg
    base'). Returns the base mg value, or None. Requires both a base cue and a
    salt/equivalence cue so plain excipient masses never match."""
    t = _s(text)
    if not t:
        return None
    low = _FOOTNOTE_MARKER_RE.sub(" ", t.lower())
    if not _BASE_CTX_RE.search(low):
        return None
    if not (_SALT_EQUIV_CUE_RE.search(low) or any(w in low for w in _SALT_WORDS)):
        return None
    nums = [(float(m.group(1)), m.start(), m.end()) for m in _MG_NUM_RE.finditer(low)]
    if not nums:
        return None
    # base = the mg-number sitting CLOSEST before a 'base' token.
    base_val = None
    best_gap = 40
    for bm in _BASE_CTX_RE.finditer(low):
        bpos = bm.start()
        for val, _s0, e in nums:
            if e <= bpos and (bpos - e) < best_gap:
                base_val, best_gap = val, (bpos - e)
    if base_val is None:
        # 'base' present but not adjacent to a number → take the value right after
        # an equivalence cue ("equivalent to 300 mg", "as 300 mg").
        m = re.search(r"(?:equivalent to|equals?|as|corresponds? to|provid\w*|"
                      r"calculated as|expressed as)\D{0,14}(\d+(?:\.\d+)?)\s*mg", low)
        if m:
            base_val = float(m.group(1))
    return base_val


def _iter_classified_cells(cls: Dict):
    """Yield every non-empty cell string across a classified Excel (all sheets +
    the chosen sheet's rows/header), so a footnote below the composition table is
    reachable regardless of which sheet it sits on."""
    seen_ids = set()
    def _emit_rows(header, rows):
        for cell in (header or []):
            s = _s(cell)
            if s:
                yield s
        for r in (rows or []):
            for cell in (r or []):
                s = _s(cell)
                if s:
                    yield s
    for sh in (cls.get("sheets") or []):
        if not isinstance(sh, dict):
            continue
        seen_ids.add(id(sh.get("rows")))
        yield from _emit_rows(sh.get("header"), sh.get("rows"))
    # The chosen sheet's rows may be a distinct list (unit/detailed info copy).
    if id(cls.get("rows")) not in seen_ids:
        yield from _emit_rows(cls.get("header"), cls.get("rows"))


def detect_salt_base_from_classified(cls: Dict) -> Optional[Dict]:
    """Scan a classified Excel for an asterisk salt/base (or overage) footnote and
    return the parsed conversion (RS Bug 2), else None. A salt/base match wins
    over an overage match. Product-agnostic — any salt-form API footnote resolves
    the same way (Trilaciclib 2HCl 349 mg ≡ 300 mg base → salt_factor 1.1633)."""
    if not isinstance(cls, dict):
        return None
    overage_hit = None
    for cell in _iter_classified_cells(cls):
        low = cell.lower()
        # Cheap pre-filter: only parse cells that look like a conversion/overage
        # footnote (must mention mg + a salt/base cue, or an overage percentage).
        looks_saltbase = ("mg" in low and ("base" in low
                          or any(w in low for w in _SALT_WORDS)))
        looks_overage = "overage" in low
        if not (looks_saltbase or looks_overage):
            continue
        r = parse_salt_base_footnote(cell)
        if not r:
            continue
        if r["kind"] == "salt_base":
            return r
        if r["kind"] == "overage" and overage_hit is None:
            overage_hit = r

    # Fallback: a footnote that gives ONLY the base weight ("* equivalent to 300 mg
    # base") while the salt weight sits in a marked Qty cell ("349*"). Pair the
    # base number with the largest marked quantity above it (RS Bug 2 — real
    # Trilaciclib format that the two-number parser above misses).
    base_w = None
    for cell in _iter_classified_cells(cls):
        bw = _footnote_base_weight(cell)
        if bw:
            base_w = bw
            break
    if base_w:
        salt_w = None
        for cell in _iter_classified_cells(cls):
            if _FOOTNOTE_MARKER_RE.search(cell):
                n = _num_or_none(_strip_footnote_markers(cell))
                if n and n > base_w and (salt_w is None or n > salt_w):
                    salt_w = n
        if salt_w:
            return {"kind": "salt_base", "salt_weight": salt_w, "base_weight": base_w,
                    "salt_factor": round(salt_w / base_w, 6), "overage_pct": 0.0,
                    "raw": f"{salt_w:g} mg salt equivalent to {base_w:g} mg base"}
    return overage_hit


def _is_qs_ingredient(name: str) -> bool:
    """Return True when the ingredient name signals q.s. handling.
    Product-agnostic: '@' suffix, gases, process aids."""
    s = _s(name).lower().strip()
    if not s:
        return False
    if s.endswith("@") or s.rstrip().endswith("@"):
        return True
    for hint in _QS_INGREDIENT_HINTS:
        if hint in s:
            return True
    return False


def _is_qs_quantity(cell_value: str) -> bool:
    """Enhanced q.s. quantity detection. Handles textual markers and any value
    that cannot be numerically parsed after footnote stripping."""
    if cell_value is None:
        return True
    s = _s(cell_value).lower().strip()
    if not s:
        return True
    s_norm = re.sub(r"[^a-z0-9 ]+", "", s).strip()
    if s_norm in _QS_QUANTITY_STRINGS or s in _QS_QUANTITY_STRINGS:
        return True
    if _is_qs_value(s):
        return True
    # If numeric extraction after footnote stripping fails, treat as q.s.
    cleaned = _strip_footnote_markers(_s(cell_value))
    if _num_or_none(cleaned) is None:
        # If the raw cell has NO digits at all, it's q.s.-like text
        if not re.search(r"\d", cleaned):
            return True
    return False


_API_FUNC_RE = re.compile(r"active|drug\s+substance|\bapi\b|a\.?p\.?i\.?",
                          re.IGNORECASE)
_DOSAGE_BY_BASIS = {
    # RS Bug 6a: a mg/mL basis defaults to "Injection" (user may override to an
    # oral solution/suspension in the UI).
    "vial": "Sterile Injection", "ml": "Injection",
    "tablet": "Tablet", "capsule": "Capsule", "sachet": "Oral Suspension",
    "dose": "", "unit": "",
}


def parse_single_strength_unit_composition(classified: Dict,
                                           mdd_mg_day: Optional[float] = None,
                                           unit_basis: Optional[str] = None,
                                           salt_factor: float = 1.0,
                                           density_g_per_ml: float = 1.0,
                                           api_component: Optional[str] = None,
                                           no_of_doses: Optional[int] = None,
                                           dose_volume_ml: Optional[float] = None,
                                           overage_pct: float = 0.0) -> Dict:
    """Single-strength unit composition parser (RS RF1).

    Composition has ONE quantity column with a unit basis (mg/vial, mg/mL,
    mg/tablet, mg/sachet, mg/dose). The API row is auto-detected (its
    Function/Role cell reads Active / API / Drug Substance, else the first
    non-q.s. numeric row) and its per-unit quantity yields the dose multiplier.

    Solids (mg/vial, mg/tablet, …): the user supplies the API's Maximum Daily
    Dose (MDD, mg/day) and

        multiplier               = MDD_mg_day × salt_factor / api_qty_per_unit

    Volume-dosed liquids (mg/mL basis — RS Bug 1): the user supplies the daily
    dose VOLUME (mL/day) and the multiplier IS that volume directly — it is not
    derived from MDD ÷ strength, so a formulation strength that bakes in an API
    overage (e.g. 1.1 mg/mL for a 1 mg/mL label with 10% overage) does not skew
    the dose. In both cases:

        amount_in_maximum_dose_mg[i] = quantity_per_unit[i] × multiplier

    overage_pct (0.0 = none) only affects the DISPLAYED label strength (RS Bug
    6b): effective strength = api_qty / (1 + overage_pct); component amounts keep
    using the formulation strength as printed in the composition.

    salt_factor (default 1.0) reconciles a salt composition with a free-base MDD
    label. Drug-product mass: liquids use multiplier × 1000 × density (no summing
    of dissolved solids); solids sum the non-q.s. component amounts. A legacy
    no_of_doses path is retained only when MDD/volume are not supplied.
    """
    header = classified["header"]
    rows = classified["rows"]
    comp_idx = classified.get("comp_idx")
    qty_idx = classified.get("qty_idx")
    if qty_idx is None:
        qty_idx = _col_index(header, _QTY_HINTS)
    unit_basis = unit_basis or classified.get("unit_basis") or "unit"
    salt_factor = float(salt_factor) if salt_factor else 1.0
    density_g_per_ml = float(density_g_per_ml) if density_g_per_ml else 1.0
    overage_pct = float(overage_pct) if overage_pct else 0.0
    dose_volume_ml = float(dose_volume_ml) if dose_volume_ml else None
    is_liquid = unit_basis == "ml"

    if comp_idx is None or qty_idx is None:
        return {"mode": "single_strength_unit_composition", "rows": [],
                "needs_dose_basis": True,
                "error": "missing component or quantity column"}

    # Optional display columns
    matcode_idx = _col_index(header, ("material code", "mat code", "material_code",
                                      "sap code", "sap_code"))
    func_idx = _col_index(header, ("function", "role", "category"))
    stage_idx = _col_index(header, _STAGE_HINTS)
    compendia_idx = _col_index(header, _COMPENDIA_HINTS)

    qty_label = header[qty_idx]
    comp_label = header[comp_idx]

    display_columns = []
    if matcode_idx is not None:
        display_columns.append(header[matcode_idx])
    display_columns.append(comp_label)
    if func_idx is not None:
        display_columns.append(header[func_idx])
    if compendia_idx is not None:
        display_columns.append(header[compendia_idx])
    display_columns.append(qty_label)
    if stage_idx is not None:
        display_columns.append(header[stage_idx])

    # ── Pre-scan: locate the API row + its per-unit quantity ──────────────────
    prescan: List[Tuple[str, Optional[float], bool, str]] = []
    for r in rows:
        if comp_idx >= len(r):
            continue
        nm_raw = _s(r[comp_idx])
        if not nm_raw or _is_footer_row(nm_raw):
            continue
        nm = re.sub(r"\s*@\s*$", "", nm_raw).strip()
        raw_q = _s(r[qty_idx]) if qty_idx < len(r) else ""
        isqs = _is_qs_ingredient(nm_raw) or _is_qs_quantity(raw_q)
        q = _num_or_none(_strip_footnote_markers(raw_q)) if not isqs else None
        fv = _s(r[func_idx]) if (func_idx is not None and func_idx < len(r)) else ""
        prescan.append((nm, q, isqs, fv))

    api_name, api_qty = "", None
    if api_component:                       # explicit user/caller choice
        for nm, q, isqs, fv in prescan:
            if q and _rs_norm(nm) == _rs_norm(api_component):
                api_name, api_qty = nm, q
                break
    if api_qty is None and func_idx is not None:   # Function/Role = Active/API
        for nm, q, isqs, fv in prescan:
            if q and _API_FUNC_RE.search(fv):
                api_name, api_qty = nm, q
                break
    if api_qty is None:                     # fallback: first non-q.s. numeric row
        for nm, q, isqs, fv in prescan:
            if (not isqs) and q:
                api_name, api_qty = nm, q
                break

    # RS Bug 2: auto-reconcile a salt-form API with a free-base MDD label. When the
    # caller did not pass a salt factor, derive it from a base-equivalent asterisk
    # footnote: salt_factor = api_qty(salt) / base_weight. This covers the common
    # Trilaciclib format where the footnote gives only the base weight ("* 349 mg
    # dihydrochloride equivalent to 300 mg base" OR just "* equivalent to 300 mg
    # base") and the salt weight (349) is the API's Qty cell. Without this the
    # multiplier wrongly used the salt weight (432/349 = 1.238 instead of 1.44).
    salt_auto_applied = False
    if abs(salt_factor - 1.0) < 1e-9 and api_qty and api_qty > 0:
        for cell in _iter_classified_cells(classified):
            bw = _footnote_base_weight(cell)
            if bw and 0 < bw < api_qty:
                salt_factor = round(api_qty / bw, 6)
                salt_auto_applied = True
                break

    # ── Dose multiplier ───────────────────────────────────────────────────────
    # Volume-dosed liquids (RS Bug 1): the daily dose is a VOLUME (mL/day); the
    # multiplier IS that volume — never MDD ÷ strength — so an API overage baked
    # into the mg/mL strength does not inflate it.
    # Solids (RF2): multiplier = MDD × salt × (1 + overage) / api_qty. When the
    # solid strength is inclusive of a manufacturing overage, the number of units
    # per day = MDD_label ÷ effective_strength = MDD ÷ (api_qty / (1+overage)).
    # overage_pct = 0 (default) leaves the classic MDD ÷ api_qty behaviour intact
    # (no regression for Esomeprazole / Trilaciclib).
    if is_liquid and dose_volume_ml and dose_volume_ml > 0:
        multiplier = float(dose_volume_ml)
        mult_basis = "dose_volume_ml"
    elif mdd_mg_day and api_qty and api_qty > 0:
        multiplier = (float(mdd_mg_day) * salt_factor * (1.0 + overage_pct)) / float(api_qty)
        mult_basis = "mdd_over_api_qty"
    elif no_of_doses:
        multiplier = float(no_of_doses)
        mult_basis = "no_of_doses_legacy"
    else:
        multiplier = 1.0
        mult_basis = "default_multiplier_1"

    comp_rows: List[Dict] = []
    display_rows: List[Dict] = []
    for r in rows:
        if comp_idx >= len(r):
            continue
        name_raw = _s(r[comp_idx])
        if not name_raw:
            continue
        # Skip Total / Drug Product / Limit footer rows
        if _is_footer_row(name_raw):
            continue

        # display name: strip trailing '@' so the report reads cleanly
        name = re.sub(r"\s*@\s*$", "", name_raw).strip()

        # q.s. determination — name/quantity/ingredient hints
        raw_qty_cell = _s(r[qty_idx]) if qty_idx < len(r) else ""
        is_qs = (_is_qs_ingredient(name_raw)
                 or _is_qs_quantity(raw_qty_cell))

        cleaned_qty = _strip_footnote_markers(raw_qty_cell)
        qty = _num_or_none(cleaned_qty) if not is_qs else None

        amount_mg = None
        basis = "qs"
        if not is_qs and qty is not None and qty > 0:
            amount_mg = round(qty * multiplier, 6)
            basis = f"qty_times_multiplier_per_{unit_basis}"

        row_cols = {}
        if matcode_idx is not None and matcode_idx < len(r):
            mc = _s(r[matcode_idx])
            row_cols[header[matcode_idx]] = "" if mc in ("-", "—") else mc
        row_cols[comp_label] = name
        if func_idx is not None and func_idx < len(r):
            row_cols[header[func_idx]] = _s(r[func_idx])
        if compendia_idx is not None and compendia_idx < len(r):
            row_cols[header[compendia_idx]] = _s(r[compendia_idx])
        row_cols[qty_label] = raw_qty_cell
        if stage_idx is not None and stage_idx < len(r):
            row_cols[header[stage_idx]] = _s(r[stage_idx])

        comp_rows.append({
            "component": name,
            "quantity": qty if qty is not None else None,
            "amount_in_maximum_dose_mg": amount_mg,
            "amount_basis": basis,
            "_is_qs": is_qs,
            "solvents": {},
            "columns": row_cols,
        })
        display_rows.append({"ingredient": name, "columns": row_cols})

    known = [c["amount_in_maximum_dose_mg"] for c in comp_rows
             if (not c["_is_qs"]) and c["amount_in_maximum_dose_mg"] is not None]
    solid_mass = round(sum(known), 6) if known else None
    needs_dose_basis = any((not c["_is_qs"])
                           and c["amount_in_maximum_dose_mg"] is None
                           for c in comp_rows)

    # Drug-product mass per daily dose. Liquids (mL basis): the daily dose is a
    # VOLUME — mass = multiplier(mL/day) × 1000 × density; never sum dissolved
    # solids. Solids: sum of the non-q.s. component amounts. (is_liquid computed
    # once, up front.)
    if is_liquid:
        drug_product_mass_mg = round(multiplier * 1000.0 * density_g_per_ml, 6)
    else:
        drug_product_mass_mg = solid_mass
    # The API's own amount in the maximum daily dose (salt basis).
    api_amount_mg = (round(api_qty * multiplier, 6)
                     if api_qty is not None else None)

    # RF6 metadata: strength string + inferred dosage form (never a column header).
    # RS Bug 6b: for an overage product the DISPLAYED strength is the EFFECTIVE
    # (label) strength = api_qty / (1 + overage), e.g. 1.1 mg/mL → "1 mg/mL"; a
    # footnote records the overage. Component amounts still use the formulation
    # strength as printed. The API name is included for liquids per the approved
    # convention ("1 mg/mL Epinephrine").
    strength_note = ""
    if api_qty is not None:
        # Effective LABEL strength backs out (a) any manufacturing overage and
        # (b) a salt-form conversion, so the displayed strength is the free-base
        # label value, never the salt formulation weight (RS Bug 2 — Trilaciclib
        # 349 mg dihydrochloride → 300 mg base). salt_factor/overage default to
        # neutral, so Esomeprazole and other free-base APIs are unchanged (RF9).
        _sf = salt_factor if salt_factor else 1.0
        eff_qty = api_qty / (1.0 + overage_pct) / _sf
        if is_liquid:
            strength_label = f"{eff_qty:g} mg/mL"
            if api_name:
                strength_label = f"{strength_label} {api_name}"
        else:
            strength_label = f"{eff_qty:g} mg/{unit_basis}"
        if abs(_sf - 1.0) > 1e-9:
            # Salt-form footnote takes precedence: it records the salt weight and
            # its free-base equivalent (memory acceptance point 6).
            strength_note = (f"* {api_qty:g} mg {api_name or 'salt'} equivalent to "
                             f"{eff_qty:g} mg base")
        elif overage_pct:
            strength_note = (f"* API strength inclusive of {overage_pct * 100:g}% "
                             "overage")
    else:
        strength_label = ""
    dosage_form_inferred = _DOSAGE_BY_BASIS.get(unit_basis, "")

    return {
        "mode": "single_strength_unit_composition",
        "no_of_doses": round(multiplier, 6),   # kept for legacy display only
        "multiplier": round(multiplier, 6),
        "multiplier_basis": mult_basis,
        "mdd_mg_day": (float(mdd_mg_day) if mdd_mg_day else None),
        "salt_factor": salt_factor,
        "density_g_per_ml": density_g_per_ml,
        "api_component": api_name,
        "api_qty_per_unit": api_qty,
        "api_amount_mg": api_amount_mg,
        "unit_basis": unit_basis,
        "component_col": comp_label,
        "quantity_col": qty_label,
        "amount_col": "Amount in Maximum Dose (mg)",
        "mdi_col": "", "mdi_unit": "",
        "columns": [comp_label, qty_label, "Amount in Maximum Dose (mg)"],
        "solvents_display": [],
        "solvent_canon": {},
        "rows": comp_rows,
        "footer_total": {}, "footer_limit": {}, "drug_product_row": {},
        "has_calculated_values": False,
        "needs_dose_basis": needs_dose_basis,
        # Nominal MDD (mg/day): solids use the supplied MDD; a volume-dosed liquid
        # uses the label dose = effective strength × volume (e.g. 1 mg/mL × 8 mL =
        # 8 mg/day), never the sum of dissolved solids.
        "product_mdd_mg": (
            float(mdd_mg_day) if mdd_mg_day
            else round((api_qty / (1.0 + overage_pct) if overage_pct else api_qty)
                       * multiplier, 6)
            if (is_liquid and mult_basis == "dose_volume_ml" and api_qty is not None)
            else solid_mass),
        "drug_product_mass_mg": drug_product_mass_mg,
        "mdd_source": ("dose_volume_ml" if mult_basis == "dose_volume_ml"
                       else "mdd_over_api_qty" if mdd_mg_day else "legacy_doses"),
        "dose_volume_ml": dose_volume_ml,
        "overage_pct": overage_pct,
        "strength_label": strength_label,
        "strength_note": strength_note,
        "dosage_form_inferred": dosage_form_inferred,
        "_display_columns": display_columns,
        "_display_sections": [{"name": "Composition", "rows": display_rows}],
        "audit": {"unit_basis": unit_basis, "multiplier": round(multiplier, 6),
                  "api_component": api_name, "api_qty_per_unit": api_qty,
                  "mdd_mg_day": mdd_mg_day, "salt_factor": salt_factor},
        "warnings": [],
    }


def parse_component_mdd_only_excel(classified: Dict) -> Dict:
    """
    Mode C parser. Component name + a direct daily-amount column
    (Amount in Maximum Dose, or MDD/Maximum Daily Intake). Uses it directly,
    converting g→mg when needed. No strength / no_of_doses required.
    """
    header = classified["header"]
    rows = classified["rows"]
    comp_idx = classified.get("comp_idx")
    amount_idx = _col_index(header, _AMOUNT_HINTS)
    mdd_idx = _col_index(header, _MDD_HINTS)
    use_idx = amount_idx if amount_idx is not None else mdd_idx
    if comp_idx is None or use_idx is None:
        return {"mode": "component_mdd_only", "rows": [], "needs_dose_basis": True}

    use_label = header[use_idx].lower()
    unit = "mg"
    if re.search(r"\(\s*g\s*\)|\bgram", use_label) and not re.search(r"mg|µg|mcg|ug", use_label):
        unit = "g"
    elif re.search(r"µg|mcg|ug", use_label):
        unit = "ug"

    comp_rows = []
    display_rows = []
    for r in rows:
        if comp_idx >= len(r):
            continue
        name = _s(r[comp_idx])
        if not name:
            continue
        is_qs = any(h in name.lower() for h in _QS_HINTS)
        if _is_qs_ingredient(name):
            is_qs = True
        raw_val = _s(r[use_idx]) if use_idx < len(r) else ""
        if _is_qs_quantity(raw_val):
            is_qs = True
        val = _clean_num(_strip_footnote_markers(raw_val)) if use_idx < len(r) else None
        amount_mg = None
        basis = "none"
        if not is_qs and val is not None and val > 0:
            if unit == "g":
                amount_mg = val * 1000.0; basis = "mdi_grams"
            elif unit == "ug":
                amount_mg = val / 1000.0; basis = "mdi_micrograms"
            else:
                amount_mg = val; basis = "component_mdd_mg"
        comp_rows.append({
            "component": name, "quantity": None,
            "amount_in_maximum_dose_mg": amount_mg, "amount_basis": basis,
            "_is_qs": is_qs, "solvents": {}, "columns": {header[comp_idx]: name,
                                                         header[use_idx]: _s(r[use_idx])},
        })
        display_rows.append({"ingredient": name,
                             "columns": {header[comp_idx]: name,
                                         header[use_idx]: _s(r[use_idx])}})

    needs = any((not c["_is_qs"]) and c["amount_in_maximum_dose_mg"] is None for c in comp_rows)
    known = [c["amount_in_maximum_dose_mg"] for c in comp_rows
             if (not c["_is_qs"]) and c["amount_in_maximum_dose_mg"] is not None]
    return {
        "mode": "component_mdd_only", "no_of_doses": None,
        "component_col": header[comp_idx], "quantity_col": "",
        "amount_col": "Amount in Maximum Dose (mg)", "mdi_col": header[use_idx],
        "mdi_unit": unit,
        "columns": ["Components", "Amount in Maximum Dose (mg)"],
        "solvents_display": [], "solvent_canon": {},
        "rows": comp_rows, "footer_total": {}, "footer_limit": {},
        "drug_product_row": {}, "has_calculated_values": False,
        "needs_dose_basis": needs,
        "product_mdd_mg": round(sum(known), 6) if known else None,
        "mdd_source": "component_mdd_direct",
        "_display_columns": [header[comp_idx], header[use_idx]],
        "_display_sections": [{"name": "Composition", "rows": display_rows}],
        "audit": {"amount_unit": unit}, "warnings": [],
    }


def parse_rs_excel(raw: Dict, no_of_doses_override: int = 0) -> Dict:
    """
    Convert the raw extracted RS spreadsheet into a structured model.

    Implements the daily-intake hierarchy, normalising every quantitative
    component to `amount_in_maximum_dose_mg`:
      1. Amount in Maximum Dose (mg)            → use directly
      2. Maximum Daily Intake (g) / MDD (g)     → ×1000 → mg
      3. MDD (mg) / component daily amount (mg) → use directly
      4. Quantity/unit (mg) × No. of doses      → compute
      5. none of the above                      → needs_dose_basis = True
    """
    if not isinstance(raw, dict):
        raw = {}
    audit: Dict[str, Any] = {}
    warnings: List[str] = []

    component_col = _s(raw.get("component_col"))
    quantity_col  = _s(raw.get("quantity_col"))
    amount_col    = _s(raw.get("amount_col"))
    mdi_col       = _s(raw.get("mdi_col"))
    columns       = [_s(c) for c in (raw.get("columns") or []) if _s(c)]
    solvents_raw  = [_s(s) for s in (raw.get("solvents") or []) if _s(s)]
    has_calc      = bool(raw.get("has_calculated_values"))

    no_of_doses = no_of_doses_override or _num_or_none(raw.get("no_of_doses")) or 1
    no_of_doses = int(no_of_doses) if no_of_doses else 1

    # Determine mdi unit from header
    mdi_unit = ""
    if mdi_col:
        h = mdi_col.lower()
        if re.search(r"\(\s*g\s*\)|\bgram", h) and not re.search(r"mg|µg|mcg|ug", h):
            mdi_unit = "g"
        elif re.search(r"µg|mcg|ug", h):
            mdi_unit = "ug"
        else:
            mdi_unit = "mg"

    # Canonicalise solvent names against the master
    solvents: List[str] = []
    solvent_canon: Dict[str, str] = {}
    for s in solvents_raw:
        canon = RSM.resolve_solvent(s) or s
        solvents.append(s)             # preserve the sheet's display label
        solvent_canon[s] = canon

    def cell(row: Dict, col: str, fallbacks: List[str] = None) -> str:
        cols = row.get("columns", {})
        if isinstance(cols, dict):
            if col and col in cols:
                return _s(cols[col])
            for fb in (fallbacks or []):
                for k, v in cols.items():
                    if fb.lower() in k.lower():
                        return _s(v)
        # Also check top-level row keys (some LLM outputs flatten the row)
        if col and col in row:
            return _s(row[col])
        for fb in (fallbacks or []):
            for k, v in row.items():
                if k == "columns":
                    continue
                if fb.lower() in str(k).lower():
                    return _s(v)
        return ""

    # Walk rows: classify footer rows, build component rows
    comp_rows: List[Dict] = []
    footer_total: Dict[str, Any] = {}
    footer_limit: Dict[str, Any] = {}
    drug_product_row: Dict[str, Any] = {}

    for r in (raw.get("rows") or []):
        if not isinstance(r, dict):
            continue
        name = (_s(r.get("component"))
                or _s(r.get("ingredient"))
                or _s(r.get("name"))
                or cell(r, component_col, ["component", "name", "ingredient", "material"]))
        kind = _is_footer_row(name)

        # Per-solvent subvalues for this row.
        # IMPORTANT: match the solvent name to the column's solvent portion with
        # word boundaries, because some solvent names are substrings of others
        # (e.g. "Ethanol" ⊂ "Methanol"). Without this, Methanol's column would
        # wrongly satisfy a naive "ethanol in header" test.
        solvent_vals: Dict[str, Dict[str, Any]] = {}
        cols = r.get("columns", {})
        cols = cols if isinstance(cols, dict) else {}
        for disp in solvents:
            limit_v = None
            de_v = None
            d_low = disp.lower().strip()
            for k, v in cols.items():
                kl = str(k).lower()
                # Strip the role words to isolate the solvent portion of the header
                solvent_part = re.sub(
                    r"\b(limit|ppm|daily|exposure|mg|\(.*?\))\b", " ", kl)
                solvent_part = re.sub(r"[^a-z0-9 ]+", " ", solvent_part)
                tokens = solvent_part.split()
                # Match only if the solvent name appears as a whole token sequence
                disp_tokens = re.sub(r"[^a-z0-9 ]+", " ", d_low).split()
                is_match = disp_tokens and _seq_in(disp_tokens, tokens)
                if not is_match:
                    continue
                if "limit" in kl or "ppm" in kl:
                    limit_v = _num_or_none(v)
                elif "exposure" in kl or "daily" in kl:
                    de_v = _num_or_none(v)
            solvent_vals[disp] = {"limit": limit_v, "daily_exposure": de_v}

        if kind == "total":
            footer_total = {disp: solvent_vals[disp] for disp in solvents}
            continue
        if kind == "limit":
            footer_limit = {disp: solvent_vals[disp] for disp in solvents}
            continue
        if kind == "drug_product":
            drug_product_row = {
                "component": name,
                "quantity": _num_or_none(cell(r, quantity_col, ["quantity"])),
                "amount_max_dose": _num_or_none(cell(r, amount_col, ["amount in maximum", "amount"])),
                "solvents": solvent_vals,
            }
            continue
        if not name:
            continue

        is_qs = any(h in name.lower() for h in _QS_HINTS)
        if _is_qs_ingredient(name):
            is_qs = True
        # If ALL three quantity cells (amount/qty/mdi) are q.s.-like, force q.s.
        raw_amount = cell(r, amount_col, ["amount in maximum", "amount"])
        raw_qty = cell(r, quantity_col, ["quantity"])
        raw_mdi = cell(r, mdi_col, ["maximum daily intake", "mdd"]) if mdi_col else ""
        _qs_cells = [raw_amount, raw_qty, raw_mdi]
        if all(_is_qs_quantity(v) for v in _qs_cells if v):
            is_qs = True

        # ── daily-intake hierarchy → amount_in_maximum_dose_mg ───────────────
        amount_mg: Optional[float] = None
        basis = "none"
        amt = _num_or_none(_strip_footnote_markers(raw_amount))
        qty = _num_or_none(_strip_footnote_markers(raw_qty))
        mdi = (_num_or_none(_strip_footnote_markers(raw_mdi))
               if mdi_col else None)

        if is_qs:
            pass                        # calc-exempt
        elif amt is not None and amt > 0:
            amount_mg = amt
            basis = "amount_in_maximum_dose"
        elif mdi is not None and mdi > 0:
            if mdi_unit == "g":
                amount_mg = mdi * 1000.0
                basis = "mdi_grams"
            elif mdi_unit == "ug":
                amount_mg = mdi / 1000.0
                basis = "mdi_micrograms"
            else:
                amount_mg = mdi
                basis = "mdd_mg"
        elif qty is not None and qty > 0:
            amount_mg = qty * no_of_doses
            basis = "qty_times_doses"

        comp_rows.append({
            "component": name,
            "quantity": qty,
            "amount_in_maximum_dose_mg": amount_mg,
            "amount_basis": basis,
            "_is_qs": is_qs,
            "solvents": solvent_vals,     # sheet-provided limits/exposures (detailed mode)
            "columns": dict(r.get("columns", {})) if isinstance(r.get("columns"), dict) else {},
        })

    # Determine whether any quantitative row lacks a dose basis
    needs_dose_basis = any(
        (not cr["_is_qs"]) and cr["amount_in_maximum_dose_mg"] is None
        for cr in comp_rows
    )

    mode = "detailed" if (has_calc and solvents) else "basic"

    # ── Infer product-level Maximum Daily Dose from the Excel (no user input) ──
    # Priority: an explicit "Drug Product" total row → else the sum of component
    # amounts in maximum dose. This is shown on the verification screen and is
    # editable, mirroring the injection workflow (no forced MDD/strength entry).
    product_mdd_mg: Optional[float] = None
    mdd_source = "not_determinable"
    dp_amt = None
    if drug_product_row:
        dp_amt = drug_product_row.get("amount_max_dose")
    if dp_amt is not None and dp_amt > 0:
        product_mdd_mg = float(dp_amt)
        mdd_source = "excel_drug_product_row"
    else:
        known = [cr["amount_in_maximum_dose_mg"] for cr in comp_rows
                 if (not cr["_is_qs"]) and cr["amount_in_maximum_dose_mg"] is not None]
        if known:
            product_mdd_mg = round(sum(known), 6)
            mdd_source = "sum_of_component_amounts"

    return {
        "mode": mode,
        "no_of_doses": no_of_doses,
        "component_col": component_col,
        "quantity_col": quantity_col,
        "amount_col": amount_col,
        "mdi_col": mdi_col,
        "mdi_unit": mdi_unit,
        "columns": columns,
        "solvents_display": solvents,
        "solvent_canon": solvent_canon,
        "rows": comp_rows,
        "footer_total": footer_total,
        "footer_limit": footer_limit,
        "drug_product_row": drug_product_row,
        "has_calculated_values": has_calc,
        "needs_dose_basis": needs_dose_basis,
        "product_mdd_mg": product_mdd_mg,
        "mdd_source": mdd_source,
        "audit": audit,
        "warnings": warnings,
    }


