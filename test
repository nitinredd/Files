    """
    return []


# ── Excel composition parser ──────────────────────────────────────────────────
def parse_composition_excel(excel_bytes: bytes) -> Dict:
    """
    Generic parser: works for oral sachets, injections, any formulation.
    Returns sections with ingredients and their amounts.
    """
    wb = openpyxl.load_workbook(BytesIO(excel_bytes), data_only=True)
    ws = wb.worksheets[0]
    rows_text: List[str] = []
    all_rows: List[List[str]] = []
    for i, row in enumerate(ws.iter_rows(values_only=True)):
        if any(c is not None for c in row):
            row_str = [str(c) if c is not None else "" for c in row]
            rows_text.append(f"Row {i+1}: {' | '.join(row_str)}")
            all_rows.append(row_str)
    wb.close()
    sheet_dump = "\n".join(rows_text[:100])

    prompt = (
        "You are extracting the ingredient composition table from a pharmaceutical "
        "drug product spreadsheet. Extract the table structure EXACTLY as printed.\n\n"
        "DO NOT calculate doses, daily dose, or total mass. DO NOT infer dosing. "
        "Only extract what is literally in the spreadsheet.\n\n"
        "Your tasks:\n"
        "1. Identify the column that contains the INGREDIENT/MATERIAL NAME.\n"
        "2. Identify the column that contains the AMOUNT per single dose unit "
        "(per sachet / per tablet / per mL / per vial). If multiple amount columns "
        "exist for different strengths, choose the one with the LARGEST values "
        "(highest strength = worst case for elemental impurity assessment).\n"
        "3. Identify the unit of that amount column (mg, g, mL, mg/mL, µg).\n"
        "4. Extract every ingredient row with all its column values.\n\n"
        "Return ONLY this JSON (no markdown, no comments):\n"
        "{\n"
        '  "ingredient_col": "<exact header text of the ingredient-name column>",\n'
        '  "amount_col": "<exact header text of the chosen amount column>",\n'
        '  "amount_unit": "<mg | g | mL | mg/mL | µg>",\n'
        '  "columns": ["<exact col1 header>","<exact col2 header>", "..."],\n'
        '  "sections": [\n'
        '    {\n'
        '      "name": "<section header text, or empty string>",\n'
        '      "rows": [\n'
        '        {"ingredient":"<name>","columns":{"<col header>":"<cell value>"}}\n'
        '      ]\n'
        '    }\n'
        '  ]\n'
        "}\n\n"
        "RULES:\n"
        "- columns[]: list the exact header text of every column, in order.\n"
        "- The amount column (e.g. 'mg/tab', 'mg/unit', 'Qty/unit', 'mg/0.65 mL') "
        "MUST be included in columns[] and must appear immediately after the "
        "ingredient-name column. Never drop the per-unit amount column.\n"
        "- For each row, map each cell to its exact column header in the columns dict.\n"
        "- ingredient_col and amount_col MUST be values that appear in columns[].\n"
        "- amount_unit: read from the amount column header "
        "(e.g. 'Qty/unit (mg/0.65 mL)' → 'mg'; 'mg/sachet' → 'mg').\n"
        "- Include EVERY ingredient row, even pH adjusters and 'QS' rows.\n"
        "- Do NOT invent or compute any values. Extract only.\n\n"
        f"Spreadsheet:\n{sheet_dump}"
    )
    raw = claude_text(prompt)
    parsed = safe_json_parse(raw, {})

    if isinstance(parsed, dict) and isinstance(parsed.get("sections"), list) and parsed["sections"]:
        result = parsed
    else:
        logger.warning("Excel parse: fallback to raw rows")
        fallback_rows = []
        for row in all_rows[1:]:
            if len(row) > 2 and row[0].strip():
                fallback_rows.append({"ingredient": row[0], "amount": row[2] if len(row)>2 else "0",
                                       "unit": "", "function": ""})
        result = {"sections": [{"name": "Composition", "rows": fallback_rows}],
                  "ingredient_col": "", "amount_col": "", "amount_unit": "mg",
                  "columns": []}

    # NOTE: doses_per_day, route, and MDD are NOT extracted here — the user
    # enters them manually in the UI and they are injected into comp_data
    # afterwards. The Excel parser only provides the ingredient table structure.
    result["ingredient_col"]  = safe_str(result.get("ingredient_col", ""))
    result["amount_col"]      = safe_str(result.get("amount_col", ""))
    result["amount_unit"]     = safe_str(result.get("amount_unit", "mg"))
    result["amount_per_dose"] = True  # amounts are per dose unit; scaled by doses_per_day
    # Defaults — always overridden by header in the pipeline
    result.setdefault("doses_per_day", 1)
    result.setdefault("route", "oral")
    result.setdefault("mdd_g", 1.0)
    if not isinstance(result.get("sections"), list): result["sections"] = []
    if not isinstance(result.get("columns"), list):  result["columns"] = []

    # ── Safeguard: ensure the amount column (e.g. "mg/tab") is always present ──
    # The component name + its per-unit amount must both appear in the rendered
    # table. If Claude omitted the amount column from `columns`, re-insert it
    # right after the ingredient column so the quantity is never dropped.
    cols = [safe_str(c) for c in result.get("columns", []) if safe_str(c)]
    ing_col = result["ingredient_col"]
    amt_col = result["amount_col"]
    if amt_col and amt_col not in cols:
        if ing_col and ing_col in cols:
            insert_at = cols.index(ing_col) + 1
            cols.insert(insert_at, amt_col)
        else:
            cols.append(amt_col)
    # If no columns were detected at all, derive them from the row data
    if not cols:
        seen: List[str] = []
        for sec in result.get("sections", []):
            if not isinstance(sec, dict): continue
            for row in (sec.get("rows") or []):
                if isinstance(row, dict) and isinstance(row.get("columns"), dict):
                    for k in row["columns"].keys():
                        if k not in seen:
                            seen.append(k)
        cols = seen
    result["columns"] = cols
    result["all_rows"] = all_rows
    return result


