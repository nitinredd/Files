    ann_summary = [{"material":a.get("material_name","N/A"),
                    "supplier":a.get("supplier_name","N/A"),
                    "n_elements":len(a.get("elements",[])or[])}
                   for a in annexure_data if isinstance(a, dict)]

    t5 = safe_calc_table(calc_tables,"class1_2a")
    t6 = safe_calc_table(calc_tables,"class2b")
    t7 = safe_calc_table(calc_tables,"class3")

    crossing = {sym: {"total":t5["element_totals"].get(sym,0),
                      "pde30":round(t5["pde"].get(sym,0)*0.3,4)}
                for sym in TABLE5_ELEMENTS
                if t5["pde"].get(sym) and t5["element_totals"].get(sym,0) > t5["pde"].get(sym,0)*0.3}

    # Tell Claude how many TOC sections there are so it writes the right structure
    toc_info = ""
    if toc:
        toc_info = "TOC sections from reference: " + "; ".join(
            f"{e.get('no','?')}. {e.get('title','')}" for e in toc[:15])

    prompt = (
        "You are a pharmaceutical regulatory writer creating an ICH Q3D (R2) TSR.\n\n"
        f"Product: {meta.get('product_name','')}\n"
        f"Dosage form: {meta.get('dosage_form','')}\n"
        f"Route: {route}\n"
        f"MDD: {mdd_g}g/day ({doses} dose(s)/day)\n"
        f"Document No: {meta.get('document_no','')}\n\n"
        f"{toc_info}\n\n"
        f"Annexures ({len(annexure_data)} materials):\n{json.dumps(ann_summary)}\n\n"
        "Calculation formula: Daily exposure (µg/day) = Amount_in_MDD(g) × Conc(µg/g)\n"
        f"- Class 1+2A totals: {json.dumps(t5['element_totals'])}\n"
        f"- Class 2B totals:   {json.dumps(t6['element_totals'])}\n"
        f"- Class 3 totals:    {json.dumps(t7['element_totals'])}\n"
        f"- Route-specific PDEs used: {route}\n"
        f"- Elements crossing 30% PDE: {json.dumps(crossing)}\n\n"
        "Generate concise factual ICH Q3D regulatory text matching the product.\n"
        "Return ONLY this JSON (no markdown):\n"
        '{"abstract":"","objective":"","study_location":"NA","background":"",\n'
        '"sources_intro":"","drug_substance_section":"","excipient_intro":"",\n'
        '"manufacturing_section":"","container_closure_section":"","utilities_section":"",\n'
        '"control_strategy":"","testing_recommendation":"","conclusion":"",\n'
        '"observation":"","reference":"NA"}'
    )
    raw    = claude_text(prompt, max_tokens=6000)
    parsed = safe_json_parse(raw, {})
    if not isinstance(parsed, dict):
        logger.error("Text generation returned no valid JSON; using empty sections")
        return empty
    for k, v in empty.items(): parsed.setdefault(k, v)
    return parsed


# ── Assemble and invoke Node.js ───────────────────────────────────────────────
def assemble_and_generate(ref_structure: Dict, page_images: List[bytes],
                          figure_pages: List[Dict], annexure_data: List[Dict],
                          comp_data: Dict, calc_tables: Dict, text_sections: Dict,
                          ref_bytes: bytes = b"", logo_b64: str = "",
                          logo_type: str = "") -> bytes:

    figures_b64: List[Dict] = []
    for fig in figure_pages:
        if not isinstance(fig, dict): continue
        pi = fig.get("page_index")
        if pi is None: continue
        try:
            img_bytes = extract_figure_from_page(ref_bytes, pi, dpi=200)
        except Exception as e:
            logger.warning(f"Figure raster p{pi}: {e}")
            img_bytes = safe_list_get(page_images, pi, b"")
        if not img_bytes: continue
        figures_b64.append({"page_index":pi,
                             "description":fig.get("description",""),
                             "figure_label":fig.get("figure_label","Figure 1"),
                             "data_b64":base64.standard_b64encode(img_bytes).decode(),
                             "media_type":"image/png"})

    annexure_list = [{"material":a.get("material_name","N/A"),
                      "supplier":a.get("supplier_name","N/A"),
                      "annexure":f"Annexure {a.get('annexure_number','?')}"}
                     for a in annexure_data if isinstance(a, dict)]

    additional_tables = extract_additional_tables([])

    report_data = {
        "meta":              ref_structure.get("meta",{}) or {},
        "toc_entries":       ref_structure.get("toc_entries",[]) or [],
        "logo_b64":          logo_b64,
        "logo_type":         logo_type,
        "text_sections":     text_sections or {},
        # Composition: exact columns from Excel as extracted
        "composition":       comp_data.get("sections",[]) or [],
        "comp_columns":      comp_data.get("columns",[]) or [],
        "comp_meta":         {"route": comp_data.get("route","oral"),
                              "mdd_g": comp_data.get("mdd_g",1.0),
                              "doses_per_day": comp_data.get("doses_per_day",1),
                              "unit": comp_data.get("unit",""),
                              "ingredient_col": comp_data.get("ingredient_col",""),
                              "amount_col": comp_data.get("amount_col",""),
                              "amount_unit": comp_data.get("amount_unit","mg")},
        "annexure_list":     annexure_list,
        "calc_tables":       calc_tables or {},
        "revision_history":  ref_structure.get("revision_history",[]) or [],
        "signatures":        ref_structure.get("signatures",[]) or [],
        "figures":           figures_b64,
        "pde_values":        dict(ICH_PDE),
        # All non-EI tables extracted verbatim from reference PDF
        "additional_tables": additional_tables,
    }

    with tempfile.TemporaryDirectory() as tmpdir:
        json_path = Path(tmpdir) / "report_data.json"
        docx_path = Path(tmpdir) / "report.docx"
        js_script = Path(__file__).parent / "generate_report.js"
        with open(json_path,"w",encoding="utf-8") as f:
            json.dump(report_data, f, ensure_ascii=False)
        result = subprocess.run(
            ["node", str(js_script), str(json_path), str(docx_path)],
            capture_output=True, text=True, timeout=180)
        if result.returncode != 0:
            raise RuntimeError(
                f"Node.js failed (exit {result.returncode}).\n"
                f"STDERR: {result.stderr[-2000:]}\nSTDOUT: {result.stdout[-500:]}")
        if not docx_path.exists():
            raise RuntimeError(f"Node.js OK but no DOCX written.\nSTDOUT: {result.stdout}")
        docx_bytes = docx_path.read_bytes()
        if len(docx_bytes) < 5000:
            raise RuntimeError(f"DOCX too small ({len(docx_bytes)} bytes).")
        return docx_bytes


