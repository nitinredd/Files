  W[3] = CW - W[0] - W[1] - W[2];

  var hdr = new TableRow({children:[
    cell("S. No.",     {bold:true, fill:CLR.HDR_GREY, w:W[0], size:SZ.SM}),
    cell("Ingredient", {bold:true, fill:CLR.HDR_GREY, w:W[1], size:SZ.SM}),
    cell("Excipient Manufacturer/\nSupplier", {bold:true, fill:CLR.HDR_GREY, w:W[2], size:SZ.SM}),
    cell("Refer the following\nsupplier declaration", {bold:true, fill:CLR.HDR_GREY, w:W[3], size:SZ.SM}),
  ]});

  var rows = supplierDeclarations.map(function(s, i) {
    return new TableRow({children:[
      cell(String(s.s_no || (i+1)), {w:W[0], size:SZ.SM}),
      cellL(String(s.ingredient||""), {w:W[1], size:SZ.SM}),
      cellL(String(s.supplier||""), {w:W[2], size:SZ.SM}),
      cell(String(s.annexure||""), {w:W[3], size:SZ.SM}),
