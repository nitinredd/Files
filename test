def _match_ingredient(ingredient_name: str, conc_map: Dict[str, Dict[str, float]]) -> Dict[str, float]:
“”“Fuzzy-match ingredient name to closest key in conc_map. Never raises.”””
if not conc_map or not ingredient_name:
return {}
ingredient_lower = ingredient_name.lower().strip()
best_key = None
best_score = 0
for key in conc_map:
if not key:
continue
key_lower = key.lower().strip()
# Token overlap score
ing_tokens = set(t for t in re.split(r’[\s()-,]+’, ingredient_lower) if t)
key_tokens  = set(t for t in re.split(r’[\s()-,]+’, key_lower)  if t)
if not ing_tokens or not key_tokens:
continue
overlap = len(ing_tokens & key_tokens)
if overlap > best_score:
best_score = overlap
best_key = key
return conc_map.get(best_key, {}) if best_score > 0 else {}

