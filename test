# ── Build comp_data for the existing engine ───────────────────────────────────
def build_injection_comp_data(parsed: Dict, model_info: Dict) -> Dict:
    """
    Translate the parsed injection model into the comp_data structure that the
    existing calculate_ei_tables() consumes. Pre-computes per-component daily
    intake so the engine remains a generic (intake × concentration) calculator.

    Strategy:
      • If a component-level MDD column exists, each component's daily intake
        is component_mdd_mg → g/day (mass-based) directly.
      • Else, for mass-based model with density, total daily product intake =
        density_g_per_ml × dose_volume_ml × doses_per_day, and each component's
        daily intake is derived from its share if quantities are present.
      • For volume-based model, daily intake unit is mL/day = dose_volume_ml ×
        doses_per_day for the whole product; per-component volume intake equals
        that (concentration already per-mL of product).
    """
    model = model_info.get("model", "mass_based")
    dose_volume_ml = _sfloat(parsed.get("dose_volume_ml", 0))
    doses = max(1, _sint(parsed.get("doses_per_day", 1)))
    density = _sfloat(parsed.get("density_g_per_ml", 0))
    rows = parsed.get("rows", [])
    component_mdd = parsed.get("component_mdd", {}) or {}
    ingredient_col = parsed.get("ingredient_col", "")
    selected_qty_col = parsed.get("selected_qty_col", "")

    out_rows: List[Dict] = []
    for i, r in enumerate(rows):
        name = _sstr(r.get("ingredient", "")) or _row_field(r, ingredient_col,
                                                            ["ingredient", "name"])
        if not name:
            continue
        qty_text = _row_field(r, selected_qty_col) if selected_qty_col else ""
        fn = _row_field(r, parsed.get("function_col", ""), ["function", "role"])
        is_qs = _is_qs_row(name, qty_text, fn)

        # Determine this component's daily intake
        daily_intake = 0.0
        intake_basis = "none"
        component_mg = 0.0

        if i in component_mdd and component_mdd[i] > 0:
            # Component-level Maximum Daily Intake is the source of truth.
            # Convert to a consistent mass (mg) for reporting, and to g/day for
            # the mass-based exposure model. When the column is already in grams,
            # it IS the daily intake (g/day) and is used directly — no derivation.
            mdd_unit = parsed.get("mdd_col_unit", "mg")
            raw_val = component_mdd[i]
            if mdd_unit == "g":
                daily_g_direct = raw_val                     # already g/day
                component_mg = raw_val * 1000.0              # for mg reporting
            elif mdd_unit == "ug":
                daily_g_direct = raw_val / 1_000_000.0
                component_mg = raw_val / 1000.0
            else:  # mg
                component_mg = raw_val * doses
                daily_g_direct = component_mg / 1000.0
            if model == "volume_based":
                daily_intake = dose_volume_ml * doses
                intake_basis = "product_volume"
            else:
                daily_intake = daily_g_direct
                intake_basis = ("component_mdi_grams" if mdd_unit == "g"
                                else "component_mdd")
        elif not is_qs:
            # The qty cell may be a plain number ("104") while the dose volume
            # lives in the column header ("Qty/unit (mg / 0.65 mL)"). Parse a
            # ratio from the cell first; if absent, take the plain mass number.
            ratio = parse_ratio(qty_text) if qty_text else None
            comp_mass_mg = 0.0
            if ratio and ratio["mass_mg"] > 0:
                comp_mass_mg = ratio["mass_mg"]
            elif qty_text:
                num = re.sub(r"[^0-9.\-]", "", qty_text)
                comp_mass_mg = _sfloat(num) if num else 0.0
            if comp_mass_mg > 0:
                component_mg = comp_mass_mg * doses
                daily_intake = (dose_volume_ml * doses) if model == "volume_based" \
                    else (component_mg / 1000.0)
                intake_basis = "product_volume" if model == "volume_based" else "ratio_mass"
            elif model == "mass_based" and density > 0 and dose_volume_ml > 0:
                daily_intake = 0.0
                intake_basis = "missing_component_mass"
            elif model == "volume_based" and dose_volume_ml > 0:
                daily_intake = dose_volume_ml * doses
                intake_basis = "product_volume"

        out_rows.append({
            "ingredient": name,
            "columns": {"Component": name,
                        "Qty": qty_text,
                        "mg/unit": (round(component_mg / max(1, doses), 4)
                                    if component_mg else "")},
            "_is_qs": is_qs,
            "_daily_intake": round(daily_intake, 8),
            "_intake_basis": intake_basis,
            "_component_mg": round(component_mg, 6),
            "section": r.get("_section", ""),
        })

    # ── Build the VERBATIM display schema for Table 1 (separate from calc) ─────
    # Table 1 must reflect the uploaded Excel EXACTLY: original headers, every
    # column (codes, function, pharmacopeial refs, strengths, MDD), q.s. rows,
    # and original ordering. This is independent of the calculation schema above.
    display_columns = [c for c in (parsed.get("columns") or []) if _sstr(c)]
    # Group the original rows back into their sections, preserving order.
    display_sections: List[Dict] = []
    seen_secs: Dict[str, Dict] = {}
    order: List[str] = []
    for r in rows:
        sname = _sstr(r.get("_section", ""))
        if sname not in seen_secs:
            seen_secs[sname] = {"name": sname, "rows": []}
            order.append(sname)
        # Preserve the original cell map verbatim
        orig_cols = r.get("columns", {})
        disp_cols = dict(orig_cols) if isinstance(orig_cols, dict) else {}
        seen_secs[sname]["rows"].append({
            "ingredient": _sstr(r.get("ingredient", "")),
            "columns": disp_cols,
        })
    for sname in order:
        display_sections.append(seen_secs[sname])

    return {
        "route": "parenteral",
        "doses_per_day": doses,
        "dose_volume_ml": dose_volume_ml,
        "density_g_per_ml": density,
        "calculation_model": model,
        # ── Calculation schema (consumed by calculate_ei_tables) ──────────────
        "ingredient_col": "Component",
        "amount_col": "mg/unit",
        "amount_unit": "mg",
        "columns": ["Component", "Qty", "mg/unit"],
        "sections": [{"name": "Composition", "rows": out_rows}],
        "_injection_rows": out_rows,
        # ── Display schema (verbatim Excel, used for Table 1 rendering) ────────
        "_display_columns": display_columns,
        "_display_sections": display_sections,
        "mdd_total_mg_per_day": _sfloat(parsed.get("mdd_mg", 0)),
    }


# ── Strict validation gate ────────────────────────────────────────────────────
def validate_injection(parsed: Dict, model_info: Dict, comp_data: Dict,
                       annexure_data: List[Dict]) -> Tuple[List[str], List[str]]:
    """Return (errors, warnings). Non-empty errors block generation."""
    errors: List[str] = []
    warnings: List[str] = []

    # API row
    if parsed.get("api_row_index") is None:
        errors.append("API row could not be identified in the composition Excel "
                      "(no Function=Active and no product-name match).")
    # MDD — satisfied by either an API-level MDD OR component-level daily intake
    # values present for the quantitative (non-q.s.) rows.
    has_component_intake = any(
        (not r.get("_is_qs")) and _sfloat(r.get("_daily_intake", 0)) > 0
        for r in comp_data.get("_injection_rows", [])
    )
    if _sfloat(parsed.get("mdd_mg", 0)) <= 0 and not has_component_intake:
        errors.append("Maximum Daily Dose / Intake could not be determined from "
                      "the Excel (no MDD/Max Daily Intake column, no ratio header, "
                      "and no mg/mL × volume).")
    # Dose volume when required
    model = model_info.get("model", "mass_based")
    if model == "volume_based" and _sfloat(parsed.get("dose_volume_ml", 0)) <= 0:
        errors.append("Dose volume (mL) is required for the volume-based model "
                      "but could not be parsed.")
    # Density required for mass-based whole-product fallback
    needs_density = any(
        r.get("_intake_basis") == "missing_component_mass"
        for r in comp_data.get("_injection_rows", [])
    )
    if needs_density and _sfloat(parsed.get("density_g_per_ml", 0)) <= 0:
        errors.append("Density is required (mass-based model without component "
                      "quantities) but was not provided.")
    # Annexure units
    if model_info.get("ambiguous"):
        errors.append("Annexure concentration units are missing or ambiguous — "
                      "cannot select a calculation model. Please review.")
    # PDE route
    if comp_data.get("route", "") != "parenteral":
        errors.append("Route must be 'parenteral' for injection products.")
    # mg/mL × volume ≈ MDD consistency
    sm = _sfloat(parsed.get("strength_mg_per_ml", 0))
    dv = _sfloat(parsed.get("dose_volume_ml", 0))
    mdd = _sfloat(parsed.get("mdd_mg", 0))
    doses = max(1, _sint(parsed.get("doses_per_day", 1)))
    if sm > 0 and dv > 0 and mdd > 0:
        expected = sm * dv * doses
        if expected > 0 and abs(expected - mdd) / mdd > 0.05:
            warnings.append(
                f"mg/mL × dose volume × doses = {expected:.3f} mg/day does not "
                f"match API MDD = {mdd:.3f} mg/day (>5% difference). Please confirm "
                "the selected presentation and dose volume."
            )
    # Non-QS ingredient without annexure mapping is checked downstream by the
    # engine's match audit; here we flag QS handling.
    qs_rows = [r["ingredient"] for r in comp_data.get("_injection_rows", [])
               if r.get("_is_qs")]
    if qs_rows:
        warnings.append(
            "q.s. / process-aid rows excluded from quantitative summation: "
            + ", ".join(qs_rows[:8])
        )
    return errors, warnings
