    # ── File upload ───────────────────────────────────────────────────────────
    uploaded = st.file_uploader(
        "Upload annexure PDF(s) — one per vendor material",
        type=["pdf"],
        accept_multiple_files=True,
        key="annexure_pdfs",
    )

    if not uploaded:
        st.info("📁 Upload one or more annexure PDFs to begin.")
        with st.expander("ℹ️ How it works"):
            st.markdown("""
**Step 1** — Upload annexure PDFs (scanned or digital, any number)

**Step 2** — Claude Vision reads each page at 250 DPI:
- Page 1: extracts supplier name, material name, date, method
- All pages: extracts every element's measured concentration exactly as printed
- Multiple pages with same element → takes the maximum (conservative)
- All 25 ICH Q3D elements included (0.0 if not tested)

**Step 3** — Download ZIP containing one JSON per PDF

**Step 4** — Upload the JSONs to the TSR Report Generator

**Unit handling (critical):** every value is normalized to µg/g (ppm).
- `ppm / µg/g / mg/kg` → as-is
- `ppb / ng/g / µg/kg` → ÷ 1000  (so 285 ppb = 0.285 µg/g)
- `%` → × 10000

**Reading rules** (applied automatically):
- `0.30` → 0.30 µg/g
- `<0.30` → 0.30 (conservative upper bound)
- `BDL (0.034 ppm)` → 0.034 (uses the bracketed reporting limit)
- `BLQ / Below LOQ` (no bracket) → the document's own LOQ, else 0.0
- `ND / Not Detected / Below LOD` → 0.0 (true non-detect)
- `NA / blank / Not Tested` → 0.0
- Never uses a hardcoded 0.05 placeholder

Each element keeps a full audit trail: raw value, raw unit, converted µg/g,
data status (actual / less_than / bdl / nd / not_tested), and observed text.
""")
        return

    st.markdown(f"**{len(uploaded)} file(s) selected:**")
    for f in uploaded:
        size_kb = len(f.getvalue()) / 1024
        st.write(f"  📄 {f.name} ({size_kb:.0f} KB)")

    st.markdown("---")

    if st.button("🚀 Convert All PDFs", type="primary"):
        results: List[Dict] = []
        errors: List[str]   = []

        overall_bar = st.progress(0.0)
        overall_txt = st.empty()

        for idx, uploaded_file in enumerate(uploaded):
            overall_txt.info(
                f"Processing {idx + 1}/{len(uploaded)}: **{uploaded_file.name}**"
            )

            # Per-file status area
            with st.expander(f"📄 {uploaded_file.name}", expanded=True):
                status_line = st.empty()
                file_bar    = st.progress(0.0)

                def _progress(msg: str, pct: float = 0.0,
                               _sl=status_line, _fb=file_bar):
                    _sl.write(f"  ⏳ {msg}")
                    _fb.progress(min(pct, 1.0))

                try:
                    result = convert_pdf_to_json(
                        pdf_bytes        = uploaded_file.getvalue(),
                        filename         = uploaded_file.name,
                        index            = idx + 1,
                        progress_callback= _progress,
                    )
                    results.append(result)

                    # Summary
                    els     = result.get("elements", [])
                    nonzero = [e for e in els if e.get("concentration_value", 0) > 0]
                    zero    = [e for e in els if e.get("concentration_value", 0) == 0]

                    file_bar.progress(1.0)
                    if result.get("_error"):
                        status_line.error(
                            f"❌ Error: {result.get('extraction_notes','unknown')}"
                        )
                        errors.append(uploaded_file.name)
                    else:
                        status_line.success(
                            f"✅ {result.get('material_name','?')} "
                            f"({result.get('supplier_name','?')}) — "
                            f"{len(nonzero)} elements with values, "
                            f"{len(zero)} not detected / not tested"
                        )

                    # Show element table
                    if els:
                        nonzero_els = [e for e in els if e.get("concentration_value",0) > 0]
                        zero_els    = [e for e in els if e.get("concentration_value",0) == 0.0]
                        st.markdown(
                            f"**Extracted concentrations:** "
                            f"{len(nonzero_els)} non-zero, {len(zero_els)} zero/ND"
                        )
                        # Show non-zero first, then zero
                        rows = []
                        for e in sorted(els, key=lambda x: -x.get("concentration_value",0)):
                            cv = e.get("concentration_value", 0)
                            raw_v = e.get("raw_value", cv)
                            raw_u = e.get("raw_unit", "")
                            # Flag suspicious unit conversions (raw ppb but value unchanged)
                            unit_flag = ""
                            if raw_u and raw_u.lower() in ("ppb","ng/g","µg/kg","ug/kg") and abs(raw_v - cv) < 1e-9 and cv > 0:
                                unit_flag = " ⚠️UNIT?"
                            rows.append({
                                "Symbol":        e.get("symbol", ""),
                                "Name":          e.get("name", ""),
                                "Class":         e.get("class", ""),
                                "µg/g (ppm)":    cv,
                                "Raw value":     raw_v,
                                "Raw unit":      raw_u,
                                "Status":        e.get("data_status", "") + unit_flag,
                                "Observed":      e.get("observed_level", ""),
                                "Method":        e.get("analytical_method", ""),
                            })
                        st.dataframe(rows, use_container_width=True, height=350)
                        if not nonzero_els:
                            st.error(
                                "❌ ALL concentrations are 0.0 — this annexure will "
                                "contribute NOTHING to EI calculations. "
                                "Check: (1) the PDF has a readable EI table, "
                                "(2) vendor results show actual numbers not all ND."
                            )

                    # Show extraction notes
                    notes = result.get("extraction_notes", "")
                    if notes:
                        with st.expander("📋 Page-by-page extraction log"):
                            st.text(notes)

                except Exception as e:
                    err_msg = f"Unexpected error: {e}"
                    logger.exception(err_msg)
                    status_line.error(f"❌ {err_msg}")
                    errors.append(uploaded_file.name)
                    results.append({
                        "annexure_number":  idx + 1,
                        "filename":         uploaded_file.name,
                        "supplier_name":    "",
                        "material_name":    "",
                        "source_type":      "",
                        "date_filled":      "",
                        "analytical_method":"",
                        "lot_number":       "",
                        "specification_reference": "",
                        "extraction_notes": err_msg,
                        "elements":         [],
                        "_error":           True,
                    })

            overall_bar.progress((idx + 1) / len(uploaded))

        overall_txt.success(
            f"✅ Conversion complete: "
            f"{len(results) - len(errors)}/{len(uploaded)} succeeded"
        )

        # ── Build and offer ZIP download ──────────────────────────────────────
        if results:
            st.markdown("---")
            st.subheader("📦 Download JSONs")

            zip_bytes = build_zip(results)
            ts        = datetime.now().strftime("%Y%m%d_%H%M%S")
            zip_name  = f"annexure_jsons_{ts}.zip"

            st.download_button(
                label  = "📥 Download ZIP (all JSONs)",
                data   = zip_bytes,
                file_name = zip_name,
                mime   = "application/zip",
            )

            st.markdown(
                f"ZIP contains **{len(results)} JSON file(s)** + `_manifest.json`. "
                "Upload the JSON files to the **TSR Report Generator** (app.py)."
            )

            if errors:
                st.warning(
                    f"⚠️ {len(errors)} file(s) had errors: {', '.join(errors)}. "
                    "Their JSONs are included with empty elements lists."
                )

            # Show manifest summary
            st.markdown("**Manifest summary:**")
            manifest_rows = []
            for r in results:
                n_nz = sum(1 for e in r.get("elements",[])
                           if e.get("concentration_value",0) > 0)
                manifest_rows.append({
                    "File":          r.get("filename",""),
                    "Material":      r.get("material_name",""),
                    "Supplier":      r.get("supplier_name",""),
                    "Non-zero vals": n_nz,
                    "Status": "❌ Error" if r.get("_error") else "✅ OK",
                })
            st.dataframe(manifest_rows, use_container_width=True)


