def _infer_route(dosage_form: str) -> str:
    """Product-agnostic route inference from free-text dosage form."""
    dl = safe_str(dosage_form).lower()
    if any(k in dl for k in ("injection", "parenteral", "intravenous", "iv ",
                             " im", "vial", "ampoule", "ampule", "infusion")):
        return "parenteral"
    if any(k in dl for k in ("cream", "ointment", "gel", "lotion", "patch",
                             "transdermal", "topical")):
        return "topical"
    if any(k in dl for k in ("inhal", "nebul", "respiratory", "aerosol")):
        return "inhalation"
    if any(k in dl for k in ("tablet", "capsule", "sachet", "granule", "powder",
                             "syrup", "suspension", "solution", "drop", "oral")):
        return "oral"
    return "oral"


def _infer_route_specific(dosage_form: str, context: str = "") -> str:
    """RF8 — DISPLAY-ONLY route subtype for the narrative / document header.

    The CALCULATION route (and therefore the PDE column) is decided separately by
    _infer_route / comp_data['route']; all parenteral subtypes share the parenteral
    PDE, so this never touches the exposure math. Returns 'subcutaneous' /
    'intravenous' / 'intramuscular' / 'parenteral' for injectables (from device /
    route cues in the dosage form or context), else the base route unchanged."""
    base = _infer_route(dosage_form)
    if base != "parenteral":
        return base
    blob = f"{safe_str(dosage_form)} {safe_str(context)}".lower()
    if re.search(r"\b(subcutaneous|subcut|sub-?cut|subq|sub\s*q|sc|uniject|"
                 r"pre[-\s]?filled\s+syringe|prefilled\s+syringe|pen\s*injector|"
                 r"auto[-\s]?injector)\b", blob):
        return "subcutaneous"
    if re.search(r"\b(intravenous|iv|infusion|i\.v)\b", blob):
        return "intravenous"
    if re.search(r"\b(intramuscular|im|i\.m|depot)\b", blob):
        return "intramuscular"
    return "parenteral"


