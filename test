            # Step 6: Process annexures
            log.info(f"🔬 Processing {len(annexure_files)} annexure(s)…")
            annexure_data: List[Dict] = []
            for i, af in enumerate(sorted(annexure_files, key=lambda f: f.name)):
                file_bytes = af.getvalue()
                if af.name.lower().endswith(".pdf"):
                    log.info(f"Extracting EI table from PDF annexure {af.name}...")
                    raw_json = extract_annexure_pdf_to_json(file_bytes, af.name, dpi=200)
                    source = raw_json.get("_source", {}) if isinstance(raw_json, dict) else {}
                    if source.get("cache_hit"):
                        st.info(f"  Annexure {i+1} ({af.name}): PDF extraction loaded from SHA-256 cache.")
                    ann = process_annexure(raw_json, i+1)
                    annexure_data.append(ann)
                    els = ann.get("elements", []) or []
                    concs = [_parse_conc(e.get("concentration_value")) for e in els if isinstance(e, dict)]
                    numeric_concs = [c for c in concs if isinstance(c, (int, float))]
                    n_005 = sum(1 for c in numeric_concs if abs(c - 0.05) < 0.001)
                    n_real = sum(1 for c in numeric_concs if c > 0 and abs(c - 0.05) > 0.001)
                    has_warn = ann.get("_warning_placeholder_values", False)
                    status = "WARN" if has_warn else "OK"
                    st.write(
