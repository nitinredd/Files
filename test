// Calculation Tables 5, 6, 7 with safe wrapper
function safeTable(key) {
const empty = {
elements: [], rows: [], total_daily_intake: 0,
element_totals: {}, pde: {}, threshold_30pct: {},
};
if (!calcTables || typeof calcTables !== “object” || !calcTables[key]) {
