        tc("Intention",    { bold: true, fill: CLR.HEADER_LIGHT, w: 2700 }),
        tc("Employee ID",  { bold: true, fill: CLR.HEADER_LIGHT, w: 1800 }),
        tc("User Name",    { bold: true, fill: CLR.HEADER_LIGHT, w: 3240 }),
        tc("Date (IST)",   { bold: true, fill: CLR.HEADER_LIGHT, w: 2160 }),
      ]}),
      ...sigRows
    ]
  });

  return [
    para("ELECTRONIC SIGNATURES", { bold: true, size: FONT_LG, align: AlignmentType.CENTER }),
    para(""),
    sigTbl,
  ];
}

// ─────────────────────────────────────────────────────────────────────────────
// MAIN DOCUMENT ASSEMBLY
// ─────────────────────────────────────────────────────────────────────────────
async function generateReport(dataPath, outPath) {
  const data = JSON.parse(fs.readFileSync(dataPath, "utf-8"));
  const { meta, text_sections: txt, composition, annexure_list,
          calc_tables, revision_history, signatures, figures, pde_values } = data;

  const sopFormat = meta.sop_format_number || "";
  const children  = [];

  // 1. Title page
  children.push(...buildTitlePage(meta, sopFormat));

  // 2. Table of Contents
  children.push(...buildTOC([]));

  // 3. Abstract / Objective / Study Location / Background
  children.push(...buildTextSections(txt));

  // 4. Composition table
  children.push(...buildCompositionTable(composition));

  // 5. Figure(s) – fishbone and any other diagrams from reference PDF
  (figures || []).forEach(fig => children.push(...buildFigure(fig)));

  // 6. Sources text + Annexure Table 2
  children.push(...buildAnnexureSection(txt, annexure_list));

  // 7. Manufacturing + Container Closure + Utilities + Control Strategy
  if (txt.manufacturing_section)
    children.push(para(txt.manufacturing_section, { size: FONT_BODY }));
  if (txt.container_closure_section)
    children.push(para(txt.container_closure_section, { size: FONT_BODY }));
  if (txt.utilities_section)
    children.push(para(txt.utilities_section, { size: FONT_BODY }));
  if (txt.control_strategy)
    children.push(para(txt.control_strategy, { size: FONT_BODY }));
  children.push(pageBreak());

  // 8. Calculation Tables 5, 6, 7
  if (calc_tables) {
    if (calc_tables.class1_2a)
      children.push(...buildCalcTable(5, calc_tables.class1_2a, pde_values));
    if (calc_tables.class2b)
      children.push(...buildCalcTable(6, calc_tables.class2b, pde_values));
    if (calc_tables.class3)
      children.push(...buildCalcTable(7, calc_tables.class3, pde_values));
    children.push(pageBreak());
  }

  // 9. Observation & Conclusion
  children.push(heading("6. Summary & Conclusion"));
  children.push(para([{ text: "Observation:", bold: true, size: FONT_BODY }]));
  children.push(para(txt.observation || "", { size: FONT_BODY }));
  children.push(para([{ text: "Conclusion:", bold: true, size: FONT_BODY }]));
  children.push(para(txt.conclusion  || "", { size: FONT_BODY }));
  children.push(pageBreak());

  // 10. List of Annexures (Table 8)
  const ann8 = new Table({
    width: { size: CONTENT_W, type: WidthType.DXA },
    columnWidths: [4200, 3600, 2040],
    rows: [
      new TableRow({ children: [
        tc("Name of Ingredient / Material", { bold: true, fill: CLR.HEADER_LIGHT, w: 4200 }),
        tc("Vendor",                         { bold: true, fill: CLR.HEADER_LIGHT, w: 3600 }),
        tc("Title of Annexure",              { bold: true, fill: CLR.HEADER_LIGHT, w: 2040 }),
      ]}),
      ...(annexure_list || []).map((a, i) =>
        new TableRow({ children: [
          tc(a.material  || "", { align: AlignmentType.LEFT, w: 4200 }),
          tc(a.supplier  || "", { align: AlignmentType.LEFT, w: 3600 }),
          tc(a.annexure  || `Annexure ${i+1}`, { w: 2040 }),
        ]}))
    ]
  });
  children.push(heading("8. List of annexures"), ann8, pageBreak());

  // 11. Revision history
  children.push(...buildRevisionHistory(revision_history), pageBreak());

  // 12. Electronic Signatures
  children.push(...buildSignatures(meta, signatures));

  // ── Assemble Document ─────────────────────────────────────────────────────
  const doc = new Document({
    styles: {
      default: { document: { run: { font: FONT, size: FONT_BODY } } }
    },
    sections: [{
      properties: {
        page: {
          size: { width: PAGE_W, height: PAGE_H },
          margin: { top: 1000, right: MARGIN, bottom: MARGIN, left: MARGIN }
        }
      },
      headers: { default: buildPageHeader(meta) },
      footers: { default: buildPageFooter() },
      children,
    }]
  });

  const buf = await Packer.toBuffer(doc);
  fs.writeFileSync(outPath, buf);
  console.log(`Report written: ${outPath}  (${Math.round(buf.length/1024)} KB)`);
}

// ─────────────────────────────────────────────────────────────────────────────
const [,, dataPath, outPath] = process.argv;
if (!dataPath || !outPath) {
  console.error("Usage: node generate_report.js <report_data.json> <output.docx>");
  process.exit(1);
}
generateReport(dataPath, outPath).catch(e => { console.error(e); process.exit(1); });
