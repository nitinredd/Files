    for i, img in enumerate(page_images):
        try:
            raw = claude_vision(img, sections_prompt)
            d = safe_json_parse(raw, {})
            if d and isinstance(d, dict):
                d["page_index"] = i
                pages_data.append(d)
            else:
                pages_data.append({
                    "page_index": i, "page_type": "unknown", "content_blocks": [],
                })
        except Exception as ex:
            logger.warning(f"Page {i} extraction: {ex}")
            pages_data.append({
                "page_index": i, "page_type": "unknown", "content_blocks": [],
            })

    revision_data: List[Dict] = []
    sig_data: List[Dict] = []

    if len(page_images) >= 2:
        rev_prompt = (
            "This page contains a revision history table and/or electronic signatures.\n"
            "Extract as JSON (no markdown):\n"
