// ── 7.0 SUMMARY AND CONCLUSION ──────────────────────────────────────────────
function buildSummaryAndConclusion(txt, riskSummaryTable, validationWarnings, manualReviewItems, conclusionStatus) {
  txt = txt || {};
  var ch = [];
  ch.push(secHd("7.0 SUMMARY AND CONCLUSION:"));

  // Risk summary table (object form: {title, columns, rows[]}) or legacy array
  var rstRows = null, rstTitle = "Table 7: Residual Solvent Assessment and Controls for Drug Product";
  if (riskSummaryTable && typeof riskSummaryTable === "object" && Array.isArray(riskSummaryTable.rows)) {
    rstRows = riskSummaryTable.rows;
    if (riskSummaryTable.title) rstTitle = "Table 7: " + riskSummaryTable.title;
  } else if (Array.isArray(txt.risk_summary_table) && txt.risk_summary_table.length > 0) {
    rstRows = txt.risk_summary_table;
  }
  if (rstRows && rstRows.length > 0) {
    ch.push(lftPara(rstTitle, true, SZ.SM));
    var W = [Math.round(CW*0.55), CW - Math.round(CW*0.55)];
    var hdr = new TableRow({children:[
      cell("Potential Risks", {bold:true, fill:CLR.HDR_GREY, w:W[0], size:SZ.SM}),
      cell("Action / Mitigation", {bold:true, fill:CLR.HDR_GREY, w:W[1], size:SZ.SM}),
    ]});
    var riskRows = rstRows.map(function(r) {
      return new TableRow({children:[
        cellL(String(r.risk || r.potential_risk || ""), {w:W[0], size:SZ.SM}),
        cellL(String(r.action || r.mitigation || ""), {w:W[1], size:SZ.SM}),
      ]});
    });
    ch.push(new Table({width:{size:CW, type:WidthType.DXA}, columnWidths:W,
                       rows:[hdr].concat(riskRows)}));
    ch.push(blk());
  }

  // Manual Review / Validation Warnings sub-section (only when warnings exist)
  var warns = Array.isArray(validationWarnings) ? validationWarnings : [];
  var mris  = Array.isArray(manualReviewItems) ? manualReviewItems : [];
  if (warns.length > 0 || mris.length > 0) {
    ch.push(lftPara("Manual Review / Validation Warnings", true, SZ.SM));
    if (conclusionStatus) {
      ch.push(bodyPara("Conclusion status: " + String(conclusionStatus) +
        ". This assessment was generated with unresolved manual-review items; a " +
        "final compliance conclusion requires review and resolution of the items below."));
    }
    var uniq = {};
    var lines = [];
    warns.concat(mris).forEach(function(w){
      var s = String(w); if (!uniq[s]) { uniq[s] = 1; lines.push(s); }
    });
    lines.forEach(function(s){ ch.push(bodyPara("\u2022 " + s)); });
    ch.push(blk());
  }

  bodyParas(txt.summary_and_conclusion || "").forEach(function(p){ch.push(p);});
  ch.push(blk());
  ch.push(pgBrk());
  return ch;
}

