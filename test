// ── SPELL-CHECK OFF INJECTION ────────────────────────────────────────────────
function injectSpellOff(buf) {
  var spellOff = '<w:hideSpellingErrors/><w:hideGrammaticalErrors/>';
  return JSZip.loadAsync(buf).then(function(zip) {
    var sf = zip.file("word/settings.xml");
    var sp;
    if (sf) {
      sp = sf.async("string").then(function(xml) {
        if (!xml.includes("hideSpellingErrors")) {
          xml = xml.replace("</w:settings>", spellOff + "</w:settings>");
        }
        zip.file("word/settings.xml", xml);
      });
    } else {
      zip.file("word/settings.xml",
        '<?xml version="1.0" encoding="UTF-8" standalone="yes"?>' +
        '<w:settings xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main">' +
        spellOff + '</w:settings>');
      sp = Promise.resolve();
    }
    return sp.then(function() {
      return zip.generateAsync({
        type: "nodebuffer",
        compression: "DEFLATE",
        compressionOptions: {level:6},
      });
    });
  });
}

// ── MAIN ASSEMBLY ────────────────────────────────────────────────────────────
function generateReport(dataPath, outPath) {
  var raw = fs.readFileSync(dataPath, "utf-8");
  var data = JSON.parse(raw);

  var meta        = data.meta        || {};
  var logoB64     = data.logo_b64    || "";
  var logoType    = data.logo_type   || "";

  var apis         = data.apis         || [];
  var address      = data.manufacturing_address || {};
  var regStatus    = data.regulatory_status || "";
  var prodInfo     = data.product_info || {};
  var rawMaterials = data.raw_materials || [];
  var composition  = data.composition  || [];
  var equipment    = data.equipment    || [];
  var process      = data.manufacturing_process || [];
  var flow         = data.process_flow || {};
  var patentStatus = data.patent_status || "";
  var innovator    = data.innovator    || {};
  var fpSpec       = data.finished_product_spec || [];
  var dissolution  = data.dissolution  || {};
  var stability    = data.stability    || [];
  var rld          = data.rld_utilization || {};
  var narcotic     = data.narcotic_declaration || {};
  var annexures    = data.annexure_list || [];
  var revisions    = data.revision_history || [];
  var signatures   = data.signatures || [];

  var ch = [];

  buildTitlePage(meta).forEach(function(x){ch.push(x);});
  buildTOC().forEach(function(x){ch.push(x);});
  buildDrugInformation(apis).forEach(function(x){ch.push(x);});
  buildManufacturingAddress(address).forEach(function(x){ch.push(x);});
  buildRegulatoryStatus(regStatus).forEach(function(x){ch.push(x);});
  buildProductAndComposition(prodInfo, rawMaterials, composition)
    .forEach(function(x){ch.push(x);});
  buildEquipmentDetails(equipment).forEach(function(x){ch.push(x);});
  buildManufacturingProcess(process).forEach(function(x){ch.push(x);});
  buildProcessFlow(flow).forEach(function(x){ch.push(x);});
  buildDrugSubstanceSpecs(apis).forEach(function(x){ch.push(x);});
  buildPatentStatus(patentStatus, innovator.brand_name).forEach(function(x){ch.push(x);});
  buildInnovatorDetails(innovator).forEach(function(x){ch.push(x);});
  buildFinishedProductSpec(fpSpec).forEach(function(x){ch.push(x);});
  buildDissolutionSection(dissolution).forEach(function(x){ch.push(x);});
  buildStabilitySection(stability).forEach(function(x){ch.push(x);});
  buildRLDUtilization(rld).forEach(function(x){ch.push(x);});
  buildNarcoticDeclaration(narcotic).forEach(function(x){ch.push(x);});
  buildAnnexureList(annexures).forEach(function(x){ch.push(x);});
  buildRevisionHistory(revisions).forEach(function(x){ch.push(x);});
  buildSignatures(meta, signatures).forEach(function(x){ch.push(x);});

  var doc = new Document({
    settings: {hideSpellingErrors:true, hideGrammaticalErrors:true},
    styles: {default: {document: {run: {font:F, size:SZ.TEXT, color:CLR.BLACK}}}},
    sections: [{
      properties: {page: {
        size: {width:PAGE_W, height:PAGE_H},
        margin: {top:MAR_T, right:MAR_R, bottom:MAR_B, left:MAR_L, header:360, footer:360},
      }},
      headers: {default: buildHeader(meta, logoB64, logoType)},
      footers: {default: buildFooter()},
      children: ch,
    }],
  });

  return Packer.toBuffer(doc)
    .then(injectSpellOff)
    .then(function(finalBuf) {
      fs.writeFileSync(outPath, finalBuf);
      console.log("BE NOC document written: " + outPath +
                  " (" + Math.round(finalBuf.length/1024) + " KB)");
    });
}

// ── Entry point ──────────────────────────────────────────────────────────────
var dp = process.argv[2], op = process.argv[3];
if (!dp || !op) {
  console.error("Usage: node generate_benoc.js <data.json> <out.docx>");
  process.exit(1);
}
generateReport(dp, op).catch(function(err) {
  console.error("FATAL:", err.message || err);
  if (err.stack) console.error(err.stack.split("\n").slice(0, 8).join("\n"));
  process.exit(1);
});
