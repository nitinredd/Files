# PAYLOAD ASSEMBLY
# ══════════════════════════════════════════════════════════════════════════════
def build_benoc_payload(meta: Dict, annexures: List[Dict],
                        generate_images: bool = True,
                        generate_charts: bool = True) -> Tuple[Dict, Dict]:
    """Assemble the full generate_benoc.js payload and return (payload, validation).
    Warning-first: the payload is always assembled; the caller decides whether to
    render based on validation['can_generate']."""
    meta = meta or {}
    annexures = annexures or []
    grouped = collect_by_type(annexures)
    main = grouped.get("main") or {}

    apis = build_apis(main, meta, grouped, generate_images=generate_images)

    # Composition / raw materials / equipment / process — main document first,
    # then the scientist's OPTIONAL gap-fill metadata (never blocks when absent).
    composition = [s for s in _as_list(main.get("composition")) if isinstance(s, dict)]
    if not composition:
        composition = [s for s in _as_list(meta.get("manual_composition"))
                       if isinstance(s, dict)]
    raw_materials = [r for r in _as_list(main.get("raw_materials")) if isinstance(r, dict)]
    if not raw_materials:
        raw_materials = [r for r in _as_list(meta.get("manual_raw_materials"))
                         if isinstance(r, dict)]
    equipment = [e for e in _as_list(main.get("equipment")) if isinstance(e, dict)]
    if not equipment:
        equipment = [e for e in _as_list(meta.get("manual_equipment"))
                     if isinstance(e, dict)]
    process = [p for p in _as_list(main.get("manufacturing_process")) if isinstance(p, dict)]
    if not process and _s(meta.get("manual_process_narrative")):
        process = [{"subtitle": "", "narrative": _s(meta.get("manual_process_narrative"))}]

    # Dissolution — main document, else optional metadata dissolution tables.
    diss_src = main
    if not (isinstance(main.get("dissolution"), dict)
            and _as_list(main["dissolution"].get("tables"))):
        md = meta.get("manual_dissolution")
        if isinstance(md, dict) and _as_list(md.get("tables")):
            diss_src = {"dissolution": md}

    narcotic = detect_controlled_substances(apis, meta,
                                            grouped.get("narcotic_declaration"))
    manufacturing_address = build_manufacturing_address(
        main, grouped.get("location_declaration"))

    # product_info (Section 4 header fields).
    product_info = {
        "product_name": _first(main.get("product_name"), meta.get("product_name")),
        "dosage_form": _first(main.get("dosage_form"), meta.get("dosage_form")),
        "indications": _as_list((apis[0].get("indications") if apis else [])),
        "indication": "",
        "label_claim": _first(meta.get("label_claim"), meta.get("strength")),
    }

    innovator = build_innovator(main, grouped, meta)

    # RLD utilization block.
    rld = grouped.get("rld_utilization")
    rld_block = {}
    if rld:
        rld_block = {
            "product_name": _first(rld.get("product_name"), meta.get("product_name")),
            "brand_name": _s(rld.get("brand_name")),
            "manufacturer": _s(rld.get("manufacturer")),
            "class_of_drug": _s(rld.get("class_of_drug")),
            "country": _s(rld.get("country")),
            "pack_and_count": _s(rld.get("pack_and_count")),
            "total_quantity": _s(rld.get("total_quantity")),
            "declared_by": _s(rld.get("declared_by")),
            "title": _s(rld.get("title")),
            "company_address": _s(rld.get("company_address")),
            "breakup": [b for b in _as_list(rld.get("breakup")) if isinstance(b, dict)],
        }

    annexure_list = build_annexure_list(grouped, apis, narcotic["applicable"])

    # Revision history — default one "first issue" row so Section 17 always
    # renders a table (mirrors the DEG-EG workflow). Never blocks.
    revision_history = _as_list(meta.get("revision_history"))
    if not revision_history:
        doc_no = _s(meta.get("document_no"))
        ver = _first(meta.get("version"), "1.0, CURRENT")
        revision_history = [{
            "document_version": (f"{doc_no} / {ver}" if doc_no else ver),
            "changes": "New document. First issue.",
        }]

    payload: Dict[str, Any] = {
        "meta": {
            "title": _first(meta.get("title"),
                            "Application for Grant of NOC for Import of Innovator "
                            "Product for Bio-Equivalence Study"),
            "document_no": _s(meta.get("document_no")),
            "product_name": product_info["product_name"],
            "dosage_form": product_info["dosage_form"],
            "department": _first(meta.get("department"), "FR&D"),
            "market": _s(meta.get("market")),
            "strength": _s(meta.get("strength")),
            "protocol": _first(meta.get("protocol"), "NA"),
            "version": _first(meta.get("version"), "1.0, CURRENT"),
            "sop_format_number": _s(meta.get("sop_format_number")),
        },
        "apis": apis,
        "manufacturing_address": manufacturing_address,
        "regulatory_status": _first(main.get("regulatory_status"), "Not applicable"),
        "product_info": product_info,
        "raw_materials": raw_materials,
        "composition": composition,
        "equipment": equipment,
        "manufacturing_process": process,
        "process_flow": (main.get("process_flow")
                         if isinstance(main.get("process_flow"), dict) else {}),
        "patent_status": _first(main.get("patent_status"), "Not applicable"),
        "innovator": innovator,
        "finished_product_spec": build_finished_product_spec(main, grouped),
        "dissolution": build_dissolution(diss_src, generate_charts=generate_charts),
        "stability": build_stability(grouped.get("stability") or []),
        "rld_utilization": rld_block,
        "narcotic_declaration": narcotic,
        "annexure_list": annexure_list,
        "revision_history": revision_history,
        "signatures": _as_list(meta.get("signatures")),
    }

    validation = validate_benoc(grouped, payload, annexures)
    validation["grouped_summary"] = {
        "apis": len(apis),
        "composition_stages": len(composition),
        "equipment": len(payload["equipment"]),
        "stability_blocks": len(payload["stability"]),
        "annexures": len(annexure_list),
        "narcotic_applicable": narcotic["applicable"],
    }
    return payload, validation
