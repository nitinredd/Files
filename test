      logoCell=new TableCell({
        width:{size:C4,type:WidthType.DXA},borders:allBdr(4),margins:mg(),
        verticalAlign:VerticalAlign.CENTER,
        children:[new Paragraph({alignment:AlignmentType.RIGHT,spacing:{before:0,after:0},
          children:[new ImageRun({type:lt,data:buf,transformation:{width:110,height:44}})],
        })],
      });
    } catch(e) {
      logoCell=cell("Dr. Reddy's",{bold:true,size:SZ.XS,w:C4,align:AlignmentType.RIGHT});
