def set_cell_border(cell, **kwargs):
    """Apply borders to a table cell."""
    tc   = cell._tc
    tcPr = tc.get_or_add_tcPr()
    tcBorders = OxmlElement("w:tcBorders")
    for edge in ("top", "left", "bottom", "right", "insideH", "insideV"):
        attrs = kwargs.get(edge, {"val": "single", "sz": "4", "color": "000000"})
        el = OxmlElement(f"w:{edge}")
        el.set(qn("w:val"),   attrs.get("val",   "single"))
        el.set(qn("w:sz"),    attrs.get("sz",    "4"))
        el.set(qn("w:color"), attrs.get("color", "000000"))
        tcBorders.append(el)
    tcPr.append(tcBorders)


def shade_cell(cell, fill_hex: str):
    """Apply background colour to a table cell."""
    tc   = cell._tc
    tcPr = tc.get_or_add_tcPr()
    shd  = OxmlElement("w:shd")
    shd.set(qn("w:val"),   "clear")
    shd.set(qn("w:color"), "auto")
    shd.set(qn("w:fill"),  fill_hex)
    tcPr.append(shd)


